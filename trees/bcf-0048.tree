}

\subtree{\title{GF(3) spatial trit}
\p{The trit for this tile is computed from Plus Code digit sum:}
\pre{\startverb
digits: 8 4 9 V Q H 9 F 4 7
values: 6 2 7 15 14 5 7 3 2 5
sum = 66
66 mod 3 = 0
trit = 0 - 1 = -1 (MINUS)
\stopverb}
\p{MINUS tile = validator role in the GF(3) spatial coloring. The station at this tile validates data from neighboring ERGODIC(0) and PLUS(+1) tiles.}
}

\subtree{\title{Station placement at this tile}
\p{The three station objects from \ref{bcf-0043} are placed within this 14m×14m tile:}
\table{
\tr{\th{Object}\th{Trit}\th{Position in tile}\th{IKEA item}}
\tr{\td{Reading chair}\td{-1}\td{NW quadrant (window)}\td{POÄNG + LACK}}
\tr{\td{Screen}\td{0}\td{Center-east (wall-mounted)}\td{KALLAX 2×2 shelf}}
\tr{\td{Pegboard}\td{+1}\td{SE quadrant (wall)}\td{SKÅDIS pegboard}}
}
\p{Chair faces north-northwest toward Market St. Natural light from west windows. Cyton headset stored on pegboard hook. Station trit sum: (−1) + 0 + (+1) = 0. ✓}
}

