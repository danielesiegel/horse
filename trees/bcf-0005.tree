\subtree{\title{Related Work}

\subtree{\title{A Geometry of Music}
\taxon{reference}
\meta{authors}{Dmitri Tymoczko}
\meta{publisher}{Oxford University Press}
\meta{year}{2011}
\meta{isbn}{978-0195336672}
\p{Geometric/topological framework for musical structure. Orbifold voice-leading spaces. Foundation for sonification of BCI signals and musical neurofeedback. Shared in BCI Factory group chat by Lucas Blakeslee.}}}

