\subtree{\title{Primary}

\subtree{\title{The Communal Science Lab}
\taxon{reference}
\meta{authors}{Bret Victor, Luke Iannini}
\meta{institution}{Dynamicland Foundation}
\meta{year}{2024}
\meta{url}{https://dynamicland.org/2024/The_communal_science_lab.pdf}
\p{Core philosophical grounding for BCI Factory as a shared research space. Identifies four values systematically absent from computing: visibility, agency, physical reality, and in-person collaboration.}}

