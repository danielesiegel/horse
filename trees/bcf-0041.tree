\title{Slop Trail}
\taxon{section}
\date{2026-04-04}
\tag{slop}
\meta{description}{1097 orphan skills with zero transclusion links — 82\% of repo bytes}

\import{macros}

\p{1097 skills have zero inbound and zero outbound transclusion links. They are static markdown blobs that no random walk reaches. They constitute 9.2 MB (82\%) of the skill forest.}

