\title{BCI Equivalence Classes: SF Landscape 2026}
\taxon{analysis}
\author{barton-rhodes}
\date{2026-04-05}
\import{macros}
\tag{bci}
\tag{landscape}
\tag{equivalence-class}
\tag{sf}
\meta{modality}{multi}
\meta{scope}{industry-map}

\p{Five equivalence classes of BCI companies, centered on San Francisco / Bay Area, with cross-class power rankings. Each class has a canonical representative and challenger set. Data as of April 2026.}

\subtree{\title{[V] Vision Prosthetics}
\taxon{equivalence-class}
\meta{canonical}{Science Corp (Alameda)}
\meta{trit}{+1}

\p{\strong{Science Corp} — $490M total, $1.5B valuation. PRIMA retinal implant (NEJM: 27/32 patients reading at 1yr). Biohybrid cortical interface in R and D. Max Hodak (ex-Neuralink), Alan Mardinly (CSO), Murat Gunel (Yale neurosurgery).}

\p{Graveyard: Second Sight (bankrupt), Retina Implant AG (dissolved), Nano Retina (closed), Pixium (liquidated → Science).}

\subtree{\title{Challengers}
\table{
\tr{\th{Entity}\th{Approach}\th{Status}}
\tr{\td{Monash Gennaris}\td{Modular cortical tiles, bypasses retina}\td{Pre-human, FDA Breakthrough}}
\tr{\td{Cortigent (Orion)}\td{60-electrode cortical, Second Sight spinoff}\td{6 patients, underfunded}}
\tr{\td{Fudan (Shanghai)}\td{Tellurium nanowire prosthesis, no external power}\td{Published in Science 2025, macaques only}}
\tr{\td{Daniel Palanker (Stanford)}\td{Invented PRIMA, working on 20μm pixels}\td{Academic — IS Science's engine}}
}}}

\subtree{\title{[U] Focused Ultrasound BCI}
\taxon{equivalence-class}
\meta{canonical}{Nudge (SF)}
\meta{trit}{0}

\p{\strong{Nudge} — $100M Series A (Thrive + Greenoaks). Fred Ehrsam (Coinbase co-founder), Quintin Frerichs, Jeremy Barenholtz. Non-invasive focused ultrasound neuromod + imaging. Nudge Zero testing on humans daily.}

\subtree{\title{Challengers}
\table{
\tr{\th{Entity}\th{Approach}\th{Status}}
\tr{\td{Openwater (Mary Lou Jepsen)}\td{Holographic ultrasound imaging+modulation}\td{~$36M, unvalidated claims}}
\tr{\td{Insightec (Israel)}\td{MR-guided FUS, FDA-approved for tremor}\td{$400M+, ablation not BCI}}
\tr{\td{CMU/Battelle (DARPA N3)}\td{Acousto-electromagnetic tFUS}\td{Best fundamental science}}
\tr{\td{Mikhail Shapiro (Caltech)}\td{Sonogenetics — engineered proteins + ultrasound}\td{If it works, obsoletes hardware}}
}}}

\subtree{\title{[I] High-Bandwidth Invasive}
\taxon{equivalence-class}
\meta{canonical}{Neuralink (Fremont)}
\meta{trit}{-1}

\p{Four-way race with genuinely different bets.}

\subtree{\title{Contenders}
\table{
\tr{\th{Company}\th{Electrodes}\th{Key move}\th{Stage}}
\tr{\td{Neuralink}\td{1,024}\td{3+ human patients, surgical robot}\td{IDE trial}}
\tr{\td{Paradromics}\td{65,536}\td{FDA IDE Nov 2025, 100 Mbit/s wireless, 200+ bits/sec}\td{First implant Q1 2026}}
\tr{\td{Precision Neuro}\td{4,096}\td{Medtronic partnership Jan 2026}\td{FDA IDE Mar 2026}}
\tr{\td{Synchron}\td{16}\td{$345M, no craniotomy, 6 patients}\td{Pivotal trial planning}}
\tr{\td{Neuracle (Beijing)}\td{ECoG}\td{World's first commercial NMPA clearance Mar 2026}\td{Commercial}}
}}}

\subtree{\title{[C] Non-Invasive Consumer}
\taxon{equivalence-class}
\meta{canonical}{Meta EMG Wristband}
\meta{trit}{+1}

\p{\strong{Meta Neural Band} — shipping since Sept 2025, $799 at Best Buy. Thomas Reardon (CTRL-Labs). Will reach 100M+ users before any BCI reaches 10K brains.}

\subtree{\title{Challengers}
\table{
\tr{\th{Company}\th{Modality}\th{Status}}
\tr{\td{Neurable}\td{EEG in M and D headphones}\td{Shipping, MW75 Neuro}}
\tr{\td{Elemind (Meredith Perry)}\td{EEG + acoustic neurostim}\td{Shipping, CES 2026}}
\tr{\td{Apple BCI-HID}\td{Protocol for 3rd-party BCIs}\td{May 2025, no hardware yet}}
\tr{\td{Kernel Flow}\td{TD-fNIRS helmet}\td{Clinic-only, ~$50K}}
\tr{\td{BrainCo (China)}\td{EEG headband + prosthetic hand}\td{Mass production Feb 2026}}
}}}

\subtree{\title{[M] Minimally Invasive / Neural Dust}
\taxon{equivalence-class}
\meta{canonical}{Forest Neurotech (SF)}
\meta{trit}{-1}

\p{\strong{Forest Neurotech} — Mark Chevillet (ex-Meta BCI), Eddie Chang (UCSF). Epidural thin-film, ~$11M seed.}

\subtree{\title{Challengers}
\table{
\tr{\th{Company}\th{Approach}\th{Status}}
\tr{\td{Inner Cosmos (Meron Gribetz)}\td{Coin-sized cortical, office procedure}\td{First-in-human 2024}}
\tr{\td{Motif Neurotech (Jacob Robinson)}\td{Sub-scalp stim, DARPA N3}\td{Preclinical, ~$19M}}
\tr{\td{Inbrain (Barcelona)}\td{Graphene neural interfaces}\td{Preclinical, ~$35M, EU flagship}}
\tr{\td{iota/Liminal (Berkeley)}\td{Neural dust, ultrasonic motes}\td{Winding down under Astellas}}
}}}

\subtree{\title{Cross-Class Power Rankings}
\table{
\tr{\th{Axis}\th{Leader}\th{Closest challenger}\th{Wildcard}}
\tr{\td{Vision}\td{Science Corp (no peer)}\td{Monash Gennaris}\td{Fudan tellurium nanowires}}
\tr{\td{Focused ultrasound}\td{Nudge (capital) / Openwater (tech)}\td{CMU DARPA N3}\td{Caltech sonogenetics}}
\tr{\td{Invasive}\td{Neuralink (deployed)}\td{Paradromics (65K electrodes)}\td{Synchron (no craniotomy)}}
\tr{\td{Consumer}\td{Meta EMG (scale)}\td{Neurable (stealth shipping)}\td{Apple BCI-HID (platform)}}
\tr{\td{Minimal-invasive}\td{Inner Cosmos (first in human)}\td{Inbrain (graphene)}\td{Motif (true no-surgery)}}
}

\p{The real question isn't which BCI company wins — it's which \emph{layer} captures value: silicon (Neuralink/Paradromics), surgical access (Synchron/Precision), software/decode (Arctop/BrainGate), or platform (Apple/Meta).}
}

\subtree{\title{Morgan Hough: Frontier Tower Bridge Node}
\taxon{connection}
\meta{person}{Morgan Hough}
\meta{location}{Frontier Tower, SF}
\meta{role}{Neurotech channel organizer, NeurotechSF}

\p{Morgan Hough runs the Neurotech channel at Frontier Tower. Dry electrode systems, PiEEG, BCI benchmarks. Gateway to Sandhya Kannan (Constellation EEG pilot). Bridges Frontier Tower ↔ Vivarium. Play: HIGH. Coplay: HIGH.}

