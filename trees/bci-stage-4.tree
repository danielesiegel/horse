\title{Stage 4: Decode → Categorical Semantics}
\taxon{definition}
\import{macros}

\p{The fourth stage decodes neural intent into capability-secured actions,
mediated by CRDTs for concurrent state and polynomial functors for I/O typing.}

\subtree{
\title{Capability-secured intent via OCapN}
\taxon{example}

\p{Decoded neural intents are \strong{capabilities}. The brain is a vat issuing
capability tokens that authorize actions. Decoded intent = capability reference
(unforgeable, attenuated). Effector = receiving vat (robotic arm, keyboard,
smart home). CapTP = transport protocol ensuring intent → action fidelity.}

\p{BCI outputs \em{must} be capability-secured: a misclassified "move arm" should
not have unbounded authority. Object capabilities give exactly the right
attenuation model.}
}

\subtree{
\title{CRDT for concurrent BCI state}
\taxon{example}

\p{Multiple processing pipelines (EEG decoder, fNIRS decoder, sEMG decoder) produce
concurrent state updates that must merge consistently. The brain state is a CRDT:
text CRDTs for neural speech decoding, structured CRDTs for hierarchical cognitive
state (attention, valence, arousal), version control for rolling back
misclassified intents.}
}

\subtree{
\title{E-graph optimization of decode pipeline}
\taxon{example}

\p{E-graphs (equality saturation) optimize the decode DAG. Multiple equivalent
paths exist (FFT→threshold vs wavelet→classifier). The e-graph finds the
Pareto-optimal path for latency × accuracy. Rewrite rules encode domain
knowledge.}
}

\subtree{
\title{Polynomial functors for BCI I/O}
\taxon{example}

\p{Polynomial functors type the BCI I/O:
#{p_{\mathrm{BCI}} = \Sigma_{s : \mathrm{BrainState}} y^{\mathrm{Action}(s)}}.
Each brain state #{s} has a dependent type of available actions. Cospans of
polynomials = undirected wiring between BCI subsystems.}
}
