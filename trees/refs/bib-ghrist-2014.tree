\title{Elementary Applied Topology}
\taxon{reference}
\date{2014}
\meta{author}{Robert Ghrist}

\p{R. Ghrist. \em{Elementary Applied Topology}. Createspace, 2014. Sheaves, cosheaves, and cohomology for sensor networks. The BCI electrode montage as a topological space with signal sheaves ([[horse-0002]], [[bci-0001]]) follows Ghrist's framework for distributed sensing.}
