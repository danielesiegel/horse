\title{Cohomological characterisations of structured decompositions}
\taxon{reference}
\author{Benjamin Merlin Bumpus}
\author{Zoltan A. Kocsis}
\author{Jeroen P. Zuiddam}
\date{2024}
\tag{cohomology}
\tag{sheaf}
\tag{decomposition}

\p{B. M. Bumpus, Z. A. Kocsis, J. P. Zuiddam. \em{Cohomological Characterisations of Structured Decompositions}. arXiv:2408.15184, 2024.}

\p{Provides the cohomological obstruction framework used to unify the monotile filtration and the Matryoshka Cliff: global sections of a presheaf on a poset are obstructed by a non-vanishing #{\check{H}^1} class. The decomposition theory connects to sheaves on graphs and the sheaf-theoretic approach to database queries via attributed C-sets.}
