\subtree{
\title{GF(3) Conservation Theorem}
\taxon{theorem}

\p{If each stage's functor is GF(3)-linear, the composite pipeline
Signal → Sites → Cohomology → Descent → Decode preserves trit parity.}

\p{Stage 1: montage composition preserves trit count (linear combination).
Stage 2: Beer-Lambert is linear, so trit parity is conserved.
Stage 3: descent gluing is a limit and preserves algebraic structure.
Stage 4: capability attenuation maps GF(3) → GF(3).}
}
