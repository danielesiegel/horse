\subtree{
\title{Validation}
\ul{
\li{Attachment detonation catches EICAR test file and macro-enabled document}
\li{URL Defense rewrites and blocks known phishing URLs}
\li{TAP Dashboard displays threat summary}
\li{SIEM receives and alerts on TAP events}
}
}
}