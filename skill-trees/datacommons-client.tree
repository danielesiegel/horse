\p{df = response.to_observations_as_records()}

\pre{\startverb

\stopverb}
}
}

\subtree{
\title{Finding Statistical Variables}
\p{Statistical variables use specific naming patterns in Data Commons:}

\p{\strong{Common variable patterns:}}

\ul{
\li{\code{\startverb Count_Person\stopverb} - Total population}
\li{\code{\startverb Count_Person_Female\stopverb} - Female population}
\li{\code{\startverb UnemploymentRate_Person\stopverb} - Unemployment rate}
\li{\code{\startverb Median_Income_Household\stopverb} - Median household income}
\li{\code{\startverb Count_Death\stopverb} - Death count}
\li{\code{\startverb Median_Age_Person\stopverb} - Median age}
}

\p{\strong{Discovery methods:}}

\pre{\startverb
# Check what variables are available for an entity
available = client.observation.fetch_available_statistical_variables(
    entity_dcids=["geoId/06"]
)

# Or explore via the web interface
# https://datacommons.org/tools/statvar
\stopverb}
}

\subtree{
\title{Working with Pandas}
\p{All observation responses integrate with Pandas:}

\pre{\startverb
response = client.observation.fetch(
    variable_dcids=["Count_Person"],
    entity_dcids=["geoId/06", "geoId/48"],
    date="all"
)

# Convert to DataFrame
df = response.to_observations_as_records()
# Columns: date, entity, variable, value

# Reshape for analysis
pivot = df.pivot_table(
    values='value',
    index='date',
    columns='entity'
)
\stopverb}
}

\subtree{
\title{API Authentication}
\p{\strong{For datacommons.org (default):}}

\ul{
\li{An API key is required}
\li{Set via environment variable: \code{\startverb export DC_API_KEY="your_key"\stopverb}}
\li{Or pass when initializing: \code{\startverb client = DataCommonsClient(api_key="your_key")\stopverb}}
\li{Request keys at: https://apikeys.datacommons.org/}
}

\p{\strong{For custom Data Commons instances:}}

\ul{
\li{No API key required}
\li{Specify custom endpoint: \code{\startverb client = DataCommonsClient(url="https://custom.datacommons.org")\stopverb}}
}
}

\subtree{
\title{Reference Documentation}
\p{Comprehensive documentation for each endpoint is available in the \code{\startverb references/\stopverb} directory:}

\ul{
\li{\strong{\code{\startverb references/observation.md\stopverb}}: Complete Observation API documentation with all methods, parameters, response formats, and common use cases}
\li{\strong{\code{\startverb references/node.md\stopverb}}: Complete Node API documentation for graph exploration, property queries, and hierarchy navigation}
\li{\strong{\code{\startverb references/resolve.md\stopverb}}: Complete Resolve API documentation for entity identification and DCID resolution}
\li{\strong{\code{\startverb references/getting_started.md\stopverb}}: Quickstart guide with end-to-end examples and common patterns}
}
}

