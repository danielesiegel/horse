\subtree{
\title{Tips for Effective Use}
\ol{
\li{\strong{Always start with resolution}: Convert names to DCIDs before querying data}
\li{\strong{Use relation expressions for hierarchies}: Query all children at once instead of individual queries}
\li{\strong{Check data availability first}: Use \code{\startverb fetch_available_statistical_variables()\stopverb} to see what's queryable}
\li{\strong{Leverage Pandas integration}: Convert responses to DataFrames for analysis}
\li{\strong{Cache resolutions}: If querying the same entities repeatedly, store name→DCID mappings}
\li{\strong{Filter by facet for consistency}: Use \code{\startverb filter_facet_domains\stopverb} to ensure data from the same source}
\li{\strong{Read reference docs}: Each endpoint has extensive documentation in the \code{\startverb references/\stopverb} directory}
}
}
}