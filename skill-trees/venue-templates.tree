\subtree{
\title{3. Research Poster Templates}
\p{Academic poster templates for conference presentations:}

\p{\strong{Standard Formats}:}

\ul{
\li{A0 (841 × 1189 mm / 33.1 × 46.8 in)}
\li{A1 (594 × 841 mm / 23.4 × 33.1 in)}
\li{36" × 48" (914 × 1219 mm) - Common US size}
\li{42" × 56" (1067 × 1422 mm)}
\li{48" × 36" (landscape orientation)}
}

\p{\strong{Template Packages}:}

\ul{
\li{\strong{beamerposter}: Classic academic poster template}
\li{\strong{tikzposter}: Modern, colorful poster design}
\li{\strong{baposter}: Structured multi-column layout}
}

\p{\strong{Design Features}:}

\ul{
\li{Optimal font sizes for readability at distance}
\li{Color schemes (colorblind-safe palettes)}
\li{Grid layouts and column structures}
\li{QR code integration for supplementary materials}
}
}

\subtree{
\title{4. Grant Proposal Templates}
\p{Templates and formatting requirements for major funding agencies:}

\p{\strong{NSF (National Science Foundation)}:}

\ul{
\li{Full proposal template (15-page project description)}
\li{Project Summary (1 page: Overview, Intellectual Merit, Broader Impacts)}
\li{Budget and budget justification}
\li{Biographical sketch (3-page limit)}
\li{Facilities, Equipment, and Other Resources}
\li{Data Management Plan}
}

\p{\strong{NIH (National Institutes of Health)}:}

\ul{
\li{R01 Research Grant (multi-year)}
\li{R21 Exploratory/Developmental Grant}
\li{K Awards (Career Development)}
\li{Specific Aims Page (1 page, most critical component)}
\li{Research Strategy (Significance, Innovation, Approach)}
\li{Biographical sketches (5-page limit)}
}

\p{\strong{DOE (Department of Energy)}:}

\ul{
\li{Office of Science proposals}
\li{ARPA-E templates}
\li{Technology Readiness Level (TRL) descriptions}
\li{Commercialization and impact sections}
}

\p{\strong{DARPA (Defense Advanced Research Projects Agency)}:}

\ul{
\li{BAA (Broad Agency Announcement) responses}
\li{Heilmeier Catechism framework}
\li{Technical approach and milestones}
\li{Transition planning}
}

\p{\strong{Private Foundations}:}

\ul{
\li{Gates Foundation}
\li{Wellcome Trust}
\li{Howard Hughes Medical Institute (HHMI)}
\li{Chan Zuckerberg Initiative (CZI)}
}
}
}

\subtree{
\title{Workflow: Finding and Using Templates}
\subtree{
\title{Step 1: Identify Target Venue}
\p{Determine the specific publication venue, conference, or funding agency:}

\pre{\startverb
Example queries:
- "I need to submit to Nature"
- "What are the requirements for NeurIPS 2025?"
- "Show me NSF proposal formatting"
- "I'm creating a poster for ISMB"
\stopverb}
}

\subtree{
\title{Step 2: Query Template and Requirements}
\p{Access venue-specific templates and formatting guidelines:}

\p{\strong{For Journals}:}

\pre{\startverb
# Load journal formatting requirements
Reference: references/journals_formatting.md
Search for: "Nature" or specific journal name

# Retrieve template
Template: assets/journals/nature_article.tex
\stopverb}

\p{\strong{For Conferences}:}

\pre{\startverb
# Load conference formatting
Reference: references/conferences_formatting.md
Search for: "NeurIPS" or specific conference

# Retrieve template
Template: assets/journals/neurips_article.tex
\stopverb}

\p{\strong{For Posters}:}

\pre{\startverb
# Load poster guidelines
Reference: references/posters_guidelines.md

# Retrieve template
Template: assets/posters/beamerposter_academic.tex
\stopverb}

\p{\strong{For Grants}:}

\pre{\startverb
# Load grant requirements
Reference: references/grants_requirements.md
Search for: "NSF" or specific agency

# Retrieve template
Template: assets/grants/nsf_proposal_template.tex
\stopverb}
}

\subtree{
\title{Step 3: Review Formatting Requirements}
\p{Check critical specifications before customizing:}

\p{\strong{Key Requirements to Verify}:}

\ul{
\li{Page limits (varies by venue)}
\li{Font size and family}
\li{Margin specifications}
\li{Line spacing}
\li{Citation style (APA, Vancouver, Nature, etc.)}
\li{Figure/table requirements}
\li{File format (PDF, Word, LaTeX source)}
\li{Anonymization (for double-blind review)}
\li{Supplementary material limits}
}
}

\subtree{
\title{Step 4: Customize Template}
\p{Use helper scripts or manual customization:}

\p{\strong{Option 1: Helper Script (Recommended)}:}

\pre{\startverb
python scripts/customize_template.py \
  --template assets/journals/nature_article.tex \
  --title "Your Paper Title" \
  --authors "First Author, Second Author" \
  --affiliations "University Name" \
  --output my_nature_paper.tex
\stopverb}

\p{\strong{Option 2: Manual Editing}:}

\ul{
\li{Open template file}
\li{Replace placeholder text (marked with comments)}
\li{Fill in title, authors, affiliations, abstract}
\li{Add your content to each section}
}
}

\subtree{
\title{Step 5: Validate Format}
\p{Check compliance with venue requirements:}

\pre{\startverb
python scripts/validate_format.py \
  --file my_paper.pdf \
  --venue "Nature" \
  --check-all
\stopverb}

\p{\strong{Validation Checks}:}

\ul{
\li{Page count within limits}
\li{Font sizes correct}
\li{Margins meet specifications}
\li{References formatted correctly}
\li{Figures meet resolution requirements}
}
}

\subtree{
\title{Step 6: Compile and Review}
\p{Compile LaTeX and review output:}

\pre{\startverb
# Compile LaTeX
pdflatex my_paper.tex
bibtex my_paper
pdflatex my_paper.tex
pdflatex my_paper.tex

# Or use latexmk for automated compilation
latexmk -pdf my_paper.tex
\stopverb}

\p{Review checklist:}

\ul{
\li{[ ] All sections present and properly formatted}
\li{[ ] Citations render correctly}
\li{[ ] Figures appear with proper captions}
\li{[ ] Page count within limits}
\li{[ ] Author guidelines followed}
\li{[ ] Supplementary materials prepared (if needed)}
}
}
}

