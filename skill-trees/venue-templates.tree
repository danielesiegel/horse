\subtree{
\title{Helper Scripts}
\subtree{
\title{query_template.py}
\p{Search and retrieve templates by venue name, type, or keywords:}

\pre{\startverb
# Find templates for a specific journal
python scripts/query_template.py --venue "Nature" --type "article"

# Search by keyword
python scripts/query_template.py --keyword "machine learning"

# List all available templates
python scripts/query_template.py --list-all

# Get requirements for a venue
python scripts/query_template.py --venue "NeurIPS" --requirements
\stopverb}
}

\subtree{
\title{customize_template.py}
\p{Customize templates with author and project information:}

\pre{\startverb
# Basic customization
python scripts/customize_template.py \
  --template assets/journals/nature_article.tex \
  --output my_paper.tex

# With author information
python scripts/customize_template.py \
  --template assets/journals/nature_article.tex \
  --title "Novel Approach to Protein Folding" \
  --authors "Jane Doe, John Smith, Alice Johnson" \
  --affiliations "MIT, Stanford, Harvard" \
  --email "[email protected]" \
  --output my_paper.tex

# Interactive mode
python scripts/customize_template.py --interactive
\stopverb}
}

\subtree{
\title{validate_format.py}
\p{Check document compliance with venue requirements:}

\pre{\startverb
# Validate a compiled PDF
python scripts/validate_format.py \
  --file my_paper.pdf \
  --venue "Nature" \
  --check-all

# Check specific aspects
python scripts/validate_format.py \
  --file my_paper.pdf \
  --venue "NeurIPS" \
  --check page-count,margins,fonts

# Generate validation report
python scripts/validate_format.py \
  --file my_paper.pdf \
  --venue "Science" \
  --report validation_report.txt
\stopverb}
}
}

\subtree{
\title{Best Practices}
\subtree{
\title{Template Selection}
\ol{
\li{\strong{Verify currency}: Check template date and compare with latest author guidelines}
\li{\strong{Check official sources}: Many journals provide official LaTeX classes}
\li{\strong{Test compilation}: Compile template before adding content}
\li{\strong{Read comments}: Templates include helpful inline comments}
}
}

\subtree{
\title{Customization}
\ol{
\li{\strong{Preserve structure}: Don't remove required sections or packages}
\li{\strong{Follow placeholders}: Replace marked placeholder text systematically}
\li{\strong{Maintain formatting}: Don't override venue-specific formatting}
\li{\strong{Keep backups}: Save original template before customization}
}
}

\subtree{
\title{Compliance}
\ol{
\li{\strong{Check page limits}: Verify before final submission}
\li{\strong{Validate citations}: Use correct citation style for venue}
\li{\strong{Test figures}: Ensure figures meet resolution requirements}
\li{\strong{Review anonymization}: Remove identifying information if required}
}
}

\subtree{
\title{Submission}
\ol{
\li{\strong{Follow instructions}: Read complete author guidelines}
\li{\strong{Include all files}: LaTeX source, figures, bibliography}
\li{\strong{Generate properly}: Use recommended compilation method}
\li{\strong{Check output}: Verify PDF matches expectations}
}
}
}

\subtree{
\title{Common Formatting Requirements}
\subtree{
\title{Page Limits (Typical)}
\pre{\startverb
| Venue Type | Typical Limit | Notes |
|------------|---------------|-------|
| **Nature Article** | 5 pages | ~3000 words excluding refs |
| **Science Report** | 5 pages | Figures count toward limit |
| **PLOS ONE** | No limit | Unlimited length |
| **NeurIPS** | 8 pages | + unlimited refs/appendix |
| **ICML** | 8 pages | + unlimited refs/appendix |
| **NSF Proposal** | 15 pages | Project description only |
| **NIH R01** | 12 pages | Research strategy |
\stopverb}
}

\subtree{
\title{Citation Styles by Venue}
\pre{\startverb
| Venue | Citation Style | Format |
|-------|---------------|--------|
| **Nature** | Numbered (superscript) | Nature style |
| **Science** | Numbered (superscript) | Science style |
| **PLOS** | Numbered (brackets) | Vancouver |
| **Cell Press** | Author-year | Cell style |
| **ACM** | Numbered | ACM style |
| **IEEE** | Numbered (brackets) | IEEE style |
| **APA journals** | Author-year | APA 7th |
\stopverb}
}

\subtree{
\title{Figure Requirements}
\pre{\startverb
| Venue | Resolution | Format | Color |
|-------|-----------|--------|-------|
| **Nature** | 300+ dpi | TIFF, EPS, PDF | RGB or CMYK |
| **Science** | 300+ dpi | TIFF, PDF | RGB |
| **PLOS** | 300-600 dpi | TIFF, EPS | RGB |
| **IEEE** | 300+ dpi | EPS, PDF | RGB or Grayscale |
\stopverb}
}
}

