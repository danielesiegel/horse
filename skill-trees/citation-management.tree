# For advanced validation
pip install crossref-commons  # Enhanced CrossRef API access
pip install pylatexenc  # LaTeX special character handling
\stopverb}
}
}

\subtree{
\title{Summary}
\p{The citation-management skill provides:}

\ol{
\li{\strong{Comprehensive search capabilities} for Google Scholar and PubMed}
\li{\strong{Automated metadata extraction} from DOI, PMID, arXiv ID, URLs}
\li{\strong{Citation validation} with DOI verification and completeness checking}
\li{\strong{BibTeX formatting} with standardization and cleaning tools}
\li{\strong{Quality assurance} through validation and reporting}
\li{\strong{Integration} with scientific writing workflow}
\li{\strong{Reproducibility} through documented search and extraction methods}
}

\p{Use this skill to maintain accurate, complete citations throughout your research and ensure publication-ready bibliographies.}
}
}