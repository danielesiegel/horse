\ul{
\li{\strong{Literature Review}: Multi-database systematic search and synthesis}
\li{\strong{Citation Management}: Metadata extraction and validation}
}

\p{\strong{Combined workflow}:}

\ol{
\li{Use literature-review for systematic search methodology}
\li{Use citation-management to extract and validate citations}
\li{Use literature-review to synthesize findings}
\li{Use citation-management to ensure bibliography accuracy}
}
}

\subtree{
\title{Scientific Writing Skill}
\p{\strong{Citation Management} ensures accurate references for \strong{Scientific Writing}:}

\ul{
\li{Export validated BibTeX for use in LaTeX manuscripts}
\li{Verify citations match publication standards}
\li{Format references according to journal requirements}
}
}

\subtree{
\title{Venue Templates Skill}
\p{\strong{Citation Management} works with \strong{Venue Templates} for submission-ready manuscripts:}

\ul{
\li{Different venues require different citation styles}
\li{Generate properly formatted references}
\li{Validate citations meet venue requirements}
}
}
}

