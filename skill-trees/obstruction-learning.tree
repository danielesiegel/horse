# voice-enforcement.toml
[triads.obstruction]
validator = "Milena (Enhanced)"   # -1: detects obstruction
coordinator = "Petra (Premium)"   # 0: mediates resolution
generator = "Federica (Premium)"  # +1: proposes fix
sum = 0
\stopverb}
}

