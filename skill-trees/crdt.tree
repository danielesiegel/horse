\subtree{
\title{Performance Characteristics}
\pre{\startverb
| Operation | Complexity | Notes |
|-----------|-----------|-------|
| Create | O(1) | Instant |
| Mutate | O(1) | Typically <1ms |
| Query | O(1) | Instant lookup |
| Merge | O(n) | Linear in elements |
| Verify | O(n²) | Polynomial for verification |
\stopverb}
}

\subtree{
\title{CRDT Properties}
\subtree{
\title{Idempotence}
\pre{\startverb
merge(merge(A, B), B) = merge(A, B)
\stopverb}

\p{Merging duplicate states produces same result.}
}

\subtree{
\title{Commutativity}
\pre{\startverb
merge(A, B) = merge(B, A)
\stopverb}

\p{Order of merges doesn't matter.}
}

\subtree{
\title{Associativity}
\pre{\startverb
merge(merge(A, B), C) = merge(A, merge(B, C))
\stopverb}

\p{Grouping of merges doesn't matter.}
}
}

\subtree{
\title{Comparison with Traditional Databases}
\pre{\startverb
| Feature | CRDT | Traditional DB |
|---------|------|----------------|
| Network partitions | ✓ Handles | ✗ Requires coordination |
| Latency | ✓ Low | ✗ Network round-trips |
| Consistency | Eventual | Strong |
| Conflict resolution | Automatic | Manual |
| Scalability | ✓ P2P friendly | ✓ Centralized scaling |
\stopverb}
}

