\title{Joker Sims Parser}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{DBPF package parser and validator for The Sims save files}

\subtree{
\title{joker-sims-parser - Sims DBPF Package Parser Skill}
\p{\strong{Comprehensive DBPF parsing and analysis tool for The Sims 2, 3, and 4 save files.}}

\subtree{
\title{Summary}
\p{joker-sims-parser provides production-grade parsing of DBPF (Database Packed File) package files used across all Sims generations. It handles format detection, resource enumeration, metadata extraction, and batch analysis of save directories.}
}

\subtree{
\title{GF(3) Role}
\pre{\startverb
| Aspect | Value |
|--------|-------|
| Trit | -1 (MINUS) |
| Role | VALIDATOR |
| Function | Validates DBPF package format correctness and resource integrity |
\stopverb}
}

\subtree{
\title{Capabilities}
\ul{
\li{\code{\startverb parse-dbpf\stopverb} - Parse and validate complete DBPF file structure}
\li{\code{\startverb detect-version\stopverb} - Identify game version from DBPF format automatically}
\li{\code{\startverb list-resources\stopverb} - Enumerate all resources with full metadata}
\li{\code{\startverb extract-resource\stopverb} - Extract individual resources by type/group/ID}
\li{\code{\startverb batch-scan\stopverb} - Recursively scan directories for all Sims saves}
\li{\code{\startverb format-analysis\stopverb} - Detailed analysis of package structure and composition}
\li{\code{\startverb metadata-extraction\stopverb} - Timeline analysis, compression ratios, size calculations}
}
}

\subtree{
\title{Formats Supported}
\subtree{
\title{The Sims 2}
\ul{
\li{Extension: \code{\startverb .sims\stopverb}, \code{\startverb .sims2\stopverb}}
\li{DBPF Version: 1.0 - 1.1}
\li{Compression: QFS/RefPack}
\li{Index Structure: 7.0 with deletion tracking}
}
}

\subtree{
\title{The Sims 3}
\ul{
\li{Extension: \code{\startverb .package\stopverb}, \code{\startverb .sims3pack\stopverb}}
\li{DBPF Version: 2.0}
\li{Compression: QFS/RefPack}
\li{Index Structure: 7.0 (simplified)}
}
}

\subtree{
\title{The Sims 4}
\ul{
\li{Extension: \code{\startverb .package\stopverb}, \code{\startverb .ts4script\stopverb}}
\li{DBPF Version: 2.0}
\li{Compression: ZLIB}
\li{\startverb Index Structure: 7.1 with Type IDs (40-50% compression improvement)\stopverb}
}
}
}

\subtree{
\title{GF(3) Integration}
\p{\strong{Trit Assignment}: -1 (MINUS role) \strong{Function}: Validation and format verification \strong{Conservation}: Maintains GF(3) balance in skill triads \strong{Role in ASI}: Verifies package integrity before processing}
}

\subtree{
\title{CLI Commands}
\pre{\startverb
# Analyze package file structure
joker parse <file>

# List all resources with metadata
joker list <file>

# Scan directory for Sims saves
joker info <directory>

# Extract specific resources (future)
joker extract <file> <type>
\stopverb}
}

\subtree{
\title{Example Usage}
\pre{\startverb
# Parse a Sims 3 save file
$ joker parse ~/Documents/TheSims3/Saves/UserSaveGame.sims3pack

=== Sims Package Analysis ===

File: UserSaveGame.sims3pack
Game Version: Sims 3
DBPF Version: 2.0
Total Resources: 1247
File Size: 52428800 bytes

Compressed Resources: 892
Uncompressed Resources: 355

# Scan for all saves in a directory
$ joker info ~/Documents/TheSims3/Saves/

~/Documents/TheSims3/Saves/UserSaveGame1.sims3pack
  Game: Sims 3
  Resources: 1247
  
~/Documents/TheSims3/Saves/UserSaveGame2.sims3pack
  Game: Sims 3
  Resources: 892
\stopverb}
}

\subtree{
\title{Technical Details}
\subtree{
\title{DBPF Header Structure (96 bytes)}
\ul{
\li{Magic: 4 bytes ("DBPF")}
\li{Version: 8 bytes (major/minor)}
\li{Reserved: 16 bytes}
\li{File metadata: 20 bytes (size, timestamps)}
\li{Index pointers: 20 bytes (location, size, count)}
\li{Index metadata: 8 bytes (version, deletion tracking)}
}
}

\subtree{
\title{Resource Entry Structure (24-32 bytes)}
\ul{
\li{Resource ID: 12 bytes (Type/Group/ID)}
\li{Offset: 4 bytes (position in file)}
\li{Size: 8 bytes (compressed and raw)}
\li{TypeID: 4 bytes (Sims 4 only)}
}
}

\subtree{
\title{Compression Detection}
\ul{
\li{CompressedSize == 0xFFFFFFFF → Uncompressed}
\li{CompressedSize != 0xFFFFFFFF → Compressed (QFS or ZLIB)}
}
}
}

