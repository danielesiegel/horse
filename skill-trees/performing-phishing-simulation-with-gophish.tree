\title{Tools & Resources}
\ul{
\li{\strong{GoPhish}: https://getgophish.com/}
\li{\strong{GoPhish API Docs}: https://docs.getgophish.com/api-documentation/}
\li{\strong{GoPhish GitHub}: https://github.com/gophish/gophish}
\li{\strong{Evilginx2} (for advanced AiTM testing): https://github.com/kgretzky/evilginx2}
