}
}

\subtree{
\title{Validation}
\ul{
\li{Successfully deploy GoPhish and access admin panel}
\li{Create and send a test phishing email to a test mailbox}
\li{Capture simulated credentials on landing page}
\li{Generate campaign report with open/click/submit rates}
\li{Redirect users to awareness training after interaction}
}
}
}