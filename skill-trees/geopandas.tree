\subtree{
\title{Common Workflows}
\subtree{
\title{Load, Transform, Analyze, Export}
\pre{\startverb
# 1. Load data
gdf = gpd.read_file("data.shp")

# 2. Check and transform CRS
print(gdf.crs)
gdf = gdf.to_crs("EPSG:3857")

# 3. Perform analysis
gdf['area'] = gdf.geometry.area
buffered = gdf.copy()
buffered['geometry'] = gdf.geometry.buffer(100)

# 4. Export results
gdf.to_file("results.gpkg", layer='original')
buffered.to_file("results.gpkg", layer='buffered')
\stopverb}
}

\subtree{
\title{Spatial Join and Aggregate}
\pre{\startverb
# Join points to polygons
points_in_polygons = gpd.sjoin(points_gdf, polygons_gdf, predicate='within')

# Aggregate by polygon
aggregated = points_in_polygons.groupby('index_right').agg({
    'value': 'sum',
    'count': 'size'
})

# Merge back to polygons
result = polygons_gdf.merge(aggregated, left_index=True, right_index=True)
\stopverb}
}

\subtree{
\title{Multi-Source Data Integration}
\pre{\startverb
# Read from different sources
roads = gpd.read_file("roads.shp")
buildings = gpd.read_file("buildings.geojson")
parcels = gpd.read_postgis("SELECT * FROM parcels", con=engine, geom_col='geom')

# Ensure matching CRS
buildings = buildings.to_crs(roads.crs)
parcels = parcels.to_crs(roads.crs)

# Perform spatial operations
buildings_near_roads = buildings[buildings.geometry.distance(roads.union_all()) < 50]
\stopverb}
}
}

\subtree{
\title{Performance Tips}
\ol{
\li{\strong{Use spatial indexing}: GeoPandas creates spatial indexes automatically for most operations}
\li{\strong{Filter during read}: Use \code{\startverb bbox\stopverb}, \code{\startverb mask\stopverb}, or \code{\startverb where\stopverb} parameters to load only needed data}
\li{\strong{Use Arrow for I/O}: Add \code{\startverb use_arrow=True\stopverb} for 2-4x faster reading/writing}
\li{\strong{Simplify geometries}: Use \code{\startverb .simplify()\stopverb} to reduce complexity when precision isn't critical}
\li{\strong{Batch operations}: Vectorized operations are much faster than iterating rows}
\li{\strong{Use appropriate CRS}: Projected CRS for area/distance, geographic for visualization}
}
}

\subtree{
\title{Best Practices}
\ol{
\li{\strong{Always check CRS} before spatial operations}
\li{\strong{Use projected CRS} for area and distance calculations}
\li{\strong{Match CRS} before spatial joins or overlays}
\li{\strong{Validate geometries} with \code{\startverb .is_valid\stopverb} before operations}
\li{\strong{Use \code{\startverb .copy()\stopverb}} when modifying geometry columns to avoid side effects}
\li{\strong{Preserve topology} when simplifying for analysis}
\li{\strong{Use GeoPackage} format for modern workflows (better than Shapefile)}
\li{\strong{Set max_distance} in sjoin_nearest for better performance}
}
}
}