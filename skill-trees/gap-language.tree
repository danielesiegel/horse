\subtree{
\title{Computational Capabilities}
\ul{
\li{\strong{Group Theory}: Permutation groups, Matrix groups, Finitely presented groups.}
\li{\strong{Representation Theory}: Character tables, Representations.}
\li{\strong{Combinatorics}: Combinatorial structures, Graph symmetries.}
}
}

\subtree{
\title{Scientific Skill Interleaving}
\p{This skill interleaves with:}

\ul{
\li{\code{\startverb acsets\stopverb}: For categorical perspective on algebraic structures.}
\li{\code{\startverb gay-mcp\stopverb}: For color-theoretic interpretation of group actions.}
\li{\code{\startverb python\stopverb}: Via \code{\startverb gap-system\stopverb} bindings or IPC.}
}
}

\subtree{
\title{Usage}
\pre{\startverb
# Run a GAP computation
gap -c 'Print(Order(SymmetricGroup(5)), "\n");'
\stopverb}
}

