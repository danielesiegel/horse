\subtree{
\title{Common Use Case Patterns}
\subtree{
\title{Pattern 1: Solve and Verify}
\pre{\startverb
from sympy import symbols, solve, simplify
x = symbols('x')

# Solve equation
equation = x**2 - 5*x + 6
solutions = solve(equation, x)  # [2, 3]

# Verify solutions
for sol in solutions:
    result = simplify(equation.subs(x, sol))
    assert result == 0
\stopverb}
}

\subtree{
\title{Pattern 2: Symbolic to Numeric Pipeline}
\pre{\startverb
# 1. Define symbolic problem
x, y = symbols('x y')
expr = sin(x) + cos(y)

# 2. Manipulate symbolically
simplified = simplify(expr)
derivative = diff(simplified, x)

# 3. Convert to numerical function
f = lambdify((x, y), derivative, 'numpy')

# 4. Evaluate numerically
results = f(x_data, y_data)
\stopverb}
}

\subtree{
\title{Pattern 3: Document Mathematical Results}
\pre{\startverb
# Compute result symbolically
integral_expr = Integral(x**2, (x, 0, 1))
result = integral_expr.doit()

# Generate documentation
print(f"LaTeX: {latex(integral_expr)} = {latex(result)}")
print(f"Pretty: {pretty(integral_expr)} = {pretty(result)}")
print(f"Numerical: {result.evalf()}")
\stopverb}
}
}

\subtree{
\title{Integration with Scientific Workflows}
\subtree{
\title{With NumPy}
\pre{\startverb
import numpy as np
from sympy import symbols, lambdify

x = symbols('x')
expr = x**2 + 2*x + 1

f = lambdify(x, expr, 'numpy')
x_array = np.linspace(-5, 5, 100)
y_array = f(x_array)
\stopverb}
}

\subtree{
\title{With Matplotlib}
\pre{\startverb
import matplotlib.pyplot as plt
import numpy as np
from sympy import symbols, lambdify, sin

x = symbols('x')
expr = sin(x) / x

f = lambdify(x, expr, 'numpy')
x_vals = np.linspace(-10, 10, 1000)
y_vals = f(x_vals)

plt.plot(x_vals, y_vals)
plt.show()
\stopverb}
}

\subtree{
\title{With SciPy}
\pre{\startverb
from scipy.optimize import fsolve
from sympy import symbols, lambdify

# Define equation symbolically
x = symbols('x')
equation = x**3 - 2*x - 5

# Convert to numerical function
f = lambdify(x, equation, 'numpy')

# Solve numerically with initial guess
solution = fsolve(f, 2)
\stopverb}
}
}

\subtree{
\title{Quick Reference: Most Common Functions}
\pre{\startverb
# Symbols
from sympy import symbols, Symbol
x, y = symbols('x y')

# Basic operations
from sympy import simplify, expand, factor, collect, cancel
from sympy import sqrt, exp, log, sin, cos, tan, pi, E, I, oo

# Calculus
from sympy import diff, integrate, limit, series, Derivative, Integral

# Solving
from sympy import solve, solveset, linsolve, nonlinsolve, dsolve

# Matrices
from sympy import Matrix, eye, zeros, ones, diag

# Logic and sets
from sympy import And, Or, Not, Implies, FiniteSet, Interval, Union

# Output
from sympy import latex, pprint, lambdify, init_printing

# Utilities
from sympy import evalf, N, nsimplify
\stopverb}
}

\subtree{
\title{Getting Started Examples}
\subtree{
\title{Example 1: Solve Quadratic Equation}
\pre{\startverb
from sympy import symbols, solve, sqrt
x = symbols('x')
solution = solve(x**2 - 5*x + 6, x)
# [2, 3]
\stopverb}
}

\subtree{
\title{Example 2: Calculate Derivative}
\pre{\startverb
from sympy import symbols, diff, sin
x = symbols('x')
f = sin(x**2)
df_dx = diff(f, x)
# 2*x*cos(x**2)
\stopverb}
}

\subtree{
\title{Example 3: Evaluate Integral}
\pre{\startverb
from sympy import symbols, integrate, exp
x = symbols('x')
integral = integrate(x * exp(-x**2), (x, 0, oo))
# 1/2
\stopverb}
}

\subtree{
\title{Example 4: Matrix Eigenvalues}
\pre{\startverb
from sympy import Matrix
M = Matrix([[1, 2], [2, 1]])
eigenvals = M.eigenvals()
# {3: 1, -1: 1}
\stopverb}
}

\subtree{
\title{Example 5: Generate Python Function}
\pre{\startverb
from sympy import symbols, lambdify
import numpy as np
x = symbols('x')
expr = x**2 + 2*x + 1
f = lambdify(x, expr, 'numpy')
f(np.array([1, 2, 3]))
# array([ 4,  9, 16])
\stopverb}
}
}

\subtree{
\title{Troubleshooting Common Issues}
\ol{
\li{\strong{"NameError: name 'x' is not defined"}}
\li{Solution: Always define symbols using \code{\startverb symbols()\stopverb} before use}
}

\ol{
\li{\strong{Unexpected numerical results}}
\li{Issue: Using floating-point numbers like \code{\startverb 0.5\stopverb} instead of \code{\startverb Rational(1, 2)\stopverb}}
\li{Solution: Use \code{\startverb Rational()\stopverb} or \code{\startverb S()\stopverb} for exact arithmetic}
}

\ol{
\li{\strong{Slow performance in loops}}
\li{Issue: Using \code{\startverb subs()\stopverb} and \code{\startverb evalf()\stopverb} repeatedly}
\li{Solution: Use \code{\startverb lambdify()\stopverb} to create a fast numerical function}
}

\ol{
\li{\strong{"Can't solve this equation"}}
\li{Try different solvers: \code{\startverb solve\stopverb}, \code{\startverb solveset\stopverb}, \code{\startverb nsolve\stopverb} (numerical)}
\li{Check if the equation is solvable algebraically}
\li{Use numerical methods if no closed-form solution exists}
}

\ol{
\li{\strong{Simplification not working as expected}}
\li{Try different simplification functions: \code{\startverb simplify\stopverb}, \code{\startverb factor\stopverb}, \code{\startverb expand\stopverb}, \code{\startverb trigsimp\stopverb}}
\li{Add assumptions to symbols (e.g., \code{\startverb positive=True\stopverb})}
\li{Use \code{\startverb simplify(expr, force=True)\stopverb} for aggressive simplification}
}
}

