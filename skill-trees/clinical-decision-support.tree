\li{\code{\startverb calculate_statistics.py\stopverb} - Hazard ratios, Cox regression, log-rank tests, Fisher's exact}
\li{\code{\startverb validate_cds_document.py\stopverb} - Quality and compliance checks (HIPAA, statistical reporting standards)}
\li{\code{\startverb grade_evidence.py\stopverb} - Automated GRADE assessment helper for treatment recommendations}
}
