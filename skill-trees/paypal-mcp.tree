\title{Paypal Mcp}

\taxon{skill}

\meta{description}{PayPal MCP server integration for invoices, payments, subscriptions, disputes, and transaction reporting via @paypal/mcp.}

\subtree{
\title{paypal-mcp Skill}
\p{PayPal MCP server integration for invoices, payments, subscriptions, disputes, and transaction reporting via @paypal/mcp.}

\subtree{
\title{GF(3) Assignment}
\pre{\startverb
Trit: 0 (ERGODIC)
Role: Coordinator - orchestrates payment flows between crypto and fiat
Color: #26D826 (green)
\stopverb}
}

\subtree{
\title{MCP Server Setup}
\subtree{
\title{Amp Configuration (~/.amp/servers.json)}
\pre{\startverb
{
  "paypal": {
    "command": "npx",
    "args": ["-y", "@paypal/mcp", "--tools=all"],
    "env": {
      "PAYPAL_ACCESS_TOKEN": "${PAYPAL_ACCESS_TOKEN}",
      "PAYPAL_ENVIRONMENT": "SANDBOX"
    }
  }
}
\stopverb}
}

\subtree{
\title{Claude Configuration (~/.claude.json)}
\pre{\startverb
{
  "mcpServers": {
    "paypal": {
      "command": "npx",
      "args": ["-y", "@paypal/mcp", "--tools=all"],
      "env": {
        "PAYPAL_ACCESS_TOKEN": "${PAYPAL_ACCESS_TOKEN}",
        "PAYPAL_ENVIRONMENT": "PRODUCTION"
      }
    }
  }
}
\stopverb}
}
}

\subtree{
\title{Token Generation}
\p{PayPal requires OAuth2 access tokens. Token validity:}

\ul{
\li{\strong{Sandbox}: 3-8 hours}
\li{\strong{Production}: 8 hours}
}

\subtree{
\title{Generate Access Token}
\pre{\startverb
# Sandbox
curl -X POST https://api-m.sandbox.paypal.com/v1/oauth2/token \
  -H "Accept: application/json" \
  -H "Accept-Language: en_US" \
  -u "${PAYPAL_CLIENT_ID}:${PAYPAL_CLIENT_SECRET}" \
  -d "grant_type=client_credentials"

# Production
curl -X POST https://api-m.paypal.com/v1/oauth2/token \
  -H "Accept: application/json" \
  -H "Accept-Language: en_US" \
  -u "${PAYPAL_CLIENT_ID}:${PAYPAL_CLIENT_SECRET}" \
  -d "grant_type=client_credentials"
\stopverb}
}

\subtree{
\title{Token Refresh Script}
\pre{\startverb
#!/bin/bash
# paypal-token-refresh.sh
export PAYPAL_ACCESS_TOKEN=$(curl -s -X POST \
  "https://api-m.${PAYPAL_ENVIRONMENT:-sandbox}.paypal.com/v1/oauth2/token" \
  -H "Accept: application/json" \
  -u "${PAYPAL_CLIENT_ID}:${PAYPAL_CLIENT_SECRET}" \
  -d "grant_type=client_credentials" | jq -r '.access_token')
echo "Token refreshed: ${PAYPAL_ACCESS_TOKEN:0:20}..."
\stopverb}
}
}

\subtree{
\title{Available Tools}
\subtree{
\title{Invoices}
\pre{\startverb
| Tool | Description |
|------|-------------|
| `create_invoice` | Create a new invoice |
| `list_invoices` | List all invoices |
| `get_invoice` | Get invoice details by ID |
| `send_invoice` | Send invoice to recipient |
| `send_invoice_reminder` | Send payment reminder |
| `cancel_sent_invoice` | Cancel a sent invoice |
| `generate_invoice_qr_code` | Generate QR code for invoice payment |
\stopverb}
}

\subtree{
\title{Payments}
\pre{\startverb
| Tool | Description |
|------|-------------|
| `create_order` | Create a payment order |
| `get_order` | Get order details |
| `pay_order` | Capture/execute payment |
| `create_refund` | Issue a refund |
| `get_refund` | Get refund status |
\stopverb}
}

\subtree{
\title{Dispute Management}
\pre{\startverb
| Tool | Description |
|------|-------------|
| `list_disputes` | List all disputes |
| `get_dispute` | Get dispute details |
| `accept_dispute_claim` | Accept a dispute claim |
\stopverb}
}

\subtree{
\title{Shipment Tracking}
\pre{\startverb
| Tool | Description |
|------|-------------|
| `create_shipment_tracking` | Add tracking info to transaction |
| `get_shipment_tracking` | Get tracking status |
\stopverb}
}

\subtree{
\title{Catalog Management}
\pre{\startverb
| Tool | Description |
|------|-------------|
