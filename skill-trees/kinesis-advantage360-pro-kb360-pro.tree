\title{"kinesis advantage360 pro (kb360 pro)"}

\taxon{skill}

\meta{description}{"Official Kinesis Advantage360 Professional (ZMK / Clique) keyboard usage: layers, Bluetooth profiles, Mod shortcuts, Clique programming, ergonomics, troubleshooting, and document URLs from kinesis-ergo.com/support/kb360pro. Use when configuring, pairing, resetting firmware, or answering questions about this split ergonomic keyboard."}

\subtree{
\title{Kinesis Advantage360 Pro (KB360 Pro)}
\p{Primary hub (manuals, FAQs, tickets): https://kinesis-ergo.com/support/kb360pro/}

\p{Models: \strong{KB360-PRO-}* and \strong{KB365-PRO-}* (Professional series). Firmware: \strong{ZMK} (Apache 2.0). Programming: \strong{Kinesis Clique} (browser) or GitHub/ZMK for advanced users.}

