\subtree{
\title{Mathematical Foundation}
\subtree{
\title{Coalgebra Definition}
\pre{\startverb
Coalgebra for F: (X, γ: X → F(X))
  - X is carrier (state space)
  - γ is structure map (observation)
  - F is endofunctor (observation type)
\stopverb}
}

\subtree{
\title{Stream Functor}
\pre{\startverb
F(X) = A × X    (head × tail)
νF ≅ A^ω       (infinite sequences)
\stopverb}
}

\subtree{
\title{Bisimulation}
\pre{\startverb
R is bisimulation ⟺
  ∀(x,y) ∈ R: (γ_X(x), γ_Y(y)) ∈ F(R)

Behavioral equivalence: x ∼ y ⟺ ∃R bisimulation. (x,y) ∈ R
\stopverb}
}

\subtree{
\title{Coinduction Principle}
\pre{\startverb
To prove P(ν F), show:
  P is F-consistent: P(x) ⟹ P(tail(x))
  P(seed) holds
\stopverb}
}
}

