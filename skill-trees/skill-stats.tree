\title{Skill Stats}

\taxon{skill}

\meta{trit}{0}

\meta{description}{Skill statistics, thread usage analysis, GF(3) conservation tracking, and probe verification for the 443+ skill ecosystem}

\subtree{
\title{Skill Stats}
\p{Analyze skill ecosystem health, thread usage, and GF(3) conservation.}

\subtree{
\title{Quick Commands}
\pre{\startverb
# Count skills
ls ~/.claude/skills/*/SKILL.md | wc -l

# Trit distribution
grep -h "^trit:" ~/.claude/skills/*/SKILL.md | sort | uniq -c

# Skills with probes
grep -l "^probe:" ~/.claude/skills/*/SKILL.md | wc -l

# Recently modified
ls -lt ~/.claude/skills/*/SKILL.md | head -20
\stopverb}
}

\subtree{
\title{GF(3) Conservation Check}
\pre{\startverb
# Calculate global trit sum
grep -h "^trit:" ~/.claude/skills/*/SKILL.md | \
  awk '{sum += $2} END {print "GF(3) Sum:", sum}'
\stopverb}

\p{Target: Sum should be 0 (or divisible by 3).}
}

\subtree{
\title{Thread-Skill Usage Analysis}
\p{Use \code{\startverb find_thread\stopverb} to discover skill usage patterns:}

\pre{\startverb
find_thread query="skill after:7d" limit=20
\stopverb}

\p{Then extract skill mentions from thread summaries.}
}

\subtree{
\title{Probe Verification}
\p{Run all skill probes:}

\pre{\startverb
for skill in ~/.claude/skills/*/SKILL.md; do
  name=$(dirname $skill | xargs basename)
  probe=$(grep "^probe:" $skill | sed 's/^probe: *//')
  if [ -n "$probe" ]; then
    echo "Probing: $name"
    eval "$probe" 2>&1 | head -3
  fi
done
\stopverb}
}

\subtree{
\title{Dashboard Generation}
\pre{\startverb
bb ~/ies/scripts/asi_skill_selector.bb list > skill_inventory.txt
\stopverb}
}

\subtree{
\title{Integration with DuckDB}
\pre{\startverb
-- Load skill metadata into DuckDB
CREATE TABLE skill_stats AS
SELECT 
  skill_name,
  trit,
  has_probe,
  last_modified,
  usage_count
FROM read_json('skill_metadata.json');

-- GF(3) balance check
SELECT SUM(trit) as global_balance FROM skill_stats;

-- Most used skills
SELECT skill_name, usage_count 
FROM skill_stats 
ORDER BY usage_count DESC 
LIMIT 20;
\stopverb}
}

\subtree{
\title{Key Metrics}
\pre{\startverb
| Metric | Query |
|--------|-------|
| Total skills | `ls ~/.claude/skills/*/SKILL.md \| wc -l` |
| With trit | `grep -l "^trit:" ~/.claude/skills/*/SKILL.md \| wc -l` |
| With probe | `grep -l "^probe:" ~/.claude/skills/*/SKILL.md \| wc -l` |
| MINUS count | `grep -h "^trit: -1" ~/.claude/skills/*/SKILL.md \| wc -l` |
| ERGODIC count | `grep -h "^trit: 0" ~/.claude/skills/*/SKILL.md \| wc -l` |
| PLUS count | `grep -h "^trit: 1" ~/.claude/skills/*/SKILL.md \| wc -l` |
\stopverb}
}

\subtree{
\title{Skill Health Score}
\pre{\startverb
Health = (skills_with_trit / total) × (skills_with_probe / total) × (1 - |gf3_sum| / total)
\stopverb}

\p{Target: Health > 0.8}
}

