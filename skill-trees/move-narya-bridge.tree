\subtree{
\title{Why Observational Equality Matters}
\subtree{
\title{Traditional (Axiom-based)}
\pre{\startverb
-- Agda: Need postulate
postulate
  funext : {A : Set} {B : A → Set} {f g : (x : A) → B x}
         → ((x : A) → f x ≡ g x) → f ≡ g
\stopverb}
}

\subtree{
\title{Narya (Observational)}
\pre{\startverb
-- Narya: Function extensionality is DEFINITIONAL
-- Id(A → B)(f, g) ≡ (x : A) → Id(B)(f x, g x)

-- So if we prove ∀ x. f x = g x, we immediately have f = g
-- No postulate, no axiom, no appeal to univalence
\stopverb}

\p{This matters for GF(3) because:}

\ul{
\li{\code{\startverb add(a, b)\stopverb} and \code{\startverb add(b, a)\stopverb} are equal if equal pointwise}
\li{Conservation is preserved under function composition}
\li{Bridge types give internal parametricity}
}
}
}

\subtree{
\title{Commands}
\pre{\startverb
# Translate Move module to Narya
just move-narya MODULE.move

# Check Narya translation
just narya-check MODULE.narya

# List proof obligations (holes)
just narya-holes MODULE.narya

# Interactive proof session
just narya-prove MODULE.narya

# Verify GF(3) conservation in Narya
just narya-verify-gf3 MODULE.narya
\stopverb}
}

\subtree{
\title{Performance Notes}
\pre{\startverb
| Operation | Expected Time |
|-----------|---------------|
| Translation (small module) | < 1s |
| Type checking | < 1s for small proofs |
| Proof search | Seconds to minutes |
| Full verification | Depends on proof complexity |
\stopverb}

\p{Narya is research-grade, not production. Use for:}

\ul{
\li{Prototyping verification approaches}
\li{Understanding observational equality}
\li{Research into GF(3) formal semantics}
}

\p{For production verification, consider Lean 4 or Coq after prototyping in Narya.}
}

