\subtree{
\title{Scripts}
\subtree{
\title{openalex_client.py}
\p{Main API client with:}

\ul{
\li{Automatic rate limiting}
\li{Exponential backoff retry logic}
\li{Pagination support}
\li{Batch operations}
\li{Error handling}
}

\p{Use for direct API access with full control.}
}

\subtree{
\title{query_helpers.py}
\p{High-level helper functions for common operations:}

\ul{
\li{\code{\startverb find_author_works()\stopverb} - Get papers by author}
\li{\code{\startverb find_institution_works()\stopverb} - Get papers from institution}
\li{\code{\startverb find_highly_cited_recent_papers()\stopverb} - Get influential papers}
\li{\code{\startverb get_open_access_papers()\stopverb} - Find OA publications}
\li{\code{\startverb get_publication_trends()\stopverb} - Analyze trends over time}
\li{\code{\startverb analyze_research_output()\stopverb} - Comprehensive analysis}
}

\p{Use for common research queries with simplified interfaces.}
}
}

\subtree{
\title{Troubleshooting}
\subtree{
\title{Rate Limiting}
\p{If encountering 403 errors:}

\ol{
\li{Ensure email is added to requests}
\li{Verify not exceeding 10 req/sec}
\li{Client automatically implements exponential backoff}
}
}

\subtree{
\title{Empty Results}
\p{If searches return no results:}

\ol{
\li{Check filter syntax (see \code{\startverb references/api_guide.md\stopverb})}
\li{Use two-step pattern for entity lookups (don't filter by names)}
\li{Verify entity IDs are correct format}
}
}

\subtree{
\title{Timeout Errors}
\p{For large queries:}

\ol{
\li{Use pagination with \code{\startverb per-page=200\stopverb}}
\li{Use \code{\startverb select=\stopverb} to limit returned fields}
\li{Break into smaller queries if needed}
}
}
}

\subtree{
\title{Rate Limits}
\ul{
\li{\strong{Default}: 1 request/second, 100k requests/day}
\li{\strong{Polite pool (with email)}: 10 requests/second, 100k requests/day}
}

\p{Always use polite pool for production workflows by providing email to client.}
}

\subtree{
\title{Notes}
\ul{
\li{No authentication required}
\li{All data is open and free}
\li{Rate limits apply globally, not per IP}
\li{Use LitLLM with OpenRouter if LLM-based analysis is needed (don't use Perplexity API directly)}
\li{Client handles pagination, retries, and rate limiting automatically}
}
}
}