\title{Openalex Database}

\taxon{skill}

\meta{description}{Query and analyze scholarly literature using the OpenAlex database. This skill should be used when searching for academic papers, analyzing research trends, finding works by authors or institutions, tracking citations, discovering open access publications, or conducting bibliometric analysis across 240M+ scholarly works. Use for literature searches, research output analysis, citation analysis, and academic database queries.}

\subtree{
\title{OpenAlex Database}
\subtree{
\title{Overview}
\p{OpenAlex is a comprehensive open catalog of 240M+ scholarly works, authors, institutions, topics, sources, publishers, and funders. This skill provides tools and workflows for querying the OpenAlex API to search literature, analyze research output, track citations, and conduct bibliometric studies.}
}

\subtree{
\title{Quick Start}
\subtree{
\title{Basic Setup}
\p{Always initialize the client with an email address to access the polite pool (10x rate limit boost):}

\pre{\startverb
from scripts.openalex_client import OpenAlexClient

client = OpenAlexClient(email="your-email@example.edu")
\stopverb}
}

\subtree{
\title{Installation Requirements}
\p{Install required package using uv:}

\pre{\startverb
uv pip install requests
\stopverb}

\p{No API key required - OpenAlex is completely open.}
}
}

\subtree{
\title{Core Capabilities}
\subtree{
\title{1. Search for Papers}
\p{\strong{Use for}: Finding papers by title, abstract, or topic}

\pre{\startverb
# Simple search
results = client.search_works(
    search="machine learning",
    per_page=100
)

# Search with filters
results = client.search_works(
    search="CRISPR gene editing",
    filter_params={
        "publication_year": ">2020",
        "is_oa": "true"
    },
    sort="cited_by_count:desc"
)
\stopverb}
}

\subtree{
\title{2. Find Works by Author}
\p{\strong{Use for}: Getting all publications by a specific researcher}

\p{Use the two-step pattern (entity name → ID → works):}

\pre{\startverb
from scripts.query_helpers import find_author_works

works = find_author_works(
    author_name="Jennifer Doudna",
    client=client,
    limit=100
)
\stopverb}

\p{\strong{Manual two-step approach}:}

\pre{\startverb
# Step 1: Get author ID
author_response = client._make_request(
    '/authors',
    params={'search': 'Jennifer Doudna', 'per-page': 1}
)
author_id = author_response['results'][0]['id'].split('/')[-1]

# Step 2: Get works
works = client.search_works(
    filter_params={"authorships.author.id": author_id}
)
\stopverb}
}

\subtree{
\title{3. Find Works from Institution}
\p{\strong{Use for}: Analyzing research output from universities or organizations}

\pre{\startverb
from scripts.query_helpers import find_institution_works

works = find_institution_works(
    institution_name="Stanford University",
    client=client,
    limit=200
)
\stopverb}
}

\subtree{
\title{4. Highly Cited Papers}
\p{\strong{Use for}: Finding influential papers in a field}

\pre{\startverb
from scripts.query_helpers import find_highly_cited_recent_papers

papers = find_highly_cited_recent_papers(
    topic="quantum computing",
    years=">2020",
    client=client,
    limit=100
)
\stopverb}
}

\subtree{
\title{5. Open Access Papers}
\p{\strong{Use for}: Finding freely available research}

\pre{\startverb
from scripts.query_helpers import get_open_access_papers

papers = get_open_access_papers(
    search_term="climate change",
    client=client,
    oa_status="any",  # or "gold", "green", "hybrid", "bronze"
    limit=200
)
\stopverb}
}

\subtree{
\title{6. Publication Trends Analysis}
\p{\strong{Use for}: Tracking research output over time}

\pre{\startverb
from scripts.query_helpers import get_publication_trends

trends = get_publication_trends(
    search_term="artificial intelligence",
    filter_params={"is_oa": "true"},
    client=client
)

# Sort and display
for trend in sorted(trends, key=lambda x: x['key'])[-10:]:
    print(f"{trend['key']}: {trend['count']} publications")
\stopverb}
}

\subtree{
\title{7. Research Output Analysis}
\p{\strong{Use for}: Comprehensive analysis of author or institution research}

\pre{\startverb
from scripts.query_helpers import analyze_research_output

analysis = analyze_research_output(
    entity_type='institution',  # or 'author'
    entity_name='MIT',
    client=client,
    years='>2020'
)

print(f"Total works: {analysis['total_works']}")
print(f"Open access: {analysis['open_access_percentage']}%")
print(f"Top topics: {analysis['top_topics'][:5]}")
\stopverb}
}

\subtree{
\title{8. Batch Lookups}
\p{\strong{Use for}: Getting information for multiple DOIs, ORCIDs, or IDs efficiently}

\pre{\startverb
dois = [
    "https://doi.org/10.1038/s41586-021-03819-2",
    "https://doi.org/10.1126/science.abc1234",
    # ... up to 50 DOIs
]

works = client.batch_lookup(
    entity_type='works',
    ids=dois,
    id_field='doi'
)
\stopverb}
}

\subtree{
\title{9. Random Sampling}
\p{\strong{Use for}: Getting representative samples for analysis}

\pre{\startverb
# Small sample
works = client.sample_works(
    sample_size=100,
    seed=42,  # For reproducibility
    filter_params={"publication_year": "2023"}
)

# Large sample (>10k) - automatically handles multiple requests
works = client.sample_works(
    sample_size=25000,
    seed=42,
    filter_params={"is_oa": "true"}
)
\stopverb}
}

\subtree{
\title{10. Citation Analysis}
\p{\strong{Use for}: Finding papers that cite a specific work}

\pre{\startverb
# Get the work
work = client.get_entity('works', 'https://doi.org/10.1038/s41586-021-03819-2')

# Get citing papers using cited_by_api_url
import requests
citing_response = requests.get(
    work['cited_by_api_url'],
    params={'mailto': client.email, 'per-page': 200}
)
citing_works = citing_response.json()['results']
\stopverb}
}

\subtree{
\title{11. Topic and Subject Analysis}
\p{\strong{Use for}: Understanding research focus areas}

\pre{\startverb
# Get top topics for an institution
topics = client.group_by(
    entity_type='works',
    group_field='topics.id',
    filter_params={
        "authorships.institutions.id": "I136199984",  # MIT
        "publication_year": ">2020"
    }
)

for topic in topics[:10]:
    print(f"{topic['key_display_name']}: {topic['count']} works")
\stopverb}
}

\subtree{
\title{12. Large-Scale Data Extraction}
\p{\strong{Use for}: Downloading large datasets for analysis}

\pre{\startverb
# Paginate through all results
all_papers = client.paginate_all(
    endpoint='/works',
    params={
        'search': 'synthetic biology',
        'filter': 'publication_year:2020-2024'
    },
    max_results=10000
)

# Export to CSV
import csv
with open('papers.csv', 'w', newline='', encoding='utf-8') as f:
    writer = csv.writer(f)
    writer.writerow(['Title', 'Year', 'Citations', 'DOI', 'OA Status'])

    for paper in all_papers:
        writer.writerow([
            paper.get('title', 'N/A'),
            paper.get('publication_year', 'N/A'),
            paper.get('cited_by_count', 0),
            paper.get('doi', 'N/A'),
            paper.get('open_access', {}).get('oa_status', 'closed')
        ])
\stopverb}
}
}

\subtree{
\title{Critical Best Practices}
\subtree{
\title{Always Use Email for Polite Pool}
\p{Add email to get 10x rate limit (1 req/sec → 10 req/sec):}

\pre{\startverb
client = OpenAlexClient(email="your-email@example.edu")
\stopverb}
}

\subtree{
\title{Use Two-Step Pattern for Entity Lookups}
\p{Never filter by entity names directly - always get ID first:}

\pre{\startverb
# ✅ Correct
# 1. Search for entity → get ID
# 2. Filter by ID

# ❌ Wrong
# filter=author_name:Einstein  # This doesn't work!
\stopverb}
}

\subtree{
\title{Use Maximum Page Size}
\p{Always use \code{\startverb per-page=200\stopverb} for efficient data retrieval:}

\pre{\startverb
results = client.search_works(search="topic", per_page=200)
\stopverb}
}

\subtree{
\title{Batch Multiple IDs}
\p{Use batch_lookup() for multiple IDs instead of individual requests:}

\pre{\startverb
# ✅ Correct - 1 request for 50 DOIs
works = client.batch_lookup('works', doi_list, 'doi')

# ❌ Wrong - 50 separate requests
for doi in doi_list:
    work = client.get_entity('works', doi)
\stopverb}
}

\subtree{
\title{Use Sample Parameter for Random Data}
\p{Use \code{\startverb sample_works()\stopverb} with seed for reproducible random sampling:}

\pre{\startverb
# ✅ Correct
works = client.sample_works(sample_size=100, seed=42)

# ❌ Wrong - random page numbers bias results
# Using random page numbers doesn't give true random sample
\stopverb}
}

\subtree{
\title{Select Only Needed Fields}
\p{Reduce response size by selecting specific fields:}

\pre{\startverb
results = client.search_works(
    search="topic",
    select=['id', 'title', 'publication_year', 'cited_by_count']
)
\stopverb}
}
}

\subtree{
\title{Common Filter Patterns}
\subtree{
\title{Date Ranges}
\pre{\startverb
# Single year
filter_params={"publication_year": "2023"}

# After year
filter_params={"publication_year": ">2020"}

# Range
filter_params={"publication_year": "2020-2024"}
\stopverb}
}

\subtree{
\title{Multiple Filters (AND)}
\pre{\startverb
# All conditions must match
filter_params={
    "publication_year": ">2020",
    "is_oa": "true",
    "cited_by_count": ">100"
}
\stopverb}
}

\subtree{
\title{Multiple Values (OR)}
\pre{\startverb
# Any institution matches
filter_params={
    "authorships.institutions.id": "I136199984|I27837315"  # MIT or Harvard
}
\stopverb}
}

\subtree{
\title{Collaboration (AND within attribute)}
\pre{\startverb
# Papers with authors from BOTH institutions
filter_params={
    "authorships.institutions.id": "I136199984+I27837315"  # MIT AND Harvard
}
\stopverb}
}

\subtree{
\title{Negation}
\pre{\startverb
# Exclude type
filter_params={
    "type": "!paratext"
}
\stopverb}
}
}

\subtree{
\title{Entity Types}
\p{OpenAlex provides these entity types:}

\ul{
\li{\strong{works} - Scholarly documents (articles, books, datasets)}
\li{\strong{authors} - Researchers with disambiguated identities}
\li{\strong{institutions} - Universities and research organizations}
\li{\strong{sources} - Journals, repositories, conferences}
\li{\strong{topics} - Subject classifications}
\li{\strong{publishers} - Publishing organizations}
\li{\strong{funders} - Funding agencies}
}

\p{Access any entity type using consistent patterns:}

\pre{\startverb
client.search_works(...)
client.get_entity('authors', author_id)
client.group_by('works', 'topics.id', filter_params={...})
\stopverb}
}

\subtree{
\title{External IDs}
\p{Use external identifiers directly:}

\pre{\startverb
# DOI for works
work = client.get_entity('works', 'https://doi.org/10.7717/peerj.4375')

# ORCID for authors
author = client.get_entity('authors', 'https://orcid.org/0000-0003-1613-5981')

# ROR for institutions
institution = client.get_entity('institutions', 'https://ror.org/02y3ad647')

# ISSN for sources
source = client.get_entity('sources', 'issn:0028-0836')
\stopverb}
}

