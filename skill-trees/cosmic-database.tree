\title{Cosmic Database}

\taxon{skill}

\meta{description}{"Access COSMIC cancer mutation database. Query somatic mutations, Cancer Gene Census, mutational signatures, gene fusions, for cancer research and precision oncology. Requires authentication."}

\subtree{
\title{COSMIC Database}
\subtree{
\title{Overview}
\p{COSMIC (Catalogue of Somatic Mutations in Cancer) is the world's largest and most comprehensive database for exploring somatic mutations in human cancer. Access COSMIC's extensive collection of cancer genomics data, including millions of mutations across thousands of cancer types, curated gene lists, mutational signatures, and clinical annotations programmatically.}
}

\subtree{
\title{When to Use This Skill}
\p{This skill should be used when:}

\ul{
\li{Downloading cancer mutation data from COSMIC}
\li{Accessing the Cancer Gene Census for curated cancer gene lists}
\li{Retrieving mutational signature profiles}
\li{Querying structural variants, copy number alterations, or gene fusions}
\li{Analyzing drug resistance mutations}
\li{Working with cancer cell line genomics data}
\li{Integrating cancer mutation data into bioinformatics pipelines}
\li{Researching specific genes or mutations in cancer contexts}
}
}

\subtree{
\title{Prerequisites}
\subtree{
\title{Account Registration}
\p{COSMIC requires authentication for data downloads:}

\ul{
\li{\strong{Academic users}: Free access with registration at https://cancer.sanger.ac.uk/cosmic/register}
\li{\strong{Commercial users}: License required (contact QIAGEN)}
}
}

\subtree{
\title{Python Requirements}
\pre{\startverb
uv pip install requests pandas
\stopverb}
}
}

\subtree{
\title{Quick Start}
\subtree{
\title{1. Basic File Download}
\p{Use the \code{\startverb scripts/download_cosmic.py\stopverb} script to download COSMIC data files:}

\pre{\startverb
from scripts.download_cosmic import download_cosmic_file

# Download mutation data
download_cosmic_file(
    email="your_email@institution.edu",
    password="your_password",
    filepath="GRCh38/cosmic/latest/CosmicMutantExport.tsv.gz",
    output_filename="cosmic_mutations.tsv.gz"
)
\stopverb}
}

\subtree{
\title{2. Command-Line Usage}
\pre{\startverb
# Download using shorthand data type
python scripts/download_cosmic.py user@email.com --data-type mutations

# Download specific file
python scripts/download_cosmic.py user@email.com \
    --filepath GRCh38/cosmic/latest/cancer_gene_census.csv

# Download for specific genome assembly
python scripts/download_cosmic.py user@email.com \
    --data-type gene_census --assembly GRCh37 -o cancer_genes.csv
\stopverb}
}

\subtree{
\title{3. Working with Downloaded Data}
\pre{\startverb
import pandas as pd

# Read mutation data
mutations = pd.read_csv('cosmic_mutations.tsv.gz', sep='\t', compression='gzip')

# Read Cancer Gene Census
gene_census = pd.read_csv('cancer_gene_census.csv')

# Read VCF format
import pysam
vcf = pysam.VariantFile('CosmicCodingMuts.vcf.gz')
\stopverb}
}
}

\subtree{
\title{Available Data Types}
\subtree{
\title{Core Mutations}
\p{Download comprehensive mutation data including point mutations, indels, and genomic annotations.}

\p{\strong{Common data types}:}

\ul{
\li{\code{\startverb mutations\stopverb} - Complete coding mutations (TSV format)}
\li{\code{\startverb mutations_vcf\stopverb} - Coding mutations in VCF format}
\li{\code{\startverb sample_info\stopverb} - Sample metadata and tumor information}
}

\pre{\startverb
# Download all coding mutations
download_cosmic_file(
    email="user@email.com",
    password="password",
    filepath="GRCh38/cosmic/latest/CosmicMutantExport.tsv.gz"
)
\stopverb}
}

\subtree{
\title{Cancer Gene Census}
\p{Access the expert-curated list of ~700+ cancer genes with substantial evidence of cancer involvement.}

\pre{\startverb
# Download Cancer Gene Census
download_cosmic_file(
    email="user@email.com",
    password="password",
    filepath="GRCh38/cosmic/latest/cancer_gene_census.csv"
)
\stopverb}

\p{\strong{Use cases}:}

\ul{
\li{Identifying known cancer genes}
\li{Filtering variants by cancer relevance}
\li{Understanding gene roles (oncogene vs tumor suppressor)}
\li{Target gene selection for research}
}
}

\subtree{
\title{Mutational Signatures}
\p{Download signature profiles for mutational signature analysis.}

\pre{\startverb
# Download signature definitions
download_cosmic_file(
    email="user@email.com",
    password="password",
    filepath="signatures/signatures.tsv"
)
\stopverb}

\p{\strong{Signature types}:}

\ul{
\li{Single Base Substitution (SBS) signatures}
\li{Doublet Base Substitution (DBS) signatures}
\li{Insertion/Deletion (ID) signatures}
}
}

\subtree{
\title{Structural Variants and Fusions}
\p{Access gene fusion data and structural rearrangements.}

\p{\strong{Available data types}:}

\ul{
\li{\code{\startverb structural_variants\stopverb} - Structural breakpoints}
\li{\code{\startverb fusion_genes\stopverb} - Gene fusion events}
}

\pre{\startverb
# Download gene fusions
download_cosmic_file(
    email="user@email.com",
    password="password",
    filepath="GRCh38/cosmic/latest/CosmicFusionExport.tsv.gz"
)
\stopverb}
}

\subtree{
\title{Copy Number and Expression}
\p{Retrieve copy number alterations and gene expression data.}

\p{\strong{Available data types}:}

\ul{
\li{\code{\startverb copy_number\stopverb} - Copy number gains/losses}
\li{\code{\startverb gene_expression\stopverb} - Over/under-expression data}
}

\pre{\startverb
# Download copy number data
download_cosmic_file(
    email="user@email.com",
    password="password",
    filepath="GRCh38/cosmic/latest/CosmicCompleteCNA.tsv.gz"
)
\stopverb}
}

\subtree{
\title{Resistance Mutations}
\p{Access drug resistance mutation data with clinical annotations.}

\pre{\startverb
# Download resistance mutations
download_cosmic_file(
    email="user@email.com",
    password="password",
    filepath="GRCh38/cosmic/latest/CosmicResistanceMutations.tsv.gz"
)
\stopverb}
}
}

\subtree{
\title{Working with COSMIC Data}
\subtree{
\title{Genome Assemblies}
\p{COSMIC provides data for two reference genomes:}

\ul{
\li{\strong{GRCh38} (recommended, current standard)}
\li{\strong{GRCh37} (legacy, for older pipelines)}
}

\p{Specify the assembly in file paths:}

\pre{\startverb
# GRCh38 (recommended)
filepath="GRCh38/cosmic/latest/CosmicMutantExport.tsv.gz"

# GRCh37 (legacy)
filepath="GRCh37/cosmic/latest/CosmicMutantExport.tsv.gz"
\stopverb}
}

\subtree{
\title{Versioning}
\ul{
\li{Use \code{\startverb latest\stopverb} in file paths to always get the most recent release}
\li{COSMIC is updated quarterly (current version: v102, May 2025)}
\li{Specific versions can be used for reproducibility: \code{\startverb v102\stopverb}, \code{\startverb v101\stopverb}, etc.}
}
}

\subtree{
\title{File Formats}
\ul{
\li{\strong{TSV/CSV}: Tab/comma-separated, gzip compressed, read with pandas}
\li{\strong{VCF}: Standard variant format, use with pysam, bcftools, or GATK}
\li{All files include headers describing column contents}
}
}

\subtree{
\title{Common Analysis Patterns}
\p{\strong{Filter mutations by gene}:}

\pre{\startverb
import pandas as pd

mutations = pd.read_csv('cosmic_mutations.tsv.gz', sep='\t', compression='gzip')
tp53_mutations = mutations[mutations['Gene name'] == 'TP53']
\stopverb}

\p{\strong{Identify cancer genes by role}:}

\pre{\startverb
gene_census = pd.read_csv('cancer_gene_census.csv')
oncogenes = gene_census[gene_census['Role in Cancer'].str.contains('oncogene', na=False)]
tumor_suppressors = gene_census[gene_census['Role in Cancer'].str.contains('TSG', na=False)]
\stopverb}

\p{\strong{Extract mutations by cancer type}:}

\pre{\startverb
mutations = pd.read_csv('cosmic_mutations.tsv.gz', sep='\t', compression='gzip')
lung_mutations = mutations[mutations['Primary site'] == 'lung']
\stopverb}

\p{\strong{Work with VCF files}:}

\pre{\startverb
import pysam

vcf = pysam.VariantFile('CosmicCodingMuts.vcf.gz')
for record in vcf.fetch('17', 7577000, 7579000):  # TP53 region
    print(record.id, record.ref, record.alts, record.info)
\stopverb}
}
}

