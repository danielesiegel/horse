\subtree{
\title{Helper Functions}
\p{The download script includes helper functions for common operations:}

\subtree{
\title{Get Common File Paths}
\pre{\startverb
from scripts.download_cosmic import get_common_file_path

# Get path for mutations file
path = get_common_file_path('mutations', genome_assembly='GRCh38')
# Returns: 'GRCh38/cosmic/latest/CosmicMutantExport.tsv.gz'

# Get path for gene census
path = get_common_file_path('gene_census')
# Returns: 'GRCh38/cosmic/latest/cancer_gene_census.csv'
\stopverb}

\p{\strong{Available shortcuts}:}

\ul{
\li{\code{\startverb mutations\stopverb} - Core coding mutations}
\li{\code{\startverb mutations_vcf\stopverb} - VCF format mutations}
\li{\code{\startverb gene_census\stopverb} - Cancer Gene Census}
\li{\code{\startverb resistance_mutations\stopverb} - Drug resistance data}
\li{\code{\startverb structural_variants\stopverb} - Structural variants}
\li{\code{\startverb gene_expression\stopverb} - Expression data}
\li{\code{\startverb copy_number\stopverb} - Copy number alterations}
\li{\code{\startverb fusion_genes\stopverb} - Gene fusions}
\li{\code{\startverb signatures\stopverb} - Mutational signatures}
\li{\code{\startverb sample_info\stopverb} - Sample metadata}
}
}
}

\subtree{
\title{Troubleshooting}
\subtree{
\title{Authentication Errors}
\ul{
\li{Verify email and password are correct}
\li{Ensure account is registered at cancer.sanger.ac.uk/cosmic}
\li{Check if commercial license is required for your use case}
}
}

\subtree{
\title{File Not Found}
\ul{
\li{Verify the filepath is correct}
\li{Check that the requested version exists}
\li{Use \code{\startverb latest\stopverb} for the most recent version}
\li{Confirm genome assembly (GRCh37 vs GRCh38) is correct}
}
}

\subtree{
\title{Large File Downloads}
\ul{
\li{COSMIC files can be several GB in size}
\li{Ensure sufficient disk space}
\li{Download may take several minutes depending on connection}
\li{The script shows download progress for large files}
}
}

\subtree{
\title{Commercial Use}
\ul{
\li{Commercial users must license COSMIC through QIAGEN}
\li{Contact: cosmic-translation@sanger.ac.uk}
\li{Academic access is free but requires registration}
}
}
}

\subtree{
\title{Integration with Other Tools}
\p{COSMIC data integrates well with:}

\ul{
\li{\strong{Variant annotation}: VEP, ANNOVAR, SnpEff}
\li{\strong{Signature analysis}: SigProfiler, deconstructSigs, MuSiCa}
\li{\strong{Cancer genomics}: cBioPortal, OncoKB, CIViC}
\li{\strong{Bioinformatics}: Bioconductor, TCGA analysis tools}
\li{\strong{Data science}: pandas, scikit-learn, PyTorch}
}
}

