\subtree{
\title{Common Workflows}
\subtree{
\title{Workflow 1: Basic Literature Search}
\ol{
\li{Identify key concepts and synonyms}
\li{Construct query with Boolean operators and field tags}
\li{Review initial results and refine query}
\li{Apply filters (date, article type, language)}
\li{Export results for analysis}
}
}

\subtree{
\title{Workflow 2: Systematic Review Search}
\ol{
\li{Define research question using PICO framework}
\li{Identify all relevant MeSH terms and synonyms}
\li{Construct comprehensive search strategy}
\li{Search multiple databases (include PubMed)}
\li{Document search strategy and date}
\li{Export results for screening and review}
}
}

\subtree{
\title{Workflow 3: Programmatic Data Extraction}
\ol{
\li{Design search query and test in web interface}
\li{Implement search using ESearch API}
\li{Use history server for large result sets}
\li{Retrieve detailed records with EFetch}
\li{Parse XML/JSON responses}
\li{Store data locally with caching}
\li{Implement rate limiting and error handling}
}
}

\subtree{
\title{Workflow 4: Citation Discovery}
\ol{
\li{Start with known relevant article}
\li{Use Similar Articles to find related work}
\li{Check citing articles (when available)}
\li{Explore MeSH terms from relevant articles}
\li{Construct new searches based on discoveries}
\li{Use ELink to find related database entries}
}
}

\subtree{
\title{Workflow 5: Ongoing Literature Monitoring}
\ol{
\li{Construct comprehensive search query}
\li{Test and refine query for precision}
\li{Save search to My NCBI account}
\li{Set up email alerts for new matches}
\li{Create RSS feed for feed reader monitoring}
\li{Review new articles regularly}
}
}
}

\subtree{
\title{Tips and Best Practices}
\subtree{
\title{Search Strategy}
\ul{
\li{Start broad, then narrow with field tags and filters}
\li{Include synonyms and MeSH terms for comprehensive coverage}
\li{Use quotation marks for exact phrases}
\li{Check Search Details in Advanced Search to verify query translation}
\li{Combine multiple searches using search history}
}
}

\subtree{
\title{API Usage}
\ul{
\li{Obtain API key for higher rate limits (10 req/sec vs 3 req/sec)}
\li{Use history server for result sets > 500 articles}
\li{Implement exponential backoff for rate limit handling}
\li{Cache results locally to minimize redundant requests}
\li{Always include descriptive User-Agent header}
}
}

\subtree{
\title{Quality Filtering}
\ul{
\li{Prefer systematic reviews and meta-analyses for synthesized evidence}
\li{Use publication type filters to find specific study designs}
\li{Filter by date for most recent research}
\li{Apply language filters as appropriate}
\li{Use free full text filter for immediate access}
}
}

\subtree{
\title{Citation Management}
\ul{
\li{Export early and often to avoid losing search results}
\li{Use .nbib format for compatibility with most reference managers}
\li{Create My NCBI account for permanent collections}
\li{Document search strategies for reproducibility}
\li{Use Collections to organize research by project}
}
}
}

\subtree{
\title{Limitations and Considerations}
\subtree{
\title{Database Coverage}
\ul{
\li{Primarily biomedical and life sciences literature}
\li{Pre-1975 articles often lack abstracts}
\li{Full author names available from 2002 forward}
\li{Non-English abstracts available but may default to English display}
}
}

\subtree{
\title{Search Limitations}
\ul{
\li{Display limited to 10,000 results maximum}
\li{Search history expires after 8 hours of inactivity}
\li{Clipboard holds max 500 items with 8-hour expiration}
\li{Automatic term mapping may produce unexpected results}
}
}

\subtree{
\title{API Considerations}
\ul{
\li{Rate limits apply (3-10 requests/second)}
\li{Large queries may time out (use history server)}
\li{XML parsing required for detailed data extraction}
\li{API key recommended for production use}
}
}

\subtree{
\title{Access Limitations}
\ul{
\li{PubMed provides citations and abstracts (not always full text)}
\li{Full text access depends on publisher, institutional access, or open access status}
\li{LinkOut availability varies by journal and institution}
\li{Some content requires subscription or payment}
}
}
}

