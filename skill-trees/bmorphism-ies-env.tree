\li{Long-running applications}
\li{Libraries requiring JVM features}
\li{Performance-critical code}
\li{Full ecosystem access}
}

\p{\strong{Example}:}

\pre{\startverb
clj -M -e "(println \"Hello\")"
clj -M:deps tree  # View dependency tree
\stopverb}

\p{\strong{Documentation}: https://clojure.org/guides/getting_started}
}

