}

\subtree{
\title{dust (1.2.3)}
\p{\strong{Purpose}: du + rust = dust (modern du) \strong{Use Cases}:}

\ul{
\li{Tree view of disk usage}
\li{Colored output}
\li{Quick overview}
}

\p{\strong{Example}:}

\pre{\startverb
