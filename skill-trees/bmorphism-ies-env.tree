\title{Bmorphism Ies Env}

\taxon{skill}

\meta{version}{1.0.0}

\meta{trit}{0}

\meta{description}{Documentation and orchestration for the bmorphism/ies flox environment toolkit}

\subtree{
\title{bmorphism-ies-env}
\p{Comprehensive documentation and MCP integration for the 31-tool bmorphism/ies flox environment.}

\p{\strong{Trit}: 0 (ERGODIC) - Infrastructure coordinator \strong{Environment}: \code{\startverb bmorphism/ies\stopverb} \strong{Package Count}: 31 tools across languages, utilities, and infrastructure}

\subtree{
\title{Overview}
\p{This skill provides documentation, usage patterns, and MCP tooling for the curated bmorphism/ies flox environment. The environment is optimized for:}

\ul{
\li{Multi-language development (Clojure, Julia, Python, Ruby, JavaScript, Java)}
\li{Systems programming and reverse engineering}
\li{Data processing and visualization}
\li{Cloud infrastructure management}
\li{Text editing and language tooling}
}
}

\subtree{
\title{Environment Manifest}
\subtree{
\title{Programming Languages & Runtimes (8 tools)}
\subtree{
\title{babashka (1.12.209)}
\p{\strong{Purpose}: Fast-starting Clojure scripting without JVM overhead \strong{Use Cases}:}

\ul{
\li{Shell scripting with Clojure syntax}
\li{MCP servers (like flox-mcp-server.bb)}
\li{Data pipeline orchestration}
\li{CI/CD scripts}
}

\p{\strong{Example}:}

\pre{\startverb
bb -e "(+ 1 2 3)"  # => 6
bb script.clj      # Run script
\stopverb}

\p{\strong{Key Features}:}

\ul{
\li{Instant startup (~10ms)}
\li{Built-in libraries: cheshire (JSON), babashka.process, babashka.fs}
\li{Native image compilation via GraalVM}
\li{SCI (Small Clojure Interpreter) for sandboxing}
}

\p{\strong{Documentation}: https://book.babashka.org}
}

\subtree{
\title{clojure (1.12.3.1577)}
\p{\strong{Purpose}: Full Clojure runtime with JVM \strong{Use Cases}:}

