\title{References}
\ul{
\li{[STRIDE Threat Modeling](https://docs.microsoft.com/en-us/azure/security/develop/threat-modeling-tool-threats)}
\li{[OWASP Threat Modeling](https://owasp.org/www-community/Threat_Modeling)}
\li{Template: \code{\startverb stride-template.md\stopverb} (in this skill directory)}
}
}
}