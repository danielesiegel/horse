\title{Tmux}

\taxon{skill}

\meta{description}{Terminal multiplexer.}

\subtree{
\title{tmux}
\p{Terminal multiplexer.}

\subtree{
\title{Sessions}
\pre{\startverb
tmux new -s name
tmux attach -t name
tmux ls
tmux kill-session -t name
\stopverb}
}

\subtree{
\title{Keys (prefix: C-b)}
\pre{\startverb
d       Detach
c       New window
n/p     Next/prev window
0-9     Select window
%       Split vertical
"       Split horizontal
o       Next pane
z       Toggle zoom
x       Kill pane
[       Copy mode
]       Paste
\stopverb}
}

\subtree{
\title{Copy Mode}
\pre{\startverb
Space   Start selection
Enter   Copy selection
q       Quit
/       Search forward
?       Search backward
\stopverb}
}

\subtree{
\title{Config}
\pre{\startverb
# ~/.tmux.conf
set -g prefix C-a
set -g mouse on
set -g base-index 1
\stopverb}
}
}