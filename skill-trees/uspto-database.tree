\subtree{
\title{Task 4: Tracking Assignments and Ownership}
\subtree{
\title{Patent and Trademark Assignments}
\p{Both patents and trademarks have Assignment Search APIs for tracking ownership changes.}

\subtree{
\title{Patent Assignment API}
\p{\strong{Base URL}: \code{\startverb https://assignment-api.uspto.gov/patent/v1.4/\stopverb}}

\p{\strong{Search by patent number:}}

\pre{\startverb
import requests
import xml.etree.ElementTree as ET

def get_patent_assignments(patent_number, api_key):
    url = f"https://assignment-api.uspto.gov/patent/v1.4/assignment/patent/{patent_number}"
    headers = {"X-Api-Key": api_key}

    response = requests.get(url, headers=headers)
    if response.status_code == 200:
        return response.text  # Returns XML

assignments_xml = get_patent_assignments("11234567", api_key)
root = ET.fromstring(assignments_xml)

for assignment in root.findall('.//assignment'):
    recorded_date = assignment.find('recordedDate').text
    assignor = assignment.find('.//assignor/name').text
    assignee = assignment.find('.//assignee/name').text
    conveyance = assignment.find('conveyanceText').text

    print(f"{recorded_date}: {assignor} → {assignee}")
    print(f"  Type: {conveyance}\n")
\stopverb}

\p{\strong{Search by company name:}}

\pre{\startverb
def find_company_patents(company_name, api_key):
    url = "https://assignment-api.uspto.gov/patent/v1.4/assignment/search"
    headers = {"X-Api-Key": api_key}
    data = {"criteria": {"assigneeName": company_name}}

    response = requests.post(url, headers=headers, json=data)
    return response.text
\stopverb}
}
}

\subtree{
\title{Common Assignment Types}
\ul{
\li{\strong{ASSIGNMENT OF ASSIGNORS INTEREST} - Ownership transfer}
\li{\strong{SECURITY AGREEMENT} - Collateral/security interest}
\li{\strong{MERGER} - Corporate merger}
\li{\strong{CHANGE OF NAME} - Name change}
\li{\strong{ASSIGNMENT OF PARTIAL INTEREST} - Partial ownership}
}
}
}

