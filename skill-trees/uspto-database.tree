\title{Uspto Database}

\taxon{skill}

\meta{description}{"Access USPTO APIs for patent/trademark searches, examination history (PEDS), assignments, citations, office actions, TSDR, for IP analysis and prior art searches."}

\subtree{
\title{USPTO Database}
\subtree{
\title{Overview}
\p{USPTO provides specialized APIs for patent and trademark data. Search patents by keywords/inventors/assignees, retrieve examination history via PEDS, track assignments, analyze citations and office actions, access TSDR for trademarks, for IP analysis and prior art searches.}
}

\subtree{
\title{When to Use This Skill}
\p{This skill should be used when:}

\ul{
\li{\strong{Patent Search}: Finding patents by keywords, inventors, assignees, classifications, or dates}
\li{\strong{Patent Details}: Retrieving full patent data including claims, abstracts, citations}
\li{\strong{Trademark Search}: Looking up trademarks by serial or registration number}
\li{\strong{Trademark Status}: Checking trademark status, ownership, and prosecution history}
\li{\strong{Examination History}: Accessing patent prosecution data from PEDS (Patent Examination Data System)}
\li{\strong{Office Actions}: Retrieving office action text, citations, and rejections}
\li{\strong{Assignments}: Tracking patent/trademark ownership transfers}
\li{\strong{Citations}: Analyzing patent citations (forward and backward)}
\li{\strong{Litigation}: Accessing patent litigation records}
\li{\strong{Portfolio Analysis}: Analyzing patent/trademark portfolios for companies or inventors}
}
}

\subtree{
\title{USPTO API Ecosystem}
\p{The USPTO provides multiple specialized APIs for different data needs:}

\subtree{
\title{Core APIs}
\ol{
\li{\strong{PatentSearch API} - Modern ElasticSearch-based patent search (replaced legacy PatentsView in May 2025)}
\li{Search patents by keywords, inventors, assignees, classifications, dates}
\li{Access to patent data through June 30, 2025}
\li{45 requests/minute rate limit}
\li{\strong{Base URL}: \code{\startverb https://search.patentsview.org/api/v1/\stopverb}}
}

\ol{
\li{\strong{PEDS (Patent Examination Data System)} - Patent examination history}
\li{Application status and transaction history from 1981-present}
\li{Office action dates and examination events}
\li{Use \code{\startverb uspto-opendata-python\stopverb} Python library}
\li{\strong{Replaced}: PAIR Bulk Data (PBD) - decommissioned}
}

\ol{
\li{\strong{TSDR (Trademark Status & Document Retrieval)} - Trademark data}
\li{Trademark status, ownership, prosecution history}
\li{Search by serial or registration number}
\li{\strong{Base URL}: \code{\startverb https://tsdrapi.uspto.gov/ts/cd/\stopverb}}
}
}

\subtree{
\title{Additional APIs}
\ol{
\li{\strong{Patent Assignment Search} - Ownership records and transfers}
\li{\strong{Trademark Assignment Search} - Trademark ownership changes}
\li{\strong{Enriched Citation API} - Patent citation analysis}
\li{\strong{Office Action Text Retrieval} - Full text of office actions}
\li{\strong{Office Action Citations} - Citations from office actions}
\li{\strong{Office Action Rejection} - Rejection reasons and types}
\li{\strong{PTAB API} - Patent Trial and Appeal Board proceedings}
\li{\strong{Patent Litigation Cases} - Federal district court litigation data}
\li{\strong{Cancer Moonshot Data Set} - Cancer-related patents}
}
}
}

\subtree{
\title{Quick Start}
\subtree{
\title{API Key Registration}
\p{All USPTO APIs require an API key. Register at: \strong{https://account.uspto.gov/api-manager/}}

\p{Set the API key as an environment variable:}

\pre{\startverb
export USPTO_API_KEY="your_api_key_here"
\stopverb}
}

\subtree{
\title{Helper Scripts}
\p{This skill includes Python scripts for common operations:}

\ul{
\li{\strong{\code{\startverb scripts/patent_search.py\stopverb}} - PatentSearch API client for searching patents}
\li{\strong{\code{\startverb scripts/peds_client.py\stopverb}} - PEDS client for examination history}
\li{\strong{\code{\startverb scripts/trademark_client.py\stopverb}} - TSDR client for trademark data}
}
}
}

\subtree{
\title{Task 1: Searching Patents}
\subtree{
\title{Using the PatentSearch API}
\p{The PatentSearch API uses a JSON query language with various operators for flexible searching.}

\subtree{
\title{Basic Patent Search Examples}
\p{\strong{Search by keywords in abstract:}}

\pre{\startverb
from scripts.patent_search import PatentSearchClient

client = PatentSearchClient()

# Search for machine learning patents
results = client.search_patents({
    "patent_abstract": {"_text_all": ["machine", "learning"]}
})

for patent in results['patents']:
    print(f"{patent['patent_number']}: {patent['patent_title']}")
\stopverb}

\p{\strong{Search by inventor:}}

\pre{\startverb
results = client.search_by_inventor("John Smith")
\stopverb}

\p{\strong{Search by assignee/company:}}

\pre{\startverb
results = client.search_by_assignee("Google")
\stopverb}

\p{\strong{Search by date range:}}

\pre{\startverb
results = client.search_by_date_range("2024-01-01", "2024-12-31")
\stopverb}

\p{\strong{Search by CPC classification:}}

\pre{\startverb
results = client.search_by_classification("H04N")  # Video/image tech
\stopverb}
}

\subtree{
\title{Advanced Patent Search}
\p{Combine multiple criteria with logical operators:}

\pre{\startverb
results = client.advanced_search(
    keywords=["artificial", "intelligence"],
    assignee="Microsoft",
    start_date="2023-01-01",
    end_date="2024-12-31",
    cpc_codes=["G06N", "G06F"]  # AI and computing classifications
)
\stopverb}
}

\subtree{
\title{Direct API Usage}
\p{For complex queries, use the API directly:}

\pre{\startverb
import requests

url = "https://search.patentsview.org/api/v1/patent"
headers = {
    "X-Api-Key": "YOUR_API_KEY",
    "Content-Type": "application/json"
}

query = {
    "q": {
        "_and": [
            {"patent_date": {"_gte": "2024-01-01"}},
            {"assignee_organization": {"_text_any": ["Google", "Alphabet"]}},
            {"cpc_subclass_id": ["G06N", "H04N"]}
        ]
    },
    "f": ["patent_number", "patent_title", "patent_date", "inventor_name"],
    "s": [{"patent_date": "desc"}],
    "o": {"per_page": 100, "page": 1}
}

response = requests.post(url, headers=headers, json=query)
results = response.json()
\stopverb}
}
}

\subtree{
\title{Query Operators}
\ul{
\li{\strong{Equality}: \code{\startverb {"field": "value"}\stopverb} or \code{\startverb {"field": {"_eq": "value"}}\stopverb}}
\li{\strong{Comparison}: \code{\startverb _gt\stopverb}, \code{\startverb _gte\stopverb}, \code{\startverb _lt\stopverb}, \code{\startverb _lte\stopverb}, \code{\startverb _neq\stopverb}}
\li{\strong{Text search}: \code{\startverb _text_all\stopverb}, \code{\startverb _text_any\stopverb}, \code{\startverb _text_phrase\stopverb}}
\li{\strong{String matching}: \code{\startverb _begins\stopverb}, \code{\startverb _contains\stopverb}}
\li{\strong{Logical}: \code{\startverb _and\stopverb}, \code{\startverb _or\stopverb}, \code{\startverb _not\stopverb}}
}

\p{\strong{Best Practice}: Use \code{\startverb _text_*\stopverb} operators for text fields (more performant than \code{\startverb _contains\stopverb} or \code{\startverb _begins\stopverb})}
}

\subtree{
\title{Available Patent Endpoints}
\ul{
\li{\code{\startverb /patent\stopverb} - Granted patents}
\li{\code{\startverb /publication\stopverb} - Pregrant publications}
\li{\code{\startverb /inventor\stopverb} - Inventor information}
\li{\code{\startverb /assignee\stopverb} - Assignee information}
\li{\code{\startverb /cpc_subclass\stopverb}, \code{\startverb /cpc_at_issue\stopverb} - CPC classifications}
\li{\code{\startverb /uspc\stopverb} - US Patent Classification}
\li{\code{\startverb /ipc\stopverb} - International Patent Classification}
\li{\code{\startverb /claims\stopverb}, \code{\startverb /brief_summary_text\stopverb}, \code{\startverb /detail_description_text\stopverb} - Text data (beta)}
}
}

