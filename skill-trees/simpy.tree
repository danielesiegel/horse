\subtree{
\title{Best Practices}
\ol{
\li{\strong{Generator functions}: Always use \code{\startverb yield\stopverb} in process functions}
\li{\strong{Resource context managers}: Use \code{\startverb with resource.request() as req:\stopverb} for automatic cleanup}
\li{\strong{Reproducibility}: Set \code{\startverb random.seed()\stopverb} for consistent results}
\li{\strong{Monitoring}: Collect data throughout simulation, not just at the end}
\li{\strong{Validation}: Compare simple cases with analytical solutions}
\li{\strong{Documentation}: Comment process logic and parameter choices}
\li{\strong{Modular design}: Separate process logic, statistics, and configuration}
}
}

\subtree{
\title{Common Pitfalls}
\ol{
\li{\strong{Forgetting yield}: Processes must yield events to pause}
\li{\strong{Event reuse}: Events can only be triggered once}
\li{\strong{Resource leaks}: Use context managers or ensure release}
\li{\strong{Blocking operations}: Avoid Python blocking calls in processes}
\li{\strong{Time units}: Stay consistent with time unit interpretation}
\li{\strong{Deadlocks}: Ensure at least one process can make progress}
}
}

