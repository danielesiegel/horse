\subtree{
\title{Common Use Cases}
\subtree{
\title{Use Case 1: Explore Cell Types in a Tissue}
\pre{\startverb
with cellxgene_census.open_soma() as census:
    cells = cellxgene_census.get_obs(
        census, "homo_sapiens",
        value_filter="tissue_general == 'lung' and is_primary_data == True",
        column_names=["cell_type"]
    )
    print(cells["cell_type"].value_counts())
\stopverb}
}

\subtree{
\title{Use Case 2: Query Marker Gene Expression}
\pre{\startverb
with cellxgene_census.open_soma() as census:
    adata = cellxgene_census.get_anndata(
        census=census,
        organism="Homo sapiens",
        var_value_filter="feature_name in ['CD4', 'CD8A', 'CD19']",
        obs_value_filter="cell_type in ['T cell', 'B cell'] and is_primary_data == True",
    )
\stopverb}
}

\subtree{
\title{Use Case 3: Train Cell Type Classifier}
\pre{\startverb
from cellxgene_census.experimental.ml import experiment_dataloader

with cellxgene_census.open_soma() as census:
    dataloader = experiment_dataloader(
        census["census_data"]["homo_sapiens"],
        measurement_name="RNA",
        X_name="raw",
        obs_value_filter="is_primary_data == True",
        obs_column_names=["cell_type"],
        batch_size=128,
        shuffle=True,
    )

    # Train model
    for epoch in range(epochs):
        for batch in dataloader:
            # Training logic
            pass
\stopverb}
}

\subtree{
\title{Use Case 4: Cross-Tissue Analysis}
\pre{\startverb
with cellxgene_census.open_soma() as census:
    adata = cellxgene_census.get_anndata(
        census=census,
        organism="Homo sapiens",
        obs_value_filter="cell_type == 'macrophage' and tissue_general in ['lung', 'liver', 'brain'] and is_primary_data == True",
    )

    # Analyze macrophage differences across tissues
    sc.tl.rank_genes_groups(adata, groupby="tissue_general")
\stopverb}
}
}

\subtree{
\title{Troubleshooting}
\subtree{
\title{Query Returns Too Many Cells}
\ul{
\li{Add more specific filters to reduce scope}
\li{Use \code{\startverb tissue\stopverb} instead of \code{\startverb tissue_general\stopverb} for finer granularity}
\li{Filter by specific \code{\startverb dataset_id\stopverb} if known}
\li{Switch to out-of-core processing for large queries}
}
}

\subtree{
\title{Memory Errors}
\ul{
\li{Reduce query scope with more restrictive filters}
\li{Select fewer genes with \code{\startverb var_value_filter\stopverb}}
\li{Use out-of-core processing with \code{\startverb axis_query()\stopverb}}
\li{Process data in batches}
}
}

\subtree{
\title{Duplicate Cells in Results}
\ul{
\li{Always include \code{\startverb is_primary_data == True\stopverb} in filters}
\li{Check if intentionally querying across multiple datasets}
}
}

\subtree{
\title{Gene Not Found}
\ul{
\li{Verify gene name spelling (case-sensitive)}
\li{Try Ensembl ID with \code{\startverb feature_id\stopverb} instead of \code{\startverb feature_name\stopverb}}
\li{Check dataset presence matrix to see if gene was measured}
\li{Some genes may have been filtered during Census construction}
}
}

\subtree{
\title{Version Inconsistencies}
\ul{
\li{Always specify \code{\startverb census_version\stopverb} explicitly}
\li{Use same version across all analyses}
\li{Check release notes for version-specific changes}
}
}
}
}