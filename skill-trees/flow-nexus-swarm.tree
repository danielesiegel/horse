\li{[Best Practices](#best-practices)}
}
}

\subtree{
\title{Overview}
\p{Flow Nexus provides cloud-based orchestration for AI agent swarms with:}

\ul{
\li{\strong{Multi-topology Support}: Hierarchical, mesh, ring, and star architectures}
\li{\strong{Event-driven Workflows}: Message queue processing with async execution}
\li{\strong{Template Library}: Pre-built swarm configurations for common use cases}
\li{\strong{Intelligent Agent Assignment}: Vector similarity matching for optimal agent selection}
\li{\strong{Real-time Monitoring}: Comprehensive metrics and audit trails}
\li{\strong{Scalable Infrastructure}: Cloud-based execution with auto-scaling}
}
}

\subtree{
\title{Swarm Management}
\subtree{
\title{Initialize Swarm}
\p{Create a new swarm with specified topology and configuration:}

\pre{\startverb
mcp__flow-nexus__swarm_init({
  topology: "hierarchical", // Options: mesh, ring, star, hierarchical
  maxAgents: 8,
  strategy: "balanced" // Options: balanced, specialized, adaptive
})
\stopverb}

\p{\strong{Topology Guide:}}

\ul{
\li{\strong{Hierarchical}: Tree structure with coordinator nodes (best for complex projects)}
\li{\strong{Mesh}: Peer-to-peer collaboration (best for research and analysis)}
\li{\strong{Ring}: Circular coordination (best for sequential workflows)}
\li{\strong{Star}: Centralized hub (best for simple delegation)}
}

\p{\strong{Strategy Guide:}}

\ul{
\li{\strong{Balanced}: Equal distribution of workload across agents}
\li{\strong{Specialized}: Agents focus on specific expertise areas}
\li{\strong{Adaptive}: Dynamic adjustment based on task complexity}
}
}

\subtree{
\title{Spawn Agents}
\p{Add specialized agents to the swarm:}

\pre{\startverb
mcp__flow-nexus__agent_spawn({
  type: "researcher", // Options: researcher, coder, analyst, optimizer, coordinator
  name: "Lead Researcher",
  capabilities: ["web_search", "analysis", "summarization"]
})
\stopverb}

\p{\strong{Agent Types:}}

\ul{
\li{\strong{Researcher}: Information gathering, web search, analysis}
\li{\strong{Coder}: Code generation, refactoring, implementation}
\li{\strong{Analyst}: Data analysis, pattern recognition, insights}
\li{\strong{Optimizer}: Performance tuning, resource optimization}
\li{\strong{Coordinator}: Task delegation, progress tracking, integration}
}
}

\subtree{
\title{Orchestrate Tasks}
\p{Distribute tasks across the swarm:}

\pre{\startverb
mcp__flow-nexus__task_orchestrate({
  task: "Build a REST API with authentication and database integration",
  strategy: "parallel", // Options: parallel, sequential, adaptive
  maxAgents: 5,
  priority: "high" // Options: low, medium, high, critical
})
\stopverb}

\p{\strong{Execution Strategies:}}

\ul{
\li{\strong{Parallel}: Maximum concurrency for independent subtasks}
\li{\strong{Sequential}: Step-by-step execution with dependencies}
\li{\strong{Adaptive}: AI-powered strategy selection based on task analysis}
}
}

\subtree{
\title{Monitor & Scale Swarms}
\pre{\startverb
// Get detailed swarm status
mcp__flow-nexus__swarm_status({
  swarm_id: "optional-id" // Uses active swarm if not provided
})

// List all active swarms
mcp__flow-nexus__swarm_list({
  status: "active" // Options: active, destroyed, all
})

// Scale swarm up or down
mcp__flow-nexus__swarm_scale({
  target_agents: 10,
  swarm_id: "optional-id"
})

// Gracefully destroy swarm
mcp__flow-nexus__swarm_destroy({
  swarm_id: "optional-id"
})
\stopverb}
}
}

\subtree{
\title{Workflow Automation}
\subtree{
\title{Create Workflow}
\p{Define event-driven workflows with message queue processing:}

\pre{\startverb
mcp__flow-nexus__workflow_create({
  name: "CI/CD Pipeline",
  description: "Automated testing, building, and deployment",
  steps: [
    {
      id: "test",
      action: "run_tests",
      agent: "tester",
      parallel: true
    },
    {
      id: "build",
      action: "build_app",
      agent: "builder",
      depends_on: ["test"]
    },
    {
      id: "deploy",
      action: "deploy_prod",
      agent: "deployer",
      depends_on: ["build"]
    }
  ],
  triggers: ["push_to_main", "manual_trigger"],
  metadata: {
    priority: 10,
    retry_policy: "exponential_backoff"
  }
})
\stopverb}

\p{\strong{Workflow Features:}}

\ul{
\li{\strong{Dependency Management}: Define step dependencies with \code{\startverb depends_on\stopverb}}
\li{\strong{Parallel Execution}: Set \code{\startverb parallel: true\stopverb} for concurrent steps}
\li{\strong{Event Triggers}: GitHub events, schedules, manual triggers}
\li{\strong{Retry Policies}: Automatic retry on transient failures}
\li{\strong{Priority Queuing}: High-priority workflows execute first}
}
}

\subtree{
\title{Execute Workflow}
\p{Run workflows synchronously or asynchronously:}

\pre{\startverb
mcp__flow-nexus__workflow_execute({
  workflow_id: "workflow_id",
  input_data: {
    branch: "main",
    commit: "abc123",
    environment: "production"
  },
  async: true // Queue-based execution for long-running workflows
})
\stopverb}

\p{\strong{Execution Modes:}}

\ul{
\li{\strong{Sync (async: false)}: Immediate execution, wait for completion}
\li{\strong{Async (async: true)}: Message queue processing, non-blocking}
}
}

\subtree{
\title{Monitor Workflows}
\pre{\startverb
// Get workflow status and metrics
mcp__flow-nexus__workflow_status({
  workflow_id: "id",
  execution_id: "specific-run-id", // Optional
  include_metrics: true
})

// List workflows with filters
mcp__flow-nexus__workflow_list({
  status: "running", // Options: running, completed, failed, pending
  limit: 10,
  offset: 0
})

// Get complete audit trail
mcp__flow-nexus__workflow_audit_trail({
  workflow_id: "id",
  limit: 50,
  start_time: "2025-01-01T00:00:00Z"
})
\stopverb}
}

\subtree{
\title{Agent Assignment}
\p{Intelligently assign agents to workflow tasks:}

\pre{\startverb
mcp__flow-nexus__workflow_agent_assign({
  task_id: "task_id",
  agent_type: "coder", // Preferred agent type
  use_vector_similarity: true // AI-powered capability matching
})
\stopverb}

\p{\strong{Vector Similarity Matching:}}

\ul{
\li{Analyzes task requirements and agent capabilities}
\li{Finds optimal agent based on past performance}
\li{Considers workload and availability}
}
}

\subtree{
\title{Queue Management}
\p{Monitor and manage message queues:}

\pre{\startverb
mcp__flow-nexus__workflow_queue_status({
  queue_name: "optional-specific-queue",
  include_messages: true // Show pending messages
})
\stopverb}
}
}

\subtree{
\title{Agent Orchestration}
\subtree{
\title{Full-Stack Development Pattern}
\pre{\startverb
// 1. Initialize swarm with hierarchical topology
mcp__flow-nexus__swarm_init({
  topology: "hierarchical",
  maxAgents: 8,
  strategy: "specialized"
})

// 2. Spawn specialized agents
mcp__flow-nexus__agent_spawn({ type: "coordinator", name: "Project Manager" })
mcp__flow-nexus__agent_spawn({ type: "coder", name: "Backend Developer" })
mcp__flow-nexus__agent_spawn({ type: "coder", name: "Frontend Developer" })
mcp__flow-nexus__agent_spawn({ type: "coder", name: "Database Architect" })
mcp__flow-nexus__agent_spawn({ type: "analyst", name: "QA Engineer" })

// 3. Create development workflow
mcp__flow-nexus__workflow_create({
  name: "Full-Stack Development",
  steps: [
    { id: "requirements", action: "analyze_requirements", agent: "coordinator" },
    { id: "db_design", action: "design_schema", agent: "Database Architect" },
    { id: "backend", action: "build_api", agent: "Backend Developer", depends_on: ["db_design"] },
    { id: "frontend", action: "build_ui", agent: "Frontend Developer", depends_on: ["requirements"] },
    { id: "integration", action: "integrate", agent: "Backend Developer", depends_on: ["backend", "frontend"] },
    { id: "testing", action: "qa_testing", agent: "QA Engineer", depends_on: ["integration"] }
  ]
})

// 4. Execute workflow
mcp__flow-nexus__workflow_execute({
  workflow_id: "workflow_id",
  input_data: {
    project: "E-commerce Platform",
    tech_stack: ["Node.js", "React", "PostgreSQL"]
  }
})
\stopverb}
}

\subtree{
\title{Research & Analysis Pattern}
\pre{\startverb
// 1. Initialize mesh topology for collaborative research
mcp__flow-nexus__swarm_init({
  topology: "mesh",
  maxAgents: 5,
  strategy: "balanced"
})

// 2. Spawn research agents
mcp__flow-nexus__agent_spawn({ type: "researcher", name: "Primary Researcher" })
mcp__flow-nexus__agent_spawn({ type: "researcher", name: "Secondary Researcher" })
mcp__flow-nexus__agent_spawn({ type: "analyst", name: "Data Analyst" })
mcp__flow-nexus__agent_spawn({ type: "analyst", name: "Insights Analyst" })

// 3. Orchestrate research task
mcp__flow-nexus__task_orchestrate({
  task: "Research machine learning trends for 2025 and analyze market opportunities",
  strategy: "parallel",
  maxAgents: 4,
  priority: "high"
})
\stopverb}
}

\subtree{
\title{CI/CD Pipeline Pattern}
\pre{\startverb
mcp__flow-nexus__workflow_create({
  name: "Deployment Pipeline",
  description: "Automated testing, building, and multi-environment deployment",
  steps: [
    { id: "lint", action: "lint_code", agent: "code_quality", parallel: true },
    { id: "unit_test", action: "unit_tests", agent: "test_runner", parallel: true },
    { id: "integration_test", action: "integration_tests", agent: "test_runner", parallel: true },
    { id: "build", action: "build_artifacts", agent: "builder", depends_on: ["lint", "unit_test", "integration_test"] },
    { id: "security_scan", action: "security_scan", agent: "security", depends_on: ["build"] },
    { id: "deploy_staging", action: "deploy", agent: "deployer", depends_on: ["security_scan"] },
    { id: "smoke_test", action: "smoke_tests", agent: "test_runner", depends_on: ["deploy_staging"] },
    { id: "deploy_prod", action: "deploy", agent: "deployer", depends_on: ["smoke_test"] }
  ],
  triggers: ["github_push", "github_pr_merged"],
  metadata: {
    priority: 10,
    auto_rollback: true
  }
})
\stopverb}
}

\subtree{
\title{Data Processing Pipeline Pattern}
\pre{\startverb
mcp__flow-nexus__workflow_create({
  name: "ETL Pipeline",
  description: "Extract, Transform, Load data processing",
  steps: [
    { id: "extract", action: "extract_data", agent: "data_extractor" },
    { id: "validate_raw", action: "validate_data", agent: "validator", depends_on: ["extract"] },
    { id: "transform", action: "transform_data", agent: "transformer", depends_on: ["validate_raw"] },
    { id: "enrich", action: "enrich_data", agent: "enricher", depends_on: ["transform"] },
    { id: "load", action: "load_data", agent: "loader", depends_on: ["enrich"] },
    { id: "validate_final", action: "validate_data", agent: "validator", depends_on: ["load"] }
  ],
  triggers: ["schedule:0 2 * * *"], // Daily at 2 AM
  metadata: {
    retry_policy: "exponential_backoff",
    max_retries: 3
  }
})
\stopverb}
}
}

\subtree{
\title{Templates & Patterns}
\subtree{
\title{Use Pre-built Templates}
\pre{\startverb
// Create swarm from template
mcp__flow-nexus__swarm_create_from_template({
  template_name: "full-stack-dev",
  overrides: {
    maxAgents: 6,
    strategy: "specialized"
  }
})

// List available templates
mcp__flow-nexus__swarm_templates_list({
  category: "quickstart", // Options: quickstart, specialized, enterprise, custom, all
  includeStore: true
})
\stopverb}

\p{\strong{Available Template Categories:}}

\p{\strong{Quickstart Templates:}}

\ul{
\li{\code{\startverb full-stack-dev\stopverb}: Complete web development swarm}
\li{\code{\startverb research-team\stopverb}: Research and analysis swarm}
\li{\code{\startverb code-review\stopverb}: Automated code review swarm}
\li{\code{\startverb data-pipeline\stopverb}: ETL and data processing}
}

\p{\strong{Specialized Templates:}}

\ul{
\li{\code{\startverb ml-development\stopverb}: Machine learning project swarm}
\li{\code{\startverb mobile-dev\stopverb}: Mobile app development}
\li{\code{\startverb devops-automation\stopverb}: Infrastructure and deployment}
\li{\code{\startverb security-audit\stopverb}: Security analysis and testing}
}

\p{\strong{Enterprise Templates:}}

\ul{
\li{\code{\startverb enterprise-migration\stopverb}: Large-scale system migration}
\li{\code{\startverb multi-repo-sync\stopverb}: Multi-repository coordination}
\li{\code{\startverb compliance-review\stopverb}: Regulatory compliance workflows}
\li{\code{\startverb incident-response\stopverb}: Automated incident management}
}
}

\subtree{
\title{Custom Template Creation}
\p{Save successful swarm configurations as reusable templates for future projects.}
}
