\subtree{
\title{Key Concepts}
\subtree{
\title{Coordinate Systems}
\p{\strong{Critical:} Pysam uses \strong{0-based, half-open} coordinates (Python convention):}

\ul{
\li{Start positions are 0-based (first base is position 0)}
\li{End positions are exclusive (not included in the range)}
\li{Region 1000-2000 includes bases 1000-1999 (1000 bases total)}
}

\p{\strong{Exception:} Region strings in \code{\startverb fetch()\stopverb} follow samtools convention (1-based):}

\pre{\startverb
samfile.fetch("chr1", 999, 2000)      # 0-based: positions 999-1999
samfile.fetch("chr1:1000-2000")       # 1-based string: positions 1000-2000
\stopverb}

\p{\strong{VCF files:} Use 1-based coordinates in the file format, but \code{\startverb VariantRecord.start\stopverb} is 0-based.}
}

\subtree{
\title{Indexing Requirements}
\p{Random access to specific genomic regions requires index files:}

\ul{
\li{\strong{BAM files}: Require \code{\startverb .bai\stopverb} index (create with \code{\startverb pysam.index()\stopverb})}
\li{\strong{CRAM files}: Require \code{\startverb .crai\stopverb} index}
\li{\strong{FASTA files}: Require \code{\startverb .fai\stopverb} index (create with \code{\startverb pysam.faidx()\stopverb})}
\li{\strong{VCF.gz files}: Require \code{\startverb .tbi\stopverb} tabix index (create with \code{\startverb pysam.tabix_index()\stopverb})}
\li{\strong{BCF files}: Require \code{\startverb .csi\stopverb} index}
}

\p{Without an index, use \code{\startverb fetch(until_eof=True)\stopverb} for sequential reading.}
}

\subtree{
\title{File Modes}
\p{Specify format when opening files:}

\ul{
\li{\code{\startverb "rb"\stopverb} - Read BAM (binary)}
\li{\code{\startverb "r"\stopverb} - Read SAM (text)}
\li{\code{\startverb "rc"\stopverb} - Read CRAM}
\li{\code{\startverb "wb"\stopverb} - Write BAM}
\li{\code{\startverb "w"\stopverb} - Write SAM}
\li{\code{\startverb "wc"\stopverb} - Write CRAM}
}
}

\subtree{
\title{Performance Considerations}
\ol{
\li{\strong{Always use indexed files} for random access operations}
\li{\strong{Use \code{\startverb pileup()\stopverb} for column-wise analysis} instead of repeated fetch operations}
\li{\strong{Use \code{\startverb count()\stopverb} for counting} instead of iterating and counting manually}
\li{\strong{Process regions in parallel} when analyzing independent genomic regions}
\li{\strong{Close files explicitly} to free resources}
\li{\strong{Use \code{\startverb until_eof=True\stopverb}} for sequential processing without index}
\li{\strong{Avoid multiple iterators} unless necessary (use \code{\startverb multiple_iterators=True\stopverb} if needed)}
}
}
}

\subtree{
\title{Common Pitfalls}
\ol{
\li{\strong{Coordinate confusion:} Remember 0-based vs 1-based systems in different contexts}
\li{\strong{Missing indices:} Many operations require index files—create them first}
\li{\strong{Partial overlaps:} \code{\startverb fetch()\stopverb} returns reads overlapping region boundaries, not just those fully contained}
\li{\strong{Iterator scope:} Keep pileup iterator references alive to avoid "PileupProxy accessed after iterator finished" errors}
\li{\strong{Quality score editing:} Cannot modify \code{\startverb query_qualities\stopverb} in place after changing \code{\startverb query_sequence\stopverb}—create a copy first}
\li{\strong{Stream limitations:} Only stdin/stdout are supported for streaming, not arbitrary Python file objects}
\li{\strong{Thread safety:} While GIL is released during I/O, comprehensive thread-safety hasn't been fully validated}
}
}

\subtree{
\title{Command-Line Tools}
\p{Pysam provides access to samtools and bcftools commands:}

\pre{\startverb
# Sort BAM file
pysam.samtools.sort("-o", "sorted.bam", "input.bam")

# Index BAM
pysam.samtools.index("sorted.bam")

# View specific region
pysam.samtools.view("-b", "-o", "region.bam", "input.bam", "chr1:1000-2000")

# BCF tools
pysam.bcftools.view("-O", "z", "-o", "output.vcf.gz", "input.vcf")
\stopverb}

\p{\strong{Error handling:}}

\pre{\startverb
try:
    pysam.samtools.sort("-o", "output.bam", "input.bam")
except pysam.SamtoolsError as e:
    print(f"Error: {e}")
\stopverb}
}

