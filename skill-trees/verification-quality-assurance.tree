\subtree{
\title{Troubleshooting}
\subtree{
\title{Common Issues}
\p{\strong{Low Truth Scores:}}

\pre{\startverb
# Get detailed breakdown
npx claude-flow@alpha truth --verbose --threshold 0.0

# Check specific criteria
npx claude-flow@alpha verify check --verbose

# View agent-specific issues
npx claude-flow@alpha truth --agent <agent-name> --format json
\stopverb}

\p{\strong{Rollback Failures:}}

\pre{\startverb
# Check git status
git status

# View rollback history
npx claude-flow@alpha verify rollback --history

# Manual rollback
git reset --hard HEAD~1
\stopverb}

\p{\strong{Verification Timeouts:}}

\pre{\startverb
# Increase timeout
npx claude-flow@alpha verify check --timeout 60s

# Verify in batches
npx claude-flow@alpha verify batch --batch-size 10
\stopverb}
}
}

\subtree{
\title{Exit Codes}
\p{Verification commands return standard exit codes:}

\ul{
\li{\code{\startverb 0\stopverb}: Verification passed (score ≥ threshold)}
\li{\code{\startverb 1\stopverb}: Verification failed (score < threshold)}
\li{\code{\startverb 2\stopverb}: Error during verification (invalid input, system error)}
}
}

