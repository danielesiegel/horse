\subtree{
\title{Best Practices}
\ol{
\li{\strong{Set Appropriate Thresholds}: Use 0.99 for critical code, 0.95 for standard, 0.90 for experimental}
\li{\strong{Enable Auto-rollback}: Prevent bad code from persisting}
\li{\strong{Monitor Trends}: Track improvement over time, not just current scores}
\li{\strong{Integrate with CI/CD}: Make verification part of your pipeline}
\li{\strong{Use Watch Mode}: Get immediate feedback during development}
\li{\strong{Export Metrics}: Track quality metrics in your monitoring system}
\li{\strong{Review Rollbacks}: Understand why changes were rejected}
\li{\strong{Train Agents}: Use verification feedback to improve agent performance}
}
}

