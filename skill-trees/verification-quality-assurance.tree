\meta{version}{"2.0.0"}

\meta{description}{"Comprehensive truth scoring, code quality verification, and automatic rollback system with 0.95 accuracy threshold for ensuring high-quality agent outputs and codebase reliability."}

\subtree{
\title{Verification & Quality Assurance Skill}
\subtree{
\title{What This Skill Does}
\p{This skill provides a comprehensive verification and quality assurance system that ensures code quality and correctness through:}

\ul{
\li{\strong{Truth Scoring}: Real-time reliability metrics (0.0-1.0 scale) for code, agents, and tasks}
\li{\strong{Verification Checks}: Automated code correctness, security, and best practices validation}
\li{\strong{Automatic Rollback}: Instant reversion of changes that fail verification (default threshold: 0.95)}
\li{\strong{Quality Metrics}: Statistical analysis with trends, confidence intervals, and improvement tracking}
\li{\strong{CI/CD Integration}: Export capabilities for continuous integration pipelines}
\li{\strong{Real-time Monitoring}: Live dashboards and watch modes for ongoing verification}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Claude Flow installed (\code{\startverb npx claude-flow@alpha\stopverb})}
\li{Git repository (for rollback features)}
\li{Node.js 18+ (for dashboard features)}
}
}

\subtree{
\title{Quick Start}
\pre{\startverb
# View current truth scores
npx claude-flow@alpha truth

# Run verification check
npx claude-flow@alpha verify check

# Verify specific file with custom threshold
npx claude-flow@alpha verify check --file src/app.js --threshold 0.98

# Rollback last failed verification
npx claude-flow@alpha verify rollback --last-good
\stopverb}
}

\subtree{
\title{Complete Guide}
\subtree{
\title{Truth Scoring System}
\subtree{
\title{View Truth Metrics}
\p{Display comprehensive quality and reliability metrics for your codebase and agent tasks.}

\p{\strong{Basic Usage:}}

\pre{\startverb
# View current truth scores (default: table format)
npx claude-flow@alpha truth

# View scores for specific time period
npx claude-flow@alpha truth --period 7d

# View scores for specific agent
npx claude-flow@alpha truth --agent coder --period 24h

# Find files/tasks below threshold
npx claude-flow@alpha truth --threshold 0.8
\stopverb}

\p{\strong{Output Formats:}}

\pre{\startverb
# Table format (default)
npx claude-flow@alpha truth --format table

# JSON for programmatic access
npx claude-flow@alpha truth --format json

# CSV for spreadsheet analysis
npx claude-flow@alpha truth --format csv

# HTML report with visualizations
npx claude-flow@alpha truth --format html --export report.html
\stopverb}

\p{\strong{Real-time Monitoring:}}

\pre{\startverb
# Watch mode with live updates
npx claude-flow@alpha truth --watch

# Export metrics automatically
npx claude-flow@alpha truth --export .claude-flow/metrics/truth-$(date +%Y%m%d).json
\stopverb}
}

