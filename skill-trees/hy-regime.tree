\subtree{
\title{Troubleshooting}
\p{\strong{"ModuleNotFoundError: No module named 'hy'"}}

\ul{
\li{Install: \code{\startverb pip install hy==0.27.0\stopverb}}
\li{Verify: \code{\startverb hy --version\stopverb}}
}

\p{\strong{DuckDB file locked}}

\ul{
\li{Close any other connections}
\li{Check for stale .duckdb locks: \code{\startverb rm belief_revision.duckdb.lock\stopverb}}
}

\p{\strong{Regime accuracy very low (< 50\%)}}

\ul{
\li{Check that batches are truly independent (mixing decreases predictability)}
\li{Verify message counts (should be exactly 69 per batch)}
\li{Check temporal distribution (even spread vs clustered affects predictions)}
}

\p{\strong{"Cannot parse message file"}}

\ul{
\li{Verify format: lines like \code{\startverb \strong{barton.qasm (You)} (HH:MM): message text\stopverb}}
\li{Ensure file is UTF-8 encoded}
\li{Check line endings (should be LF, not CRLF)}
}
}
}