\title{Babashka}

\taxon{skill}

\meta{description}{Clojure scripting without JVM startup.}

\subtree{
\title{babashka}
\p{Clojure scripting without JVM startup.}

\subtree{
\title{Script}
\pre{\startverb
#!/usr/bin/env bb
(require '[babashka.http-client :as http])
(require '[cheshire.core :as json])

(-> (http/get "https://api.github.com/users/bmorphism")
    :body
    (json/parse-string true)
    :public_repos)
\stopverb}
}

\subtree{
\title{Tasks}
\pre{\startverb
;; bb.edn
{:tasks
 {:build (shell "make")
  :test  (shell "make test")
  :repl  (babashka.nrepl.server/start-server! {:port 1667})}}
\stopverb}
}

\subtree{
\title{Filesystem}
\pre{\startverb
(require '[babashka.fs :as fs])
(fs/glob "." "**/*.clj")
(fs/copy "src" "dst")
\stopverb}
}

\subtree{
\title{Process}
\pre{\startverb
(require '[babashka.process :as p])
(-> (p/shell {:out :string} "ls -la") :out)
\stopverb}
}

\subtree{
\title{Run}
\pre{\startverb
bb script.clj
bb -e '(+ 1 2)'
bb --nrepl-server
\stopverb}
}
}