\meta{version}{"1.0"}

\meta{description}{>-}

\subtree{
\title{Performing NIST CSF Maturity Assessment}
\subtree{
\title{Overview}
\p{The NIST Cybersecurity Framework (CSF) 2.0, released in February 2024, provides a comprehensive taxonomy for managing cybersecurity risk through six core Functions: Govern, Identify, Protect, Detect, Respond, and Recover. This skill covers conducting a maturity assessment against the CSF, using the four Implementation Tiers (Partial, Risk-Informed, Repeatable, Adaptive) to measure organizational cybersecurity posture and create improvement roadmaps.}
}

\subtree{
\title{When to Use}
\ul{
\li{When conducting security assessments that involve performing nist csf maturity assessment}
\li{When following incident response procedures for related security events}
\li{When performing scheduled security testing or auditing activities}
\li{When validating security controls through hands-on testing}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Understanding of cybersecurity risk management principles}
\li{Access to NIST CSF 2.0 documentation and reference tool}
\li{Knowledge of organizational IT/OT environment and security controls}
\li{Stakeholder access across business units for assessment interviews}
}
}

\subtree{
\title{Core Concepts}
\subtree{
\title{CSF 2.0 Functions (6 Functions, 22 Categories)}
\pre{\startverb
| Function | Code | Categories | Purpose |
|----------|------|-----------|---------|
| **Govern** | GV | 6 | Establish and monitor cybersecurity risk management strategy |
| **Identify** | ID | 3 | Determine current cybersecurity risk to the organization |
| **Protect** | PR | 5 | Implement safeguards to prevent or reduce risk |
| **Detect** | DE | 2 | Find and analyze possible cybersecurity attacks |
| **Respond** | RS | 4 | Take action regarding detected cybersecurity incidents |
| **Recover** | RC | 2 | Restore capabilities impaired by cybersecurity incidents |
\stopverb}
}

\subtree{
\title{Govern Function (New in CSF 2.0)}
\ul{
\li{GV.OC: Organizational Context}
\li{GV.RM: Risk Management Strategy}
\li{GV.RR: Roles, Responsibilities, and Authorities}
\li{GV.PO: Policy}
\li{GV.OV: Oversight}
\li{GV.SC: Cybersecurity Supply Chain Risk Management}
}
}

\subtree{
\title{Implementation Tiers}
\pre{\startverb
| Tier | Name | Description |
|------|------|-------------|
| Tier 1 | Partial | Ad hoc, reactive; limited awareness of cybersecurity risk |
| Tier 2 | Risk-Informed | Risk-aware but not organization-wide; approved but may not be policy |
| Tier 3 | Repeatable | Formal policies; consistently implemented; regularly updated |
| Tier 4 | Adaptive | Continuous improvement; real-time risk response; lessons learned integrated |
\stopverb}
}
}

\subtree{
\title{Workflow}
\subtree{
\title{Phase 1: Scoping and Preparation (Weeks 1-2)}
\ol{
\li{Define assessment scope (enterprise-wide vs. business unit)}
\li{Identify stakeholders and schedule interviews}
\li{Gather existing documentation (policies, procedures, architecture diagrams)}
\li{Customize CSF Profile for organizational context}
\li{Select assessment methodology (self-assessment, facilitated, third-party)}
}
}

\subtree{
\title{Phase 2: Current State Assessment (Weeks 3-6)}
\ol{
\li{Assess each CSF Category and Subcategory against Implementation Tiers}
\li{For each subcategory, evaluate:}
\li{Policy/documentation maturity}
\li{Implementation completeness}
\li{Automation level}
\li{Measurement and metrics}
\li{Continuous improvement evidence}
\li{Score using tier criteria (1-4 scale)}
\li{Document evidence supporting each tier rating}
\li{Identify strengths, gaps, and improvement areas}
}
}

\subtree{
\title{Phase 3: Target State Definition (Weeks 7-8)}
\ol{
\li{Define target tier for each Function based on:}
\li{Risk appetite and tolerance}
\li{Industry requirements and benchmarks}
\li{Regulatory obligations}
\li{Available resources and budget}
\li{Create Target Profile documenting desired maturity state}
\li{Validate target state with executive leadership}
}
}

\subtree{
\title{Phase 4: Gap Analysis and Roadmap (Weeks 9-12)}
\ol{
\li{Compare Current Profile to Target Profile}
\li{Prioritize gaps based on risk reduction potential}
\li{Develop improvement roadmap with:}
\li{Short-term quick wins (0-3 months)}
\li{Medium-term improvements (3-12 months)}
\li{Long-term strategic initiatives (12-24 months)}
\li{Estimate resource requirements for each initiative}
\li{Assign ownership and timelines}
}
}

\subtree{
\title{Phase 5: Implementation and Reassessment (Ongoing)}
\ol{
\li{Execute improvement roadmap initiatives}
\li{Track progress against milestones}
\li{Conduct periodic reassessments (annually recommended)}
\li{Report maturity progress to leadership}
\li{Adjust roadmap based on evolving threats and business changes}
}
}
}

\subtree{
\title{Key Artifacts}
\ul{
\li{CSF Current Profile (by Function/Category/Subcategory)}
\li{CSF Target Profile}
\li{Gap Analysis Report}
\li{Maturity Assessment Scorecard}
\li{Improvement Roadmap with Priorities}
\li{Executive Summary and Dashboard}
}
}

\subtree{
\title{Common Pitfalls}
\ul{
\li{Assessing technology only without evaluating governance and people}
\li{Setting unrealistic target tiers without resource commitment}
\li{Treating assessment as one-time rather than continuous process}
\li{Ignoring the new Govern function in CSF 2.0}
\li{Not aligning CSF assessment with existing compliance requirements (ISO 27001, SOC 2)}
}
}

\subtree{
\title{References}
\ul{
\li{NIST CSF 2.0: https://csf.tools/reference/nist-cybersecurity-framework/v2-0/}
\li{NIST SP 800-53 Rev 5 (control catalog that maps to CSF)}
\li{NIST CSF 2.0 Quick Start Guides}
\li{CSF 2.0 Reference Tool: https://csrc.nist.gov/projects/cybersecurity-framework}
}
}
}