\subtree{
\title{Professional Document Styling}
\subtree{
\title{Overview}
\p{Treatment plans can be enhanced with professional medical document styling using the \code{\startverb medical_treatment_plan.sty\stopverb} LaTeX package. This custom style transforms plain academic documents into visually appealing, color-coded clinical documents that maintain scientific rigor while improving readability and usability.}
}

\subtree{
\title{Medical Treatment Plan Style Package}
\p{The \code{\startverb medical_treatment_plan.sty\stopverb} package (located in \code{\startverb assets/medical_treatment_plan.sty\stopverb}) provides:}

\p{\strong{Professional Color Scheme}}

\ul{
\li{\strong{Primary Blue} (RGB: 0, 102, 153): Headers, section titles, primary accents}
\li{\strong{Secondary Blue} (RGB: 102, 178, 204): Light backgrounds, subtle accents}
\li{\strong{Accent Blue} (RGB: 0, 153, 204): Hyperlinks, key highlights}
\li{\strong{Success Green} (RGB: 0, 153, 76): Goals, positive outcomes}
\li{\strong{Warning Red} (RGB: 204, 0, 0): Warnings, critical information}
\li{\strong{Dark Gray} (RGB: 64, 64, 64): Body text}
\li{\strong{Light Gray} (RGB: 245, 245, 245): Background fills}
}

\p{\strong{Styled Elements}}

\ul{
\li{Custom colored headers and footers with professional rules}
\li{Blue section titles with underlines for clear hierarchy}
\li{Enhanced table formatting with colored headers and alternating rows}
\li{Optimized list spacing with colored bullets and numbering}
\li{Professional page layout with appropriate margins}
}
}

\subtree{
\title{Custom Information Boxes}
\p{The style package includes five specialized box environments for organizing clinical information:}

\subtree{
\title{1. Info Box (Blue Border, Light Gray Background)}
\p{For general information, clinical assessments, and testing schedules:}

\pre{\startverb
\begin{infobox}[Title]
  \textbf{Key Information:}
  \begin{itemize}
    \item Clinical assessment details
    \item Testing schedules
    \item General guidance
  \end{itemize}
\end{infobox}
\stopverb}

\p{\strong{Use cases}: Metabolic status, baseline assessments, monitoring schedules, titration protocols}
}

\subtree{
\title{2. Warning Box (Red Border, Yellow Background)}
\p{For critical decision points, safety protocols, and alerts:}

\pre{\startverb
\begin{warningbox}[Alert Title]
  \textbf{Important Safety Information:}
  \begin{itemize}
    \item Critical drug interactions
    \item Safety monitoring requirements
    \item Red flag symptoms requiring immediate action
  \end{itemize}
\end{warningbox}
\stopverb}

\p{\strong{Use cases}: Medication safety, decision points, contraindications, emergency protocols}
}

\subtree{
\title{3. Goal Box (Green Border, Green-Tinted Background)}
\p{For treatment goals, targets, and success criteria:}

\pre{\startverb
\begin{goalbox}[Treatment Goals]
  \textbf{Primary Objectives:}
  \begin{itemize}
    \item Reduce HbA1c to <7\% within 3 months
    \item Achieve 5-7\% weight loss in 12 weeks
    \item Complete diabetes education program
  \end{itemize}
\end{goalbox}
\stopverb}

\p{\strong{Use cases}: SMART goals, target outcomes, success metrics, CGM goals}
}

\subtree{
\title{4. Key Points Box (Blue Background)}
\p{For executive summaries, key takeaways, and important recommendations:}

\pre{\startverb
\begin{keybox}[Key Highlights]
  \textbf{Essential Points:}
  \begin{itemize}
    \item Main therapeutic approach
    \item Critical patient instructions
    \item Priority interventions
  \end{itemize}
\end{keybox}
\stopverb}

\p{\strong{Use cases}: Plan overview, plate method instructions, important dietary guidelines}
}

\subtree{
\title{5. Emergency Box (Large Red Design)}
\p{For emergency contacts and urgent protocols:}

\pre{\startverb
\begin{emergencybox}
  \begin{itemize}
    \item \textbf{Emergency Services:} 911
    \item \textbf{Endocrinology Office:} [Phone] (business hours)
    \item \textbf{After-Hours Hotline:} [Phone] (nights/weekends)
    \item \textbf{Pharmacy:} [Phone and location]
  \end{itemize}
\end{emergencybox}
\stopverb}

\p{\strong{Use cases}: Emergency contacts, critical hotlines, urgent resource information}
}

\subtree{
\title{6. Patient Info Box (White with Blue Border)}
\p{For patient demographics and baseline information:}

\pre{\startverb
\begin{patientinfo}
  \begin{tabular}{ll}
    \textbf{Age:} & 23 years \\
    \textbf{Sex:} & Male \\
    \textbf{Diagnosis:} & Type 2 Diabetes Mellitus \\
    \textbf{Plan Start Date:} & \today \\
  \end{tabular}
\end{patientinfo}
\stopverb}

\p{\strong{Use cases}: Patient information sections, demographic data}
}
}

\subtree{
\title{Professional Table Formatting}
\p{Enhanced table environment with medical styling:}

\pre{\startverb
\begin{medtable}{Caption Text}
\begin{tabular}{|p{5cm}|p{4cm}|p{4.5cm}|}
\hline
\tableheadercolor  % Blue header with white text
\textcolor{white}{\textbf{Column 1}} & 
\textcolor{white}{\textbf{Column 2}} & 
\textcolor{white}{\textbf{Column 3}} \\
\hline
Data row 1 content & Value 1 & Details 1 \\
\hline
\tablerowcolor  % Alternating light gray row
Data row 2 content & Value 2 & Details 2 \\
\hline
Data row 3 content & Value 3 & Details 3 \\
\hline
\end{tabular}
\caption{Table caption}
\end{medtable}
\stopverb}

\p{\strong{Features:}}

\ul{
\li{Blue headers with white text for visual prominence}
\li{\startverb Alternating row colors (`\tablerowcolor`) for improved readability\stopverb}
\li{Automatic centering and spacing}
\li{Professional borders and padding}
}
}

\subtree{
\title{Using the Style Package}
\subtree{
\title{Basic Setup}
\ol{
\li{\strong{Add to document preamble:}}
}

\pre{\startverb
% !TEX program = xelatex
\documentclass[11pt,letterpaper]{article}

% Use custom medical treatment plan style
\usepackage{medical_treatment_plan}
\usepackage{natbib}

\begin{document}
\maketitle
% Your content here
\end{document}
\stopverb}

\ol{
\li{\strong{Ensure style file is in same directory} as your \code{\startverb .tex\stopverb} file, or install to LaTeX path}
}

\ol{
\li{\strong{Compile with XeLaTeX} (recommended for best results):}
}

\pre{\startverb
xelatex treatment_plan.tex
bibtex treatment_plan
xelatex treatment_plan.tex
xelatex treatment_plan.tex
\stopverb}
}

\subtree{
\title{Custom Title Page}
\p{The package automatically formats the title with a professional blue header:}

\pre{\startverb
\title{\textbf{Individualized Diabetes Treatment Plan}\\
\large{23-Year-Old Male Patient with Type 2 Diabetes}}
\author{Comprehensive Care Plan}
\date{\today}

\begin{document}
\maketitle
\stopverb}

\p{This creates an eye-catching blue box with white text and clear hierarchy.}
}
}

\subtree{
\title{Compilation Requirements}
\p{\strong{Required LaTeX Packages} (automatically loaded by the style):}

\ul{
\li{\code{\startverb geometry\stopverb} - Page layout and margins}
\li{\code{\startverb xcolor\stopverb} - Color support}
\li{\code{\startverb tcolorbox\stopverb} with \code{\startverb [most]\stopverb} library - Custom colored boxes}
\li{\code{\startverb tikz\stopverb} - Graphics and drawing}
\li{\code{\startverb fontspec\stopverb} - Font management (XeLaTeX/LuaLaTeX)}
\li{\code{\startverb fancyhdr\stopverb} - Custom headers and footers}
\li{\code{\startverb titlesec\stopverb} - Section styling}
\li{\code{\startverb enumitem\stopverb} - Enhanced list formatting}
\li{\code{\startverb booktabs\stopverb} - Professional table rules}
\li{\code{\startverb longtable\stopverb} - Multi-page tables}
\li{\code{\startverb array\stopverb} - Enhanced table features}
\li{\code{\startverb colortbl\stopverb} - Colored table cells}
\li{\code{\startverb hyperref\stopverb} - Hyperlinks and PDF metadata}
\li{\code{\startverb natbib\stopverb} - Bibliography management}
}

\p{\strong{Recommended Compilation:}}

\pre{\startverb
# Using XeLaTeX (best font support)
xelatex document.tex
bibtex document
xelatex document.tex
xelatex document.tex

# Using PDFLaTeX (alternative)
pdflatex document.tex
bibtex document
pdflatex document.tex
pdflatex document.tex
\stopverb}
}

\subtree{
\title{Customization Options}
\subtree{
\title{Changing Colors}
\p{Edit the style file to modify the color scheme:}

\pre{\startverb
% In medical_treatment_plan.sty
\definecolor{primaryblue}{RGB}{0, 102, 153}      % Modify these
\definecolor{secondaryblue}{RGB}{102, 178, 204}
\definecolor{accentblue}{RGB}{0, 153, 204}
\definecolor{successgreen}{RGB}{0, 153, 76}
\definecolor{warningred}{RGB}{204, 0, 0}
\stopverb}
}

\subtree{
\title{Adjusting Page Layout}
\p{Modify geometry settings in the style file:}

\pre{\startverb
\RequirePackage[margin=1in, top=1.2in, bottom=1.2in]{geometry}
\stopverb}
}

\subtree{
\title{Custom Fonts (XeLaTeX only)}
\p{Uncomment and modify in the style file:}

\pre{\startverb
\setmainfont{Your Preferred Font}
\setsansfont{Your Sans-Serif Font}
\stopverb}
}

\subtree{
\title{Header/Footer Customization}
\p{Modify in the style file:}

\pre{\startverb
\fancyhead[L]{\color{primaryblue}\sffamily\small\textbf{Treatment Plan Title}}
\fancyhead[R]{\color{darkgray}\sffamily\small Patient Info}
\stopverb}
}
}

\subtree{
\title{Style Package Download and Installation}
\subtree{
\title{Option 1: Copy to Project Directory}
\p{Copy \code{\startverb assets/medical_treatment_plan.sty\stopverb} to the same directory as your \code{\startverb .tex\stopverb} file.}
}

\subtree{
\title{Option 2: Install to User TeX Directory}
\pre{\startverb
# Find your local texmf directory
kpsewhich -var-value TEXMFHOME

# Copy to appropriate location (usually ~/texmf/tex/latex/)
mkdir -p ~/texmf/tex/latex/medical_treatment_plan
cp assets/medical_treatment_plan.sty ~/texmf/tex/latex/medical_treatment_plan/

# Update TeX file database
texhash ~/texmf
\stopverb}
}

\subtree{
\title{Option 3: System-Wide Installation}
\pre{\startverb
# Copy to system texmf directory (requires sudo)
sudo cp assets/medical_treatment_plan.sty /usr/local/texlive/texmf-local/tex/latex/
sudo texhash
\stopverb}
}
}

\subtree{
\title{Additional Professional Styles (Optional)}
\p{Other medical/clinical document styles available from CTAN:}

\p{\strong{Journal Styles:}}

\pre{\startverb
# Install via TeX Live Manager
tlmgr install nejm        # New England Journal of Medicine
tlmgr install jama        # JAMA style
tlmgr install bmj         # British Medical Journal
\stopverb}

\p{\strong{General Professional Styles:}}

\pre{\startverb
tlmgr install apa7        # APA 7th edition (health sciences)
tlmgr install IEEEtran    # IEEE (medical devices/engineering)
tlmgr install springer    # Springer journals
\stopverb}

\p{\strong{Download from CTAN:}}

\ul{
\li{Visit: https://ctan.org/}
\li{Search for medical document classes}
\li{Download and install per package instructions}
}
}

\subtree{
\title{Troubleshooting}
\p{\strong{Issue: Package not found}}

\pre{\startverb
# Install missing packages via TeX Live Manager
sudo tlmgr update --self
sudo tlmgr install tcolorbox tikz pgf
\stopverb}

\p{\strong{Issue: Missing characters (✓, ≥, etc.)}}

\ul{
\li{Use XeLaTeX instead of PDFLaTeX}
\li{\startverb Or replace with LaTeX commands: `$\checkmark$`, `$\geq$`\stopverb}
\li{Requires \code{\startverb amssymb\stopverb} package for math symbols}
}

\p{\strong{Issue: Header height warnings}}

\ul{
\li{\startverb Style file sets `\setlength{\headheight}{22pt}`\stopverb}
\li{Adjust if needed for your content}
}

\p{\strong{Issue: Boxes not rendering}}

\pre{\startverb
# Ensure complete tcolorbox installation
sudo tlmgr install tcolorbox tikz pgf
\stopverb}

\p{\strong{Issue: Font not found (XeLaTeX)}}

\ul{
\li{Comment out custom font lines in .sty file}
\li{Or install specified fonts on your system}
}
}

\subtree{
\title{Best Practices for Styled Documents}
\ol{
\li{\strong{Appropriate Box Usage}}
\li{Match box type to content purpose (goals→green, warnings→yellow/red)}
\li{Don't overuse boxes; reserve for truly important information}
\li{Keep box content concise and focused}
}

\ol{
\li{\strong{Visual Hierarchy}}
\li{Use section styling for structure}
\li{Boxes for emphasis and organization}
\li{Tables for comparative data}
\li{Lists for sequential or grouped items}
}

\ol{
\li{\strong{Color Consistency}}
\li{Stick to defined color scheme}
\li{\startverb Use `\textcolor{primaryblue}{\textbf{Text}}` for emphasis\stopverb}
\li{Maintain consistent meaning (red=warning, green=goals)}
}

\ol{
\li{\strong{White Space}}
\li{Don't overcrowd pages with boxes}
\li{\startverb Use `\vspace{0.5cm}` between major sections\stopverb}
\li{Allow breathing room around colored elements}
}

\ol{
\li{\strong{Professional Appearance}}
\li{Maintain readability as top priority}
\li{Ensure sufficient contrast for accessibility}
\li{Test print output in grayscale}
\li{Keep styling consistent throughout document}
}

\ol{
\li{\strong{Table Formatting}}
\li{\startverb Use `\tableheadercolor` for all header rows\stopverb}
\li{\startverb Apply `\tablerowcolor` to alternating rows in tables >3 rows\stopverb}
\li{Keep column widths balanced}
\li{\startverb Use `\small\sffamily` for large tables\stopverb}
}
}

\subtree{
\title{Example: Styled Treatment Plan Structure}
\pre{\startverb
% !TEX program = xelatex
\documentclass[11pt,letterpaper]{article}
\usepackage{medical_treatment_plan}
\usepackage{natbib}

\title{\textbf{Comprehensive Treatment Plan}\\
\large{Patient-Centered Care Strategy}}
\author{Multidisciplinary Care Team}
\date{\today}

\begin{document}
\maketitle

\section*{Patient Information}
\begin{patientinfo}
  % Demographics table
\end{patientinfo}

\section{Executive Summary}
\begin{keybox}[Plan Overview]
  % Key highlights
\end{keybox}

\section{Treatment Goals}
\begin{goalbox}[SMART Goals - 3 Months]
  \begin{medtable}{Primary Treatment Targets}
    % Goals table with colored headers
  \end{medtable}
\end{goalbox}

\section{Medication Plan}
\begin{infobox}[Titration Schedule]
  % Medication instructions
\end{infobox}

\begin{warningbox}[Critical Decision Point]
  % Important safety information
\end{warningbox}

\section{Emergency Protocols}
\begin{emergencybox}
  % Emergency contacts
\end{emergencybox}

\bibliographystyle{plainnat}
\bibliography{references}
\end{document}
\stopverb}
}

\subtree{
\title{Benefits of Professional Styling}
\p{\strong{Clinical Practice:}}

\ul{
\li{Faster information scanning during patient encounters}
\li{Clear visual hierarchy for critical vs. routine information}
\li{Professional appearance suitable for patient-facing documents}
\li{Color-coded sections reduce cognitive load}
}

\p{\strong{Educational Use:}}

\ul{
\li{Enhanced readability for teaching materials}
\li{Visual differentiation of concept types (goals, warnings, procedures)}
\li{Professional presentation for case discussions}
\li{Print and digital-ready formats}
}

\p{\strong{Documentation Quality:}}

\ul{
\li{Modern, polished appearance}
\li{Maintains clinical accuracy while improving aesthetics}
\li{Standardized formatting across treatment plans}
\li{Easy to customize for institutional branding}
}

\p{\strong{Patient Engagement:}}

\ul{
\li{More approachable than dense text documents}
\li{Color coding helps patients identify key sections}
\li{Professional appearance builds trust}
\li{Clear organization facilitates understanding}
}
}
}

\subtree{
\title{Ethical Considerations}
\subtree{
\title{Informed Consent}
\p{All treatment plans should involve patient understanding and voluntary agreement to proposed interventions.}
}

\subtree{
\title{Cultural Sensitivity}
\p{Treatment plans must respect diverse cultural beliefs, health practices, and communication styles.}
}

\subtree{
\title{Health Equity}
\p{Consider social determinants of health, access barriers, and health disparities when developing plans.}
}

\subtree{
\title{Privacy Protection}
\p{Maintain strict HIPAA compliance; de-identify all protected health information in shared documents.}
}

\subtree{
\title{Autonomy and Beneficence}
\p{Balance medical recommendations with patient autonomy and values while promoting patient welfare.}
}
}

