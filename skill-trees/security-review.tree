\title{Security Review}

\taxon{skill}

\meta{description}{Use this skill when adding authentication, handling user input, working with secrets, creating API endpoints, or implementing payment/sensitive features. Provides comprehensive security checklist and patterns.}

\subtree{
\title{Security Review Skill}
\p{This skill ensures all code follows security best practices and identifies potential vulnerabilities.}

\subtree{
\title{When to Activate}
\ul{
\li{Implementing authentication or authorization}
\li{Handling user input or file uploads}
\li{Creating new API endpoints}
\li{Working with secrets or credentials}
\li{Implementing payment features}
\li{Storing or transmitting sensitive data}
\li{Integrating third-party APIs}
}
}

\subtree{
\title{Security Checklist}
\subtree{
\title{1. Secrets Management}
\subtree{
\title{❌ NEVER Do This}
\pre{\startverb
const apiKey = "sk-proj-xxxxx"  // Hardcoded secret
const dbPassword = "password123" // In source code
\stopverb}
}

\subtree{
\title{✅ ALWAYS Do This}
\pre{\startverb
const apiKey = process.env.OPENAI_API_KEY
const dbUrl = process.env.DATABASE_URL

// Verify secrets exist
if (!apiKey) {
  throw new Error('OPENAI_API_KEY not configured')
}
\stopverb}
}

\subtree{
\title{Verification Steps}
\ul{
\li{[ ] No hardcoded API keys, tokens, or passwords}
\li{[ ] All secrets in environment variables}
\li{[ ] \code{\startverb .env.local\stopverb} in .gitignore}
\li{[ ] No secrets in git history}
\li{[ ] Production secrets in hosting platform (Vercel, Railway)}
}
}
}

\subtree{
\title{2. Input Validation}
\subtree{
\title{Always Validate User Input}
\pre{\startverb
import { z } from 'zod'

// Define validation schema
const CreateUserSchema = z.object({
  email: z.string().email(),
  name: z.string().min(1).max(100),
  age: z.number().int().min(0).max(150)
})

// Validate before processing
export async function createUser(input: unknown) {
  try {
    const validated = CreateUserSchema.parse(input)
    return await db.users.create(validated)
  } catch (error) {
    if (error instanceof z.ZodError) {
      return { success: false, errors: error.errors }
    }
    throw error
  }
}
\stopverb}
}

\subtree{
\title{File Upload Validation}
\pre{\startverb
function validateFileUpload(file: File) {
  // Size check (5MB max)
  const maxSize = 5 * 1024 * 1024
  if (file.size > maxSize) {
    throw new Error('File too large (max 5MB)')
  }

  // Type check
  const allowedTypes = ['image/jpeg', 'image/png', 'image/gif']
  if (!allowedTypes.includes(file.type)) {
    throw new Error('Invalid file type')
  }

  // Extension check
  const allowedExtensions = ['.jpg', '.jpeg', '.png', '.gif']
  const extension = file.name.toLowerCase().match(/\.[^.]+$/)?.[0]
  if (!extension || !allowedExtensions.includes(extension)) {
    throw new Error('Invalid file extension')
  }

  return true
}
\stopverb}
}

\subtree{
\title{Verification Steps}
\ul{
\li{[ ] All user inputs validated with schemas}
\li{[ ] File uploads restricted (size, type, extension)}
\li{[ ] No direct use of user input in queries}
\li{[ ] Whitelist validation (not blacklist)}
\li{[ ] Error messages don't leak sensitive info}
}
}
}

\subtree{
\title{3. SQL Injection Prevention}
\subtree{
\title{❌ NEVER Concatenate SQL}
\pre{\startverb
// DANGEROUS - SQL Injection vulnerability
const query = `SELECT * FROM users WHERE email = '${userEmail}'`
await db.query(query)
\stopverb}
}

\subtree{
\title{✅ ALWAYS Use Parameterized Queries}
\pre{\startverb
// Safe - parameterized query
const { data } = await supabase
  .from('users')
  .select('*')
  .eq('email', userEmail)

// Or with raw SQL
await db.query(
  'SELECT * FROM users WHERE email = $1',
  [userEmail]
)
\stopverb}
}

\subtree{
\title{Verification Steps}
\ul{
\li{[ ] All database queries use parameterized queries}
\li{[ ] No string concatenation in SQL}
\li{[ ] ORM/query builder used correctly}
\li{[ ] Supabase queries properly sanitized}
}
}
}

\subtree{
\title{4. Authentication & Authorization}
\subtree{
\title{JWT Token Handling}
\pre{\startverb
// ❌ WRONG: localStorage (vulnerable to XSS)
localStorage.setItem('token', token)

// ✅ CORRECT: httpOnly cookies
res.setHeader('Set-Cookie',
  `token=${token}; HttpOnly; Secure; SameSite=Strict; Max-Age=3600`)
\stopverb}
}

\subtree{
\title{Authorization Checks}
\pre{\startverb
export async function deleteUser(userId: string, requesterId: string) {
  // ALWAYS verify authorization first
  const requester = await db.users.findUnique({
    where: { id: requesterId }
  })

  if (requester.role !== 'admin') {
    return NextResponse.json(
      { error: 'Unauthorized' },
      { status: 403 }
    )
  }

  // Proceed with deletion
  await db.users.delete({ where: { id: userId } })
}
\stopverb}
}

\subtree{
\title{Row Level Security (Supabase)}
\pre{\startverb
-- Enable RLS on all tables
ALTER TABLE users ENABLE ROW LEVEL SECURITY;

-- Users can only view their own data
CREATE POLICY "Users view own data"
  ON users FOR SELECT
  USING (auth.uid() = id);

-- Users can only update their own data
CREATE POLICY "Users update own data"
  ON users FOR UPDATE
  USING (auth.uid() = id);
\stopverb}
}

\subtree{
\title{Verification Steps}
\ul{
\li{[ ] Tokens stored in httpOnly cookies (not localStorage)}
\li{[ ] Authorization checks before sensitive operations}
\li{[ ] Row Level Security enabled in Supabase}
\li{[ ] Role-based access control implemented}
\li{[ ] Session management secure}
}
}
}

\subtree{
\title{5. XSS Prevention}
\subtree{
\title{Sanitize HTML}
\pre{\startverb
import DOMPurify from 'isomorphic-dompurify'

// ALWAYS sanitize user-provided HTML
function renderUserContent(html: string) {
  const clean = DOMPurify.sanitize(html, {
    ALLOWED_TAGS: ['b', 'i', 'em', 'strong', 'p'],
    ALLOWED_ATTR: []
  })
  return <div dangerouslySetInnerHTML={{ __html: clean }} />
}
\stopverb}
}

\subtree{
\title{Content Security Policy}
\pre{\startverb
// next.config.js
const securityHeaders = [
  {
    key: 'Content-Security-Policy',
    value: `
      default-src 'self';
      script-src 'self' 'unsafe-eval' 'unsafe-inline';
      style-src 'self' 'unsafe-inline';
      img-src 'self' data: https:;
      font-src 'self';
      connect-src 'self' https://api.example.com;
    `.replace(/\s{2,}/g, ' ').trim()
  }
]
\stopverb}
}

\subtree{
\title{Verification Steps}
\ul{
\li{[ ] User-provided HTML sanitized}
\li{[ ] CSP headers configured}
\li{[ ] No unvalidated dynamic content rendering}
\li{[ ] React's built-in XSS protection used}
}
}
}

\subtree{
\title{6. CSRF Protection}
\subtree{
\title{CSRF Tokens}
\pre{\startverb
import { csrf } from '@/lib/csrf'

export async function POST(request: Request) {
  const token = request.headers.get('X-CSRF-Token')

  if (!csrf.verify(token)) {
    return NextResponse.json(
      { error: 'Invalid CSRF token' },
      { status: 403 }
    )
  }

  // Process request
}
\stopverb}
}

\subtree{
\title{SameSite Cookies}
\pre{\startverb
res.setHeader('Set-Cookie',
  `session=${sessionId}; HttpOnly; Secure; SameSite=Strict`)
\stopverb}
}

\subtree{
\title{Verification Steps}
\ul{
\li{[ ] CSRF tokens on state-changing operations}
\li{[ ] SameSite=Strict on all cookies}
\li{[ ] Double-submit cookie pattern implemented}
}
}
}

\subtree{
\title{7. Rate Limiting}
\subtree{
\title{API Rate Limiting}
\pre{\startverb
import rateLimit from 'express-rate-limit'

const limiter = rateLimit({
  windowMs: 15 * 60 * 1000, // 15 minutes
  max: 100, // 100 requests per window
  message: 'Too many requests'
})

// Apply to routes
app.use('/api/', limiter)
\stopverb}
}

\subtree{
\title{Expensive Operations}
\pre{\startverb
// Aggressive rate limiting for searches
const searchLimiter = rateLimit({
  windowMs: 60 * 1000, // 1 minute
  max: 10, // 10 requests per minute
  message: 'Too many search requests'
})

app.use('/api/search', searchLimiter)
\stopverb}
}

\subtree{
\title{Verification Steps}
\ul{
\li{[ ] Rate limiting on all API endpoints}
\li{[ ] Stricter limits on expensive operations}
\li{[ ] IP-based rate limiting}
\li{[ ] User-based rate limiting (authenticated)}
}
}
}

\subtree{
\title{8. Sensitive Data Exposure}
\subtree{
\title{Logging}
\pre{\startverb
// ❌ WRONG: Logging sensitive data
console.log('User login:', { email, password })
console.log('Payment:', { cardNumber, cvv })

// ✅ CORRECT: Redact sensitive data
console.log('User login:', { email, userId })
console.log('Payment:', { last4: card.last4, userId })
\stopverb}
}

\subtree{
\title{Error Messages}
\pre{\startverb
// ❌ WRONG: Exposing internal details
catch (error) {
  return NextResponse.json(
    { error: error.message, stack: error.stack },
    { status: 500 }
  )
}

// ✅ CORRECT: Generic error messages
catch (error) {
  console.error('Internal error:', error)
  return NextResponse.json(
    { error: 'An error occurred. Please try again.' },
    { status: 500 }
  )
}
\stopverb}
}

\subtree{
\title{Verification Steps}
\ul{
\li{[ ] No passwords, tokens, or secrets in logs}
\li{[ ] Error messages generic for users}
\li{[ ] Detailed errors only in server logs}
\li{[ ] No stack traces exposed to users}
}
}
}

\subtree{
\title{9. Blockchain Security (Solana)}
\subtree{
\title{Wallet Verification}
\pre{\startverb
import { verify } from '@solana/web3.js'

async function verifyWalletOwnership(
  publicKey: string,
  signature: string,
  message: string
) {
  try {
    const isValid = verify(
      Buffer.from(message),
      Buffer.from(signature, 'base64'),
      Buffer.from(publicKey, 'base64')
    )
    return isValid
  } catch (error) {
    return false
  }
}
\stopverb}
}

\subtree{
\title{Transaction Verification}
\pre{\startverb
async function verifyTransaction(transaction: Transaction) {
  // Verify recipient
  if (transaction.to !== expectedRecipient) {
    throw new Error('Invalid recipient')
  }

  // Verify amount
  if (transaction.amount > maxAmount) {
    throw new Error('Amount exceeds limit')
  }

  // Verify user has sufficient balance
  const balance = await getBalance(transaction.from)
  if (balance < transaction.amount) {
    throw new Error('Insufficient balance')
  }

  return true
}
\stopverb}
}

\subtree{
\title{Verification Steps}
\ul{
\li{[ ] Wallet signatures verified}
\li{[ ] Transaction details validated}
\li{[ ] Balance checks before transactions}
\li{[ ] No blind transaction signing}
}
}
}

\subtree{
\title{10. Dependency Security}
\subtree{
\title{Regular Updates}
\pre{\startverb
# Check for vulnerabilities
npm audit

# Fix automatically fixable issues
npm audit fix

# Update dependencies
npm update

# Check for outdated packages
npm outdated
\stopverb}
}

\subtree{
\title{Lock Files}
\pre{\startverb
# ALWAYS commit lock files
git add package-lock.json

# Use in CI/CD for reproducible builds
npm ci  # Instead of npm install
\stopverb}
}

\subtree{
\title{Verification Steps}
\ul{
\li{[ ] Dependencies up to date}
\li{[ ] No known vulnerabilities (npm audit clean)}
\li{[ ] Lock files committed}
\li{[ ] Dependabot enabled on GitHub}
\li{[ ] Regular security updates}
}
}
}
}

\subtree{
\title{Security Testing}
\subtree{
\title{Automated Security Tests}
\pre{\startverb
// Test authentication
test('requires authentication', async () => {
  const response = await fetch('/api/protected')
  expect(response.status).toBe(401)
})

// Test authorization
test('requires admin role', async () => {
  const response = await fetch('/api/admin', {
    headers: { Authorization: `Bearer ${userToken}` }
  })
  expect(response.status).toBe(403)
})

// Test input validation
test('rejects invalid input', async () => {
  const response = await fetch('/api/users', {
    method: 'POST',
    body: JSON.stringify({ email: 'not-an-email' })
  })
  expect(response.status).toBe(400)
})

// Test rate limiting
test('enforces rate limits', async () => {
  const requests = Array(101).fill(null).map(() =>
    fetch('/api/endpoint')
  )

  const responses = await Promise.all(requests)
  const tooManyRequests = responses.filter(r => r.status === 429)

  expect(tooManyRequests.length).toBeGreaterThan(0)
})
\stopverb}
}
}

\subtree{
\title{Pre-Deployment Security Checklist}
\p{Before ANY production deployment:}

\ul{
\li{[ ] \strong{Secrets}: No hardcoded secrets, all in env vars}
\li{[ ] \strong{Input Validation}: All user inputs validated}
\li{[ ] \strong{SQL Injection}: All queries parameterized}
\li{[ ] \strong{XSS}: User content sanitized}
\li{[ ] \strong{CSRF}: Protection enabled}
\li{[ ] \strong{Authentication}: Proper token handling}
\li{[ ] \strong{Authorization}: Role checks in place}
\li{[ ] \strong{Rate Limiting}: Enabled on all endpoints}
\li{[ ] \strong{HTTPS}: Enforced in production}
\li{[ ] \strong{Security Headers}: CSP, X-Frame-Options configured}
\li{[ ] \strong{Error Handling}: No sensitive data in errors}
\li{[ ] \strong{Logging}: No sensitive data logged}
\li{[ ] \strong{Dependencies}: Up to date, no vulnerabilities}
\li{[ ] \strong{Row Level Security}: Enabled in Supabase}
\li{[ ] \strong{CORS}: Properly configured}
\li{[ ] \strong{File Uploads}: Validated (size, type)}
\li{[ ] \strong{Wallet Signatures}: Verified (if blockchain)}
}
}

