\title{Kinfer Runtime}

\taxon{skill}

\meta{description}{"K-Scale kinfer model inference engine for deploying trained RL policies to real robots via ONNX Runtime in Rust"}

\subtree{
\title{K-Scale kinfer Skill}
\blockquote{*"The K-Scale model export and inference tool"*}

\subtree{
\title{Trigger Conditions}
\ul{
\li{User asks about deploying RL policies to real robots}
\li{Questions about ONNX model inference, Rust ML runtime}
\li{Policy execution on embedded systems}
\li{Real-time neural network inference}
}
}

\subtree{
\title{Overview}
\p{\strong{kinfer} is K-Scale's model inference engine for deploying trained policies:}

\ol{
\li{\strong{Model Loading}: ONNX format support via \code{\startverb ort\stopverb} (ONNX Runtime)}
\li{\strong{Real-time Execution}: Rust implementation for low latency}
\li{\strong{Logging}: NDJSON telemetry for debugging}
\li{\strong{Integration}: Seamless connection with KOS firmware}
}
}

\subtree{
\title{Architecture}
\pre{\startverb
┌─────────────────────────────────────────────────────────────────────────┐
│  kinfer Inference Pipeline                                               │
│                                                                          │
│  ┌──────────────┐      load      ┌──────────────┐                       │
│  │  ONNX Model  │───────────────▶│   Runtime    │                       │
│  │  (.onnx)     │                │  (ort-sys)   │                       │
│  └──────────────┘                └──────┬───────┘                       │
│                                         │                                │
│  ┌──────────────┐      step      ┌──────┴───────┐      output           │
│  │ Observation  │───────────────▶│   Inference  │───────────────▶Action │
│  │  (sensors)   │                │    Engine    │                       │
│  └──────────────┘                └──────────────┘                       │
│                                         │                                │
│                                         ▼                                │
│                                  ┌──────────────┐                       │
│                                  │   Logger     │                       │
│                                  │  (NDJSON)    │                       │
│                                  └──────────────┘                       │
└─────────────────────────────────────────────────────────────────────────┘
\stopverb}
}

\subtree{
\title{Key Features}
\subtree{
\title{1. Single Tokio Runtime}
\pre{\startverb
// Efficient async execution with GIL management
lazy_static! {
    static ref RUNTIME: Runtime = Runtime::new().unwrap();
}
\stopverb}
}

\subtree{
\title{2. Pre-fetch Inputs}
\pre{\startverb
// Minimize latency by preparing inputs ahead of time
fn step_and_take_action(&mut self, observation: &[f32]) -> Vec<f32> {
    // Pre-fetch next input while processing current
    ...
}
\stopverb}
}

\subtree{
\title{3. NDJSON Logging}
\pre{\startverb
// Async logging thread for telemetry
struct Logger {
    file: File,
    tx: Sender<LogEntry>,
}
\stopverb}
}
}

\subtree{
\title{Language & Stack}
\ul{
\li{\strong{Primary}: Rust (performance-critical)}
\li{\strong{ML Runtime}: ONNX Runtime (\code{\startverb ort\stopverb}, \code{\startverb ort-sys\stopverb})}
\li{\strong{Async}: Tokio for non-blocking I/O}
\li{\strong{Bindings}: Python via PyO3}
}
}

