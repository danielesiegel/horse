\subtree{
\title{Helper Scripts}
\subtree{
\title{scripts/validate_files.py}
\p{Validates BAM, bigWig, and BED files for deepTools analysis. Checks file existence, indices, and format.}

\p{\strong{Usage:}}

\pre{\startverb
python scripts/validate_files.py --bam sample1.bam sample2.bam \
    --bed peaks.bed --bigwig signal.bw
\stopverb}

\p{\strong{When to use:} Before starting any analysis, or when troubleshooting errors.}
}

\subtree{
\title{scripts/workflow_generator.py}
\p{Generates customizable bash script templates for common deepTools workflows.}

\p{\strong{Available workflows:}}

\ul{
\li{\code{\startverb chipseq_qc\stopverb}: ChIP-seq quality control}
\li{\code{\startverb chipseq_analysis\stopverb}: Complete ChIP-seq analysis}
\li{\code{\startverb rnaseq_coverage\stopverb}: Strand-specific RNA-seq coverage}
\li{\code{\startverb atacseq\stopverb}: ATAC-seq with Tn5 correction}
}

\p{\strong{Usage:}}

\pre{\startverb
# List workflows
python scripts/workflow_generator.py --list

# Generate workflow
python scripts/workflow_generator.py chipseq_qc -o qc.sh \
    --input-bam Input.bam --chip-bams "ChIP1.bam ChIP2.bam" \
    --genome-size 2913022398 --threads 8

# Run generated workflow
chmod +x qc.sh
./qc.sh
\stopverb}

\p{\strong{When to use:} Users request standard workflows or need template scripts to customize.}
}
}

