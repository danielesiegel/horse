\subtree{
\title{For Specific Tasks}
\p{\strong{"Convert BAM to bigWig":}}

\ul{
\li{Use bamCoverage with appropriate normalization}
\li{Recommend RPGC or CPM based on use case}
\li{Provide effective genome size for organism}
\li{Suggest relevant parameters (extendReads, ignoreDuplicates, binSize)}
}

\p{\strong{"Check ChIP quality":}}

\ul{
