\title{Next Cache Components}

\taxon{skill}

\meta{description}{Next.js 16 Cache Components - PPR, use cache directive, cacheLife, cacheTag, updateTag}

\subtree{
\title{Cache Components (Next.js 16+)}
\p{Cache Components enable Partial Prerendering (PPR) - mix static, cached, and dynamic content in a single route.}

\subtree{
\title{Enable Cache Components}
\pre{\startverb
// next.config.ts
import type { NextConfig } from 'next'

const nextConfig: NextConfig = {
  cacheComponents: true,
}

export default nextConfig
\stopverb}

\p{This replaces the old \code{\startverb experimental.ppr\stopverb} flag.}
}

\subtree{
\title{Three Content Types}
\p{With Cache Components enabled, content falls into three categories:}

\subtree{
\title{1. Static (Auto-Prerendered)}
\p{Synchronous code, imports, pure computations - prerendered at build time:}

\pre{\startverb
export default function Page() {
  return (
    <header>
      <h1>Our Blog</h1>  {/* Static - instant */}
      <nav>...</nav>
    </header>
  )
}
\stopverb}
}

\subtree{
\title{2. Cached (\code{\startverb use cache\stopverb})}
\p{Async data that doesn't need fresh fetches every request:}

\pre{\startverb
async function BlogPosts() {
  'use cache'
  cacheLife('hours')

  const posts = await db.posts.findMany()
  return <PostList posts={posts} />
}
\stopverb}
}

\subtree{
\title{3. Dynamic (Suspense)}
\p{Runtime data that must be fresh - wrap in Suspense:}

\pre{\startverb
import { Suspense } from 'react'

export default function Page() {
  return (
    <>
      <BlogPosts />  {/* Cached */}

      <Suspense fallback={<p>Loading...</p>}>
        <UserPreferences />  {/* Dynamic - streams in */}
      </Suspense>
    </>
  )
}

async function UserPreferences() {
  const theme = (await cookies()).get('theme')?.value
  return <p>Theme: {theme}</p>
}
\stopverb}
}
}

\subtree{
\title{\code{\startverb use cache\stopverb} Directive}
\subtree{
\title{File Level}
\pre{\startverb
'use cache'

export default async function Page() {
  // Entire page is cached
  const data = await fetchData()
  return <div>{data}</div>
}
\stopverb}
}

\subtree{
\title{Component Level}
\pre{\startverb
export async function CachedComponent() {
  'use cache'
  const data = await fetchData()
  return <div>{data}</div>
}
\stopverb}
}

\subtree{
\title{Function Level}
\pre{\startverb
export async function getData() {
  'use cache'
  return db.query('SELECT * FROM posts')
}
\stopverb}
}
}

\subtree{
\title{Cache Profiles}
\subtree{
\title{Built-in Profiles}
\pre{\startverb
'use cache'                    // Default: 5m stale, 15m revalidate
\stopverb}

\pre{\startverb
'use cache: remote'           // Platform-provided cache (Redis, KV)
\stopverb}

\pre{\startverb
'use cache: private'          // For compliance, allows runtime APIs
\stopverb}
}

\subtree{
\title{\code{\startverb cacheLife()\stopverb} - Custom Lifetime}
\pre{\startverb
import { cacheLife } from 'next/cache'

async function getData() {
  'use cache'
  cacheLife('hours')  // Built-in profile
  return fetch('/api/data')
}
\stopverb}

\p{Built-in profiles: \code{\startverb 'default'\stopverb}, \code{\startverb 'minutes'\stopverb}, \code{\startverb 'hours'\stopverb}, \code{\startverb 'days'\stopverb}, \code{\startverb 'weeks'\stopverb}, \code{\startverb 'max'\stopverb}}
}

\subtree{
\title{Inline Configuration}
\pre{\startverb
async function getData() {
  'use cache'
  cacheLife({
    stale: 3600,      // 1 hour - serve stale while revalidating
    revalidate: 7200, // 2 hours - background revalidation interval
    expire: 86400,    // 1 day - hard expiration
  })
  return fetch('/api/data')
}
\stopverb}
}
}

\subtree{
\title{Cache Invalidation}
\subtree{
\title{\code{\startverb cacheTag()\stopverb} - Tag Cached Content}
\pre{\startverb
import { cacheTag } from 'next/cache'

async function getProducts() {
  'use cache'
  cacheTag('products')
  return db.products.findMany()
}

async function getProduct(id: string) {
  'use cache'
  cacheTag('products', `product-${id}`)
  return db.products.findUnique({ where: { id } })
}
\stopverb}
}

\subtree{
\title{\code{\startverb updateTag()\stopverb} - Immediate Invalidation}
\p{Use when you need the cache refreshed within the same request:}

\pre{\startverb
'use server'

import { updateTag } from 'next/cache'

export async function updateProduct(id: string, data: FormData) {
  await db.products.update({ where: { id }, data })
  updateTag(`product-${id}`)  // Immediate - same request sees fresh data
}
\stopverb}
}

\subtree{
\title{\code{\startverb revalidateTag()\stopverb} - Background Revalidation}
\p{Use for stale-while-revalidate behavior:}

\pre{\startverb
'use server'

import { revalidateTag } from 'next/cache'

export async function createPost(data: FormData) {
  await db.posts.create({ data })
  revalidateTag('posts')  // Background - next request sees fresh data
}
\stopverb}
}
}

\subtree{
\title{Runtime Data Constraint}
\p{\strong{Cannot} access \code{\startverb cookies()\stopverb}, \code{\startverb headers()\stopverb}, or \code{\startverb searchParams\stopverb} inside \code{\startverb use cache\stopverb}.}

\subtree{
\title{Solution: Pass as Arguments}
\pre{\startverb
// Wrong - runtime API inside use cache
async function CachedProfile() {
  'use cache'
  const session = (await cookies()).get('session')?.value  // Error!
  return <div>{session}</div>
}

// Correct - extract outside, pass as argument
async function ProfilePage() {
  const session = (await cookies()).get('session')?.value
  return <CachedProfile sessionId={session} />
}

async function CachedProfile({ sessionId }: { sessionId: string }) {
  'use cache'
  // sessionId becomes part of cache key automatically
  const data = await fetchUserData(sessionId)
  return <div>{data.name}</div>
}
\stopverb}
}

\subtree{
\title{Exception: \code{\startverb use cache: private\stopverb}}
\p{For compliance requirements when you can't refactor:}

\pre{\startverb
async function getData() {
  'use cache: private'
  const session = (await cookies()).get('session')?.value  // Allowed
  return fetchData(session)
}
\stopverb}
}
}

\subtree{
\title{Cache Key Generation}
\p{Cache keys are automatic based on:}

\ul{
\li{\strong{Build ID} - invalidates all caches on deploy}
\li{\strong{Function ID} - hash of function location}
\li{\strong{Serializable arguments} - props become part of key}
\li{\strong{Closure variables} - outer scope values included}
}

\pre{\startverb
async function Component({ userId }: { userId: string }) {
  const getData = async (filter: string) => {
    'use cache'
    // Cache key = userId (closure) + filter (argument)
    return fetch(`/api/users/${userId}?filter=${filter}`)
  }
  return getData('active')
}
\stopverb}
}

\subtree{
\title{Complete Example}
\pre{\startverb
import { Suspense } from 'react'
import { cookies } from 'next/headers'
import { cacheLife, cacheTag } from 'next/cache'

export default function DashboardPage() {
  return (
    <>
      {/* Static shell - instant from CDN */}
      <header><h1>Dashboard</h1></header>
      <nav>...</nav>

      {/* Cached - fast, revalidates hourly */}
      <Stats />

      {/* Dynamic - streams in with fresh data */}
      <Suspense fallback={<NotificationsSkeleton />}>
        <Notifications />
      </Suspense>
    </>
  )
}

async function Stats() {
  'use cache'
  cacheLife('hours')
  cacheTag('dashboard-stats')

  const stats = await db.stats.aggregate()
  return <StatsDisplay stats={stats} />
}

async function Notifications() {
  const userId = (await cookies()).get('userId')?.value
  const notifications = await db.notifications.findMany({
    where: { userId, read: false }
  })
  return <NotificationList items={notifications} />
}
\stopverb}
}

\subtree{
\title{Migration from Previous Versions}
\pre{\startverb
| Old Config | Replacement |
|-----------|-------------|
| `experimental.ppr` | `cacheComponents: true` |
| `dynamic = 'force-dynamic'` | Remove (default behavior) |
| `dynamic = 'force-static'` | `'use cache'` + `cacheLife('max')` |
| `revalidate = N` | `cacheLife({ revalidate: N })` |
| `unstable_cache()` | `'use cache'` directive |
\stopverb}
}

\subtree{
\title{Limitations}
\ul{
\li{\strong{Edge runtime not supported} - requires Node.js}
\li{\strong{Static export not supported} - needs server}
\li{\strong{Non-deterministic values} (\code{\startverb Math.random()\stopverb}, \code{\startverb Date.now()\stopverb}) execute once at build time inside \code{\startverb use cache\stopverb}}
}

\p{For request-time randomness outside cache:}

\pre{\startverb
import { connection } from 'next/server'

async function DynamicContent() {
  await connection()  // Defer to request time
  const id = crypto.randomUUID()  // Different per request
  return <div>{id}</div>
}
\stopverb}

\p{Sources:}

\ul{
\li{[Cache Components Guide](https://nextjs.org/docs/app/getting-started/cache-components)}
\li{[use cache Directive](https://nextjs.org/docs/app/api-reference/directives/use-cache)}
}
}
}