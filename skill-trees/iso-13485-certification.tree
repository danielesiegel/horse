\subtree{
\title{Quick Reference}
\subtree{
\title{The 31 Required Documented Procedures}
\ol{
\li{Risk Management (4.1.5)}
\li{Software Validation (4.1.6)}
\li{Control of Documents (4.2.4)}
\li{Control of Records (4.2.5)}
\li{Internal Communication (5.5.3)}
\li{Management Review (5.6.1)}
\li{Human Resources/Competence (6.2)}
\li{Infrastructure Maintenance (6.3) - when applicable}
\li{Contamination Control (6.4.2) - when applicable}
\li{Customer Communication (7.2.3)}
\li{Design and Development (7.3.1-10) - when applicable}
\li{Purchasing (7.4.1)}
\li{Verification of Purchased Product (7.4.3)}
\li{Production Control (7.5.1)}
\li{Product Cleanliness (7.5.2) - when applicable}
\li{Installation (7.5.3) - when applicable}
\li{Servicing (7.5.4) - when applicable}
\li{Process Validation (7.5.6) - when applicable}
\li{Sterilization Validation (7.5.7) - when applicable}
\li{Product Identification (7.5.8)}
\li{Traceability (7.5.9)}
\li{Customer Property (7.5.10) - when applicable}
\li{Preservation of Product (7.5.11)}
\li{Control of M&M Equipment (7.6)}
\li{Feedback (8.2.1)}
\li{Complaint Handling (8.2.2)}
\li{Regulatory Reporting (8.2.3)}
\li{Internal Audit (8.2.4)}
\li{Process Monitoring (8.2.5)}
\li{Product Monitoring (8.2.6)}
\li{Control of Nonconforming Product (8.3)}
\li{Corrective Action (8.5.2)}
\li{Preventive Action (8.5.3)}
}

\p{*(Note: Traditional count is "31 procedures" though list shows more because some are conditional)*}
}

\subtree{
\title{Key Regulatory Requirements}
\p{\strong{FDA (United States):}}

\ul{
\li{21 CFR Part 820 (now QMSR) - harmonized with ISO 13485 as of Feb 2026}
\li{Device classification determines requirements}
\li{Establishment registration and device listing required}
}

\p{\strong{EU (European Union):}}

\ul{
\li{MDR 2017/745 (Medical Devices Regulation)}
\li{IVDR 2017/746 (In Vitro Diagnostic Regulation)}
\li{Technical documentation requirements}
\li{CE marking requirements}
}

\p{\strong{Canada:}}

\ul{
\li{Canadian Medical Devices Regulations (SOR/98-282)}
\li{Device classification system}
\li{Medical Device Establishment License (MDEL)}
}

\p{\strong{Other Regions:}}

\ul{
\li{Australia TGA, Japan PMDA, China NMPA, etc.}
\li{Often require or recognize ISO 13485 certification}
}
}

\subtree{
\title{Document Retention}
\p{\strong{Minimum retention:} Lifetime of medical device as defined by organization}

\p{\strong{Typical retention periods:}}

\ul{
\li{Design documents: Life of device + 5-10 years}
\li{Manufacturing records: Life of device}
\li{Complaint records: Life of device + 5-10 years}
\li{CAPA records: 5-10 years minimum}
\li{Calibration records: Retention period of equipment + 1 calibration cycle}
}

\p{\strong{Always comply with applicable regulatory requirements which may specify longer periods.}}
}
}

\subtree{
\title{Getting Started}
\p{\strong{First-time users should:}}

\ol{
\li{Read \code{\startverb references/iso-13485-requirements.md\stopverb} to understand the standard}
\li{If you have existing documentation, run gap analysis script}
\li{Create Quality Manual using template and guide}
\li{Develop procedures in priority order}
\li{Use comprehensive checklist for final validation}
}

\p{\strong{For specific tasks:}}

\ul{
\li{Creating Quality Manual → See Section 4 and use quality-manual-guide.md}
\li{Creating CAPA procedure → See Section 4 and use CAPA template}
\li{Gap analysis → See Section 1 and 5}
\li{Understanding requirements → See Section 2}
}

\p{\strong{Need help?} Start by describing your situation: what stage you're at, what you have, and what you need to create.}
}
}