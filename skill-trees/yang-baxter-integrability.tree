\title{Yang Baxter Integrability}

\taxon{skill}

\meta{description}{"Yang-Baxter equation for quantum integrable systems. Fusion procedure, R-matrices, cuboson weights, and partition function invariance under vertex crossings."}

\subtree{
\title{Yang-Baxter Integrability Skill}
\p{\strong{Status}: вЬЕ Production Ready \strong{Trit}: -1 (MINUS - structural/validating) \strong{Color}: #DC143C (Crimson) \strong{Principle}: Partition function invariance under vertex crossings \strong{Frame}: R-matrix solutions, fusion hierarchy, quantum groups}

\subtree{
\title{Overview}
\p{The \strong{Yang-Baxter equation} (YBE) is the master equation of quantum integrability:}

\pre{\startverb
RвВБвВВ(u) RвВБвВГ(u+v) RвВВвВГ(v) = RвВВвВГ(v) RвВБвВГ(u+v) RвВБвВВ(u)

Where:
  RбµҐв±Љ(u) = R-matrix acting on spaces i,j
  u, v = spectral parameters
\stopverb}

\p{This skill provides:}

\ol{
\li{\strong{R-Matrix Calculus}: Compute and verify R-matrices}
\li{\strong{Fusion Procedure}: Derive new solutions from old}
\li{\strong{Vertex Model Weights}: Six-vertex, cuboson, and beyond}
\li{\strong{Partition Functions}: Compute via Yang-Baxter invariance}
}
}

\subtree{
\title{The Yang-Baxter Equation}
\subtree{
\title{Graphical Form}
\pre{\startverb
   вХ≤   вХ±        вХ±   вХ≤
    вХ≤ вХ±   =    вХ±     вХ≤
     вХ≥        вХ≥       вХ≥
    вХ± вХ≤        вХ≤     вХ±
   вХ±   вХ≤        вХ≤   вХ±
\stopverb}

\p{Two ways to resolve three crossing lines give same result.}
}

\subtree{
\title{Algebraic Form (Braid Group)}
\pre{\startverb
ѕГбµҐ ѕГбµҐвВКвВБ ѕГбµҐ = ѕГбµҐвВКвВБ ѕГбµҐ ѕГбµҐвВКвВБ   (braid relation)
ѕГбµҐ ѕГв±Љ = ѕГв±Љ ѕГбµҐ               (|i-j| > 1)
\stopverb}
}
}

\subtree{
\title{Six-Vertex Model}
\p{The \strong{stochastic six-vertex model} has weights for six allowed vertex configurations:}

\pre{\startverb
Allowed vertices (no arrow creation/annihilation):

  вЖС     вЖУ     вЖТ     вЖР     вЖС     вЖУ
вЖТвФАвФЉвФАвЖТ вЖРвФАвФЉвФАвЖР вЖСвФАвФЉвФАвЖУ вЖУвФАвФЉвФАвЖС вЖРвФАвФЉвФАвЖТ вЖТвФАвФЉвФАвЖР
  вЖС     вЖУ     вЖТ     вЖР     вЖУ     вЖС

Weights: aвВБ, aвВВ, bвВБ, bвВВ, cвВБ, cвВВ

Stochastic (row-sum = 1):
  aвВБ(u) + bвВБ(u) + cвВБ(u) = 1
\stopverb}

\subtree{
\title{Stochastic Weights}
\pre{\startverb
# Stochastic six-vertex weights
aвВБ(bвВВ, q) = (1 - q*bвВВ) / (1 - q)
bвВБ(bвВВ, q) = (1 - bвВВ) / (1 - q)  
cвВБ(bвВВ, q) = (q - 1)*bвВВ / (1 - q)

# Yang-Baxter verification
verify_yang_baxter(aвВБ, aвВВ, bвВБ, bвВВ, cвВБ, cвВВ)
\stopverb}
}
}

\subtree{
\title{Colored Stochastic Six-Vertex Model}
\p{With \strong{n colors} of arrows (see colored-vertex-model skill):}

\pre{\startverb
Colors: 1, 2, ..., n (rainbow initial data)
Height function h_k(x,y) = count of arrows with color вЙ§ k

Projection property:
  Project to colors {1,...,k} вЖТ k-color model
\stopverb}
}

\subtree{
\title{Fusion Procedure}
\p{\strong{Fusion} derives new YBE solutions from existing ones:}

\pre{\startverb
R^(m,n)(u) = P_{m,n} R^(1,1)(u) R^(1,1)(u+1) ... R^(1,1)(u+m+n-2) P_{m,n}

Where P_{m,n} = symmetrizer onto (m,n)-representation
\stopverb}

\subtree{
\title{Cuboson Weights (Fused Vertices)}
\p{After fusion, vertices can carry \strong{multiple arrows} in vertical direction:}

\pre{\startverb
Standard six-vertex:  1 arrow in/out vertically
Cuboson weights:      k arrows in/out vertically (k = 1, 2, ...)

Cuboson vertex weight: W(in, out; spectral_param)
\stopverb}

\pre{\startverb
# Compute cuboson weights via fusion
cuboson = fuse_vertices(
    base_weights = six_vertex_weights(q),
    vertical_capacity = k,  # max arrows vertically
    spectral = u
)

# Verify Yang-Baxter for cuboson model
@test verify_yang_baxter(cuboson)
\stopverb}
}
}

\subtree{
\title{The "Feynman Trick" (Partition Function = 1)}
\p{A key technique uses auxiliary vertex models with partition function 1:}

\pre{\startverb
Z_auxiliary = 1  (by construction)

This creates equivalence:
  Six-vertex height function = Cuboson model last column
\stopverb}

\pre{\startverb
# Feynman trick: embed six-vertex in cuboson
embedding = feynman_embed(
    six_vertex = S6V(initial = :rainbow),
    cuboson = Cuboson(capacity = k)
)

# Height function appears in last column
@test embedding.last_column == six_vertex.height_function
\stopverb}
}

\subtree{
\title{R-Matrix Library}
\subtree{
\title{Six-Vertex R-Matrix}
\pre{\startverb
function r_matrix_six_vertex(u, q)
    # 4x4 matrix acting on V вКЧ V
    R = zeros(4, 4)
    R[1,1] = a(u,q)
    R[2,2] = R[3,3] = b(u,q)
    R[2,3] = R[3,2] = c(u,q)
    R[4,4] = a(u,q)
    return R
end

# Verify YBE
function verify_ybe(R, u, v)
    R12 = kron(R(u), I(2))
    R13 = kron(I(2), R(u+v))
    R23 = kron(I(2), R(v))
    
    LHS = R12 * R13 * R23
    RHS = R23 * R13 * R12
    
    return norm(LHS - RHS) < 1e-10
end
\stopverb}
}

\subtree{
\title{Quantum Group U_q(sl_2)}
\pre{\startverb
# R-matrix from quantum group
R_quantum(q) = universal_r_matrix(Uq_sl2(q))

# Check: Yang-Baxter вЯЇ quasi-triangular Hopf algebra
@test is_quasi_triangular(Uq_sl2(q))
\stopverb}
}
}

\subtree{
\title{Integration with Modelica (String Diagrams)}
\p{Yang-Baxter \strong{IS} the flip combinator constraint:}

\pre{\startverb
// Modelica: acausal makes YBE automatic
connector YBPort
  Real spectral;
  flow Integer color;
end YBPort;

model YangBaxterCrossing
  YBPort a, b, c;
equation
  // Conservation at crossing
  a.color + b.color = c.color;  // arrow conservation
  
  // Spectral parameter flow (acausal!)
  // Solver determines which way to evaluate
end YangBaxterCrossing;
\stopverb}

\subtree{
\title{Key Insight: Flip is Trivial}
\p{In Modelica, the Yang-Baxter equation becomes a \strong{constraint} that the solver satisfies automatically. The "which line crosses first" choice is made by the solver, not the modeler.}
}
}

\subtree{
\title{Integration with Gay-MCP (Color Projection)}
\p{Colors in the vertex model map to GF(3) trits:}

\pre{\startverb
using GayMCP, YangBaxterIntegrability

# Rainbow initial data with Gay.jl colors
rainbow = colored_vertex_model(
    n_colors = 3,
    seed = gay_seed(1069)
)

# Each color maps to a trit
color_to_trit(c) = (c - 1) % 3 - 1  # {1,2,3} вЖТ {0,1,-1}

# Projection preserves GF(3)
@test sum(color_to_trit.(rainbow.colors)) % 3 == 0
\stopverb}
}

\subtree{
\title{Gibbs Properties}
\p{Two crucial Gibbs properties of the cuboson model:}

\subtree{
\title{1. Inter-Color Gibbs Property}
\pre{\startverb
# Variational formula (Pitman transform)
inter_color_gibbs(colored_ensemble, uncolored_ensemble) = 
    argmax(monotone_coupling, kolmogorov_compatibility)

# This relates colored height function to uncolored
h_colored = pitman_transform(h_uncolored)
\stopverb}
}

\subtree{
\title{2. Uncolored Gibbs Property}
\pre{\startverb
# Q = 0: Non-crossing Bernoulli bridges (Dyson Brownian motion)
uncol_gibbs_Q0(paths) = non_crossing_bridges(paths)

# Q > 0: Path coalescence! (1-Q) factor causes merging
uncol_gibbs_Q_pos(paths, Q) = coalescing_bridges(paths, Q)

# Challenge: Q > 0 case requires careful limit
\stopverb}
}
}

