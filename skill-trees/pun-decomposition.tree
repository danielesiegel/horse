\title{Pun Decomposition}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{Pun Decomposition Skill (MINUS -1)}

\subtree{
\title{Pun Decomposition Skill (MINUS -1)}
\blockquote{*"A pun exploits multiple valid decompositions of the same phonetic surface."*}

\subtree{
\title{Core Insight}
\p{A \strong{pun} is an information reflow that maps a single surface form to multiple semantic contexts. The humor arises from the unexpected context switch—the inductive bias favors one parse, but the pun activates another.}

\pre{\startverb
pun : Surface → {Context₁, Context₂, ...}
where each Contextᵢ has a valid decomposition
\stopverb}
}

