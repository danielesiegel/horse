\subtree{
\title{Pun as Gestalt Attack}
\p{From the gestalt hacking thread:}

\pre{\startverb
enum GestaltPrinciple {
    Proximity,    // Close morphemes group
    Similarity,   // Similar sounds group  
    Closure,      // Incomplete parse completed
    Continuity,   // Smooth phonetic path preferred
    FigureGround, // Dominant meaning masks secondary
}
\stopverb}

\p{A pun exploits \strong{Closure} and \strong{FigureGround}:}

\ul{
\li{\strong{Closure}: The listener completes the parse with the expected meaning}
\li{\strong{FigureGround}: The secondary meaning lurks in background until activated}
}
}

\subtree{
\title{Decomposition Types}
\subtree{
\title{Morphemic Decomposition}
\pre{\startverb
# "I'm reading a book about anti-gravity. It's impossible to put down."
{
  surface: "put down",
  decompositions: [
    { parse: ["put", "down"], meaning: "place on surface", trit: 1 },
    { parse: ["put-down"], meaning: "stop reading", trit: -1 },
  ],
  inductive_bias: 0.7,  # Favors first parse
  pun_strength: 0.3     # Second parse activation
}
\stopverb}
}

\subtree{
\title{Phonetic Decomposition}
\pre{\startverb
# "Time flies like an arrow. Fruit flies like a banana."
{
  surface: "flies like",
  decompositions: [
    { parse: ["flies", "like"], pos: ["verb", "prep"], trit: 1 },
    { parse: ["flies", "like"], pos: ["noun", "verb"], trit: -1 },
  ],
  gestalt_principle: :figure_ground,
  context_switch: "arrow → banana"
}
\stopverb}
}

\subtree{
\title{Etymological Decomposition}
\pre{\startverb
# From the reflow skill:
{
  word: "trimester",
  decomposition: ["tri-", "mester"],
  trits: [0, 0],
  gf3_sum: 0,  # Balanced!
  resonance: :strong
}

{
  word: "semester", 
  decomposition: ["se-", "mester"],  # se- = six (2×3)
  trits: [0, 0],
  gf3_sum: 0,  # Also balanced via factorization
  resonance: :moderate
}
\stopverb}
}
}

\subtree{
\title{ACSet Schema for Puns}
\pre{\startverb
@present SchPun(FreeSchema) begin
  Surface::Ob
  Parse::Ob
  Morpheme::Ob
  Meaning::Ob
  
  surface::Hom(Parse, Surface)
  morphemes::Hom(Morpheme, Parse)
  meaning::Hom(Parse, Meaning)
  
  # Attributes
  Text::AttrType
  Trit::AttrType
  Bias::AttrType
  
  text::Attr(Surface, Text)
  trit::Attr(Parse, Trit)
  bias::Attr(Parse, Bias)
end

@acset_type Pun(SchPun, index=[:surface, :meaning])
\stopverb}
}

\subtree{
\title{Inductive Bias as Prior}
\p{The inductive bias determines which decomposition is "default":}

\pre{\startverb
P(parse₁ | surface) = softmax(bias₁ / τ)
P(parse₂ | surface) = softmax(bias₂ / τ)

where τ = temperature (context sensitivity)
\stopverb}

\p{At low temperature (focused context), one parse dominates. At high temperature (open context), multiple parses activate → PUN.}
}

\subtree{
\title{OpenGame Structure}
\p{From gestalt hacking thread:}

\pre{\startverb
┌─────────────────────────────────────────────────────────┐
│  PunGame ∆                                              │
│  ─────────────────────────────────────────────────────  │
│  play     :: Surface → ∆ [Parse]     ← enumerate parses │
│  evaluate :: [Parse] → Meaning       ← select by context│
│                                                         │
│  Pun = play produces multiple; evaluate oscillates      │
└─────────────────────────────────────────────────────────┘
\stopverb}
}

\subtree{
\title{Defense: 2-Poisson Disambiguation}
\p{When puns attack comprehension, use stochastic sampling:}

\pre{\startverb
impl PunDefender {
    fn disambiguate(&mut self, surface: &str) -> Parse {
        let parses = self.decompose(surface);
        
        if parses.len() > 1 {
            // Multiple valid parses detected
            let (_, selected) = self.poisson.next_arrival(0.0);
            // Use Poisson timing to break tie
            parses[selected.to_usize() % parses.len()].clone()
        } else {
            parses[0].clone()
        }
    }
}
\stopverb}
}

