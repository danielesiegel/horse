getDiagnostics() {
  return {
    entropy: H(stateDistribution),      // Uncertainty
    curvature: trace(FisherMatrix) / n, // Manifold curvature
    threatLevel: activatedCount / total,
    autoimmune: tritSum % 3 !== 0
