}
}

\subtree{
\title{Troubleshooting}
\p{\strong{"Tokenization coverage too low":}}

\ul{
\li{Check universe quality and completeness}
\li{Adjust p-value threshold (try 1e-6 instead of 1e-9)}
\li{Ensure universe matches genome assembly}
}

\p{\strong{"Training not converging":}}

\ul{
\li{Adjust learning rate (try 0.01-0.05 range)}
\li{Increase training epochs}
\li{Check data quality and preprocessing}
}

\p{\strong{"Out of memory errors":}}

\ul{
\li{Reduce batch size for scEmbed}
\li{Process data in chunks}
\li{Use pre-tokenization for single-cell data}
}

\p{\strong{"StarSpace not found" (BEDspace):}}

\ul{
\li{Install StarSpace separately: https://github.com/facebookresearch/StarSpace}
\li{Set \code{\startverb --path-to-starspace\stopverb} parameter correctly}
}

\p{For detailed troubleshooting and method-specific issues, consult the appropriate reference file.}
}
}