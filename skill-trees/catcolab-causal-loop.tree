\title{Catcolab Causal Loop}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{CatColab Causal Loop Diagrams - systems dynamics modeling with reinforcing (R) and balancing (B) feedback loops, delays, and Lotka-Volterra semantics for strategic analysis.}

\subtree{
\title{CatColab Causal Loop Diagrams: Systems Dynamics}
\p{\strong{Trit}: 0 (ERGODIC - coordinator/mediator) \strong{Color}: Yellow (#FFD700)}

\subtree{
\title{Overview}
\p{Causal Loop Diagrams (CLDs) in CatColab model feedback systems:}

\ul{
\li{\strong{Variables}: System quantities that change over time}
\li{\strong{Positive links (+)}: Same-direction influence (increase→increase)}
\li{\strong{Negative links (-)}: Opposite-direction influence (increase→decrease)}
\li{\strong{Loops}: Reinforcing (R) or Balancing (B) feedback}
}

\p{CLDs are essential for understanding system behavior, policy analysis, and strategic planning.}
}

\subtree{
\title{Mathematical Foundation}
\p{A causal loop diagram is a \strong{signed directed graph} with loop classification:}

\pre{\startverb
┌─────────────────────────────────────────────────────┐
│            CAUSAL LOOP DIAGRAM                       │
├─────────────────────────────────────────────────────┤
│  Variables:                                          │
│    Population, Resources, Pollution, Quality         │
│                                                      │
│  Positive Links (+):                                 │
│    Population ──(+)──► Pollution                     │
│    Resources ──(+)──► Quality                        │
│                                                      │
│  Negative Links (-):                                 │
│    Pollution ──(-)──► Quality                        │
│    Quality ──(-)──► Population (emigration)          │
│                                                      │
│  Loops:                                              │
│    R1: Population→Births→Population (reinforcing)    │
│    B1: Population→Resources→Quality→Pop (balancing)  │
└─────────────────────────────────────────────────────┘
\stopverb}
}

\subtree{
\title{Loop Classification}
\p{\strong{Reinforcing Loop (R)}: Even number of negative links}

\ul{
\li{Exponential growth or collapse}
\li{"Snowball effect" or "vicious/virtuous cycle"}
}

\p{\strong{Balancing Loop (B)}: Odd number of negative links}

\ul{
\li{Goal-seeking behavior}
\li{Homeostasis, equilibrium}
}

\pre{\startverb
REINFORCING (R):              BALANCING (B):
   A ──(+)──► B                  A ──(+)──► B
   ▲          │                  ▲          │
   │          │                  │          │
   └──(+)─────┘                  └──(-)─────┘
   (exponential)                 (equilibrium)
\stopverb}
}

\subtree{
\title{Double Theory}
\pre{\startverb
// Causal loop double theory with decorated edges
pub fn th_causal_loop() -> DiscreteDblTheory {
    let mut cat = FpCategory::new();

    // Object type
    cat.add_ob_generator(name("Variable"));

    // Morphism types (polarized links)
    cat.add_mor_generator(name("Positive"), name("Variable"), name("Variable"));
    cat.add_mor_generator(name("Negative"), name("Variable"), name("Variable"));

    // Decorations (CatColab 0.2)
    cat.add_mor_generator(name("Delay"), name("Variable"), name("Variable"));
    cat.add_mor_generator(name("Indeterminate"), name("Variable"), name("Variable"));

    cat.into()
}
\stopverb}
}

