\title{CatColab Implementation}
\subtree{
\title{Variable Declaration}
\pre{\startverb
{
  "type": "ObDecl",
  "name": "MarketShare",
  "theory_type": "Variable",
  "description": "company's percentage of total market"
}
\stopverb}
}

\subtree{
\title{Positive Link}
\pre{\startverb
{
  "type": "MorDecl",
  "name": "growth_effect",
  "dom": "MarketShare",
  "cod": "Revenue",
  "theory_type": "Positive",
  "description": "higher market share increases revenue"
}
\stopverb}
}

\subtree{
\title{Negative Link}
\pre{\startverb
{
  "type": "MorDecl",
  "name": "saturation_effect",
  "dom": "MarketShare",
