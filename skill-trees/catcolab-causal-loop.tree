\pre{\startverb
{
  "type": "MorDecl",
  "name": "investment_lag",
  "dom": "RnD_Spending",
  "cod": "ProductQuality",
  "theory_type": "Delay",
  "delay_time": 12,  // months
  "description": "R&D takes time to improve products"
}
\stopverb}
}
}

\subtree{
\title{Lotka-Volterra Semantics}
\p{CatColab generates \strong{Lotka-Volterra ODEs} from causal loops:}

\pre{\startverb
For variables X, Y with positive link X→Y:
  dY/dt = α·X·Y

For negative link X→Y:
  dY/dt = -β·X·Y

General form:
  dXᵢ/dt = Xᵢ · Σⱼ aᵢⱼ·Xⱼ
\stopverb}
}

\subtree{
\title{Practical Examples}
\subtree{
\title{Example 1: Adoption Dynamics}
\pre{\startverb
     Word of Mouth
          ↗ (+)
    Users ────────► Adoption Rate
      ▲                 │
      │                 │
      └────(+)──────────┘
           R1: Viral Growth

    Adoption Rate ──(+)──► Users
         │
         └──(-)──► Potential Users
                       │
              B1: Market Saturation
\stopverb}
}

\subtree{
\title{Example 2: Thermostat (Balancing)}
\pre{\startverb
    Desired Temp ──(+)──► Gap
         ▲                 │
         │                 │
         │                (+)
         │                 ▼
    Actual Temp ◄──(+)── Heating
         │
         └──(-)──► Gap
              B1: Temperature Control
\stopverb}
}

\subtree{
\title{Example 3: Arms Race (Reinforcing)}
\pre{\startverb
    Country A Arms ──(+)──► Country A Threat Perception
           ▲                        │
           │                       (+)
           │                        ▼
    Country B Arms ◄──(+)── Country B Arms Spending
           │
           └──(+)──► Country A Threat Perception
                R1: Escalation Spiral
\stopverb}
}
}

\subtree{
\title{Analysis Capabilities}
\ul{
\li{\strong{Loop identification}: Automatic detection of R and B loops}
\li{\strong{Dominant loop analysis}: Which loops drive behavior}
\li{\strong{Policy leverage points}: Where interventions are most effective}
\li{\strong{Scenario simulation}: Lotka-Volterra dynamics}
}
}

