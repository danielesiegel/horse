\title{Opam}

\taxon{skill}

\meta{description}{OCaml package manager (45 subcommands).}

\subtree{
\title{opam}
\p{OCaml package manager (45 subcommands).}

\subtree{
\title{Install}
\pre{\startverb
opam install dune merlin
opam remove package
opam upgrade
\stopverb}
}

\subtree{
\title{Switch}
\pre{\startverb
opam switch create 5.1.0
opam switch list
opam switch set 5.1.0
\stopverb}
}

\subtree{
\title{Environment}
\pre{\startverb
eval $(opam env)
opam exec -- dune build
\stopverb}
}

\subtree{
\title{Pin}
\pre{\startverb
opam pin add pkg ./local-path
opam pin add pkg git+https://...
opam pin remove pkg
\stopverb}
}

\subtree{
\title{Repository}
\pre{\startverb
opam repo add name url
opam repo list
opam update
\stopverb}
}

\subtree{
\title{Query}
\pre{\startverb
opam list --installed
opam show package
opam search term
\stopverb}
}
}