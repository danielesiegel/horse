\title{Github Workflow Automation}

\taxon{skill}

\tag{}

\meta{version}{1.0.0}

\meta{description}{Advanced GitHub Actions workflow automation with AI swarm coordination, intelligent CI/CD pipelines, and comprehensive repository management}

\subtree{
\title{GitHub Workflow Automation Skill}
\subtree{
\title{Overview}
\p{This skill provides comprehensive GitHub Actions automation with AI swarm coordination. It integrates intelligent CI/CD pipelines, workflow orchestration, and repository management to create self-organizing, adaptive GitHub workflows.}
}

\subtree{
\title{Quick Start}
\p{<details> <summary>💡 Basic Usage - Click to expand</summary>}

\subtree{
\title{Initialize GitHub Workflow Automation}
\pre{\startverb
# Start with a simple workflow
npx ruv-swarm actions generate-workflow \
  --analyze-codebase \
  --detect-languages \
  --create-optimal-pipeline
\stopverb}
}

\subtree{
\title{Common Commands}
\pre{\startverb
# Optimize existing workflow
npx ruv-swarm actions optimize \
  --workflow ".github/workflows/ci.yml" \
  --suggest-parallelization

# Analyze failed runs
gh run view <run-id> --json jobs,conclusion | \
  npx ruv-swarm actions analyze-failure \
    --suggest-fixes
\stopverb}

\p{</details>}
}
}

