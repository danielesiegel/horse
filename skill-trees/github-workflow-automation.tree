\subtree{
\title{Integration Checklist}
\subtree{
\title{✅ Setup Verification}
\p{<details> <summary>Verify Your Setup</summary>}

\ul{
\li{[ ] GitHub CLI (\code{\startverb gh\stopverb}) installed and authenticated}
\li{[ ] Git configured with user credentials}
\li{[ ] Node.js v16+ installed}
\li{[ ] \code{\startverb claude-flow@alpha\stopverb} package available}
\li{[ ] Repository has \code{\startverb .github/workflows\stopverb} directory}
\li{[ ] GitHub Actions enabled on repository}
\li{[ ] Necessary secrets configured}
\li{[ ] Runner permissions verified}
}

\subtree{
\title{Quick Setup Script}
\pre{\startverb
#!/bin/bash
# setup-github-automation.sh

# Install dependencies
npm install -g claude-flow@alpha

# Verify GitHub CLI
gh auth status || gh auth login

# Create workflow directory
mkdir -p .github/workflows

# Generate initial workflow
npx ruv-swarm actions generate-workflow \
  --analyze-codebase \
  --create-optimal-pipeline > .github/workflows/ci.yml

echo "✅ GitHub workflow automation setup complete"
\stopverb}

\p{</details>}
}
}
}

