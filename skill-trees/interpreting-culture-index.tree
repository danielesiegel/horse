\li{\code{\startverb archetype-facilitator.md\stopverb} - The Facilitator (Low A, Mid B, Mid C, Low D)}
\li{\code{\startverb archetype-influencer.md\stopverb} - The Influencer (Low A, High B, Low C, Low D)}
\li{\code{\startverb archetype-operator.md\stopverb} - The Operator (Low A, Low B, High C, Mid-High D)}
\li{\code{\startverb archetype-persuader.md\stopverb} - The Persuader (High A, High B, Low C, Low D)}
\li{\code{\startverb archetype-philosopher.md\stopverb} - The Philosopher (Low A, Low B, High C, Low D)}
\li{\code{\startverb archetype-rainmaker.md\stopverb} - The Rainmaker (High A, High B, Low C, Low D)}
\li{\code{\startverb archetype-scholar.md\stopverb} - The Scholar (High A, Low B, Low C, High D)}
\li{\code{\startverb archetype-socializer.md\stopverb} - The Socializer (Low A, High B, Low C, Low D)}
\li{\code{\startverb archetype-specialist.md\stopverb} - The Specialist (Low A, Low B, High C, Mid D)}
\li{\code{\startverb archetype-technical-expert.md\stopverb} - The Technical Expert (Low A, Low B, High C, Low D)}
\li{\code{\startverb archetype-traditionalist.md\stopverb} - The Traditionalist (Low A, Low B, High C, High D)}
\li{\code{\startverb archetype-trailblazer.md\stopverb} - The Trailblazer (High A, Mid B, Mid C, Low D)}
}

