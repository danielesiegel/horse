\meta{version}{"1.0"}

\meta{description}{Perform authorized initial access using EvilGinx3 adversary-in-the-middle phishing framework to capture session tokens and bypass multi-factor authentication during red team engagements.}

\subtree{
\title{Performing Initial Access with EvilGinx3}
\subtree{
\title{Overview}
\p{EvilGinx3 is a man-in-the-middle attack framework used for phishing login credentials along with session cookies, enabling bypass of multi-factor authentication (MFA). Unlike traditional credential phishing that only captures usernames and passwords, EvilGinx3 operates as a transparent reverse proxy between the victim and the legitimate authentication service, intercepting the full authentication flow including MFA tokens and session cookies. This makes it the primary tool for red teams demonstrating the risk of adversary-in-the-middle (AiTM) attacks against organizations relying solely on MFA for protection.}
}

\subtree{
\title{When to Use}
\ul{
\li{When conducting security assessments that involve performing initial access with evilginx3}
\li{When following incident response procedures for related security events}
\li{When performing scheduled security testing or auditing activities}
\li{When validating security controls through hands-on testing}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Familiarity with red teaming concepts and tools}
\li{Access to a test or lab environment for safe execution}
\li{Python 3.8+ with required dependencies installed}
\li{Appropriate authorization for any testing activities}
}
}

\subtree{
\title{Objectives}
\ul{
\li{Deploy EvilGinx3 with custom phishlets targeting authorized scope}
\li{Configure DNS and SSL certificates for the phishing domain}
\li{Capture session tokens that bypass MFA protections}
\li{Import stolen session cookies into a browser to hijack authenticated sessions}
\li{Integrate with GoPhish or custom delivery mechanisms for phishing email campaigns}
\li{Document the complete attack chain from phishing email to authenticated access}
}
}

