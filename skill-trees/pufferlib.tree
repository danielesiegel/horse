\subtree{
\title{3. Vectorization and Performance}
\p{Achieve maximum throughput with optimized parallel simulation.}

\p{\strong{Vectorization setup:}}

\pre{\startverb
import pufferlib

# Automatic vectorization
env = pufferlib.make('environment_name', num_envs=256, num_workers=8)

# Performance benchmarks:
# - Pure Python envs: 100k-500k SPS
# - C-based envs: 100M+ SPS
# - With training: 400k-4M total SPS
\stopverb}

\p{\strong{Key optimizations:}}

\ul{
\li{Shared memory buffers for zero-copy observation passing}
\li{Busy-wait flags instead of pipes/queues}
\li{Surplus environments for async returns}
\li{Multiple environments per worker}
}

\p{\strong{For vectorization optimization}, read \code{\startverb references/vectorization.md\stopverb} for:}

\ul{
\li{Architecture and performance characteristics}
\li{Worker and batch size configuration}
\li{Serial vs multiprocessing vs async modes}
\li{Shared memory and zero-copy patterns}
\li{Hierarchical vectorization for large scale}
\li{Multi-agent vectorization strategies}
\li{Performance profiling and troubleshooting}
}
}

\subtree{
\title{4. Policy Development}
\p{Build policies as standard PyTorch modules with optional utilities.}

\p{\strong{Basic policy structure:}}

\pre{\startverb
import torch.nn as nn
from pufferlib.pytorch import layer_init

class Policy(nn.Module):
    def __init__(self, observation_space, action_space):
        super().__init__()

        # Encoder
        self.encoder = nn.Sequential(
            layer_init(nn.Linear(obs_dim, 256)),
            nn.ReLU(),
            layer_init(nn.Linear(256, 256)),
            nn.ReLU()
        )

        # Actor and critic heads
        self.actor = layer_init(nn.Linear(256, num_actions), std=0.01)
        self.critic = layer_init(nn.Linear(256, 1), std=1.0)

    def forward(self, observations):
        features = self.encoder(observations)
        return self.actor(features), self.critic(features)
\stopverb}

\p{\strong{For complete policy development}, read \code{\startverb references/policies.md\stopverb} for:}

\ul{
