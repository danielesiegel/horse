\subtree{
\title{5. Environment Integration}
\p{Seamlessly integrate environments from popular RL frameworks.}

\p{\strong{Gymnasium integration:}}

\pre{\startverb
import gymnasium as gym
import pufferlib

# Wrap Gymnasium environment
gym_env = gym.make('CartPole-v1')
env = pufferlib.emulate(gym_env, num_envs=256)

# Or use make directly
env = pufferlib.make('gym-CartPole-v1', num_envs=256)
\stopverb}

\p{\strong{PettingZoo multi-agent:}}

\pre{\startverb
# Multi-agent environment
env = pufferlib.make('pettingzoo-knights-archers-zombies', num_envs=128)
\stopverb}

\p{\strong{Supported frameworks:}}

\ul{
\li{Gymnasium / OpenAI Gym}
\li{PettingZoo (parallel and AEC)}
\li{Atari (ALE)}
\li{Procgen}
\li{NetHack / MiniHack}
\li{Minigrid}
\li{Neural MMO}
\li{Crafter}
\li{GPUDrive}
\li{MicroRTS}
\li{Griddly}
\li{And more...}
}

