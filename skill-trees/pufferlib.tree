\subtree{
\title{2. Environment Development (PufferEnv)}
\p{Create custom high-performance environments with the PufferEnv API.}

\p{\strong{Basic environment structure:}}

\pre{\startverb
import numpy as np
from pufferlib import PufferEnv

class MyEnvironment(PufferEnv):
    def __init__(self, buf=None):
        super().__init__(buf)

        # Define spaces
        self.observation_space = self.make_space((4,))
        self.action_space = self.make_discrete(4)

        self.reset()

    def reset(self):
        # Reset state and return initial observation
        return np.zeros(4, dtype=np.float32)

    def step(self, action):
        # Execute action, compute reward, check done
        obs = self._get_observation()
        reward = self._compute_reward()
        done = self._is_done()
        info = {}

        return obs, reward, done, info
\stopverb}

\p{\strong{Use the template script:} \code{\startverb scripts/env_template.py\stopverb} provides complete single-agent and multi-agent environment templates with examples of:}

\ul{
\li{Different observation space types (vector, image, dict)}
\li{Action space variations (discrete, continuous, multi-discrete)}
\li{Multi-agent environment structure}
\li{Testing utilities}
}

\p{\strong{For complete environment development}, read \code{\startverb references/environments.md\stopverb} for:}

\ul{
\li{PufferEnv API details and in-place operation patterns}
\li{Observation and action space definitions}
