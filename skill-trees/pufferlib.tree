\subtree{
\title{Tips for Success}
\ol{
\li{\strong{Start simple}: Begin with Ocean environments or Gymnasium integration before creating custom environments}
}

\ol{
\li{\strong{Profile early}: Measure steps per second from the start to identify bottlenecks}
}

\ol{
\li{\strong{Use templates}: \code{\startverb scripts/train_template.py\stopverb} and \code{\startverb scripts/env_template.py\stopverb} provide solid starting points}
}

\ol{
\li{\strong{Read references as needed}: Each reference file is self-contained and focused on a specific capability}
}

\ol{
\li{\strong{Optimize progressively}: Start with Python, profile, then optimize critical paths with C if needed}
}

\ol{
\li{\strong{Leverage vectorization}: PufferLib's vectorization is key to achieving high throughput}
}

\ol{
\li{\strong{Monitor training}: Use WandB or Neptune to track experiments and identify issues early}
}

\ol{
\li{\strong{Test environments}: Validate environment logic before scaling up training}
}

\ol{
\li{\strong{Check existing environments}: Ocean suite provides 20+ pre-built environments}
}

\ol{
\li{\strong{Use proper initialization}: Always use \code{\startverb layer_init\stopverb} from \code{\startverb pufferlib.pytorch\stopverb} for policies}
}
}

\subtree{
\title{Common Use Cases}
\subtree{
\title{Training on Standard Benchmarks}
\pre{\startverb
# Atari
env = pufferlib.make('atari-pong', num_envs=256)

# Procgen
env = pufferlib.make('procgen-coinrun', num_envs=256)

# Minigrid
env = pufferlib.make('minigrid-empty-8x8', num_envs=256)
\stopverb}
}

\subtree{
\title{Multi-Agent Learning}
\pre{\startverb
# PettingZoo
env = pufferlib.make('pettingzoo-pistonball', num_envs=128)

# Shared policy for all agents
policy = create_policy(env.observation_space, env.action_space)
trainer = PuffeRL(env=env, policy=policy)
\stopverb}
}

\subtree{
\title{Custom Task Development}
\pre{\startverb
# Create custom environment
class MyTask(PufferEnv):
    # ... implement environment ...

# Vectorize and train
env = pufferlib.emulate(MyTask, num_envs=256)
trainer = PuffeRL(env=env, policy=my_policy)
\stopverb}
}

\subtree{
\title{High-Performance Optimization}
\pre{\startverb
# Maximize throughput
env = pufferlib.make(
    'my-env',
    num_envs=1024,      # Large batch
    num_workers=16,     # Many workers
    envs_per_worker=64  # Optimize per worker
)
\stopverb}
}
}

