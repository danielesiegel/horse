\title{Pufferlib}

\taxon{skill}

\meta{description}{This skill should be used when working with reinforcement learning tasks including high-performance RL training, custom environment development, vectorized parallel simulation, multi-agent systems, or integration with existing RL environments (Gymnasium, PettingZoo, Atari, Procgen, etc.). Use this skill for implementing PPO training, creating PufferEnv environments, optimizing RL performance, or developing policies with CNNs/LSTMs.}

\subtree{
\title{PufferLib - High-Performance Reinforcement Learning}
\subtree{
\title{Overview}
\p{PufferLib is a high-performance reinforcement learning library designed for fast parallel environment simulation and training. It achieves training at millions of steps per second through optimized vectorization, native multi-agent support, and efficient PPO implementation (PuffeRL). The library provides the Ocean suite of 20+ environments and seamless integration with Gymnasium, PettingZoo, and specialized RL frameworks.}
}

\subtree{
\title{When to Use This Skill}
\p{Use this skill when:}

\ul{
\li{\strong{Training RL agents} with PPO on any environment (single or multi-agent)}
\li{\strong{Creating custom environments} using the PufferEnv API}
\li{\strong{Optimizing performance} for parallel environment simulation (vectorization)}
\li{\strong{Integrating existing environments} from Gymnasium, PettingZoo, Atari, Procgen, etc.}
\li{\strong{Developing policies} with CNN, LSTM, or custom architectures}
\li{\strong{Scaling RL} to millions of steps per second for faster experimentation}
\li{\strong{Multi-agent RL} with native multi-agent environment support}
}
}

\subtree{
\title{Core Capabilities}
\subtree{
\title{1. High-Performance Training (PuffeRL)}
\p{PuffeRL is PufferLib's optimized PPO+LSTM training algorithm achieving 1M-4M steps/second.}

\p{\strong{Quick start training:}}

\pre{\startverb
# CLI training
puffer train procgen-coinrun --train.device cuda --train.learning-rate 3e-4

# Distributed training
torchrun --nproc_per_node=4 train.py
\stopverb}

\p{\strong{Python training loop:}}

\pre{\startverb
import pufferlib
from pufferlib import PuffeRL

# Create vectorized environment
env = pufferlib.make('procgen-coinrun', num_envs=256)

# Create trainer
trainer = PuffeRL(
    env=env,
    policy=my_policy,
    device='cuda',
    learning_rate=3e-4,
    batch_size=32768
)

# Training loop
for iteration in range(num_iterations):
    trainer.evaluate()  # Collect rollouts
    trainer.train()     # Train on batch
    trainer.mean_and_log()  # Log results
\stopverb}

\p{\strong{For comprehensive training guidance}, read \code{\startverb references/training.md\stopverb} for:}

\ul{
\li{Complete training workflow and CLI options}
