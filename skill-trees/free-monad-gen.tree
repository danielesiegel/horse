\title{Free Monad Gen}

\taxon{skill}

\meta{description}{Free Monad Generation Skill (PLUS +1)}

\subtree{
\title{Free Monad Generation Skill (PLUS +1)}
\blockquote{Free structure generation from signatures}

\p{\strong{Trit}: +1 (PLUS) \strong{Color}: #D82626 (Red) \strong{Role}: Generator/Creator}

\subtree{
\title{Core Concept}
\p{Free monads generate structure from a functor signature:}

\pre{\startverb
data Free f a 
  = Pure a                    -- Leaf (return)
  | Roll (f (Free f a))       -- Node (bind)
\stopverb}

\p{\strong{Universal property}: \code{\startverb Free f\stopverb} is left adjoint to forgetful functor U.}
}

\subtree{
\title{Dual: Cofree Comonad}
\pre{\startverb
data Cofree f a = a :< f (Cofree f a)
-- Head (extract) and infinite tail (duplicate)
\stopverb}

\pre{\startverb
| Free | Cofree |
|------|--------|
| Producer (effects) | Consumer (contexts) |
| Programs | Interpreters |
| Syntax | Semantics |
\stopverb}
}

\subtree{
\title{Pattern Runs on Matter}
\pre{\startverb
Pattern (Free) ────runs-on────→ Matter (Cofree)
   ↓                                ↑
 Program                         Environment
   ↓                                ↑
 Effects                         Handlers
\stopverb}
}

\subtree{
\title{Integration with Gay.jl}
\pre{\startverb
# Free monad for color stream generation
struct ColorFree{A}
    tag::Symbol  # :pure or :roll
    value::Union{A, Tuple{UInt64, ColorFree{A}}}
end

# Generate free color structure
function free_color_stream(seed::UInt64, n::Int)
    if n == 0
        ColorFree(:pure, seed)
    else
        next_seed = splitmix64(seed)
        ColorFree(:roll, (seed, free_color_stream(next_seed, n-1)))
    end
end

# Interpret to actual colors
function interpret(free::ColorFree, palette)
    if free.tag == :pure
        return []
    else
        (seed, rest) = free.value
        color = gay_color(seed)
        [color; interpret(rest, palette)]
    end
end
\stopverb}
}

\subtree{
\title{Freer Monad (More Efficient)}
\pre{\startverb
data Freer f a where
  Pure :: a -> Freer f a
  Impure :: f x -> (x -> Freer f a) -> Freer f a
\stopverb}

\p{Benefits:}

\ul{
\li{O(1) bind (vs O(n) for Free)}
\li{Existential continuation}
\li{Better for effect systems}
}
}

\subtree{
\title{DSL Generation Pattern}
\pre{\startverb
-- 1. Define signature functor
data MusicF next
  = Note Pitch Duration next
  | Rest Duration next
  | Chord [Pitch] Duration next
  | Par (Free MusicF ()) (Free MusicF ()) next

-- 2. Free monad gives DSL
type Music = Free MusicF

-- 3. Smart constructors
note :: Pitch -> Duration -> Music ()
note p d = liftF (Note p d ())

-- 4. Programs are data
melody = do
  note C4 quarter
  note E4 quarter
  note G4 half
\stopverb}
}

