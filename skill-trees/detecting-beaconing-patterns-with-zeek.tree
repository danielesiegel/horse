\title{Detecting Beaconing Patterns With Zeek}

\taxon{skill}

\tag{detecting}

\tag{beaconing}

\tag{patterns}

\tag{with}

\meta{version}{"1.0"}

\meta{description}{Performs statistical analysis of Zeek conn.log connection intervals to detect C2 beaconing patterns. Uses the ZAT library to load Zeek logs into Pandas DataFrames, calculates inter-arrival time standard deviation, and flags periodic connections with low jitter. Use when hunting for command-and-control callbacks in network data.}

