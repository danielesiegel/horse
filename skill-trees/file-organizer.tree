\subtree{
\title{Pro Tips}
\ol{
\li{\strong{Start Small}: Begin with one messy folder (like Downloads) to build trust}
\li{\strong{Regular Maintenance}: Run weekly cleanup on Downloads}
\li{\strong{Consistent Naming}: Use "YYYY-MM-DD - Description" format for important files}
\li{\strong{Archive Aggressively}: Move old projects to Archive instead of deleting}
\li{\strong{Keep Active Separate}: Maintain clear boundaries between active and archived work}
\li{\strong{Trust the Process}: Let Claude handle the cognitive load of where things go}
}
}

\subtree{
\title{Best Practices}
\subtree{
\title{Folder Naming}
\ul{
\li{Use clear, descriptive names}
\li{Avoid spaces (use hyphens or underscores)}
\li{Be specific: "client-proposals" not "docs"}
\li{Use prefixes for ordering: "01-current", "02-archive"}
}
}

\subtree{
\title{File Naming}
\ul{
\li{Include dates: "2024-10-17-meeting-notes.md"}
\li{Be descriptive: "q3-financial-report.xlsx"}
\li{Avoid version numbers in names (use version control instead)}
\li{Remove download artifacts: "document-final-v2 (1).pdf" → "document.pdf"}
}
}

\subtree{
\title{When to Archive}
\ul{
\li{Projects not touched in 6+ months}
\li{Completed work that might be referenced later}
\li{Old versions after migration to new systems}
\li{Files you're hesitant to delete (archive first)}
}
}
}

