\subtree{
\title{Common Tasks}
\subtree{
\title{1. Efficient Sorting}
\pre{\startverb
const std = @import("std");

pub fn sort_i32(allocator: std.mem.Allocator, items: []i32) !void {
    var list = std.ArrayList(i32).init(allocator);
    defer list.deinit();

    try list.appendSlice(items);
    std.sort.sort(i32, list.items, {}, std.sort.asc(i32));
}
\stopverb}
}

\subtree{
\title{2. Hash Table Operations}
\pre{\startverb
const std = @import("std");

pub fn main() !void {
    var gpa = std.heap.GeneralPurposeAllocator(.{}){};
    defer _ = gpa.deinit();
    const allocator = gpa.allocator();

    var map = std.StringHashMap(i32).init(allocator);
    defer map.deinit();

    try map.put("foo", 42);
    if (map.get("foo")) |value| {
        std.debug.print("Found: {}\n", .{value});
    }
}
\stopverb}
}

\subtree{
\title{3. Compression Algorithm}
\pre{\startverb
pub fn compress(allocator: std.mem.Allocator, data: []const u8) ![]u8 {
    // Implement compression (e.g., DEFLATE, LZ4)
    var output = std.ArrayList(u8).init(allocator);
    defer output.deinit();

    // Compression logic here

    return output.toOwnedSlice();
}
\stopverb}
}

\subtree{
\title{4. Performance Benchmarking}
\pre{\startverb
const std = @import("std");

pub fn benchmark(comptime name: []const u8, func: fn() void) void {
    var timer = try std.time.Timer.start();
    defer {
        const elapsed = timer.read();
        std.debug.print("{s}: {d}ns\n", .{name, elapsed});
    }

    func();
}
\stopverb}
}
}

\subtree{
\title{Performance Characteristics}
\subtree{
\title{Compilation Speed}
\ul{
\li{\strong{Incremental}: ~100ms for small modules}
\li{\strong{Full rebuild}: ~500ms - 2s}
\li{\strong{Release build}: ~1-5s with optimizations}
}
}

\subtree{
\title{Runtime Performance}
\ul{
\li{\strong{Memory usage}: Minimal (no GC overhead)}
\li{\strong{Binary size}: 1-10MB depending on features}
\li{\strong{Startup time}: <1ms for most programs}
\li{\strong{CPU efficiency}: Near-C performance}
}
}

\subtree{
\title{Comparison}
\pre{\startverb
| Operation | Zig | Go | Java |
|-----------|-----|----|----|
| Array sort (10K items) | ~1ms | ~2ms | ~5ms |
| Hash table insert | ~50ns | ~100ns | ~200ns |
| Memory allocation | ~50ns | ~100ns | ~500ns |
| Binary size (hello) | 2KB | 1MB | 50MB |
\stopverb}
}
}

\subtree{
\title{Building Zig Projects}
\subtree{
\title{Simple build.zig}
\pre{\startverb
const std = @import("std");
const Builder = std.build.Builder;

pub fn build(b: *Builder) void {
    const target = b.standardTargetOptions(.{});
    const optimize = b.standardOptimizeOption(.{});

    const exe = b.addExecutable(.{
        .name = "my_skill",
        .root_source_file = .{ .path = "main.zig" },
        .target = target,
        .optimize = optimize,
    });

    b.installArtifact(exe);

    const run_cmd = b.addRunArtifact(exe);
    const run_step = b.step("run", "Run the app");
    run_step.dependOn(&run_cmd.step);
}
\stopverb}
}

\subtree{
\title{Build Commands}
\pre{\startverb
# Build debug binary
zig build

# Build with optimizations
zig build -Doptimize=ReleaseFast

# Install to prefix
zig build --prefix /usr/local install

# Run tests
zig build test
\stopverb}
}
}

\subtree{
\title{Integration with Other Skills}
\subtree{
\title{Calling from Clojure}
\pre{\startverb
(defn call-zig-sort [data]
  "Invoke Zig sort via FFI."
  (shell/sh "zig-systems" "sort" (write-json data)))
\stopverb}
}

\subtree{
\title{Calling from Go}
\pre{\startverb
import "C"

//export SkillInvoke
func SkillInvoke(data *C.char) *C.char {
    // Call Zig compiled library
    result := C.zig_compress(data)
    return result
}
\stopverb}
}

\subtree{
\title{Calling from Hy}
\pre{\startverb
(import subprocess)
(setv result (subprocess.run ["zig-systems" "compress" "input.dat"]
                            :capture-output True))
\stopverb}
}
}

\subtree{
\title{When to Use}
\ul{
\li{\strong{Performance-critical code}: Sorting, compression, hashing}
\li{\strong{System-level operations}: File I/O, memory management, POSIX APIs}
\li{\strong{Cross-platform binaries}: Compile once, run anywhere (Linux, macOS, Windows)}
\li{\strong{FFI requirements}: Need to call from other languages}
\li{\strong{Memory-constrained systems}: Embedded, IoT, serverless}
\li{\strong{Real-time systems}: Predictable performance, no GC pauses}
}
}

\subtree{
\title{When NOT to Use}
\ul{
\li{High-level business logic (use Clojure)}
\li{Quick prototyping (Hy/Python faster iteration)}
\li{Dynamic typing requirements (Zig is statically typed)}
\li{GC convenience preferred over control}
}
}

