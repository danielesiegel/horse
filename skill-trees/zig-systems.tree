\subtree{
\title{Performance Optimization Tips}
\ol{
\li{\strong{Use ReleaseFast or ReleaseSmall} optimization levels}
\li{\strong{Minimize allocations}: Preallocate where possible}
\li{\strong{Use inline functions}: \code{\startverb inline\stopverb} keyword for hot paths}
\li{\strong{Leverage comptime}: Compute at compile time, not runtime}
\li{\strong{Profile with perf}: \code{\startverb perf record ./binary\stopverb} then \code{\startverb perf report\stopverb}}
\li{\strong{Consider SIMD}: \code{\startverb @Vector\stopverb} type for parallel operations}
}
}

