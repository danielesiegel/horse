\subtree{
\title{Troubleshooting}
\p{\strong{"zig: command not found"}}

\ul{
\li{Install Zig: \code{\startverb brew install zig\stopverb}}
\li{Verify: \code{\startverb zig version\stopverb}}
\li{Update PATH if needed}
}

\p{\strong{Build errors with C libraries}}

\ul{
\li{Use \code{\startverb zig build-exe main.zig -lc\stopverb} to link libc}
\li{Declare C imports explicitly: \code{\startverb extern "c" fn malloc(...)\stopverb}}
}

\p{\strong{Memory leaks in debug mode}}

\ul{
\li{Use GeneralPurposeAllocator for testing}
\li{Enable leak detection: \code{\startverb std.heap.GeneralPurposeAllocator(.{.safety = true})\stopverb}}
}

\p{\strong{Binary too large}}

\ul{
\li{Use ReleaseSmall optimization: \code{\startverb -O ReleaseSmall\stopverb}}
\li{Strip debug symbols: \code{\startverb strip ./binary\stopverb}}
}
}
}