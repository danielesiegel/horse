\title{Ihara Zeta}

\taxon{skill}

\meta{description}{"Ihara zeta function for graphs: non-backtracking walks, prime cycles, and spectral analysis via det(I - uB)."}

\subtree{
\title{Ihara Zeta Function Skill}
\blockquote{*"The Ihara zeta function encodes all non-backtracking closed walks - the 'prime cycles' of a graph."*}

\subtree{
\title{Overview}
\p{The Ihara zeta function generalizes the Riemann zeta function to graphs:}

\ol{
\li{\strong{Prime cycles} - Non-backtracking closed walks (graph analog of primes)}
\li{\strong{Determinant formula} - ζ_G(u)^{-1} = det(I - uB) relation}
\li{\strong{Ramanujan connection} - Riemann Hypothesis analog for graphs}
\li{\strong{Non-backtracking matrix} - Central object for spectral clustering}
}
}

\subtree{
\title{Definition}
\subtree{
\title{Ihara Zeta Function}
\p{For a graph G, the \strong{Ihara zeta function} is:}

\pre{\startverb
ζ_G(u) = ∏_{[C]} (1 - u^{|C|})^{-1}
\stopverb}

\p{where:}

\ul{
\li{Product is over equivalence classes [C] of \strong{primitive} closed non-backtracking walks}
\li{|C| is the length of the cycle}
\li{Primitive = not a power of a shorter cycle}
}
}

\subtree{
\title{Non-Backtracking Walk}
\p{A walk \code{\startverb v₀ → v₁ → v₂ → ... → vₖ\stopverb} is \strong{non-backtracking} if:}

\pre{\startverb
vᵢ₊₁ ≠ vᵢ₋₁  for all i
\stopverb}

\p{(Never immediately return to the previous vertex)}
}
}

\subtree{
\title{The Determinant Formula}
\subtree{
\title{Bass-Hashimoto Formula}
\pre{\startverb
ζ_G(u)^{-1} = (1 - u²)^{|E| - |V|} · det(I - uB)
\stopverb}

\p{where \strong{B} is the non-backtracking matrix.}
}

\subtree{
\title{Non-Backtracking Matrix}
\p{Indexed by \strong{directed edges} (e, f) where head(e) = tail(f) and e ≠ f⁻¹:}

\pre{\startverb
function non_backtracking_matrix(G)
    # Directed edges: 2|E| entries
    directed_edges = [(u,v) for (u,v) in edges(G) 
                      for dir in [(u,v), (v,u)]]
    
    m = length(directed_edges)
    B = zeros(m, m)
    
    for (i, e) in enumerate(directed_edges)
        for (j, f) in enumerate(directed_edges)
            # e = (a→b), f = (c→d)
            # Connect if b = c AND a ≠ d (non-backtracking)
            if e[2] == f[1] && e[1] != f[2]
                B[i, j] = 1
            end
        end
    end
    
    return B
end
\stopverb}
}
}

\subtree{
\title{Prime Cycles and Möbius}
\subtree{
\title{Connection to Number Theory}
\pre{\startverb
| Number Theory | Graph Theory |
|---------------|--------------|
| Prime number p | Prime cycle C |
| log p | Length |C| |
| Riemann zeta ζ(s) | Ihara zeta ζ_G(u) |
| Prime Number Theorem | Cycle counting asymptotics |
| Riemann Hypothesis | Ramanujan property |
\stopverb}
}

\subtree{
\title{Möbius Function on Paths}
\p{A path of length n is \strong{prime} (non-backtracking) iff μ(n) ≠ 0:}

\pre{\startverb
function is_prime_path(path)
    """
    Check if path is non-backtracking (prime).
    Equivalent to μ(length) ≠ 0 in our encoding.
    """
    for i in 2:length(path)-1
        if path[i-1] == path[i+1]
            return false  # Backtracking detected
        end
    end
    return true
end

function moebius_filter(paths)
    """
    Filter to prime (non-backtracking) paths using Möbius.
    μ(n) ≠ 0 ⟺ n is squarefree ⟺ no repeated factors ⟺ no backtracking.
    """
    return filter(is_prime_path, paths)
end
\stopverb}
}
}

\subtree{
\title{Ramanujan and Riemann Hypothesis}
\subtree{
\title{Graph Riemann Hypothesis}
\p{A d-regular graph G satisfies the \strong{Graph Riemann Hypothesis} if all poles of ζ_G(u) in |u| < 1/√(d-1) lie on the circle |u| = 1/√(d-1).}

\p{\strong{Theorem}: G is Ramanujan ⟺ G satisfies the Graph Riemann Hypothesis.}
}

\subtree{
\title{Verification}
\pre{\startverb
function check_graph_riemann_hypothesis(G)
    d = degree(G)
    B = non_backtracking_matrix(G)
    
    # Eigenvalues of B
    eigenvalues = eigvals(B)
    
    # Poles of zeta at 1/λ for each eigenvalue λ
    poles = 1 ./ eigenvalues
    
    # Check: all poles with |u| < 1/√(d-1) lie on |u| = 1/√(d-1)
    critical_radius = 1 / √(d - 1)
    
    for pole in poles
        r = abs(pole)
        if r < critical_radius && abs(r - critical_radius) > 0.001
            return false  # Pole inside critical circle but not on it
        end
    end
    
    return true
end
\stopverb}
}
}

\subtree{
\title{Spectral Clustering via Non-Backtracking}
\subtree{
\title{The Spectral Redemption Theorem}
\p{\strong{Bordenave-Lelarge-Massoulié (2015)}:}

\blockquote{Non-backtracking spectral clustering succeeds down to the information-theoretic threshold, where adjacency-based methods fail.}

\pre{\startverb
function non_backtracking_clustering(G, k)
    """
    Cluster graph into k communities using non-backtracking eigenvectors.
    
    Succeeds where spectral clustering on adjacency matrix fails
    (the 'spectral redemption' phenomenon).
    """
    B = non_backtracking_matrix(G)
    
    # Get top k+1 eigenvectors (skip trivial)
    λ, V = eigen(B)
    idx = sortperm(abs.(λ), rev=true)
    
    # Project directed edge eigenvectors to vertices
    vertex_embeddings = project_to_vertices(G, V[:, idx[2:k+1]])
    
    # Cluster in embedding space
    return kmeans(vertex_embeddings, k)
end
\stopverb}
}
}

\subtree{
\title{Zeta Function Computation}
\subtree{
\title{Direct Computation}
\pre{\startverb
function ihara_zeta_coefficient(G, n)
    """
    Coefficient of u^n in log ζ_G(u).
    
    = (1/n) × (number of primitive closed non-backtracking walks of length n)
    """
    B = non_backtracking_matrix(G)
    
    # tr(B^n) counts all closed non-backtracking walks of length n
    # Möbius inversion extracts primitive ones
    total = tr(B^n)
    
    # Subtract non-primitive (powers of shorter cycles)
    primitive_count = 0
    for d in divisors(n)
        if d < n
            primitive_count += moebius(n ÷ d) * ihara_zeta_coefficient(G, d) * d
        end
    end
    
    return (total - primitive_count) / n
end
\stopverb}
}

\subtree{
\title{Via Determinant}
\pre{\startverb
function ihara_zeta_inverse(G, u)
    """
    Compute ζ_G(u)^{-1} using Bass-Hashimoto formula.
    """
    B = non_backtracking_matrix(G)
    n_vertices = nv(G)
    n_edges = ne(G)
    
    # ζ_G(u)^{-1} = (1 - u²)^{|E| - |V|} × det(I - uB)
    return (1 - u^2)^(n_edges - n_vertices) * det(I - u * B)
end
\stopverb}
}
}

