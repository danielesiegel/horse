\title{Catp}

\taxon{skill}

\meta{trit}{1}

\meta{description}{Category-theoretic pipes with GF(3) flow balance checking. Validates}

\subtree{
\title{catp: Categorical Pipes}
\p{\strong{Trit}: +1 (PLUS) \strong{Principle}: Balanced data flows through morphism chains \strong{Algebra}: GF(3) flow conservation}

\subtree{
\title{Why GF(3)?}
\p{Three-phase data flow:}

\ul{
\li{\strong{Source} (-1): Read/Fetch ingestion}
\li{\strong{Transform} (0): Shape-preserving operations  }
\li{\strong{Sink} (+1): Write/Output operations}
}

\p{Sum must = 0 (mod 3) for balanced pipeline.}
}

\subtree{
\title{Operations by Trit}
\pre{\startverb
| Trit | Category | Operations |
|------|----------|-----------|
| -1 | MINUS (Sources) | slurp, read, fetch, query, search, list |
| 0 | ERGODIC (Transforms) | map, filter, select, rename, mutate, reduce, join, group-by |
| +1 | PLUS (Sinks) | println, print, write, save, spit, create, send |
\stopverb}
}

\subtree{
\title{Usage}
\pre{\startverb
# Check balance of a pipe
bb catp.bb --check '(->> [1 2 3] (map inc) (filter odd?) (reduce +))'

# Output:
# Operations: map %>% filter %>% reduce
# Trits: {"map" 0, "filter" 0, "reduce" 0}
# Sum: 0 (mod 3 = 0)
# GF(3) Balanced: ✓
\stopverb}
}

\subtree{
\title{Example: Unbalanced Pipeline}
\pre{\startverb
;; WRONG: Two transforms, one sink (missing source)
(->> (map inc)           ; 0
     (filter odd?)       ; 0
     (reduce +))         ; 0
     
; Sum: 0 ✓ (looks balanced but logically missing source!)
\stopverb}
}

\subtree{
\title{Example: Properly Balanced}
\pre{\startverb
;; CORRECT: Source → Transform → Sink
(->> [1 2 3]             ; implicit source (-1)
     (map inc)           ; transform (0)
     (filter odd?)       ; transform (0)
     (println))          ; sink (+1)

; GF(3): -1 + 0 + 0 + 1 = 0 ✓
\stopverb}
}

