\meta{version}{"1.0"}

\meta{description}{Configure AIDE (Advanced Intrusion Detection Environment) for file integrity monitoring including baseline creation, scheduled integrity checks, change detection, and alerting}

\subtree{
\title{Implementing File Integrity Monitoring with AIDE}
\subtree{
\title{Overview}
\p{AIDE (Advanced Intrusion Detection Environment) is a host-based intrusion detection system that monitors file and directory integrity using cryptographic checksums. This skill covers generating AIDE configuration files, initializing baseline databases, running integrity checks, parsing change reports, and setting up automated cron-based monitoring with alerting.}
}

\subtree{
\title{When to Use}
\ul{
\li{When deploying or configuring implementing file integrity monitoring with aide capabilities in your environment}
\li{When establishing security controls aligned to compliance requirements}
\li{When building or improving security architecture for this domain}
\li{When conducting security assessments that require this implementation}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{AIDE installed on target Linux system (apt install aide / yum install aide)}
\li{Root or sudo access for file system scanning}
\li{Python 3.8+ with standard library}
}
}

\subtree{
\title{Steps}
\ol{
\li{\strong{Generate AIDE Configuration} — Create aide.conf with monitoring rules for critical directories (/etc, /bin, /sbin, /usr/bin, /boot)}
\li{\strong{Initialize Baseline Database} — Run aide --init to create the initial file integrity baseline}
\li{\strong{Run Integrity Check} — Execute aide --check to compare current state against baseline}
\li{\strong{Parse Change Report} — Extract added, removed, and changed files from AIDE output}
\li{\strong{Configure Automated Monitoring} — Generate cron job for scheduled integrity checks}
\li{\strong{Generate Compliance Report} — Produce structured report of all file changes with severity classification}
}
}

\subtree{
\title{Expected Output}
\ul{
\li{AIDE configuration file (aide.conf)}
\li{Baseline database creation status}
\li{JSON report of file changes (added/removed/changed) with severity}
\li{Cron job configuration for automated monitoring}
}
}
}