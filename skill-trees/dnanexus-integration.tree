\subtree{
\title{Quick Start Examples}
\subtree{
\title{Upload and Analyze Data}
\pre{\startverb
import dxpy

# Upload input file
input_file = dxpy.upload_local_file("sample.fastq", project="project-xxxx")

# Run analysis
job = dxpy.DXApplet("applet-xxxx").run({
    "reads": dxpy.dxlink(input_file.get_id())
})

# Wait for completion
job.wait_on_done()

# Download results
output_id = job.describe()["output"]["aligned_reads"]["$dnanexus_link"]
dxpy.download_dxfile(output_id, "aligned.bam")
\stopverb}
}

\subtree{
\title{Search and Download Files}
\pre{\startverb
import dxpy

# Find BAM files from a specific experiment
files = dxpy.find_data_objects(
    classname="file",
    name="*.bam",
    properties={"experiment": "exp001"},
    project="project-xxxx"
)

# Download each file
for file_result in files:
    file_obj = dxpy.DXFile(file_result["id"])
    filename = file_obj.describe()["name"]
    dxpy.download_dxfile(file_result["id"], filename)
\stopverb}
}

\subtree{
\title{Create Simple App}
\pre{\startverb
# src/my-app.py
import dxpy
import subprocess

@dxpy.entry_point('main')
def main(input_file, quality_threshold=30):
    # Download input
    dxpy.download_dxfile(input_file["$dnanexus_link"], "input.fastq")

    # Process
    subprocess.check_call([
        "quality_filter",
        "--input", "input.fastq",
        "--output", "filtered.fastq",
        "--threshold", str(quality_threshold)
    ])

    # Upload output
    output_file = dxpy.upload_local_file("filtered.fastq")

    return {
        "filtered_reads": dxpy.dxlink(output_file)
    }

dxpy.run()
\stopverb}
}
}

\subtree{
\title{Workflow Decision Tree}
\p{When working with DNAnexus, follow this decision tree:}

\ol{
\li{\strong{Need to create a new executable?}}
\li{Yes → Use \strong{App Development} (references/app-development.md)}
\li{No → Continue to step 2}
}

\ol{
\li{\strong{Need to manage files or data?}}
\li{Yes → Use \strong{Data Operations} (references/data-operations.md)}
\li{No → Continue to step 3}
}

\ol{
\li{\strong{Need to run an analysis or workflow?}}
\li{Yes → Use \strong{Job Execution} (references/job-execution.md)}
\li{No → Continue to step 4}
}

\ol{
\li{\strong{Writing Python scripts for automation?}}
\li{Yes → Use \strong{Python SDK} (references/python-sdk.md)}
\li{No → Continue to step 5}
}

\ol{
\li{\strong{Configuring app settings or dependencies?}}
\li{Yes → Use \strong{Configuration} (references/configuration.md)}
}

\p{Often you'll need multiple capabilities together (e.g., app development + configuration, or data operations + job execution).}
}

\subtree{
\title{Installation and Authentication}
\subtree{
\title{Install dxpy}
\pre{\startverb
uv pip install dxpy
\stopverb}
}

\subtree{
\title{Login to DNAnexus}
\pre{\startverb
dx login
\stopverb}

\p{This authenticates your session and sets up access to projects and data.}
}

\subtree{
\title{Verify Installation}
\pre{\startverb
dx --version
dx whoami
\stopverb}
}
}

\subtree{
\title{Common Patterns}
\subtree{
\title{Pattern 1: Batch Processing}
\p{Process multiple files with the same analysis:}

\pre{\startverb
# Find all FASTQ files
files = dxpy.find_data_objects(
    classname="file",
    name="*.fastq",
    project="project-xxxx"
)

# Launch parallel jobs
jobs = []
for file_result in files:
    job = dxpy.DXApplet("applet-xxxx").run({
        "input": dxpy.dxlink(file_result["id"])
    })
    jobs.append(job)

# Wait for all completions
for job in jobs:
    job.wait_on_done()
\stopverb}
}

\subtree{
\title{Pattern 2: Multi-Step Pipeline}
\p{Chain multiple analyses together:}

\pre{\startverb
# Step 1: Quality control
qc_job = qc_applet.run({"reads": input_file})

# Step 2: Alignment (uses QC output)
align_job = align_applet.run({
    "reads": qc_job.get_output_ref("filtered_reads")
})

# Step 3: Variant calling (uses alignment output)
variant_job = variant_applet.run({
    "bam": align_job.get_output_ref("aligned_bam")
})
\stopverb}
}

\subtree{
\title{Pattern 3: Data Organization}
\p{Organize analysis results systematically:}

\pre{\startverb
# Create organized folder structure
dxpy.api.project_new_folder(
    "project-xxxx",
    {"folder": "/experiments/exp001/results", "parents": True}
)

# Upload with metadata
result_file = dxpy.upload_local_file(
    "results.txt",
    project="project-xxxx",
    folder="/experiments/exp001/results",
    properties={
        "experiment": "exp001",
        "sample": "sample1",
        "analysis_date": "2025-10-20"
    },
    tags=["validated", "published"]
)
\stopverb}
}
}

\subtree{
\title{Best Practices}
\ol{
\li{\strong{Error Handling}: Always wrap API calls in try-except blocks}
\li{\strong{Resource Management}: Choose appropriate instance types for workloads}
\li{\strong{Data Organization}: Use consistent folder structures and metadata}
\li{\strong{Cost Optimization}: Archive old data, use appropriate storage classes}
\li{\strong{Documentation}: Include clear descriptions in dxapp.json}
\li{\strong{Testing}: Test apps with various input types before production use}
\li{\strong{Version Control}: Use semantic versioning for apps}
\li{\strong{Security}: Never hardcode credentials in source code}
\li{\strong{Logging}: Include informative log messages for debugging}
\li{\strong{Cleanup}: Remove temporary files and failed jobs}
}
}

