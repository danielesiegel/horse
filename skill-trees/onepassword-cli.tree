\title{Onepassword Cli}

\taxon{skill}

\tag{secrets}

\tag{1password}

\tag{credentials}

\tag{security}

\tag{auth}

\meta{version}{1.0.0}

\meta{trit}{0}

\meta{description}{1Password CLI (op) for secure secret management, credential injection, and shell plugin auth. Use when users need secrets, API keys, env vars, or authenticating third-party CLIs.}

\subtree{
\title{1Password CLI Skill}
\p{Manage secrets via \code{\startverb op\stopverb} CLI integrated with the 1Password desktop app.}

\subtree{
\title{Prerequisites}
\ul{
\li{\code{\startverb op\stopverb} installed via \code{\startverb flox install _1password-cli\stopverb}}
\li{1Password desktop app with \strong{Settings → Developer → Integrate with 1Password CLI} enabled}
\li{\startverb Authenticated session: `eval $(op signin)`\stopverb}
}
}

\subtree{
\title{Session Management}
\p{\strong{CRITICAL}: Always initialize the session before any \code{\startverb op\stopverb} command:}

\pre{\startverb
eval $(op signin)
\stopverb}

\p{Without this, \code{\startverb op\stopverb} commands fail with "account is not signed in". The \code{\startverb eval\stopverb} sets the \code{\startverb OP_SESSION_*\stopverb} env var in the current shell.}

\p{Verify with:}

\pre{\startverb
op whoami
\stopverb}
}

\subtree{
\title{Core Commands}
\pre{\startverb
| Command | Purpose |
|---------|---------|
| `op vault list` | List all vaults |
| `op item list` | List all items across vaults |
| `op item get "Name"` | Get full item details |
| `op item get "Name" --field password --reveal` | Get specific field value |
| `op read op://Vault/Item/Field` | Secret reference (scriptable) |
| `op document get "Name"` | Download stored documents |
| `op inject -i template -o output` | Fill templates with secrets |
| `op run --env-file .env -- cmd` | Inject secrets as env vars |
\stopverb}
}

\subtree{
\title{Secret References}
\p{The \code{\startverb op://\stopverb} URI scheme for embedding secrets in configs and scripts:}

\pre{\startverb
# Read a single secret
op read "op://VaultName/ItemName/field"

# Export to env var
export API_KEY=$(op read "op://VaultName/ItemName/credential")

# Use in one-liners
op run --env-file .env -- docker compose up
\stopverb}

\subtree{
\title{Template Injection}
\p{Create a template file with \code{\startverb op://\stopverb} references:}

\pre{\startverb
# config.template.yml
api_key: op://VaultName/APIService/credential
db_password: op://VaultName/Database/password
\stopverb}

\p{Then inject:}

\pre{\startverb
op inject -i config.template.yml -o config.yml
\stopverb}
}
}

\subtree{
\title{Shell Plugins}
\p{Authenticate third-party CLIs through 1Password instead of plaintext tokens:}

\pre{\startverb
# Initialize a plugin (e.g., GitHub CLI)
op plugin init gh

# After setup, gh authenticates via 1Password automatically
gh repo list
\stopverb}

\p{Available plugins include: \code{\startverb gh\stopverb}, \code{\startverb aws\stopverb}, \code{\startverb openai\stopverb}, \code{\startverb mysql\stopverb}, \code{\startverb psql\stopverb}, \code{\startverb vercel\stopverb}, \code{\startverb stripe\stopverb}, \code{\startverb flyctl\stopverb}, \code{\startverb heroku\stopverb}, \code{\startverb brew\stopverb}, \code{\startverb cargo\stopverb}, \code{\startverb snyk\stopverb}, \code{\startverb docker\stopverb}, and 60+ more.}

\p{List all: \code{\startverb op plugin list\stopverb}}
}

\subtree{
\title{Item CRUD}
\pre{\startverb
# Create a new item
op item create --category=login \
  --title="My Service" \
  --vault="Shared" \
  --field username=admin \
  --field password=secret123

# Edit an item
op item edit "My Service" --field password=newpass

# Delete an item
op item delete "My Service"

# Search items
op item list --tags="production" --vault="VaultName"
\stopverb}
}

\subtree{
\title{Workflow Patterns}
\subtree{
\title{Inject Secrets into a Process}
\pre{\startverb
# .env.template
DB_HOST=op://VaultName/Database/host
DB_PASS=op://VaultName/Database/password

# Run with secrets injected (never touch disk)
op run --env-file .env.template -- ./start-server.sh
\stopverb}
}

\subtree{
\title{CI/CD with Service Accounts}
\pre{\startverb
# Create service account token (one-time)
op service-account create "CI Bot" --vault VaultName

# In CI, use OP_SERVICE_ACCOUNT_TOKEN env var
export OP_SERVICE_ACCOUNT_TOKEN="..."
op read "op://VaultName/Deploy Key/credential"
\stopverb}
}

\subtree{
\title{Rotate Credentials}
\pre{\startverb
op item edit "API Key" --field credential=$(openssl rand -hex 32)
\stopverb}
}
}

\subtree{
\title{Account Info}
\p{Verify your current setup:}

\pre{\startverb
op whoami
op vault list
\stopverb}
}

\subtree{
\title{Error Handling}
\pre{\startverb
| Error | Fix |
|-------|-----|
| "account is not signed in" | Run `eval $(op signin)` |
| "no item found" | Check vault name and item title spelling |
| "You do not have permission" | Verify vault access in 1Password app |
| Session expires | Re-run `eval $(op signin)` |
\stopverb}
}

\subtree{
\title{JSON Output}
\p{Add \code{\startverb --format json\stopverb} to any command for machine-parseable output:}

\pre{\startverb
op item list --format json | jq '.[].title'
op item get "My Item" --format json | jq '.fields[] | select(.label=="password") | .value'
\stopverb}
}
}