\title{Kegg Database}

\taxon{skill}

\meta{description}{"Direct REST API access to KEGG (academic use only). Pathway analysis, gene-pathway mapping, metabolic pathways, drug interactions, ID conversion. For Python workflows with multiple databases, prefer bioservices. Use this for direct HTTP/REST work or KEGG-specific control."}

\subtree{
\title{KEGG Database}
\subtree{
\title{Overview}
\p{KEGG (Kyoto Encyclopedia of Genes and Genomes) is a comprehensive bioinformatics resource for biological pathway analysis and molecular interaction networks.}

\p{\strong{Important}: KEGG API is made available only for academic use by academic users.}
}

\subtree{
\title{When to Use This Skill}
\p{This skill should be used when querying pathways, genes, compounds, enzymes, diseases, and drugs across multiple organisms using KEGG's REST API.}
}

\subtree{
\title{Quick Start}
\p{The skill provides:}

\ol{
\li{Python helper functions (\code{\startverb scripts/kegg_api.py\stopverb}) for all KEGG REST API operations}
\li{Comprehensive reference documentation (\code{\startverb references/kegg_reference.md\stopverb}) with detailed API specifications}
}

\p{When users request KEGG data, determine which operation is needed and use the appropriate function from \code{\startverb scripts/kegg_api.py\stopverb}.}
}

\subtree{
\title{Core Operations}
\subtree{
\title{1. Database Information (\code{\startverb kegg_info\stopverb})}
\p{Retrieve metadata and statistics about KEGG databases.}

\p{\strong{When to use}: Understanding database structure, checking available data, getting release information.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.kegg_api import kegg_info

# Get pathway database info
info = kegg_info('pathway')

# Get organism-specific info
hsa_info = kegg_info('hsa')  # Human genome
\stopverb}

\p{\strong{Common databases}: \code{\startverb kegg\stopverb}, \code{\startverb pathway\stopverb}, \code{\startverb module\stopverb}, \code{\startverb brite\stopverb}, \code{\startverb genes\stopverb}, \code{\startverb genome\stopverb}, \code{\startverb compound\stopverb}, \code{\startverb glycan\stopverb}, \code{\startverb reaction\stopverb}, \code{\startverb enzyme\stopverb}, \code{\startverb disease\stopverb}, \code{\startverb drug\stopverb}}
}

\subtree{
\title{2. Listing Entries (\code{\startverb kegg_list\stopverb})}
\p{List entry identifiers and names from KEGG databases.}

\p{\strong{When to use}: Getting all pathways for an organism, listing genes, retrieving compound catalogs.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.kegg_api import kegg_list

# List all reference pathways
pathways = kegg_list('pathway')

# List human-specific pathways
hsa_pathways = kegg_list('pathway', 'hsa')

# List specific genes (max 10)
genes = kegg_list('hsa:10458+hsa:10459')
\stopverb}

\p{\strong{Common organism codes}: \code{\startverb hsa\stopverb} (human), \code{\startverb mmu\stopverb} (mouse), \code{\startverb dme\stopverb} (fruit fly), \code{\startverb sce\stopverb} (yeast), \code{\startverb eco\stopverb} (E. coli)}
}

\subtree{
\title{3. Searching (\code{\startverb kegg_find\stopverb})}
\p{Search KEGG databases by keywords or molecular properties.}

\p{\strong{When to use}: Finding genes by name/description, searching compounds by formula or mass, discovering entries by keywords.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.kegg_api import kegg_find

# Keyword search
results = kegg_find('genes', 'p53')
shiga_toxin = kegg_find('genes', 'shiga toxin')

# Chemical formula search (exact match)
compounds = kegg_find('compound', 'C7H10N4O2', 'formula')

# Molecular weight range search
drugs = kegg_find('drug', '300-310', 'exact_mass')
\stopverb}

\p{\strong{Search options}: \code{\startverb formula\stopverb} (exact match), \code{\startverb exact_mass\stopverb} (range), \code{\startverb mol_weight\stopverb} (range)}
}

\subtree{
\title{4. Retrieving Entries (\code{\startverb kegg_get\stopverb})}
\p{Get complete database entries or specific data formats.}

\p{\strong{When to use}: Retrieving pathway details, getting gene/protein sequences, downloading pathway maps, accessing compound structures.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.kegg_api import kegg_get

# Get pathway entry
pathway = kegg_get('hsa00010')  # Glycolysis pathway

# Get multiple entries (max 10)
genes = kegg_get(['hsa:10458', 'hsa:10459'])

# Get protein sequence (FASTA)
sequence = kegg_get('hsa:10458', 'aaseq')

# Get nucleotide sequence
nt_seq = kegg_get('hsa:10458', 'ntseq')

# Get compound structure
mol_file = kegg_get('cpd:C00002', 'mol')  # ATP in MOL format

# Get pathway as JSON (single entry only)
pathway_json = kegg_get('hsa05130', 'json')

# Get pathway image (single entry only)
pathway_img = kegg_get('hsa05130', 'image')
\stopverb}

\p{\strong{Output formats}: \code{\startverb aaseq\stopverb} (protein FASTA), \code{\startverb ntseq\stopverb} (nucleotide FASTA), \code{\startverb mol\stopverb} (MOL format), \code{\startverb kcf\stopverb} (KCF format), \code{\startverb image\stopverb} (PNG), \code{\startverb kgml\stopverb} (XML), \code{\startverb json\stopverb} (pathway JSON)}

\p{\strong{Important}: Image, KGML, and JSON formats allow only one entry at a time.}
}

\subtree{
\title{5. ID Conversion (\code{\startverb kegg_conv\stopverb})}
\p{Convert identifiers between KEGG and external databases.}

\p{\strong{When to use}: Integrating KEGG data with other databases, mapping gene IDs, converting compound identifiers.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.kegg_api import kegg_conv

# Convert all human genes to NCBI Gene IDs
conversions = kegg_conv('ncbi-geneid', 'hsa')

# Convert specific gene
gene_id = kegg_conv('ncbi-geneid', 'hsa:10458')

# Convert to UniProt
uniprot_id = kegg_conv('uniprot', 'hsa:10458')

# Convert compounds to PubChem
pubchem_ids = kegg_conv('pubchem', 'compound')

# Reverse conversion (NCBI Gene ID to KEGG)
kegg_id = kegg_conv('hsa', 'ncbi-geneid')
\stopverb}

\p{\strong{Supported conversions}: \code{\startverb ncbi-geneid\stopverb}, \code{\startverb ncbi-proteinid\stopverb}, \code{\startverb uniprot\stopverb}, \code{\startverb pubchem\stopverb}, \code{\startverb chebi\stopverb}}
}

\subtree{
\title{6. Cross-Referencing (\code{\startverb kegg_link\stopverb})}
\p{Find related entries within and between KEGG databases.}

\p{\strong{When to use}: Finding pathways containing genes, getting genes in a pathway, mapping genes to KO groups, finding compounds in pathways.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.kegg_api import kegg_link

# Find pathways linked to human genes
pathways = kegg_link('pathway', 'hsa')

# Get genes in a specific pathway
genes = kegg_link('genes', 'hsa00010')  # Glycolysis genes

# Find pathways containing a specific gene
gene_pathways = kegg_link('pathway', 'hsa:10458')

# Find compounds in a pathway
compounds = kegg_link('compound', 'hsa00010')

# Map genes to KO (orthology) groups
ko_groups = kegg_link('ko', 'hsa:10458')
\stopverb}

\p{\strong{Common links}: genes ↔ pathway, pathway ↔ compound, pathway ↔ enzyme, genes ↔ ko (orthology)}
}

\subtree{
\title{7. Drug-Drug Interactions (\code{\startverb kegg_ddi\stopverb})}
\p{Check for drug-drug interactions.}

\p{\strong{When to use}: Analyzing drug combinations, checking for contraindications, pharmacological research.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.kegg_api import kegg_ddi

# Check single drug
interactions = kegg_ddi('D00001')

# Check multiple drugs (max 10)
interactions = kegg_ddi(['D00001', 'D00002', 'D00003'])
\stopverb}
}
}

\subtree{
\title{Common Analysis Workflows}
\subtree{
\title{Workflow 1: Gene to Pathway Mapping}
\p{\strong{Use case}: Finding pathways associated with genes of interest (e.g., for pathway enrichment analysis).}

\pre{\startverb
from scripts.kegg_api import kegg_find, kegg_link, kegg_get

# Step 1: Find gene ID by name
gene_results = kegg_find('genes', 'p53')

# Step 2: Link gene to pathways
pathways = kegg_link('pathway', 'hsa:7157')  # TP53 gene

# Step 3: Get detailed pathway information
for pathway_line in pathways.split('\n'):
    if pathway_line:
        pathway_id = pathway_line.split('\t')[1].replace('path:', '')
        pathway_info = kegg_get(pathway_id)
        # Process pathway information
\stopverb}
}

\subtree{
\title{Workflow 2: Pathway Enrichment Context}
\p{\strong{Use case}: Getting all genes in organism pathways for enrichment analysis.}

\pre{\startverb
from scripts.kegg_api import kegg_list, kegg_link

# Step 1: List all human pathways
pathways = kegg_list('pathway', 'hsa')

# Step 2: For each pathway, get associated genes
for pathway_line in pathways.split('\n'):
    if pathway_line:
        pathway_id = pathway_line.split('\t')[0]
        genes = kegg_link('genes', pathway_id)
        # Process genes for enrichment analysis
\stopverb}
}

\subtree{
\title{Workflow 3: Compound to Pathway Analysis}
\p{\strong{Use case}: Finding metabolic pathways containing compounds of interest.}

\pre{\startverb
from scripts.kegg_api import kegg_find, kegg_link, kegg_get

# Step 1: Search for compound
compound_results = kegg_find('compound', 'glucose')

# Step 2: Link compound to reactions
reactions = kegg_link('reaction', 'cpd:C00031')  # Glucose

# Step 3: Link reactions to pathways
pathways = kegg_link('pathway', 'rn:R00299')  # Specific reaction

# Step 4: Get pathway details
pathway_info = kegg_get('map00010')  # Glycolysis
\stopverb}
}

\subtree{
\title{Workflow 4: Cross-Database Integration}
\p{\strong{Use case}: Integrating KEGG data with UniProt, NCBI, or PubChem databases.}

\pre{\startverb
from scripts.kegg_api import kegg_conv, kegg_get

# Step 1: Convert KEGG gene IDs to external database IDs
uniprot_map = kegg_conv('uniprot', 'hsa')
ncbi_map = kegg_conv('ncbi-geneid', 'hsa')

# Step 2: Parse conversion results
for line in uniprot_map.split('\n'):
    if line:
        kegg_id, uniprot_id = line.split('\t')
        # Use external IDs for integration

# Step 3: Get sequences using KEGG
sequence = kegg_get('hsa:10458', 'aaseq')
\stopverb}
}

\subtree{
\title{Workflow 5: Organism-Specific Pathway Analysis}
\p{\strong{Use case}: Comparing pathways across different organisms.}

\pre{\startverb
from scripts.kegg_api import kegg_list, kegg_get

# Step 1: List pathways for multiple organisms
human_pathways = kegg_list('pathway', 'hsa')
mouse_pathways = kegg_list('pathway', 'mmu')
yeast_pathways = kegg_list('pathway', 'sce')

# Step 2: Get reference pathway for comparison
ref_pathway = kegg_get('map00010')  # Reference glycolysis

# Step 3: Get organism-specific versions
hsa_glycolysis = kegg_get('hsa00010')
mmu_glycolysis = kegg_get('mmu00010')
\stopverb}
}
}

\subtree{
\title{Pathway Categories}
\p{KEGG organizes pathways into seven major categories. When interpreting pathway IDs or recommending pathways to users:}

\ol{
\li{\strong{Metabolism} (e.g., \code{\startverb map00010\stopverb} - Glycolysis, \code{\startverb map00190\stopverb} - Oxidative phosphorylation)}
\li{\strong{Genetic Information Processing} (e.g., \code{\startverb map03010\stopverb} - Ribosome, \code{\startverb map03040\stopverb} - Spliceosome)}
\li{\strong{Environmental Information Processing} (e.g., \code{\startverb map04010\stopverb} - MAPK signaling, \code{\startverb map02010\stopverb} - ABC transporters)}
\li{\strong{Cellular Processes} (e.g., \code{\startverb map04140\stopverb} - Autophagy, \code{\startverb map04210\stopverb} - Apoptosis)}
\li{\strong{Organismal Systems} (e.g., \code{\startverb map04610\stopverb} - Complement cascade, \code{\startverb map04910\stopverb} - Insulin signaling)}
\li{\strong{Human Diseases} (e.g., \code{\startverb map05200\stopverb} - Pathways in cancer, \code{\startverb map05010\stopverb} - Alzheimer disease)}
\li{\strong{Drug Development} (chronological and target-based classifications)}
}

\p{Reference \code{\startverb references/kegg_reference.md\stopverb} for detailed pathway lists and classifications.}
}

\subtree{
\title{Important Identifiers and Formats}
\subtree{
\title{Pathway IDs}
\ul{
\li{\code{\startverb map#####\stopverb} - Reference pathway (generic, not organism-specific)}
\li{\code{\startverb hsa#####\stopverb} - Human pathway}
\li{\code{\startverb mmu#####\stopverb} - Mouse pathway}
}
}

\subtree{
\title{Gene IDs}
\ul{
\li{Format: \code{\startverb organism:gene_number\stopverb} (e.g., \code{\startverb hsa:10458\stopverb})}
}
}

\subtree{
\title{Compound IDs}
\ul{
\li{Format: \code{\startverb cpd:C#####\stopverb} (e.g., \code{\startverb cpd:C00002\stopverb} for ATP)}
}
}

\subtree{
\title{Drug IDs}
\ul{
\li{Format: \code{\startverb dr:D#####\stopverb} (e.g., \code{\startverb dr:D00001\stopverb})}
}
}

\subtree{
\title{Enzyme IDs}
\ul{
\li{Format: \code{\startverb ec:EC_number\stopverb} (e.g., \code{\startverb ec:1.1.1.1\stopverb})}
}
}

\subtree{
\title{KO (KEGG Orthology) IDs}
\ul{
\li{Format: \code{\startverb ko:K#####\stopverb} (e.g., \code{\startverb ko:K00001\stopverb})}
}
}
}

\subtree{
\title{API Limitations}
\p{Respect these constraints when using the KEGG API:}

\ol{
\li{\strong{Entry limits}: Maximum 10 entries per operation (except image/kgml/json: 1 entry only)}
\li{\strong{Academic use}: API is for academic use only; commercial use requires licensing}
\li{\strong{HTTP status codes}: Check for 200 (success), 400 (bad request), 404 (not found)}
\li{\strong{Rate limiting}: No explicit limit, but avoid rapid-fire requests}
}
}

\subtree{
\title{Detailed Reference}
\p{For comprehensive API documentation, database specifications, organism codes, and advanced usage, refer to \code{\startverb references/kegg_reference.md\stopverb}. This includes:}

\ul{
\li{Complete list of KEGG databases}
\li{Detailed API operation syntax}
\li{All organism codes}
\li{HTTP status codes and error handling}
\li{Integration with Biopython and R/Bioconductor}
\li{Best practices for API usage}
}
}

\subtree{
\title{Troubleshooting}
\p{\strong{404 Not Found}: Entry or database doesn't exist; verify IDs and organism codes \strong{400 Bad Request}: Syntax error in API call; check parameter formatting \strong{Empty results}: Search term may not match entries; try broader keywords \strong{Image/KGML errors}: These formats only work with single entries; remove batch processing}
}

\subtree{
\title{Additional Tools}
\p{For interactive pathway visualization and annotation:}

\ul{
\li{\strong{KEGG Mapper}: https://www.kegg.jp/kegg/mapper/}
\li{\strong{BlastKOALA}: Automated genome annotation}
\li{\strong{GhostKOALA}: Metagenome/metatranscriptome annotation}
}
}
}