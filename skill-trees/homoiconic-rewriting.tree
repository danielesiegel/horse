\subtree{
\title{Homoiconic Rewriting}
\blockquote{\em{Code = Data = Graph = Parallel Reduction}}

\p{\strong{Trit}: 0 (ERGODIC - coordinates the stack)}

\subtree{
\title{Core Synthesis}
\pre{\startverb
┌─────────────────────────────────────────────────────────────────┐
│              HOMOICONIC REWRITING PIPELINE                      │
├─────────────────────────────────────────────────────────────────┤
│                                                                  │
│   λ-term ──quote──→ S-exp ──parse──→ INet ──CUDA──→ Result     │
│     │                  │               │              │         │
│   typed              data            graph         parallel     │
│   code            (homoiconic)     rewriting      reduction     │
│                                                                  │
└─────────────────────────────────────────────────────────────────┘
\stopverb}
}

