\title{Ruler}

\taxon{skill}

\meta{description}{Unified AI agent configuration propagation across 18+ coding assistants.}

\subtree{
\title{ruler}
\p{Unified AI agent configuration propagation across 18+ coding assistants.}

\p{\strong{Repository}: https://github.com/intellectronica/ruler \strong{Documentation}: https://deepwiki.com/intellectronica/ruler}

\subtree{
\title{Overview}
\p{Ruler centralizes AI agent instructions in \code{\startverb .ruler/\stopverb} and distributes them to all configured agents via \code{\startverb ruler apply\stopverb}. Supports Model Context Protocol (MCP) propagation with merge/overwrite strategies.}

\pre{\startverb
.ruler/
├── *.md           # Rules (concatenated alphabetically)
├── ruler.toml     # Agent config + MCP settings
└── mcp.json       # Shared MCP servers
\stopverb}
}

\subtree{
\title{Installation}
\pre{\startverb
npm install -g ruler
# or
npx ruler init
\stopverb}
}

\subtree{
\title{Commands}
\subtree{
\title{ruler init}
\p{Creates \code{\startverb .ruler/\stopverb} directory with default files:}

\pre{\startverb
ruler init           # Local project
ruler init --global  # ~/.config/ruler/
\stopverb}

\p{\strong{Creates:}}

\ul{
\li{\code{\startverb instructions.md\stopverb} - Central AI instructions}
\li{\code{\startverb ruler.toml\stopverb} - Configuration file}
\li{\code{\startverb mcp.json\stopverb} - MCP server definitions}
}
}

\subtree{
\title{ruler apply}
\p{Propagates rules to all configured agents:}

\pre{\startverb
ruler apply                          # All default agents
ruler apply --agents claude,codex    # Specific agents
ruler apply --no-mcp                 # Skip MCP propagation
ruler apply --mcp-overwrite          # Replace native MCP configs
ruler apply --no-gitignore           # Skip .gitignore updates
\stopverb}
}

\subtree{
\title{ruler revert}
\p{Restores files from backups:}

\pre{\startverb
ruler revert                  # Restore all, delete backups
ruler revert --keep-backups   # Restore but keep .bak files
\stopverb}
}
}

\subtree{
\title{Supported Agents (18)}
\pre{\startverb
| Agent | Identifier | Instructions Output | MCP Config |
|-------|------------|---------------------|------------|
| **GitHub Copilot** | `copilot` | `.github/copilot-instructions.md` | `.vscode/mcp.json` |
| **Claude Code** | `claude` | `CLAUDE.md` | `.mcp.json` |
| **OpenAI Codex CLI** | `codex` | `AGENTS.md` | `.codex/config.toml` |
| **Jules** | `jules` | `AGENTS.md` | - |
| **Cursor** | `cursor` | `.cursor/rules/ruler_cursor_instructions.mdc` | `.cursor/mcp.json` |
| **Windsurf** | `windsurf` | `.windsurf/rules/ruler_windsurf_instructions.md` | `~/.codeium/windsurf/mcp_config.json` |
| **Cline** | `cline` | `.clinerules` | - |
