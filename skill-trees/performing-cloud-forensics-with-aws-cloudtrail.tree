\title{Performing Cloud Forensics With Aws Cloudtrail}

\taxon{skill}

\tag{cloud-security}

\tag{aws}

\tag{cloudtrail}

\tag{forensics}

\tag{incident-response}

\tag{dfir}

\tag{boto3}

\tag{s3}

\meta{version}{"1.0"}

\meta{description}{Perform forensic investigation of AWS environments using CloudTrail logs to reconstruct attacker activity, identify compromised credentials, and analyze API call patterns.}

\subtree{
\title{Performing Cloud Forensics with AWS CloudTrail}
\subtree{
\title{When to Use}
\ul{
\li{When investigating suspected AWS account compromise}
\li{After detecting unauthorized API calls or credential exposure}
\li{During incident response involving cloud infrastructure}
\li{When analyzing S3 data exfiltration or IAM privilege escalation}
\li{For post-incident forensic timeline reconstruction}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{AWS account with CloudTrail enabled (management and data events)}
\li{IAM permissions for cloudtrail:LookupEvents, s3:GetObject, athena:StartQueryExecution}
\li{boto3 Python SDK installed}
\li{CloudTrail logs delivered to S3 with optional Athena table configured}
\li{AWS CLI configured with appropriate credentials}
}
}

\subtree{
\title{Workflow}
\ol{
\li{\strong{Scope Investigation}: Identify timeframe, affected accounts, and compromised credentials.}
\li{\strong{Query CloudTrail}: Use boto3 lookup_events or Athena to retrieve relevant API events.}
\li{\strong{Filter by Indicators}: Search for suspicious user agents, source IPs, and event names.}
\li{\strong{Reconstruct Timeline}: Build chronological sequence of attacker actions from API calls.}
\li{\strong{Analyze Access Patterns}: Identify data access, IAM changes, and resource modifications.}
\li{\strong{Identify Persistence}: Check for new IAM users, access keys, roles, or Lambda functions.}
\li{\strong{Generate Report}: Produce forensic timeline with findings and remediation steps.}
}
}

\subtree{
\title{Key Concepts}
\pre{\startverb
| Concept | Description |
|---------|-------------|
| LookupEvents | CloudTrail API to query management events (last 90 days) |
| Athena Queries | SQL queries against CloudTrail logs in S3 for historical analysis |
| User Agent Analysis | Identify tool signatures (AWS CLI, SDK, console, custom) |
| AccessKeyId | Track activity by specific IAM access key |
| EventName | AWS API action name (e.g., GetObject, CreateUser, AssumeRole) |
| sourceIPAddress | Origin IP of API call for geolocation analysis |
\stopverb}
}

\subtree{
\title{Tools & Systems}
\pre{\startverb
| Tool | Purpose |
|------|---------|
| boto3 CloudTrail client | Programmatic CloudTrail event lookup |
| AWS Athena | SQL-based analysis of CloudTrail S3 logs |
| AWS CLI | Command-line CloudTrail queries |
| jq | JSON processing for CloudTrail event parsing |
| CloudTrail Lake | Advanced event data store with SQL query support |
\stopverb}
}

\subtree{
\title{Output Format}
\pre{\startverb
Forensic Report: AWS-IR-[DATE]-[SEQ]
Account: [AWS Account ID]
Timeframe: [Start] to [End]
Compromised Credentials: [Access Key IDs]
Suspicious Events: [Count]
Source IPs: [List of attacker IPs]
Actions Taken: [API calls by attacker]
Data Accessed: [S3 objects, secrets, etc.]
Persistence Mechanisms: [New users, keys, roles]
\stopverb}
}
}