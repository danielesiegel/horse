\meta{description}{End-to-end encryption (E2EE) ensures that only the communicating parties can read messages, with no intermediary (including the server) able to decrypt them. This skill implements a simplified version}

\subtree{
\title{Implementing End-to-End Encryption for Messaging}
\subtree{
\title{Overview}
\p{End-to-end encryption (E2EE) ensures that only the communicating parties can read messages, with no intermediary (including the server) able to decrypt them. This skill implements a simplified version of the Signal Protocol's Double Ratchet algorithm, using X25519 for key exchange, HKDF for key derivation, and AES-256-GCM for message encryption.}
}

\subtree{
\title{When to Use}
\ul{
\li{When deploying or configuring implementing end to end encryption for messaging capabilities in your environment}
\li{When establishing security controls aligned to compliance requirements}
\li{When building or improving security architecture for this domain}
\li{When conducting security assessments that require this implementation}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Familiarity with cryptography concepts and tools}
\li{Access to a test or lab environment for safe execution}
\li{Python 3.8+ with required dependencies installed}
\li{Appropriate authorization for any testing activities}
}
}

\subtree{
\title{Objectives}
\ul{
\li{Implement X25519 Diffie-Hellman key exchange for session establishment}
\li{Build the Double Ratchet key management algorithm}
\li{Encrypt and decrypt messages with per-message keys}
\li{Implement forward secrecy (compromise of current key does not reveal past messages)}
\li{Handle out-of-order message delivery}
\li{Implement key agreement using X3DH (Extended Triple Diffie-Hellman)}
}
}

\subtree{
\title{Key Concepts}
\subtree{
\title{Signal Protocol Components}
\pre{\startverb
| Component | Purpose | Algorithm |
|-----------|---------|-----------|
| X3DH | Initial key agreement | X25519 |
| Double Ratchet | Ongoing key management | X25519 + HKDF + AES-GCM |
| Sending Chain | Per-message encryption keys | HMAC-SHA256 chain |
| Receiving Chain | Per-message decryption keys | HMAC-SHA256 chain |
| Root Chain | Derives new chain keys on DH ratchet | HKDF |
\stopverb}
}

\subtree{
\title{Forward Secrecy}
\p{Each message uses a unique encryption key derived from a ratcheting chain. After a key is used, it is deleted, ensuring that compromise of the current state does not reveal previously sent/received messages.}
}
}

\subtree{
\title{Security Considerations}
\ul{
\li{Delete message keys immediately after decryption}
\li{Implement message ordering and replay protection}
\li{Use authenticated encryption (AES-GCM) for all messages}
\li{Protect identity keys with device-level security}
\li{Verify identity keys out-of-band (safety numbers)}
}
}

\subtree{
\title{Validation Criteria}
\ul{
\li{[ ] X25519 key exchange produces shared secret}
\li{[ ] Messages encrypt and decrypt correctly between two parties}
\li{[ ] Different messages produce different ciphertexts}
\li{[ ] Forward secrecy: old keys cannot decrypt new messages}
\li{[ ] Out-of-order messages can be decrypted}
\li{[ ] Tampered messages are rejected by authentication}
}
}
}