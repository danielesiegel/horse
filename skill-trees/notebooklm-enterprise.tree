\subtree{
\title{API Quick Reference}
\subtree{
\title{Create Notebook}
\pre{\startverb
curl -X POST "${BASE}/notebooks" \
  -H "Authorization: Bearer ${TOKEN}" \
  -d '{"title": "My Notebook"}'
\stopverb}
}

\subtree{
\title{Add Sources (batch of 5)}
\pre{\startverb
curl -X POST "${BASE}/notebooks/${NB}/sources:batchCreate" \
  -H "Authorization: Bearer ${TOKEN}" \
  -d '{"userContents": [{"webContent": {"url": "https://deepwiki.com/org/repo"}}]}'
\stopverb}

\p{\strong{Critical}: field is \code{\startverb webContent.url\stopverb}, not \code{\startverb uri\stopverb}, not \code{\startverb googleDriveSource\stopverb}.}
}

\subtree{
\title{Get Notebook + Sources}
\pre{\startverb
curl -s "${BASE}/notebooks/${NB}" -H "Authorization: Bearer ${TOKEN}"
\stopverb}
}

\subtree{
\title{Share}
\pre{\startverb
curl -X POST "${BASE}/notebooks/${NB}:share" \
  -H "Authorization: Bearer ${TOKEN}" \
  -d '{"accountAndRoles": [{"email": "user@example.com", "role": "PROJECT_ROLE_WRITER"}]}'
\stopverb}
}

\subtree{
\title{Audio Overview}
\pre{\startverb
curl -X POST "${BASE}/notebooks/${NB}/audioOverviews" \
  -H "Authorization: Bearer ${TOKEN}" -d '{}'
\stopverb}
}
}

\subtree{
\title{Source URL Rules}
\p{\strong{Works}: DeepWiki URLs, direct PDFs, PMC, arXiv, Frontiers, PLOS, Nature \strong{Fails}: DOI redirects (\code{\startverb doi.org/...\stopverb}), ScienceDirect, paywalled publishers}

\p{For the flashcard pipeline, all sources are DeepWiki URLs: \code{\startverb https://deepwiki.com/{org}/{repo}\stopverb}}
}

\subtree{
\title{Babashka Pipeline Integration}
\p{The backfill pipeline (\code{\startverb n/nblm_backfill.bb\stopverb}) automates this skill's operations:}

\pre{\startverb
bb n/nblm_backfill.bb --dry-run    # plan: chunk 944 repos into 4 notebooks
bb n/nblm_backfill.bb              # create notebooks + add sources
bb n/nblm_backfill.bb --status     # check ingestion across all notebooks
bb n/nblm_backfill.bb --generate   # trigger nblm-flashcards for each notebook
\stopverb}

\p{State persisted at \code{\startverb ~/worlds/n/flashcards/backfill-state.json\stopverb}.}
}

\subtree{
\title{GCP Context}
\pre{\startverb
| Field | Value |
|-------|-------|
| Project ID | `merovingians` |
| Project Number | `302712368086` |
| API | `discoveryengine.googleapis.com` |
| Version | `v1alpha` only |
| Auth | `gcloud auth print-access-token` |
\stopverb}
}

\subtree{
\title{Gotchas}
\ol{
\li{Use project \strong{number} not ID in API paths}
\li{\code{\startverb v1alpha\stopverb} only — no v1 or v1beta}
\li{No list-sources endpoint — sources in GET notebook response}
\li{Batch size 5-10 for source adds}
\li{Ingestion is async — poll for \code{\startverb SOURCE_STATUS_COMPLETE\stopverb}}
\li{DOI URLs always fail (no redirect following)}
\li{Duplicate sources silently accepted}
\li{Audio overview: empty \code{\startverb {}\stopverb} body only, field names rejected}
\li{Audio has no download API — listen in notebook UI only}
\li{Podcast API returns 404 despite docs}
}
}

