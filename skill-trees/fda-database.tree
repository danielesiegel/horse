\subtree{
\title{Support and Troubleshooting}
\subtree{
\title{Common Issues}
\p{\strong{Issue}: Rate limit exceeded}

\ul{
\li{\strong{Solution}: Use API key, implement delays, or reduce request frequency}
}

\p{\strong{Issue}: No results found}

\ul{
\li{\strong{Solution}: Try broader search terms, check spelling, use wildcards}
}

\p{\strong{Issue}: Invalid query syntax}

\ul{
\li{\strong{Solution}: Review query syntax in \code{\startverb references/api_basics.md\stopverb}}
}

\p{\strong{Issue}: Missing fields in results}

\ul{
\li{\strong{Solution}: Not all records contain all fields; always check field existence}
}
}

