\li{Journal-specific figure examples}
\li{Tips for each library (matplotlib, seaborn, plotly)}
}
}

\subtree{
\title{Scripts Directory}
\p{\strong{Use these helper scripts for automation:}}

\ul{
\li{\strong{\code{\startverb figure_export.py\stopverb}}: Export utilities}
\li{\code{\startverb save_publication_figure()\stopverb}: Save in multiple formats with correct DPI}
\li{\code{\startverb save_for_journal()\stopverb}: Use journal-specific requirements automatically}
\li{\code{\startverb check_figure_size()\stopverb}: Verify dimensions meet journal specs}
\li{Run directly: \code{\startverb python scripts/figure_export.py\stopverb} for examples}
}

\ul{
\li{\strong{\code{\startverb style_presets.py\stopverb}}: Pre-configured styles}
\li{\code{\startverb apply_publication_style()\stopverb}: Apply preset styles (default, nature, science, cell)}
\li{\code{\startverb set_color_palette()\stopverb}: Quick palette switching}
\li{\code{\startverb configure_for_journal()\stopverb}: One-command journal configuration}
\li{Run directly: \code{\startverb python scripts/style_presets.py\stopverb} to see examples}
}
}

\subtree{
\title{Assets Directory}
\p{\strong{Use these files in figures:}}

\ul{
\li{\strong{\code{\startverb color_palettes.py\stopverb}}: Importable color definitions}
\li{All recommended palettes as Python constants}
