\subtree{
\title{Advanced Seaborn Techniques}
\p{\strong{Pairwise relationships for exploratory analysis:}}

\pre{\startverb
# Quick overview of all relationships
g = sns.pairplot(data=df, hue='condition', 
                 vars=['gene1', 'gene2', 'gene3'],
                 corner=True, diag_kind='kde', height=2)
\stopverb}

\p{\strong{Hierarchical clustering heatmap:}}

\pre{\startverb
# Cluster samples and features
g = sns.clustermap(expression_data, method='ward', 
                   metric='euclidean', z_score=0,
                   cmap='RdBu_r', center=0, 
                   figsize=(10, 8), 
                   row_colors=condition_colors,
                   cbar_kws={'label': 'Z-score'})
\stopverb}

\p{\strong{Joint distributions with marginals:}}

\pre{\startverb
# Bivariate distribution with context
g = sns.jointplot(data=df, x='gene1', y='gene2',
                  hue='treatment', kind='scatter',
                  height=6, ratio=4, marginal_kws={'kde': True})
\stopverb}
}

\subtree{
\title{Common Seaborn Issues and Solutions}
\p{\strong{Issue: Legend outside plot area}}

\pre{\startverb
g = sns.relplot(...)
g._legend.set_bbox_to_anchor((0.9, 0.5))
\stopverb}

\p{\strong{Issue: Overlapping labels}}

\pre{\startverb
plt.xticks(rotation=45, ha='right')
plt.tight_layout()
\stopverb}

\p{\strong{Issue: Text too small at final size}}

\pre{\startverb
sns.set_context('paper', font_scale=1.2)  # Increase if needed
\stopverb}
}

