\pre{\startverb
## Advanced Configuration
For complex scenarios like HOCs, render props, or custom hooks, see [ADVANCED.md](docs/ADVANCED.md).
\stopverb}

\subtree{
\title{🛠️ Adding Scripts and Resources}
\subtree{
\title{Scripts Directory}
\p{\strong{Purpose}: Executable scripts that Claude can run \strong{Location}: \code{\startverb scripts/\stopverb} in skill directory \strong{Usage}: Referenced from SKILL.md}

\p{Example:}

\pre{\startverb
# In skill directory
scripts/
├── setup.sh          # Initialization script
├── validate.js       # Validation logic
├── generate.py       # Code generation
└── deploy.sh         # Deployment script
\stopverb}

\p{Reference from SKILL.md:}

\pre{\startverb
## Setup
Run the setup script:
\stopverb}

\p{./scripts/setup.sh}

\pre{\startverb

## Validation
Validate your configuration:
\stopverb}

\p{node scripts/validate.js config.json}

\pre{\startverb

\stopverb}
}

\subtree{
\title{Resources Directory}
\p{\strong{Purpose}: Templates, examples, schemas, static files \strong{Location}: \code{\startverb resources/\stopverb} in skill directory \strong{Usage}: Referenced or copied by scripts}

\p{Example:}

\pre{\startverb
resources/
├── templates/
│   ├── component.tsx.template
│   ├── test.spec.ts.template
│   └── story.stories.tsx.template
├── examples/
│   ├── basic-example/
│   ├── advanced-example/
│   └── integration-example/
└── schemas/
    ├── config.schema.json
    └── output.schema.json
\stopverb}

\p{Reference from SKILL.md:}

\pre{\startverb
## Templates
Use the component template:
\stopverb}

\p{cp resources/templates/component.tsx.template src/components/MyComponent.tsx}

\pre{\startverb

## Examples
See working examples in `resources/examples/`:
- `basic-example/` - Simple component
- `advanced-example/` - With hooks and context
\stopverb}
}
}

