\title{Finder Color Walk}

\taxon{skill}

\meta{trit}{0}

\meta{description}{Deterministic triadic fanout over file-sets with macOS Finder label coloring, GF(3) conservation, and Strong Parallelism Invariance (SPI).}

\subtree{
\title{finder-color-walk}
\p{Deterministic \em{triadic fanout} over a file-set, with macOS Finder label coloring, supporting \strong{GF(3) conservation} and \strong{Strong Parallelism Invariance (SPI)}.}

\subtree{
\title{Contract}
\subtree{
\title{Inputs}
\ul{
\li{Root path(s) to enumerate files (user-supplied).}
\li{Optional filters (extensions, max depth, ignore globs).}
\li{Policy:}
\li{\code{\startverb raw\stopverb} (default): \code{\startverb color_at(file)\stopverb} only; SPI holds; \strong{GF(3) not guaranteed}.}
\li{\code{\startverb gf3_balanced\stopverb}: colors are assigned in position-aligned triplets across the 3 routed fibers; \strong{GF(3) holds}.}
}
}

\subtree{
\title{Outputs}
\ul{
\li{A (file → color) assignment and a (file → fiber) routing.}
\li{Optional application of macOS Finder label colors.}
}
}
}

\subtree{
\title{Guarantees}
\subtree{
\title{SPI (Strong Parallelism Invariance)}
\p{For a fixed file-set, policy, and seed:}

\ul{
\li{routing is deterministic and order-independent}
\li{color assignment is deterministic and order-independent}
}

\p{Formally: any permutation of the same input file-set yields the same final mapping.}
}

\subtree{
\title{GF(3) conservation (policy = \code{\startverb gf3_balanced\stopverb})}
\p{Let the three fibers be sorted lists \code{\startverb F0,F1,F2\stopverb} of equal length \code{\startverb N\stopverb}. For each index \code{\startverb i\stopverb} define trits \code{\startverb t0(i), t1(i), t2(i) ∈ {0,1,2}\stopverb} as assigned to \code{\startverb F0[i],F1[i],F2[i]\stopverb}. Then for all \code{\startverb i\stopverb}:}

\ul{
\li{\code{\startverb t0(i) + t1(i) + t2(i) ≡ 0 (mod 3)\stopverb}}
}

\p{Implementation: choose \code{\startverb t0,t1\stopverb} deterministically; set \code{\startverb t2 := (-t0-t1) mod 3\stopverb}.}
}
}

\subtree{
\title{Files}
\ul{
\li{\code{\startverb schema.jl\stopverb} — Catlab ACSet schema: \code{\startverb FileColorWalk\stopverb}.}
\li{\code{\startverb triadic_router.bb\stopverb} — GF(3)-balanced routing into 3 fibers.}
\li{\code{\startverb finder_color_walk.bb\stopverb} — single-stream walk (policy \code{\startverb raw\stopverb}).}
\li{\code{\startverb parallel_walk.bb\stopverb} — 3-stream walk + \code{\startverb gf3_balanced\stopverb} coloring.}
\li{\code{\startverb spi_test.py\stopverb} — verifies SPI + GF(3) (where requested).}
\li{\code{\startverb INTERLEAVED.md\stopverb} — 4-corpus synthesis notes.}
}
}

\subtree{
\title{Quick start}
\subtree{
\title{Route files into 3 fibers}
\pre{\startverb
bb triadic_router.bb --root . --out fibers.json
\stopverb}
}

\subtree{
\title{Apply GF(3)-balanced colors (dry-run by default)}
\pre{\startverb
bb parallel_walk.bb --fibers fibers.json --policy gf3_balanced --dry-run
\stopverb}
}

\subtree{
\title{Verify invariants}
\pre{\startverb
python spi_test.py --fibers fibers.json --policy gf3_balanced
\stopverb}
}
}

\subtree{
\title{macOS Finder label mapping}
\p{Trits → label colors (customize inside scripts):}

\ul{
\li{0: None}
\li{1: Green}
\li{2: Blue}
}
}

