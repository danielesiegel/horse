\li{Break into numbered steps}
\li{Explain purpose of each step}
\li{Provide verification after each step}
\li{Only proceed when verification succeeds}
\li{Acknowledge completion of phase before moving to next}
}

\p{\strong{When troubleshooting}:}

\ol{
\li{Gather symptoms}
\li{Form hypothesis}
\li{Test with diagnostic command}
\li{Interpret results}
\li{Apply fix}
\li{Verify fix resolved issue}
}

\p{\strong{When teaching analysis}:}

\ol{
