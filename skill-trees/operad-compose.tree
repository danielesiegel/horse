\subtree{
\title{Commands}
\pre{\startverb
# Compose operations
just operad-mult op1 op2 slot

# Generate GF(3) operations of given arity
just operad-gf3 arity

# Visualize operad tree
just operad-tree operation

# Check operad associativity
just operad-assoc op1 op2 op3
\stopverb}
}

