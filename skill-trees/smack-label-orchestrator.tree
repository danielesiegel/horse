\subtree{
\title{Description}
\p{Manages SMACK label assignments across apps and kernel. Coordinates mandatory access control labels with process isolation.}
}

\subtree{
\title{When to Use}
\p{This is a Tizen security/IoT skill. Use when:}

\ul{
\li{Developing Tizen applications (web, native, .NET)}
\li{Auditing Tizen app security}
\li{Provisioning TizenRT/ARTIK IoT devices}
\li{Implementing Tizen compliance}
\li{Analyzing SMACK policies or Cynara access control}
}
}

\subtree{
\title{Tizen Security Model}
\subtree{
\title{SMACK (Simplified Mandatory Access Control Kernel)}
\ul{
\li{Linux kernel 3.12+ mandatory access control}
\li{Process isolation via labels}
\li{Prevent inter-app resource access}
}
}

\subtree{
\title{Cynara}
\ul{
\li{Fast privilege access control service}
\li{Policy-based permission checking}
\li{External agent integration}
}
}

\subtree{
\title{KeyManager}
\ul{
\li{Central secure storage repository}
\li{Password-protected data access}
\li{Certificate and key management}
}
}

\subtree{
\title{Tizen Manifest}
\ul{
\li{Privilege declarations (public, partner, platform)}
\li{App sandboxing configuration}
\li{Resource access specifications}
}
}
}

