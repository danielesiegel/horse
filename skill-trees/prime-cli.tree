\title{Prime Cli}

\taxon{skill}

\meta{description}{Use the Prime Intellect CLI to set up Lab workspaces, manage verifiers environments, run evaluations, and launch hosted RL runs.}

\subtree{
\title{Prime CLI}
\p{Use this skill when the user asks about the Prime Intellect CLI, Lab, verifiers environments, evaluations, or hosted training.}

\subtree{
\title{Quick Flow}
\ol{
\li{Read local docs: AGENTS.md and environments/AGENTS.md in the workspace.}
\li{Identify which action is needed: setup, environment init or install, evaluation, or RL run.}
\li{Run the minimal prime subcommand and report results concisely.}
}
}

\subtree{
\title{Common Commands}
\p{~~~~text prime --version prime login prime lab setup}

\p{prime env init <env-name> prime env install <env-name-or-hub-id> prime env push --path ./environments/<env-name>}

\p{prime eval run <env-name-or-hub-id> -m <model> prime eval tui}

\p{prime rl models prime rl run <config.toml> ~~~~}
}

\subtree{
\title{Workspace Conventions}
\ul{
\li{prime lab setup creates configs/, environments/, and top-level AGENTS.md.}
\li{Environment modules expose load_environment and live under ./environments/<env-name>/.}
\li{Evaluation outputs go under ./outputs or ./environments/<env-name>/outputs when configured.}
}
}

\subtree{
\title{Tips}
\ul{
\li{If the user mentions a specific model, verify availability with prime rl models.}
\li{For custom endpoints, point to configs/endpoints.py.}
\li{Keep responses short and list the exact commands used.}
}
}

\subtree{
\title{Examples}
\ul{
\li{'Initialize a new environment called math-probe' -> prime env init math-probe}
\li{'Run an eval on my env using gpt-5-nano' -> prime eval run my-env -m gpt-5-nano}
\li{'Start a hosted RL run' -> prime rl run configs/<run>.toml}
}
}

\subtree{
\title{References}
\ul{
\li{AGENTS.md (workspace root)}
\li{environments/AGENTS.md}
}
}
}