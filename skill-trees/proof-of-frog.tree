\meta{description}{Proof-of-Frog Skill 🐸}

\subtree{
\title{Proof-of-Frog Skill 🐸}
\p{\strong{Trit}: 0 (ERGODIC - Coordinator) \strong{GF(3) Triad}: \code{\startverb proof-chain (-1) ⊗ proof-of-frog (0) ⊗ alife (+1) = 0\stopverb}}

\subtree{
\title{Overview}
\p{Society merge protocol implementing Block Science KOI patterns with frog lifecycle metaphor.}

\p{"Eat that frog first thing in the morning" - Brian Tracy}
}

\subtree{
\title{Frog Lifecycle (GF(3) States)}
\pre{\startverb
| Stage | Trit | Role |
|-------|------|------|
| 🥒 TADPOLE | -1 | Learning, absorbing |
| 🐸 FROGLET | 0 | Transitioning, coordinating |
| 🦎 MATURE FROG | +1 | Generating, executing |
\stopverb}
}

\subtree{
\title{Core Concepts}
\subtree{
\title{Reference IDs (Block Science KOI)}
\pre{\startverb
struct ReferenceID {
    local_name: String,      // How THIS society refers to it
    canonical_hash: vector<u8>,  // Universal content hash
    society_origin: address,     // Which pond it came from
}
\stopverb}
}

\subtree{
\title{Knowledge Nugget (The Frog to Eat)}
\pre{\startverb
struct KnowledgeNugget {
    rid: ReferenceID,
    trit: i8,           // GF(3) lifecycle stage
    eaten: bool,        // Has this frog been eaten?
    leap_count: u64,    // How many hops to get here
}
\stopverb}
}

\subtree{
\title{Society Merge}
\p{Two ponds can merge when:}

\ol{
\li{Both are GF(3) balanced}
\li{Shared RIDs exist (common reference points)}
\li{Ribbit votes reach quorum}
}
}
}

\subtree{
\title{Usage}
\pre{\startverb
# Deploy society merge
aptos move publish --named-addresses zubyul=default

# Initialize pond
aptos move run --function-id zubyul::proof_of_frog::spawn_pond

# Eat a frog (process knowledge)
aptos move run --function-id zubyul::proof_of_frog::eat_frog --args u64:0

# Propose merger
aptos move run --function-id zubyul::proof_of_frog::propose_merge --args u64:0 u64:1
\stopverb}
}

