\title{Medchem}

\taxon{skill}

\meta{description}{"Medicinal chemistry filters. Apply drug-likeness rules (Lipinski, Veber), PAINS filters, structural alerts, complexity metrics, for compound prioritization and library filtering."}

\subtree{
\title{Medchem}
\subtree{
\title{Overview}
\p{Medchem is a Python library for molecular filtering and prioritization in drug discovery workflows. Apply hundreds of well-established and novel molecular filters, structural alerts, and medicinal chemistry rules to efficiently triage and prioritize compound libraries at scale. Rules and filters are context-specific—use as guidelines combined with domain expertise.}
}

\subtree{
\title{When to Use This Skill}
\p{This skill should be used when:}

\ul{
\li{Applying drug-likeness rules (Lipinski, Veber, etc.) to compound libraries}
\li{Filtering molecules by structural alerts or PAINS patterns}
\li{Prioritizing compounds for lead optimization}
\li{Assessing compound quality and medicinal chemistry properties}
\li{Detecting reactive or problematic functional groups}
\li{Calculating molecular complexity metrics}
}
}

\subtree{
\title{Installation}
\pre{\startverb
uv pip install medchem
\stopverb}
}

\subtree{
\title{Core Capabilities}
\subtree{
\title{1. Medicinal Chemistry Rules}
\p{Apply established drug-likeness rules to molecules using the \code{\startverb medchem.rules\stopverb} module.}

\p{\strong{Available Rules:}}

\ul{
\li{Rule of Five (Lipinski)}
\li{Rule of Oprea}
\li{Rule of CNS}
\li{Rule of leadlike (soft and strict)}
\li{Rule of three}
\li{Rule of Reos}
\li{Rule of drug}
\li{Rule of Veber}
\li{Golden triangle}
\li{PAINS filters}
}

\p{\strong{Single Rule Application:}}

\pre{\startverb
import medchem as mc

# Apply Rule of Five to a SMILES string
smiles = "CC(=O)OC1=CC=CC=C1C(=O)O"  # Aspirin
passes = mc.rules.basic_rules.rule_of_five(smiles)
# Returns: True

# Check specific rules
passes_oprea = mc.rules.basic_rules.rule_of_oprea(smiles)
passes_cns = mc.rules.basic_rules.rule_of_cns(smiles)
\stopverb}

\p{\strong{Multiple Rules with RuleFilters:}}

\pre{\startverb
import datamol as dm
import medchem as mc

# Load molecules
mols = [dm.to_mol(smiles) for smiles in smiles_list]

# Create filter with multiple rules
rfilter = mc.rules.RuleFilters(
    rule_list=[
        "rule_of_five",
        "rule_of_oprea",
        "rule_of_cns",
        "rule_of_leadlike_soft"
    ]
)

# Apply filters with parallelization
results = rfilter(
    mols=mols,
    n_jobs=-1,  # Use all CPU cores
    progress=True
)
\stopverb}

\p{\strong{Result Format:} Results are returned as dictionaries with pass/fail status and detailed information for each rule.}
}

\subtree{
\title{2. Structural Alert Filters}
\p{Detect potentially problematic structural patterns using the \code{\startverb medchem.structural\stopverb} module.}

\p{\strong{Available Filters:}}

\ol{
\li{\strong{Common Alerts} - General structural alerts derived from ChEMBL curation and literature}
\li{\strong{NIBR Filters} - Novartis Institutes for BioMedical Research filter set}
\li{\strong{Lilly Demerits} - Eli Lilly's demerit-based system (275 rules, molecules rejected at >100 demerits)}
}

\p{\strong{Common Alerts:}}

\pre{\startverb
import medchem as mc

# Create filter
alert_filter = mc.structural.CommonAlertsFilters()

# Check single molecule
mol = dm.to_mol("c1ccccc1")
has_alerts, details = alert_filter.check_mol(mol)

# Batch filtering with parallelization
results = alert_filter(
    mols=mol_list,
    n_jobs=-1,
    progress=True
)
\stopverb}

\p{\strong{NIBR Filters:}}

\pre{\startverb
import medchem as mc

# Apply NIBR filters
nibr_filter = mc.structural.NIBRFilters()
results = nibr_filter(mols=mol_list, n_jobs=-1)
\stopverb}

\p{\strong{Lilly Demerits:}}

\pre{\startverb
import medchem as mc

# Calculate Lilly demerits
lilly = mc.structural.LillyDemeritsFilters()
results = lilly(mols=mol_list, n_jobs=-1)

# Each result includes demerit score and whether it passes (≤100 demerits)
\stopverb}
}

\subtree{
\title{3. Functional API for High-Level Operations}
\p{The \code{\startverb medchem.functional\stopverb} module provides convenient functions for common workflows.}

\p{\strong{Quick Filtering:}}

\pre{\startverb
import medchem as mc

# Apply NIBR filters to a list
filter_ok = mc.functional.nibr_filter(
    mols=mol_list,
    n_jobs=-1
)

# Apply common alerts
alert_results = mc.functional.common_alerts_filter(
    mols=mol_list,
    n_jobs=-1
)
\stopverb}
}

\subtree{
\title{4. Chemical Groups Detection}
\p{Identify specific chemical groups and functional groups using \code{\startverb medchem.groups\stopverb}.}

\p{\strong{Available Groups:}}

\ul{
\li{Hinge binders}
\li{Phosphate binders}
\li{Michael acceptors}
\li{Reactive groups}
\li{Custom SMARTS patterns}
}

\p{\strong{Usage:}}

\pre{\startverb
import medchem as mc

# Create group detector
group = mc.groups.ChemicalGroup(groups=["hinge_binders"])

# Check for matches
has_matches = group.has_match(mol_list)

# Get detailed match information
matches = group.get_matches(mol)
\stopverb}
}

\subtree{
\title{5. Named Catalogs}
\p{Access curated collections of chemical structures through \code{\startverb medchem.catalogs\stopverb}.}

\p{\strong{Available Catalogs:}}

\ul{
\li{Functional groups}
\li{Protecting groups}
\li{Common reagents}
\li{Standard fragments}
}

\p{\strong{Usage:}}

\pre{\startverb
import medchem as mc

# Access named catalogs
catalogs = mc.catalogs.NamedCatalogs

# Use catalog for matching
catalog = catalogs.get("functional_groups")
matches = catalog.get_matches(mol)
\stopverb}
}

\subtree{
\title{6. Molecular Complexity}
\p{Calculate complexity metrics that approximate synthetic accessibility using \code{\startverb medchem.complexity\stopverb}.}

\p{\strong{Common Metrics:}}

\ul{
\li{Bertz complexity}
\li{Whitlock complexity}
\li{Barone complexity}
}

\p{\strong{Usage:}}

\pre{\startverb
import medchem as mc

# Calculate complexity
complexity_score = mc.complexity.calculate_complexity(mol)

# Filter by complexity threshold
complex_filter = mc.complexity.ComplexityFilter(max_complexity=500)
results = complex_filter(mols=mol_list)
\stopverb}
}

\subtree{
\title{7. Constraints Filtering}
\p{Apply custom property-based constraints using \code{\startverb medchem.constraints\stopverb}.}

\p{\strong{Example Constraints:}}

\ul{
\li{Molecular weight ranges}
\li{LogP bounds}
\li{TPSA limits}
\li{Rotatable bond counts}
}

\p{\strong{Usage:}}

\pre{\startverb
import medchem as mc

# Define constraints
constraints = mc.constraints.Constraints(
    mw_range=(200, 500),
    logp_range=(-2, 5),
    tpsa_max=140,
    rotatable_bonds_max=10
)

# Apply constraints
results = constraints(mols=mol_list, n_jobs=-1)
\stopverb}
}

\subtree{
\title{8. Medchem Query Language}
\p{Use a specialized query language for complex filtering criteria.}

\p{\strong{Query Examples:}}

\pre{\startverb
# Molecules passing Ro5 AND not having common alerts
"rule_of_five AND NOT common_alerts"

# CNS-like molecules with low complexity
"rule_of_cns AND complexity < 400"

# Leadlike molecules without Lilly demerits
"rule_of_leadlike AND lilly_demerits == 0"
\stopverb}

\p{\strong{Usage:}}

\pre{\startverb
import medchem as mc

# Parse and apply query
query = mc.query.parse("rule_of_five AND NOT common_alerts")
results = query.apply(mols=mol_list, n_jobs=-1)
\stopverb}
}
}

\subtree{
\title{Workflow Patterns}
\subtree{
\title{Pattern 1: Initial Triage of Compound Library}
\p{Filter a large compound collection to identify drug-like candidates.}

\pre{\startverb
import datamol as dm
import medchem as mc
import pandas as pd

# Load compound library
df = pd.read_csv("compounds.csv")
mols = [dm.to_mol(smi) for smi in df["smiles"]]

# Apply primary filters
rule_filter = mc.rules.RuleFilters(rule_list=["rule_of_five", "rule_of_veber"])
rule_results = rule_filter(mols=mols, n_jobs=-1, progress=True)

# Apply structural alerts
alert_filter = mc.structural.CommonAlertsFilters()
alert_results = alert_filter(mols=mols, n_jobs=-1, progress=True)

# Combine results
df["passes_rules"] = rule_results["pass"]
df["has_alerts"] = alert_results["has_alerts"]
df["drug_like"] = df["passes_rules"] & ~df["has_alerts"]

# Save filtered compounds
filtered_df = df[df["drug_like"]]
filtered_df.to_csv("filtered_compounds.csv", index=False)
\stopverb}
}

\subtree{
\title{Pattern 2: Lead Optimization Filtering}
\p{Apply stricter criteria during lead optimization.}

\pre{\startverb
import medchem as mc

# Create comprehensive filter
filters = {
    "rules": mc.rules.RuleFilters(rule_list=["rule_of_leadlike_strict"]),
    "alerts": mc.structural.NIBRFilters(),
    "lilly": mc.structural.LillyDemeritsFilters(),
    "complexity": mc.complexity.ComplexityFilter(max_complexity=400)
}

# Apply all filters
results = {}
for name, filt in filters.items():
    results[name] = filt(mols=candidate_mols, n_jobs=-1)

# Identify compounds passing all filters
passes_all = all(r["pass"] for r in results.values())
\stopverb}
}

\subtree{
\title{Pattern 3: Identify Specific Chemical Groups}
\p{Find molecules containing specific functional groups or scaffolds.}

\pre{\startverb
import medchem as mc

# Create group detector for multiple groups
group_detector = mc.groups.ChemicalGroup(
    groups=["hinge_binders", "phosphate_binders"]
)

# Screen library
matches = group_detector.get_all_matches(mol_list)

# Filter molecules with desired groups
mol_with_groups = [mol for mol, match in zip(mol_list, matches) if match]
\stopverb}
}
}

\subtree{
\title{Best Practices}
\ol{
\li{\strong{Context Matters}: Don't blindly apply filters. Understand the biological target and chemical space.}
}

\ol{
\li{\strong{Combine Multiple Filters}: Use rules, structural alerts, and domain knowledge together for better decisions.}
}

\ol{
\li{\strong{Use Parallelization}: For large datasets (>1000 molecules), always use \code{\startverb n_jobs=-1\stopverb} for parallel processing.}
}

\ol{
\li{\strong{Iterative Refinement}: Start with broad filters (Ro5), then apply more specific criteria (CNS, leadlike) as needed.}
}

\ol{
\li{\strong{Document Filtering Decisions}: Track which molecules were filtered out and why for reproducibility.}
}

\ol{
\li{\strong{Validate Results}: Remember that marketed drugs often fail standard filters—use these as guidelines, not absolute rules.}
}

\ol{
\li{\strong{Consider Prodrugs}: Molecules designed as prodrugs may intentionally violate standard medicinal chemistry rules.}
}
}

