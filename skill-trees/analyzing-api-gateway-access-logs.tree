\title{Analyzing Api Gateway Access Logs}

\taxon{skill}

\tag{analyzing}

\tag{api}

\tag{gateway}

\tag{access}

\meta{version}{"1.0"}

\meta{description}{Parses API Gateway access logs (AWS API Gateway, Kong, Nginx) to detect BOLA/IDOR attacks, rate limit bypass, credential scanning, and injection attempts. Uses pandas for statistical analysis of request patterns and anomaly detection. Use when investigating API abuse or building API-specific threat detection rules.}

\subtree{
\title{Analyzing API Gateway Access Logs}
\subtree{
\title{When to Use}
\ul{
