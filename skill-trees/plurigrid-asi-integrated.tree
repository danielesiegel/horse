\subtree{
\title{GF(3) Conservation Law}
\p{All operations preserve:}

\pre{\startverb
вҲ‘ trits вүЎ 0 (mod 3)
\stopverb}

\p{Across:}

\ul{
\li{World hops (Attacker -1, Defender +1, Arbiter 0)}
\li{Color triplets (MINUS, ERGODIC, PLUS)}
\li{Schedule entries (balanced per triplet)}
\li{Skill dispersal (agent assignments)}
}
}

\subtree{
\title{Commands}
\pre{\startverb
# Generate integrated schedule
just asi-schedule 0x42D 10

# Disperse skills to all agents
just asi-disperse ~/.claude/skills/

# Verify GF(3) conservation
just asi-verify

# Play glass bead synthesis
just asi-synthesize a b p t

# World hop between letters
just asi-hop a t
\stopverb}
}

