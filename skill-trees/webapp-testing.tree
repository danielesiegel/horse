\title{Webapp Testing}

\taxon{skill}

\meta{description}{Toolkit for interacting with and testing local web applications using}

\subtree{
\title{Web App Testing with Playwright}
\subtree{
\title{Setup}
\pre{\startverb
npm init playwright@latest
\stopverb}
}

\subtree{
\title{Basic Test Structure}
\pre{\startverb
import { test, expect } from '@playwright/test';

test('homepage has title', async ({ page }) => {
  await page.goto('http://localhost:3000');
  await expect(page).toHaveTitle(/My App/);
});

test('can navigate to about page', async ({ page }) => {
  await page.goto('http://localhost:3000');
  await page.click('text=About');
  await expect(page).toHaveURL(/.*about/);
});
\stopverb}
}

\subtree{
\title{Common Actions}
\subtree{
\title{Navigation}
\pre{\startverb
await page.goto('http://localhost:3000');
await page.goBack();
await page.reload();
\stopverb}
}

\subtree{
\title{Clicking}
\pre{\startverb
await page.click('button');
await page.click('text=Submit');
await page.click('#submit-btn');
await page.click('[data-testid="submit"]');
\stopverb}
}

\subtree{
\title{Form Input}
\pre{\startverb
await page.fill('input[name="email"]', 'test@example.com');
await page.fill('#password', 'secret123');
await page.selectOption('select#country', 'USA');
await page.check('input[type="checkbox"]');
\stopverb}
}

\subtree{
\title{Waiting}
\pre{\startverb
await page.waitForSelector('.loaded');
await page.waitForURL('**/dashboard');
await page.waitForResponse('**/api/data');
await page.waitForTimeout(1000); // Avoid if possible
\stopverb}
}
}

\subtree{
\title{Assertions}
\pre{\startverb
await expect(page.locator('h1')).toHaveText('Welcome');
await expect(page.locator('.items')).toHaveCount(5);
await expect(page.locator('button')).toBeEnabled();
await expect(page.locator('.modal')).toBeVisible();
await expect(page.locator('input')).toHaveValue('test');
\stopverb}
}

\subtree{
\title{Screenshots}
\pre{\startverb
// Full page
await page.screenshot({ path: 'screenshot.png', fullPage: true });

// Element only
await page.locator('.chart').screenshot({ path: 'chart.png' });
\stopverb}
}

\subtree{
\title{Console Logs}
\pre{\startverb
page.on('console', msg => console.log(msg.text()));
page.on('pageerror', err => console.error(err.message));
\stopverb}
}

\subtree{
\title{Network Interception}
\pre{\startverb
await page.route('**/api/data', route => {
  route.fulfill({
    status: 200,
    body: JSON.stringify({ items: [] })
  });
});
\stopverb}
}

\subtree{
\title{Running Tests}
\pre{\startverb
# Run all tests
npx playwright test

# Run specific file
npx playwright test tests/login.spec.ts

# Run in headed mode
npx playwright test --headed

# Run with UI
npx playwright test --ui
\stopverb}
}
}