\title{Tailscale File Transfer}

\taxon{skill}

\meta{description}{Tailscale mesh VPN file transfer with open games semantics (play/coplay)}

\p{<!-- Propagated to amp | Trit: +1 | Source: .ruler/skills/tailscale-file-transfer -->}

\subtree{
\title{Tailscale File Transfer Skill: Open Games Integration}
\p{\strong{Status}: ✅ Production Ready \strong{Trit}: +1 (COVARIANT - receiver perspective, shared benefit) \strong{Framework}: Jules Hedges' Compositional Game Theory with Lens Optics \strong{Implementation}: Ruby (HedgesOpenGames module) \strong{Network}: Tailscale Mesh VPN (100.x.y.z IPv4)}

\subtree{
\title{Overview}
\p{\strong{Tailscale File Transfer Skill} provides peer-to-peer file sharing through Tailscale mesh networks using \strong{open games framework semantics}. Every transfer is a bidirectional game with:}

\ol{
\li{\strong{Forward pass (play)}: Sender initiates file transfer through Tailscale network}
\li{\strong{Backward pass (coplay)}: Receiver sends acknowledgment and utility score propagates backward}
\li{\strong{Lens optics}: Bidirectional transformation of state with composable utility functions}
\li{\strong{GF(3) trits}: Covariant (+1) for receiver perspective, contravariant (-1) for sender}
}
}

\subtree{
\title{Core Architecture}
\subtree{
\title{Bidirectional Lens Optics}
\pre{\startverb
Forward Pass (play):
  file_path → read & hash → resolve recipient IP → prepare context
    ↓
  execute_transfer(sequential|parallel|adaptive)
    ↓
  record to @transfer_log

Backward Pass (coplay):
  {delivered, bytes_received, transfer_time} → ack
    ↓
  calculate utility (base + quality_bonus)
    ↓
  propagate backward through lens
\stopverb}
}

\subtree{
\title{Utility Scoring}
\pre{\startverb
base_utility = delivered ? 1.0 : 0.0

quality_bonus = 0.0
quality_bonus += 0.1 if transfer_time < 5.0    # Speed bonus
quality_bonus += 0.05 if bytes_received ≥ 95%  # Completeness

final_utility = min(base_utility + quality_bonus, 1.0)
\stopverb}

\p{\strong{Examples}:}

\ul{
\li{Perfect delivery < 5s: \strong{1.0}}
\li{\startverb Successful delivery, 95%+ complete: **1.0**\stopverb}
\li{Failed transfer: \strong{0.0}}
}
}
}

\subtree{
\title{Three Transfer Strategies}
\pre{\startverb
| Strategy | Throughput | Use Case | Threads | Latency |
|----------|-----------|----------|---------|---------|
| **sequential** | 1706 KB/s | Default, small files, strict ordering | 1 | 10ms/chunk |
| **parallel** | 1706 KB/s | Large files, high bandwidth, order-independent | 4 | 5ms/chunk |
| **adaptive** | 538 KB/s (scales) | Unknown networks, dynamic chunk sizing | 1→N | adaptive |
\stopverb}
}

\subtree{
\title{Recipient Resolution}
\p{Supports multiple identifier formats:}

\pre{\startverb
# Named coplay identifier (preferred)
skill.play(file_path: "model.jl", recipient: "alice@coplay")

# Tailscale IP (100.x.y.z range)
skill.play(file_path: "model.jl", recipient: "100.64.0.1")

# Hostname
skill.play(file_path: "model.jl", recipient: "alice-mbp")
\stopverb}
}

\subtree{
\title{Mesh Network Discovery}
\pre{\startverb
skill.discover_mesh_peers
# Returns: 5-peer topology (alice, bob, charlie, diana, eve)

# Peer information includes:
# {user: "alice", hostname: "alice-mbp", ip: "100.64.0.1", status: :online}
\stopverb}
}

\subtree{
\title{Integration Points}
\subtree{
\title{With HedgesOpenGames Framework}
\ul{
\li{Implements Lens-based bidirectional optics}
\li{Supports composition operators: >> (sequential), * (parallel)}
\li{Creates OpenGame instances with strategy space}
}

\pre{\startverb
game = skill.create_open_game
# Returns: OpenGame with:
#   - name: "tailscale_file_transfer"
#   - strategy_space: [:sequential, :parallel, :adaptive]
#   - utility_fn: scoring function
#   - trit: 1 (covariant)
\stopverb}
}

\subtree{
\title{With Music-Topos CRDT System}
\pre{\startverb
# Transfer learned color models
skill.play(file_path: "learned_plr_network.jl", recipient: "collaborator@coplay")

# Distribute harmonic analysis for CRDT merge
skill.play(file_path: "analysis.json", recipient: "merge_agent@coplay")
\stopverb}
}

\subtree{
\title{With SplitMixTernary}
\pre{\startverb
skill = TailscaleFileTransferSkill.new(seed: 42)
# Deterministic network simulation based on seed
\stopverb}
}
}

\subtree{
\title{API Reference}
\subtree{
\title{Main Methods}
\subtree{
\title{\code{\startverb play(file_path:, recipient:, strategy: :sequential)\stopverb}}
\p{Initiate file transfer (forward pass).}

\p{\strong{Returns}:}

\pre{\startverb
{
  transfer_id: "transfer_1766367227_40c17a23",
  file_path: "/path/to/file",
  recipient: "alice@coplay",
  bytes_sent: 22000,
  transfer_time: 0.012547,
  success: true,
  strategy: :sequential
}
\stopverb}
}

\subtree{
\title{\code{\startverb coplay(transfer_id:, delivered:, bytes_received:, transfer_time:)\stopverb}}
\p{Process receiver acknowledgment (backward pass).}

\p{\strong{Returns}:}

\pre{\startverb
{
  transfer_id: "transfer_...",
  delivered: true,
  utility: 1.0,                    # 0.0 to 1.0
  quality_bonus: 0.15,             # Speed + completeness
  backward_propagation: {
    sender_satisfaction: 1.0,
    network_efficiency: 16.77
  }
}
\stopverb}
}

\subtree{
\title{\code{\startverb transfer_stats()\stopverb}}
\p{Get aggregate transfer statistics.}

\p{\strong{Returns}:}

\pre{\startverb
{
  total_transfers: 3,
  successful_transfers: 3,
  success_rate: 100.0,
  total_bytes: 66000,
  total_time: 0.0385,
  average_throughput_kbps: 1706.6,
  average_transfer_size: 22000
}
\stopverb}
}

\subtree{
\title{\code{\startverb discover_mesh_peers()\stopverb}}
\p{Discover available Tailscale peers.}

\p{\strong{Returns}: Array of peer hashes with user, hostname, ip, status}
}

\subtree{
\title{\code{\startverb create_open_game()\stopverb}}
\p{Create composable OpenGame instance.}

\p{\strong{Returns}: OpenGame with strategy space and utility function}
}
}
}

\subtree{
\title{GF(3) Trit Semantics}
\pre{\startverb
| Trit | Direction | Role | Usage |
|------|-----------|------|-------|
| **-1** | Contravariant | Sender (wants receiver to succeed) | Backward perspective |
| **0** | Ergodic | Router/Network (observes transfer) | Neutral observation |
| **+1** | Covariant | Receiver (gets the benefit) | Forward perspective |
\stopverb}

\p{\strong{Skill Perspective}: \code{\startverb trit: 1\stopverb} (covariant) - Receiver's benefit is primary}
}

\subtree{
\title{Performance Characteristics}
\p{\strong{Throughput}:}

\ul{
\li{Sequential: 1706 KB/s (21.5KB in 0.01s)}
\li{Parallel: 1706 KB/s with 4 concurrent threads}
\li{Adaptive: 538 KB/s with dynamic chunk sizing}
}

\p{\strong{Memory}:}

\ul{
\li{Buffer: ~1MB per active transfer (CHUNK_SIZE)}
\li{Log: ~100 bytes per transfer record}
\li{Metadata: ~1KB per active transfer}
}

\p{\strong{Scalability}:}

\ul{
\li{Linear O(n) for sequential}
\li{Sublinear O(n/4) for parallel}
\li{Adaptive O(n/k) where k grows with stability}
}
}

