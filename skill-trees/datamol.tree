\subtree{
\title{Best Practices}
\ol{
\li{\strong{Always standardize molecules} from external sources:}
}

\ol{
\li{\strong{Check for None values} after molecule parsing:}
}

\ol{
\li{\strong{Use parallel processing} for large datasets:}
}

\ol{
\li{\strong{Leverage fsspec} for cloud storage:}
}

\ol{
\li{\strong{Use appropriate fingerprints} for similarity:}
\li{ECFP (Morgan): General purpose, structural similarity}
\li{MACCS: Fast, smaller feature space}
\li{Atom pairs: Considers atom pairs and distances}
}

\ol{
\li{\strong{Consider scale limitations}:}
\li{Butina clustering: ~1,000 molecules (full distance matrix)}
\li{For larger datasets: Use diversity selection or hierarchical methods}
}

\ol{
\li{\strong{Scaffold splitting for ML}: Ensure proper train/test separation by scaffold}
}

\ol{
\li{\strong{Align molecules} when visualizing SAR series}
}
}

\subtree{
\title{Error Handling}
\pre{\startverb
# Safe molecule creation
def safe_to_mol(smiles):
    try:
        mol = dm.to_mol(smiles)
        if mol is not None:
            mol = dm.standardize_mol(mol)
        return mol
    except Exception as e:
        print(f"Failed to process {smiles}: {e}")
        return None

# Safe batch processing
valid_mols = []
for smiles in smiles_list:
    mol = safe_to_mol(smiles)
    if mol is not None:
        valid_mols.append(mol)
\stopverb}
}

\subtree{
\title{Integration with Machine Learning}
\pre{\startverb
# Feature generation
X = np.array([dm.to_fp(mol) for mol in mols])

# Or descriptors
desc_df = dm.descriptors.batch_compute_many_descriptors(mols, n_jobs=-1)
X = desc_df.values

# Train model
from sklearn.ensemble import RandomForestRegressor
model = RandomForestRegressor()
model.fit(X, y_target)

# Predict
predictions = model.predict(X_test)
\stopverb}
}

\subtree{
\title{Troubleshooting}
\p{\strong{Issue}: Molecule parsing fails}

\ul{
\li{\strong{Solution}: Use \code{\startverb dm.standardize_smiles()\stopverb} first or try \code{\startverb dm.fix_mol()\stopverb}}
}

\p{\strong{Issue}: Memory errors with clustering}

\ul{
\li{\strong{Solution}: Use \code{\startverb dm.pick_diverse()\stopverb} instead of full clustering for large sets}
}

\p{\strong{Issue}: Slow conformer generation}

\ul{
\li{\strong{Solution}: Reduce \code{\startverb n_confs\stopverb} or increase \code{\startverb rms_cutoff\stopverb} to generate fewer conformers}
}

\p{\strong{Issue}: Remote file access fails}

\ul{
\li{\strong{Solution}: Ensure fsspec and appropriate cloud provider libraries are installed (s3fs, gcsfs, etc.)}
}
}

