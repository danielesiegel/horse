\subtree{
\title{Mathematical Foundation}
\subtree{
\title{Effect Polysimy}
\pre{\startverb
$$\text{Poly}(C) = \sum_{e \in \text{Effects}} e \circ C$$
\stopverb}

\p{Multiple effects acting on the same cell carrier.}
}

\subtree{
\title{Bisimulation Quotient}
\pre{\startverb
$$X / {\sim} \cong \text{codom}(\text{anamorphism to } \nu F)$$
\stopverb}

\p{Cells are equivalent iff they unfold to the same infinite stream.}
}

\subtree{
\title{Common Solution Existence}
\pre{\startverb
$$\exists \text{common} \iff H^0(\mathcal{U}, \mathcal{F}) \neq \emptyset$$
\stopverb}

\p{A common solution exists iff the zeroth cohomology is non-empty.}

\p{\strong{Skill Name}: polysimy-effect-chains \strong{Type}: Effect Coordination \strong{Trit}: 0 (ERGODIC) \strong{NOT IN}: plurigrid/asi (should be committed) \strong{GF(3)}: Coordinates between generators and validators}
}
}
}