\title{Affective Taxis}

\taxon{skill}

\meta{description}{"Affective valence as directional derivative of interoceptive energy landscape (Sennesh & Ramstead 2025)"}

\subtree{
\title{affective-taxis}
\blockquote{Affective valence = directional derivative of interoceptive energy landscape}

\p{\strong{Version}: 1.0.0 \strong{Trit}: -1 (MINUS - validates alignment via structural conservation) \strong{Bundle}: alignment \strong{Status}: Production (8 implementation paths, 9,500+ LOC)}

\subtree{
\title{Paper}
\p{\strong{Sennesh & Ramstead (2025)}: "An Affective-Taxis Hypothesis for Alignment and Interpretability" arXiv:2505.17024v1}
}

\subtree{
\title{Core Equations}
\subtree{
\title{Eq 3: Fold-Change Detection (reward = valence)}
\pre{\startverb
r(t) = nabla_z log gamma(z; beta) . v
\stopverb}

\p{The reward signal IS the directional derivative of the log-concentration along the velocity.}
}

\subtree{
\title{Eq 5: Langevin dynamics (navigation = Bayesian inference)}
\pre{\startverb
dz/dt = nabla_z log gamma(z; beta) + sqrt(2) dW(t)
\stopverb}

\p{Following the energy landscape gradient + stochastic exploration.}
}

\subtree{
\title{GF(3) Valence Classification}
\pre{\startverb
+1 (PLUS/GREEN)  : positive directional derivative -> approaching attractant
 0 (ERGODIC/YELLOW): orthogonal to gradient -> neutral taxis
-1 (MINUS/RED)   : negative directional derivative -> approaching repellent
\stopverb}

\p{\strong{Conservation law}: sum(trits) === 0 (mod 3) across trajectories.}
}
}

