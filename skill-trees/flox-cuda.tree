\subtree{
\title{CUDA Math Libraries}
\pre{\startverb
# team/cuda-math
[include]
environments = [{ remote = "team/cuda-base" }]

[install]
libcublas.pkg-path = "flox-cuda/cudaPackages_12_8.libcublas"
libcublas.priority = 2
libcublas.systems = ["aarch64-linux", "x86_64-linux"]

libcufft.pkg-path = "flox-cuda/cudaPackages_12_8.libcufft"
libcufft.priority = 2
libcufft.systems = ["aarch64-linux", "x86_64-linux"]

libcurand.pkg-path = "flox-cuda/cudaPackages_12_8.libcurand"
libcurand.priority = 2
libcurand.systems = ["aarch64-linux", "x86_64-linux"]
\stopverb}
}

\subtree{
\title{CUDA Debugging Tools}
\pre{\startverb
# team/cuda-debug
[install]
cuda-gdb.pkg-path = "flox-cuda/cudaPackages_12_8.cuda-gdb"
cuda-gdb.systems = ["aarch64-linux", "x86_64-linux"]

nsight-systems.pkg-path = "flox-cuda/cudaPackages_12_8.nsight-systems"
nsight-systems.systems = ["aarch64-linux", "x86_64-linux"]

[vars]
CUDA_LAUNCH_BLOCKING = "1"  # Synchronous kernel launches for debugging
\stopverb}
}

\subtree{
\title{Layer for Development}
\pre{\startverb
# Base CUDA environment
flox activate -r team/cuda-base

# Add debugging tools when needed
flox activate -r team/cuda-base -- flox activate -r team/cuda-debug
\stopverb}
}
}

\subtree{
\title{Testing CUDA Installation}
\subtree{
\title{Verify CUDA Compiler}
\pre{\startverb
nvcc --version
\stopverb}
}

\subtree{
\title{Check GPU Availability}
\pre{\startverb
nvidia-smi
\stopverb}
}

\subtree{
\title{Compile Test Program}
\pre{\startverb
cat > hello_cuda.cu << 'EOF'
#include <stdio.h>

__global__ void hello() {
    printf("Hello from GPU!\n");
}

int main() {
    hello<<<1,1>>>();
    cudaDeviceSynchronize();
    return 0;
}
EOF

nvcc hello_cuda.cu -o hello_cuda
./hello_cuda
\stopverb}
}

\subtree{
\title{Test PyTorch CUDA}
\pre{\startverb
import torch
print(f"CUDA available: {torch.cuda.is_available()}")
print(f"CUDA version: {torch.version.cuda}")
print(f"GPU count: {torch.cuda.device_count()}")
if torch.cuda.is_available():
    print(f"GPU name: {torch.cuda.get_device_name(0)}")
\stopverb}
}
}

\subtree{
\title{Best Practices}
\subtree{
\title{Always Use Priority Values}
\p{CUDA packages have predictable conflicts - assign explicit priorities}
}

\subtree{
\title{Version Consistency}
\p{Use specific versions (e.g., \code{\startverb _12_8\stopverb}) for reproducibility. Don't mix CUDA versions.}
}

\subtree{
\title{Modular Design}
\p{Split base CUDA, math libs, and debugging into separate environments for flexibility}
}

\subtree{
\title{Test Compilation}
\p{Verify \code{\startverb nvcc hello.cu -o hello\stopverb} works after setup}
}

\subtree{
\title{Platform Constraints}
\p{Always include \code{\startverb systems = ["aarch64-linux", "x86_64-linux"]\stopverb}}
}

\subtree{
\title{Memory Management}
\p{Set appropriate CUDA memory allocator configs:}

\pre{\startverb
[vars]
PYTORCH_CUDA_ALLOC_CONF = "max_split_size_mb:128"
CUDA_LAUNCH_BLOCKING = "0"  # Async by default
\stopverb}
}
}

\subtree{
\title{Common CUDA Gotchas}
\subtree{
\title{CUDA Toolkit ≠ Complete Toolkit}
\p{The cudatoolkit package doesn't include all libraries. Add what you need:}

\ul{
\li{libcublas for linear algebra}
\li{libcufft for FFT}
\li{cudnn for deep learning}
}
}

\subtree{
\title{License Conflicts}
\p{Every CUDA package may need explicit priority due to LICENSE file conflicts}
}

\subtree{
\title{No macOS Support}
\p{CUDA is Linux-only. Use Metal-accelerated packages on Darwin when available}
}

\subtree{
\title{Version Mixing}
\p{Don't mix CUDA versions. Use consistent \code{\startverb _X_Y\stopverb} suffixes across all CUDA packages}
}

\subtree{
\title{Python Virtual Environments}
\p{CUDA Python packages (PyTorch, TensorFlow) should be installed in venv with correct CUDA version}
}

\subtree{
\title{Driver Requirements}
\p{Ensure NVIDIA driver supports your CUDA version. Check with \code{\startverb nvidia-smi\stopverb}}
}
}

\subtree{
\title{Troubleshooting}
\subtree{
\title{CUDA Not Found}
\pre{\startverb
# Check CUDA_HOME
echo $CUDA_HOME

# Check nvcc
which nvcc
nvcc --version

# Check library paths
echo $LD_LIBRARY_PATH
\stopverb}
}

\subtree{
\title{PyTorch Not Using GPU}
\pre{\startverb
import torch
print(torch.cuda.is_available())  # Should be True
print(torch.version.cuda)         # Should match your CUDA version

# If False, reinstall with correct CUDA version
# uv pip install torch --index-url https://download.pytorch.org/whl/cu129
\stopverb}
}

\subtree{
\title{Compilation Errors}
\pre{\startverb
# Check gcc/g++ version
gcc --version
g++ --version

# Ensure gcc-unwrapped is installed
flox list | grep gcc-unwrapped

# Check include paths
echo $CPATH
echo $LIBRARY_PATH
\stopverb}
}

\subtree{
\title{Runtime Errors}
\pre{\startverb
# Check GPU visibility
echo $CUDA_VISIBLE_DEVICES

# Check for GPU
nvidia-smi

# Run with debug output
CUDA_LAUNCH_BLOCKING=1 python my_script.py
\stopverb}
}
}

