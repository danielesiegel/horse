\subtree{
\title{Troubleshooting}
\subtree{
\title{No tiles extracted}
\ul{
\li{Lower \code{\startverb tissue_percent\stopverb} threshold}
\li{Verify slide contains tissue (check thumbnail)}
\li{Ensure extraction_mask captures tissue regions}
\li{Check tile_size is appropriate for slide resolution}
}
}

\subtree{
\title{Many background tiles}
\ul{
\li{Enable \code{\startverb check_tissue=True\stopverb}}
\li{Increase \code{\startverb tissue_percent\stopverb} threshold}
\li{Use appropriate mask (TissueMask vs BiggestTissueBoxMask)}
\li{Customize mask filters to better detect tissue}
}
}

\subtree{
\title{Extraction very slow}
\ul{
\li{Extract at lower pyramid level (level=1 or 2)}
\li{Reduce \code{\startverb n_tiles\stopverb} for RandomTiler/ScoreTiler}
\li{Use RandomTiler instead of GridTiler for sampling}
\li{Use BiggestTissueBoxMask instead of TissueMask}
}
}

\subtree{
\title{Tiles have artifacts}
\ul{
\li{Implement custom annotation-exclusion masks}
\li{Adjust filter parameters for artifact removal}
\li{Increase small object removal threshold}
\li{Apply post-extraction quality filtering}
}
}

\subtree{
\title{Inconsistent results across slides}
\ul{
\li{Use same seed for RandomTiler}
\li{Normalize staining with preprocessing filters}
\li{Adjust \code{\startverb tissue_percent\stopverb} per staining quality}
\li{Implement slide-specific mask customization}
}
}
}

