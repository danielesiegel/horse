\subtree{
\title{Tenderloin: Manifest Destiny Fund for Protocol Labs}
\blockquote{The largest compositional investment vehicle targeting Protocol Labs ecosystem}

\subtree{
\title{Thesis}
\p{Tenderloin aims to become the dominant fund for Protocol Labs stack investments through:}

\ul{
\li{\strong{Colored Operads} = typed portfolio composition across PL protocols}
\li{\strong{Wiring Diagrams} = investment flow modeling between ecosystem projects}
\li{\strong{GF(3) Conservation} = balanced long/short/neutral positions}
\li{\strong{World-Generating Events} = protocol upgrades that create new market regimes}
}
}

