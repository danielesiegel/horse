\subtree{
\title{Quick Reference}
\subtree{
\title{Most Common Commands}
\pre{\startverb
# List modes
npx claude-flow sparc modes

# Run specific mode
npx claude-flow sparc run <mode> "task"

# TDD workflow
npx claude-flow sparc tdd "feature"

# Full pipeline
npx claude-flow sparc pipeline "task"

# Batch execution
npx claude-flow sparc batch <modes> "task"
\stopverb}
}

\subtree{
\title{Most Common MCP Calls}
\pre{\startverb
// Initialize swarm
mcp__claude-flow__swarm_init { topology: "hierarchical" }

// Execute mode
mcp__claude-flow__sparc_mode { mode: "coder", task_description: "..." }

// Monitor progress
mcp__claude-flow__swarm_monitor { interval: 5000 }

// Store in memory
mcp__claude-flow__memory_usage { action: "store", key: "...", value: "..." }
\stopverb}

\p{Remember: \strong{SPARC = Systematic, Parallel, Agile, Refined, Complete}}
}
}
}