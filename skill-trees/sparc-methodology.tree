\title{Sparc Methodology}

\taxon{skill}

\tag{}

\meta{version}{2.7.0}

\meta{description}{SPARC (Specification, Pseudocode, Architecture, Refinement, Completion) comprehensive development methodology with multi-agent orchestration}

\subtree{
\title{SPARC Methodology - Comprehensive Development Framework}
\subtree{
\title{Overview}
\p{SPARC (Specification, Pseudocode, Architecture, Refinement, Completion) is a systematic development methodology integrated with Claude Flow's multi-agent orchestration capabilities. It provides 17 specialized modes for comprehensive software development, from initial research through deployment and monitoring.}
}

\subtree{
\title{Table of Contents}
\ol{
\li{[Core Philosophy](#core-philosophy)}
\li{[Development Phases](#development-phases)}
\li{[Available Modes](#available-modes)}
\li{[Activation Methods](#activation-methods)}
\li{[Orchestration Patterns](#orchestration-patterns)}
\li{[TDD Workflows](#tdd-workflows)}
\li{[Best Practices](#best-practices)}
\li{[Integration Examples](#integration-examples)}
\li{[Common Workflows](#common-workflows)}
}
}

\subtree{
\title{Core Philosophy}
\p{SPARC methodology emphasizes:}

\ul{
\li{\strong{Systematic Approach}: Structured phases from specification to completion}
\li{\strong{Test-Driven Development}: Tests written before implementation}
\li{\strong{Parallel Execution}: Concurrent agent coordination for 2.8-4.4x speed improvements}
\li{\strong{Memory Integration}: Persistent knowledge sharing across agents and sessions}
\li{\strong{Quality First}: Comprehensive reviews, testing, and validation}
\li{\strong{Modular Design}: Clean separation of concerns with clear interfaces}
}

\subtree{
\title{Key Principles}
\ol{
\li{\strong{Specification Before Code}: Define requirements and constraints clearly}
\li{\strong{Design Before Implementation}: Plan architecture and components}
\li{\strong{Tests Before Features}: Write failing tests, then make them pass}
\li{\strong{Review Everything}: Code quality, security, and performance checks}
\li{\strong{Document Continuously}: Maintain current documentation throughout}
}
}
}

\subtree{
\title{Development Phases}
\subtree{
\title{Phase 1: Specification}
\p{\strong{Goal}: Define requirements, constraints, and success criteria}

\ul{
\li{Requirements analysis}
\li{User story mapping}
\li{Constraint identification}
\li{Success metrics definition}
\li{Pseudocode planning}
}

\p{\strong{Key Modes}: \code{\startverb researcher\stopverb}, \code{\startverb analyzer\stopverb}, \code{\startverb memory-manager\stopverb}}
}

\subtree{
\title{Phase 2: Architecture}
\p{\strong{Goal}: Design system structure and component interfaces}

\ul{
\li{System architecture design}
\li{Component interface definition}
\li{Database schema planning}
\li{API contract specification}
\li{Infrastructure planning}
}

\p{\strong{Key Modes}: \code{\startverb architect\stopverb}, \code{\startverb designer\stopverb}, \code{\startverb orchestrator\stopverb}}
}

\subtree{
\title{Phase 3: Refinement (TDD Implementation)}
\p{\strong{Goal}: Implement features with test-first approach}

\ul{
\li{Write failing tests}
\li{Implement minimum viable code}
\li{Make tests pass}
\li{Refactor for quality}
\li{Iterate until complete}
}

\p{\strong{Key Modes}: \code{\startverb tdd\stopverb}, \code{\startverb coder\stopverb}, \code{\startverb tester\stopverb}}
}

\subtree{
\title{Phase 4: Review}
\p{\strong{Goal}: Ensure code quality, security, and performance}

\ul{
\li{Code quality assessment}
\li{Security vulnerability scanning}
\li{Performance profiling}
\li{Best practices validation}
\li{Documentation review}
}

\p{\strong{Key Modes}: \code{\startverb reviewer\stopverb}, \code{\startverb optimizer\stopverb}, \code{\startverb debugger\stopverb}}
}

\subtree{
\title{Phase 5: Completion}
\p{\strong{Goal}: Integration, deployment, and monitoring}

\ul{
\li{System integration}
\li{Deployment automation}
\li{Monitoring setup}
\li{Documentation finalization}
\li{Knowledge capture}
}

\p{\strong{Key Modes}: \code{\startverb workflow-manager\stopverb}, \code{\startverb documenter\stopverb}, \code{\startverb memory-manager\stopverb}}
}
}

\subtree{
\title{Available Modes}
\subtree{
\title{Core Orchestration Modes}
\subtree{
\title{\code{\startverb orchestrator\stopverb}}
\p{Multi-agent task orchestration with TodoWrite/Task/Memory coordination.}

\p{\strong{Capabilities}:}

\ul{
\li{Task decomposition into manageable units}
\li{Agent coordination and resource allocation}
\li{Progress tracking and result synthesis}
\li{Adaptive strategy selection}
\li{Cross-agent communication}
}

\p{\strong{Usage}:}

\pre{\startverb
mcp__claude-flow__sparc_mode {
  mode: "orchestrator",
  task_description: "coordinate feature development",
  options: { parallel: true, monitor: true }
}
\stopverb}
}

\subtree{
\title{\code{\startverb swarm-coordinator\stopverb}}
\p{Specialized swarm management for complex multi-agent workflows.}

\p{\strong{Capabilities}:}

\ul{
\li{Topology optimization (mesh, hierarchical, ring, star)}
\li{Agent lifecycle management}
\li{Dynamic scaling based on workload}
\li{Fault tolerance and recovery}
\li{Performance monitoring}
}
}

\subtree{
\title{\code{\startverb workflow-manager\stopverb}}
\p{Process automation and workflow orchestration.}

\p{\strong{Capabilities}:}

\ul{
\li{Workflow definition and execution}
\li{Event-driven triggers}
\li{Sequential and parallel pipelines}
\li{State management}
\li{Error handling and retry logic}
}
}

\subtree{
\title{\code{\startverb batch-executor\stopverb}}
\p{Parallel task execution for high-throughput operations.}

\p{\strong{Capabilities}:}

\ul{
\li{Concurrent file operations}
\li{Batch processing optimization}
\li{Resource pooling}
\li{Load balancing}
\li{Progress aggregation}
}
}
}

\subtree{
\title{Development Modes}
\subtree{
\title{\code{\startverb coder\stopverb}}
\p{Autonomous code generation with batch file operations.}

\p{\strong{Capabilities}:}

\ul{
\li{Feature implementation}
\li{Code refactoring}
\li{Bug fixes and patches}
\li{API development}
\li{Algorithm implementation}
}

\p{\strong{Quality Standards}:}

\ul{
\li{ES2022+ standards}
\li{TypeScript type safety}
\li{Comprehensive error handling}
\li{Performance optimization}
\li{Security best practices}
}

\p{\strong{Usage}:}

\pre{\startverb
mcp__claude-flow__sparc_mode {
  mode: "coder",
  task_description: "implement user authentication with JWT",
  options: {
    test_driven: true,
    parallel_edits: true,
    typescript: true
  }
}
\stopverb}
}

\subtree{
\title{\code{\startverb architect\stopverb}}
\p{System design with Memory-based coordination.}

\p{\strong{Capabilities}:}

\ul{
\li{Microservices architecture}
\li{Event-driven design}
\li{Domain-driven design (DDD)}
\li{Hexagonal architecture}
\li{CQRS and Event Sourcing}
}

\p{\strong{Memory Integration}:}

\ul{
\li{Store architectural decisions}
\li{Share component specifications}
\li{Maintain design consistency}
\li{Track architectural evolution}
}

\p{\strong{Design Patterns}:}

\ul{
\li{Layered architecture}
\li{Microservices patterns}
\li{Event-driven patterns}
\li{Domain modeling}
\li{Infrastructure as Code}
}

\p{\strong{Usage}:}

\pre{\startverb
mcp__claude-flow__sparc_mode {
  mode: "architect",
  task_description: "design scalable e-commerce platform",
  options: {
    detailed: true,
    memory_enabled: true,
    patterns: ["microservices", "event-driven"]
  }
}
\stopverb}
}

\subtree{
\title{\code{\startverb tdd\stopverb}}
\p{Test-driven development with comprehensive testing.}

\p{\strong{Capabilities}:}

\ul{
\li{Test-first development}
\li{Red-green-refactor cycle}
\li{Test suite design}
\li{\startverb Coverage optimization (target: 90%+)\stopverb}
\li{Continuous testing}
}

\p{\strong{TDD Workflow}:}

\ol{
\li{Write failing test (RED)}
\li{Implement minimum code}
\li{Make test pass (GREEN)}
\li{Refactor for quality (REFACTOR)}
\li{Repeat cycle}
}

\p{\strong{Testing Strategies}:}

\ul{
\li{Unit testing (Jest, Mocha, Vitest)}
\li{Integration testing}
\li{End-to-end testing (Playwright, Cypress)}
\li{Performance testing}
\li{Security testing}
}

\p{\strong{Usage}:}

\pre{\startverb
mcp__claude-flow__sparc_mode {
  mode: "tdd",
  task_description: "shopping cart feature with payment integration",
  options: {
    coverage_target: 90,
    test_framework: "jest",
    e2e_framework: "playwright"
  }
}
\stopverb}
}

\subtree{
\title{\code{\startverb reviewer\stopverb}}
\p{Code review using batch file analysis.}

\p{\strong{Capabilities}:}

\ul{
\li{Code quality assessment}
\li{Security vulnerability detection}
\li{Performance analysis}
\li{Best practices validation}
\li{Documentation review}
}

\p{\strong{Review Criteria}:}

\ul{
\li{Code correctness and logic}
\li{Design pattern adherence}
\li{Comprehensive error handling}
\li{Test coverage adequacy}
\li{Maintainability and readability}
\li{Security vulnerabilities}
\li{Performance bottlenecks}
}

\p{\strong{Batch Analysis}:}

\ul{
\li{Parallel file review}
\li{Pattern detection}
\li{Dependency checking}
\li{Consistency validation}
\li{Automated reporting}
}

\p{\strong{Usage}:}

\pre{\startverb
mcp__claude-flow__sparc_mode {
  mode: "reviewer",
  task_description: "review authentication module PR #123",
  options: {
    security_check: true,
    performance_check: true,
    test_coverage_check: true
  }
}
\stopverb}
}
}

