\li{Radio stations = Schema objects (Table, Column, etc.)}
\li{Coverage radius = Morphism composability range}
\li{Signal overlap = Translatable concepts between schemas}
\li{Dead zones = Irreversible information loss}
}

\p{\strong{Betti Numbers for Schemas}:}

\ul{
\li{Œ≤‚ÇÄ: Connected components (isolated subsystems)}
