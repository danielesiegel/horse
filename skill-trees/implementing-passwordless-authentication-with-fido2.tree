\subtree{
\title{Implementing Passwordless Authentication with FIDO2}
\subtree{
\title{Overview}
\p{Deploy FIDO2/WebAuthn passwordless authentication using security keys and platform authenticators. Covers WebAuthn API integration, FIDO2 server configuration, passkey enrollment, biometric authentication, and migration from password-based systems aligned with NIST SP 800-63B AAL3.}
}

\subtree{
\title{When to Use}
\ul{
\li{When deploying or configuring implementing passwordless authentication with fido2 capabilities in your environment}
\li{When establishing security controls aligned to compliance requirements}
\li{When building or improving security architecture for this domain}
\li{When conducting security assessments that require this implementation}
}
}

