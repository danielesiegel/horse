\title{Reafference Corollary Discharge}

\taxon{skill}

\meta{description}{"Von Holst reafference and corollary discharge for behavioral verification and signal processing"}

\subtree{
\title{Skill: Reafference & Corollary Discharge (von Holst Neuroscience)}
\p{\strong{Category}: Behavioral Verification | Neural Mechanism Implementation \strong{Level}: Advanced (Requires understanding of: reafference theory, signal processing, corollary discharge) \strong{Status}: ✓ COMPLETE & OPERATIONAL \strong{Trit Assignment}: +1 (PLUS) - Active threat detection & signal amplification \strong{Propagates To}: codex, claude, amp, cursor, copilot}

\subtree{
\title{Overview}
\p{Implements \strong{von Holst's reafference theory} (1950) - a breakthrough neuroscience principle describing how organisms distinguish self-generated signals from external threats.}

\p{\strong{Core Principle}: > "The brain doesn't passively receive sensory feedback. It actively PREDICTS what feedback should occur and CANCELS it out. Only MISMATCHES between prediction and sensation reach conscious attention."}

\p{This skill applies this mechanism to interaction analysis, creating a complete:}

\ol{
\li{\strong{Efference Copy} (prediction) generation system}
\li{\strong{Sensory Reafference} (observation) matching}
\li{\strong{Comparator} (error signal) computation}
\li{\strong{Corollary Discharge} (suppression/amplification) mechanism}
}
}

\subtree{
\title{Key Features}
\subtree{
\title{1. Efference Copy Generation}
\ul{
\li{\strong{Input}: Interaction content (file paths, descriptions)}
\li{\strong{Method}: SHA-256 hash → color index mapping (1-5)}
\li{\strong{Output}: Deterministic predicted color for each interaction}
\li{\strong{Property}: Identical predictions for identical inputs}
}
}

\subtree{
\title{2. Sensory Reafference Matching}
\ul{
\li{\strong{Input}: Observed interaction history from ~/.claude/history.jsonl}
\li{\strong{Method}: Compare predicted vs observed colors}
\li{\strong{Output}: Match score (0.0 = mismatch, 1.0 = perfect match)}
\li{\strong{Property}: TAP state classification (LIVE/VERIFY/BACKFILL)}
}
}

\subtree{
\title{3. Comparator: Error Signal Computation}
\ul{
\li{\strong{Formula}: \code{\startverb error = expected - actual\stopverb}}
\li{\strong{Method}: Color distance in 5-color space}
\li{\strong{Output}: Error magnitude (0.0-1.0) and threat level}
\li{\strong{Threat Levels}:}
\li{\strong{SAFE}: error < 0.01 (99\% confidence in prediction)}
\li{\strong{WARNING}: 0.01 ≤ error < 0.2 (partial mismatch)}
\li{\strong{CRITICAL}: error ≥ 0.2 (major divergence)}
}
}

\subtree{
\title{4. Corollary Discharge: Suppression/Amplification}
\ul{
\li{\strong{Suppression}: If match_score ≥ 0.95 → Cancel signal from consciousness}
\li{\strong{Amplification}: If match_score < 0.95 → Escalate as threat}
\li{\strong{Result}: Perfect discrimination of self-generated from external}
}
}
}

