\subtree{
\title{BOM — Passives (0603 SMD, from schematic)}
\p{Core known values (exact values need Altium schematic export):}

\ul{
\li{\startverb 60.4k 1% x24 (TIA feedback)\stopverb}
\li{200pF x24 (TIA bandwidth, fc~13kHz)}
\li{100nF x60 (bypass, 2 per board + ECU)}
\li{4.7k x4 (I2C pullups)}
\li{LED current limit resistors x16}
}
}

