\subtree{
\title{BOM — PCBs (JLCPCB, after gerber export)}
\ul{
\li{24x sensor module (25mm circular)}
\li{1x ECU (112x112mm, 4-layer)}
\li{1x STLINK breakout}
}
}

\subtree{
\title{Cost Summary}
\pre{\startverb
| Category | Cost |
|----------|------|
| Semiconductors | ~$130 |
| Passives | ~$15 |
| PCBs | ~$13 |
| Amazon | ~$150 |
| **Total** | **~$310-420** |
\stopverb}
}

\subtree{
\title{Assembly}
\ol{
\li{Export gerbers from KiCad (after Altium import)}
\li{Order PCBs from JLCPCB}
\li{Order DigiKey + Amazon parts}
\li{Solder sensor modules (24x, SMD 0603 + photodiode + LED)}
\li{Solder ECU (QFP-64 MCU, SOT-23 MUXes, TSSOP PWM)}
\li{Wire cable harnesses (8 groups of 3 sensors)}
\li{3D print sensor capsules (STL from repo or design in OpenSCAD)}
\li{Flash firmware via SWD (ST-LINK)}
\li{Connect USB, run Python GUI}
\li{Calibrate on forehead, verify heart rate waveform first}
}
}

\subtree{
\title{bci.horse Integration}
\ul{
\li{Tree: bcf-0036 in plurigrid/horse}
\li{Inventory ID: planned, not yet ordered}
\li{\startverb Role: walk-up fNIRS fleet ($419/unit vs $50k NIRSport 2)\stopverb}
\li{Calibrate against Artinis Brite Lite (if purchased)}
}
}

\subtree{
\title{Firmware}
\p{Located in \code{\startverb firmware/STM32/fNIRS/\stopverb}. STM32CubeIDE project.}

\ul{
\li{MCU: STM32L476RET6, ARM Cortex-M4 80MHz}
\li{ADC: 12-bit, DMA, 5kHz raw sampling, multiplexed to 1kHz effective}
\li{USB: CDC serial via ADUM4160 isolator}
\li{PWM: PCA9685 drives LED sources, alternating 660/940nm}
\li{SD: SDMMC logging}
}
}

\subtree{
\title{Software}
\p{Located in \code{\startverb software/\stopverb}. Python 3.}

\ul{
\li{Flask-SocketIO backend for real-time streaming}
\li{Web GUI: Plotly.js + BrainNet Viewer 3D brain mesh}
\li{Modified Beer-Lambert Law processing (NIRSimple library)}
\li{Bandpass 0.01-0.5 Hz for cortical hemodynamics}
\li{Correlation-based signal improvement for HbO/HbR}
}
}

