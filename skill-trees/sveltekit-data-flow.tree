\li{[error-redirect-handling.md](references/error-redirect-handling.md) -}
\li{[client-auth-invalidation.md](references/client-auth-invalidation.md) -}
}
}

\subtree{
\title{Notes}
\ul{
\li{Server load → universal load via \code{\startverb data\stopverb} param | ALWAYS}
\li{No class instances/functions from server load (not serializable)}
\li{\strong{Last verified:} 2025-01-11}
}

