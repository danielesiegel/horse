\subtree{
\title{Important Notes}
\subtree{
\title{Data Usage and Attribution}
\ul{
\li{AlphaFold DB is freely available under CC-BY-4.0 license}
\li{Cite: Jumper et al. (2021) Nature and Varadi et al. (2022) Nucleic Acids Research}
\li{Predictions are computational models, not experimental structures}
\li{Always assess confidence metrics before downstream analysis}
}
}

\subtree{
\title{Version Management}
\ul{
\li{Current database version: v4 (as of 2024-2025)}
\li{File URLs include version suffix (e.g., \code{\startverb _v4.cif\stopverb})}
\li{Check for database updates regularly}
\li{Older versions may be deprecated over time}
}
}

\subtree{
\title{Data Quality Considerations}
\ul{
\li{High pLDDT doesn't guarantee functional accuracy}
\li{Low confidence regions may be disordered in vivo}
\li{PAE indicates relative domain confidence, not absolute positioning}
\li{Predictions lack ligands, post-translational modifications, and cofactors}
\li{Multi-chain complexes are not predicted (single chains only)}
}
}

\subtree{
\title{Performance Tips}
\ul{
\li{Use Biopython for simple single-protein access}
\li{Use Google Cloud for bulk downloads (much faster than individual files)}
\li{Cache downloaded files locally to avoid repeated downloads}
\li{BigQuery free tier: 1 TB processed data per month}
\li{Consider network bandwidth for large-scale downloads}
}
}
}

