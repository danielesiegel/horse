\subtree{
\title{Key Concepts}
\p{\strong{UniProt Accession:} Primary identifier for proteins (e.g., "P00520"). Required for querying AlphaFold DB.}

\p{\strong{AlphaFold ID:} Internal identifier format: \code{\startverb AF-[UniProt accession]-F[fragment number]\stopverb} (e.g., "AF-P00520-F1").}

\p{\strong{pLDDT (predicted Local Distance Difference Test):} Per-residue confidence metric (0-100). Higher values indicate more confident predictions.}

\p{\strong{PAE (Predicted Aligned Error):} Matrix indicating confidence in relative positions between residue pairs. Low values (<5 Å) suggest confident relative positioning.}

\p{\strong{Database Version:} Current version is v4. File URLs include version suffix (e.g., \code{\startverb model_v4.cif\stopverb}).}

\p{\strong{Fragment Number:} Large proteins may be split into fragments. Fragment number appears in AlphaFold ID (e.g., F1, F2).}
}

\subtree{
\title{Confidence Interpretation Guidelines}
\p{\strong{pLDDT Thresholds:}}

\ul{
\li{\strong{>90}: Very high confidence - suitable for detailed analysis}
\li{\strong{70-90}: High confidence - generally reliable backbone structure}
\li{\strong{50-70}: Low confidence - use with caution, flexible regions}
\li{\strong{<50}: Very low confidence - likely disordered or unreliable}
}

\p{\strong{PAE Guidelines:}}

\ul{
\li{\strong{<5 Å}: Confident relative positioning of domains}
\li{\strong{5-10 Å}: Moderate confidence in arrangement}
\li{\strong{>15 Å}: Uncertain relative positions, domains may be mobile}
}
}

