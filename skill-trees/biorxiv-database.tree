\title{Biorxiv Database}

\taxon{skill}

\meta{description}{Efficient database search tool for bioRxiv preprint server. Use this skill when searching for life sciences preprints by keywords, authors, date ranges, or categories, retrieving paper metadata, downloading PDFs, or conducting literature reviews.}

\subtree{
\title{bioRxiv Database}
\subtree{
\title{Overview}
\p{This skill provides efficient Python-based tools for searching and retrieving preprints from the bioRxiv database. It enables comprehensive searches by keywords, authors, date ranges, and categories, returning structured JSON metadata that includes titles, abstracts, DOIs, and citation information. The skill also supports PDF downloads for full-text analysis.}
}

\subtree{
\title{When to Use This Skill}
\p{Use this skill when:}

\ul{
\li{Searching for recent preprints in specific research areas}
\li{Tracking publications by particular authors}
\li{Conducting systematic literature reviews}
\li{Analyzing research trends over time periods}
\li{Retrieving metadata for citation management}
\li{Downloading preprint PDFs for analysis}
\li{Filtering papers by bioRxiv subject categories}
}
}

\subtree{
\title{Core Search Capabilities}
\subtree{
\title{1. Keyword Search}
\p{Search for preprints containing specific keywords in titles, abstracts, or author lists.}

\p{\strong{Basic Usage:}}

\pre{\startverb
python scripts/biorxiv_search.py \
  --keywords "CRISPR" "gene editing" \
  --start-date 2024-01-01 \
  --end-date 2024-12-31 \
  --output results.json
\stopverb}

\p{\strong{With Category Filter:}}

\pre{\startverb
python scripts/biorxiv_search.py \
  --keywords "neural networks" "deep learning" \
  --days-back 180 \
  --category neuroscience \
  --output recent_neuroscience.json
\stopverb}

\p{\strong{Search Fields:} By default, keywords are searched in both title and abstract. Customize with \code{\startverb --search-fields\stopverb}:}

\pre{\startverb
python scripts/biorxiv_search.py \
  --keywords "AlphaFold" \
  --search-fields title \
  --days-back 365
\stopverb}
}

\subtree{
\title{2. Author Search}
\p{Find all papers by a specific author within a date range.}

\p{\strong{Basic Usage:}}

\pre{\startverb
python scripts/biorxiv_search.py \
  --author "Smith" \
  --start-date 2023-01-01 \
  --end-date 2024-12-31 \
  --output smith_papers.json
\stopverb}

\p{\strong{Recent Publications:}}

\pre{\startverb
# Last year by default if no dates specified
python scripts/biorxiv_search.py \
  --author "Johnson" \
  --output johnson_recent.json
\stopverb}
}

\subtree{
\title{3. Date Range Search}
\p{Retrieve all preprints posted within a specific date range.}

\p{\strong{Basic Usage:}}

\pre{\startverb
python scripts/biorxiv_search.py \
  --start-date 2024-01-01 \
  --end-date 2024-01-31 \
  --output january_2024.json
\stopverb}

\p{\strong{With Category Filter:}}

\pre{\startverb
python scripts/biorxiv_search.py \
  --start-date 2024-06-01 \
  --end-date 2024-06-30 \
  --category genomics \
  --output genomics_june.json
\stopverb}

\p{\strong{Days Back Shortcut:}}

\pre{\startverb
# Last 30 days
python scripts/biorxiv_search.py \
  --days-back 30 \
  --output last_month.json
\stopverb}
}

\subtree{
\title{4. Paper Details by DOI}
\p{Retrieve detailed metadata for a specific preprint.}

\p{\strong{Basic Usage:}}

\pre{\startverb
python scripts/biorxiv_search.py \
  --doi "10.1101/2024.01.15.123456" \
  --output paper_details.json
\stopverb}

\p{\strong{Full DOI URLs Accepted:}}

\pre{\startverb
python scripts/biorxiv_search.py \
  --doi "https://doi.org/10.1101/2024.01.15.123456"
\stopverb}
}

\subtree{
\title{5. PDF Downloads}
\p{Download the full-text PDF of any preprint.}

\p{\strong{Basic Usage:}}

\pre{\startverb
python scripts/biorxiv_search.py \
  --doi "10.1101/2024.01.15.123456" \
  --download-pdf paper.pdf
\stopverb}

\p{\strong{Batch Processing:} For multiple PDFs, extract DOIs from a search result JSON and download each paper:}

\pre{\startverb
import json
from biorxiv_search import BioRxivSearcher

# Load search results
with open('results.json') as f:
    data = json.load(f)

searcher = BioRxivSearcher(verbose=True)

# Download each paper
for i, paper in enumerate(data['results'][:10]):  # First 10 papers
    doi = paper['doi']
    searcher.download_pdf(doi, f"papers/paper_{i+1}.pdf")
\stopverb}
}
}

