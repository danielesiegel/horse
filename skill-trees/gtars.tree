\subtree{
\title{Integration with geniml}
\p{Gtars serves as the foundation for the geniml Python package, providing core genomic interval operations for machine learning workflows. When working on geniml-related tasks, use gtars for data preprocessing and tokenization.}
}

\subtree{
\title{Performance Characteristics}
\ul{
\li{\strong{Native Rust performance}: Fast execution with low memory overhead}
\li{\strong{Parallel processing}: Multi-threaded operations for large datasets}
\li{\strong{Memory efficiency}: Streaming and memory-mapped file support}
\li{\strong{Zero-copy operations}: NumPy integration with minimal data copying}
}
}

\subtree{
\title{Data Formats}
\p{Gtars works with standard genomic formats:}

\ul{
\li{\strong{BED}: Genomic intervals (3-column or extended)}
\li{\strong{WIG/BigWig}: Coverage tracks}
\li{\strong{FASTA}: Reference sequences}
\li{\strong{Fragment TSV}: Single-cell fragment files with barcodes}
}
}

\subtree{
\title{Error Handling and Debugging}
\p{Enable verbose logging for troubleshooting:}

\pre{\startverb
import gtars

# Enable debug logging
gtars.set_log_level("DEBUG")
\stopverb}

\pre{\startverb
# CLI verbose mode
gtars --verbose <command>
\stopverb}
}
}