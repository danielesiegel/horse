\title{Rust}

\taxon{skill}

\meta{description}{Rust ecosystem = cargo + rustc + clippy + rustfmt.}

\subtree{
\title{rust}
\p{Rust ecosystem = cargo + rustc + clippy + rustfmt.}

\subtree{
\title{Atomic Skills}
\pre{\startverb
| Skill | Commands | Domain |
|-------|----------|--------|
| cargo | 36 | Package manager |
| rustc | 1 | Compiler |
| clippy | 1 | Linter |
| rustfmt | 1 | Formatter |
\stopverb}
}

\subtree{
\title{Workflow}
\pre{\startverb
cargo new project
cd project
cargo add serde tokio
cargo build --release
cargo test
cargo clippy
cargo fmt
\stopverb}
}

\subtree{
\title{Cargo.toml}
\pre{\startverb
[package]
name = "myapp"
version = "0.1.0"
edition = "2021"

[dependencies]
serde = { version = "1.0", features = ["derive"] }
tokio = { version = "1", features = ["full"] }
\stopverb}
}

\subtree{
\title{Cross-compile}
\pre{\startverb
rustup target add aarch64-apple-darwin
cargo build --target aarch64-apple-darwin
\stopverb}
}
}