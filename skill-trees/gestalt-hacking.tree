\subtree{
\title{Gestalt Hacking Skill (ERGODIC 0)}
\blockquote{*"Gestalt hacking exploits perceptual grouping—proximity, similarity, closure—in the color stream."*}

\subtree{
\title{Core Insight}
\p{\strong{Gestalt} = the whole pattern, the emergent structure that is more than the sum of parts. Gestalt hacking exploits how perception groups elements into wholes.}

\pre{\startverb
play ⊗ evaluate ⅋ play ⊗ evaluate → ι (fixed point)
\stopverb}

\p{The involution \code{\startverb ι\stopverb} is where generator ≡ observer (reafference).}
}

