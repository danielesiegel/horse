\subtree{
\title{Mathematical Properties}
\subtree{
\title{Stellar Resolution Properties}
\ol{
\li{\strong{Completeness}: If proof exists, stellar resolution finds it}
\li{\strong{Soundness}: All found proofs are valid}
\li{\strong{Termination}: Bounded by search space (with memoization)}
\li{\strong{Optimality}: Finds shortest proof first (breadth-first)}
}
}

\subtree{
\title{GF(3) Conservation}
\p{Proofs maintain \strong{color invariant}:}

\pre{\startverb
Σ(colors) ≡ 0 (mod 3)
\stopverb}

\p{This ensures:}

\ul{
\li{Deterministic proof search}
\li{Consistent branching decisions}
\li{No spurious solutions}
}
}

\subtree{
\title{Unification}
\p{\strong{Robinson's Algorithm} with extensions:}

\ul{
\li{Most general unifier (MGU)}
\li{Occurs check (prevents infinite structures)}
\li{Substitution composition}
\li{Support for higher-order terms}
}
}
}

