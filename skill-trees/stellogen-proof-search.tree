\title{Stellogen Proof Search}

\taxon{skill}

\meta{version}{0.1.0}

\meta{description}{Automated resolution-based proof search via stellar resolution and bidirectional unification}

\subtree{
\title{Stellogen Proof Search}
\p{\strong{Category:} Formal Verification - Automated Theorem Proving \strong{Status:} Production Ready (21 verified test cases) \strong{Dependencies:} \code{\startverb theorem-prover-orchestration\stopverb}}

\subtree{
\title{Overview}
\p{\strong{Stellogen} is a resolution-based prover using stellar resolution - bidirectional proof search with:}

\ul{
\li{\strong{Positive rays} = axioms (covariant, "what we know")}
\li{\strong{Negative rays} = goals (contravariant, "what we want")}
\li{\strong{Interaction} = cut elimination as color-matching (GF(3) conservation)}
}

\p{\strong{21 test files} covering automata, linear logic, Prolog, unification, and boolean logic.}
}

\subtree{
\title{Architecture}
\subtree{
\title{Stellar Resolution}
\pre{\startverb
Positive Rays (Axioms)          Negative Rays (Goals)
     ↓                                   ↓
  ⊕ types                         ⊖ goals
  ⊕ rules                         ⊖ subgoals
     ↓                                   ↓
     └─────── Interaction ────────────────┘
              (Cut Elimination)
                     ↓
              Color-matched proofs
              (GF(3) conserved)
\stopverb}
}

\subtree{
\title{Proof as Interaction}
\p{A \strong{proof} is a sequence of color-matched interactions between positive and negative rays:}

\ol{
\li{Forward pass: Positive rays advance toward goal}
\li{Backward pass: Negative rays advance toward axiom}
\li{Cut: Interaction where polarity flips}
\li{Color match: GF(3) conservation (sum ≡ 0 mod 3)}
}
}
}

