\subtree{
\title{Performance}
\ul{
\li{\strong{Search time}: 0.1-5 seconds per proof (depends on complexity)}
\li{\startverb **Memoization hit rate**: 95%+ on repeated queries\stopverb}
\li{\strong{Memory}: ~50MB for full test suite in cache}
\li{\strong{Scaling}: Polynomial in search space size}
}
}

\subtree{
\title{Example: Boolean Satisfiability (3-SAT)}
\p{Encode 3-SAT clause as Stellogen goal:}

\pre{\startverb
# (x₁ ∨ ¬x₂ ∨ x₃) ∧ (¬x₁ ∨ x₂ ∨ ¬x₃)

clause1 => {
  literals: [
    {atom: :x1, polarity: :positive},
    {atom: :x2, polarity: :negative},
    {atom: :x3, polarity: :positive}
  ]
}

# Proof search finds satisfying assignment via unification
\stopverb}
}

