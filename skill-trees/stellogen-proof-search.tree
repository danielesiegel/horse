\subtree{
\title{Key Algorithms}
\ol{
\li{\strong{Stellar Resolution} - Bidirectional cut elimination}
\li{\strong{Unification} - Robinson's algorithm with occurs check}
\li{\strong{Memoization} - Proof caching by goal signature}
\li{\strong{Breadth-First Search} - Optimal proof discovery}
\li{\strong{GF(3) Tracking} - Color conservation during search}
}
}

