\subtree{
\title{Formal Definition}
\subtree{
\title{Parametrised Optic}
\p{Given a monoidal category \code{\startverb (M, ⊗, I)\stopverb} acting on \code{\startverb C\stopverb} via \code{\startverb ⊛\stopverb}:}

\pre{\startverb
ParaOptic M C (S, S') (A, A') = ∫^P M(I, P) × C(P ⊛ S, A) × C(P ⊛ A', S')
\stopverb}

\p{This coend captures:}

\ul{
\li{\strong{Parameters} \code{\startverb P\stopverb} from the monoidal category \code{\startverb M\stopverb}}
\li{\strong{Forward map} \code{\startverb P ⊛ S → A\stopverb} (observation under parameters)}
\li{\strong{Backward map} \code{\startverb P ⊛ A' → S'\stopverb} (update under parameters)}
}
}

\subtree{
\title{Actegory}
\p{An \strong{actegory} is a category \code{\startverb C\stopverb} with an action \code{\startverb ⊛ : M × C → C\stopverb} satisfying:}

\ul{
\li{\code{\startverb I ⊛ X ≅ X\stopverb} (identity acts trivially)}
\li{\code{\startverb (P ⊗ Q) ⊛ X ≅ P ⊛ (Q ⊛ X)\stopverb} (associativity)}
}

\p{\strong{Agency} = choosing \code{\startverb P\stopverb} to steer \code{\startverb X\stopverb}.}
}
}

