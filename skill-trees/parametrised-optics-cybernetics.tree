\subtree{
\title{PCT as Parametrised Optic}
\pre{\startverb
-- Perceptual Control Theory as Para
pctController :: Para C Reference Perception
pctController = Para policy controlLoop
  where
    controlLoop (ref, percept) =
      let error = ref - percept
          action = gain * error
      in applyAction action percept
\stopverb}
}
}

\subtree{
\title{Open Games Connection}
\p{\strong{Open games} (Hedges) are parametrised optics for strategic interaction:}

\pre{\startverb
       ┌─────────────────┐
   X ──┤                 ├──▶ Y     (play)
       │   Open Game G   │
   R ◀─┤                 │◀── S     (coutility)
       └─────────────────┘
\stopverb}

\p{An open game \code{\startverb G : (X, S) → (Y, R)\stopverb} has:}

\ul{
\li{\strong{Play}: \code{\startverb X → Y\stopverb} (forward: strategy → outcome)}
\li{\strong{Coplay}: \code{\startverb X × S → R\stopverb} (backward: utility propagation)}
}

\p{This is exactly a \strong{parametrised optic} where:}

\ul{
\li{Parameters = strategies}
\li{⊛ = strategic interaction}
\li{Backward pass = utility/gradient flow}
}

\subtree{
\title{Nash Equilibria via Optics}
\pre{\startverb
-- Nash equilibrium = fixed point of best response
nashEquilibrium :: OpenGame X S Y R -> X -> Bool
nashEquilibrium game strategy =
  bestResponse game strategy == strategy
\stopverb}
}
}

