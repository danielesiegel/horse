\title{Parametrised Optics Cybernetics}

\taxon{skill}

\meta{trit}{0}

\meta{description}{Parametrised optics model cybernetic systems - dynamical systems steered by agents. ⊛ represents agency exerted on systems. Connects Para(C), lenses, open games, and PCT.}

\subtree{
\title{Parametrised Optics for Cybernetic Systems}
\p{\strong{Status}: Production Ready \strong{Trit}: 0 (ERGODIC - mediates agent↔system) \strong{Color}: #25D09C}

\blockquote{*"Parametrised optics model cybernetic systems, namely dynamical systems steered by one or more agents. Then ⊛ represents agency being exerted on systems."* — Capucci, Gavranović et al.}

\subtree{
\title{Core Structure}
\subtree{
\title{The ⊛ Action (Agency)}
\pre{\startverb
        ┌─────────────────────────────────────┐
        │         CYBERNETIC SYSTEM           │
        │                                     │
   P ───┼──⊛──▶ S ────────▶ S'               │
(params)│      (state)    (next state)        │
        │        │                            │
        │        ▼                            │
        │    observation ◀── environment      │
        │        │                            │
        │        ▼                            │
        │   P' ◀─┘ (updated params)           │
        └─────────────────────────────────────┘
\stopverb}

\p{The \strong{actegory action} ⊛ : P × S → S means:}

\ul{
\li{\strong{P} (parameters/policy) = agent's controllable degrees of freedom}
\li{\strong{S} (state) = system being controlled}
\li{\strong{⊛} = agency exerted: parameters steer the system}
}
}

\subtree{
\title{Para Construction}
\pre{\startverb
-- Para(C) is the category of parametrised morphisms in C
data Para c a b where
  Para :: c p () -> c (p, a) b -> Para c a b

-- Composition via tensor product of parameters
(>>>) :: Para c a b -> Para c b d -> Para c a d
Para p f >>> Para q g = Para (p ⊗ q) (f ; (id ⊗ g))
\stopverb}

\p{In \strong{Poly} (polynomial functors):}

\pre{\startverb
Para(Poly) ≅ Lens    -- parametrised polynomial = lens
\stopverb}
}

\subtree{
\title{Lens as Bidirectional Control}
\pre{\startverb
        get
    S ────────▶ A        (observation)
    │           │
    │    set    │
    ◀───────────┘        (action)
    S'    ◀── (S, B)
\stopverb}

\p{A \strong{lens} \code{\startverb Lens S A\stopverb} has:}

\ul{
\li{\code{\startverb get : S → A\stopverb} — observe part of state}
\li{\code{\startverb set : S × A → S\stopverb} — update state with new value}
}

\p{A \strong{parametrised lens} \code{\startverb PLens P S A\stopverb}:}

\ul{
\li{\code{\startverb get : P × S → A\stopverb} — observation depends on parameters}
\li{\code{\startverb set : P × S × A → S\stopverb} — action depends on parameters}
}
}
}

