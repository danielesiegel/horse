\title{Fnox Secrets}

\taxon{skill}

\meta{version}{2.0.0}

\meta{description}{fnox Secrets Management Skill - DIRECT PIPE ONLY}

\subtree{
\title{fnox Secrets Management Skill}
\pre{\startverb
name: fnox-secrets
description: Secure secrets management - SECRETS MUST NEVER BE EXPOSED IN CONTEXT
version: 2.0.0
trit: -1  # Validator/constrainer role in GF(3) triadic system
\stopverb}

\subtree{
\title{CRITICAL SECURITY RULE}
\p{\strong{SECRETS MUST NEVER APPEAR IN CLAUDE'S CONTEXT OR OUTPUT.}}

\p{The ONLY permitted pattern is direct piping into environment variables:}

\pre{\startverb
# CORRECT - secret never visible
SECRET_NAME=$(fnox get SECRET_NAME --age-key-file ~/.age/key.txt) command_that_uses_it

# FORBIDDEN - exposes secret to context
fnox get SECRET_NAME --age-key-file ~/.age/key.txt  # NEVER DO THIS
\stopverb}
}

\subtree{
\title{Permitted Operations}
\subtree{
\title{1. Direct Pipe to Environment Variable}
\pre{\startverb
# Pipe secret directly into env var for a command
MORPH_API_KEY=$(fnox get MORPH_API_KEY --age-key-file ~/.age/key.txt) uv run python script.py
APTOS_KEY=$(fnox get APTOS_ALICE_KEY --age-key-file ~/.age/key.txt) aptos move run ...
\stopverb}
}

\subtree{
\title{2. List Secret Names (NOT values)}
\pre{\startverb
fnox list  # Shows names only, never values
\stopverb}
}

\subtree{
\title{3. Check Secret Exists}
\pre{\startverb
fnox list | grep -q SECRET_NAME && echo "exists"
\stopverb}
}

\subtree{
\title{4. Set a Secret (user provides value, not Claude)}
\pre{\startverb
fnox set SECRET_NAME --provider myage  # User enters value interactively
\stopverb}
}
}

\subtree{
\title{FORBIDDEN Operations}
\ul{
\li{\code{\startverb fnox get SECRET\stopverb} without piping to a command}
\li{Storing secret output in a variable that gets logged}
\li{Printing, echoing, or displaying secret values}
\li{Including secrets in error messages or debug output}
\li{Any operation that would expose the secret in Claude's context}
}
}

\subtree{
\title{Architecture}
\pre{\startverb
┌─────────────────────────────────────────────────────────────────────────────┐
│  FNOX SECURE ARCHITECTURE                                                   │
├─────────────────────────────────────────────────────────────────────────────┤
│                                                                             │
│  ~/.age/key.txt ────────────────┐                                          │
│                                 │                                           │
│                                 ▼                                           │
│  fnox get ──▶ DECRYPTS ──▶ $(...) ──▶ ENV VAR ──▶ SUBPROCESS               │
│                    │                                                        │
│                    └──▶ NEVER TO STDOUT/CONTEXT                            │
│                                                                             │
└─────────────────────────────────────────────────────────────────────────────┘
\stopverb}
}

\subtree{
\title{Usage Examples}
\subtree{
\title{Morph Cloud}
\pre{\startverb
MORPH_API_KEY=$(fnox get MORPH_API_KEY --age-key-file ~/.age/key.txt) uv run python -c "
from morphcloud.api import MorphCloudClient
client = MorphCloudClient()
# ... use client
"
\stopverb}
}

\subtree{
\title{Aptos}
\pre{\startverb
APTOS_PRIVATE_KEY=$(fnox get APTOS_ALICE_KEY --age-key-file ~/.age/key.txt) aptos move run \
  --function-id 0x1::coin::transfer \
  --args address:0x... u64:1000000
\stopverb}
}

\subtree{
\title{Multiple Secrets}
\pre{\startverb
# Chain multiple secrets in one command
MORPH_API_KEY=$(fnox get MORPH_API_KEY --age-key-file ~/.age/key.txt) \
DUNE_API_KEY=$(fnox get DUNE_API_KEY --age-key-file ~/.age/key.txt) \
  python my_script.py
\stopverb}
}
}

\subtree{
\title{Available Secrets (names only)}
\p{Query with: \code{\startverb fnox list\stopverb}}

\p{Categories:}

\ul{
\li{\code{\startverb APTOS_*\stopverb} - Blockchain keys}
\li{\code{\startverb MORPH_API_KEY\stopverb} - Morph Cloud}
\li{\code{\startverb DUNE_API_KEY\stopverb} - Dune Analytics}
\li{\code{\startverb AMP_API_KEY\stopverb} - AMP}
\li{\code{\startverb BEEPER_ACCESS_TOKEN\stopverb} - Beeper}
}
}

\subtree{
\title{GF(3) Trit Assignment}
\pre{\startverb
fnox-secrets: -1 (validator/constrainer)
\stopverb}

\p{Participates in triads:}

\pre{\startverb
fnox-secrets (-1) ⊗ world-runtime (0) ⊗ gay-mcp (+1) = 0 ✓
\stopverb}
}

\subtree{
\title{1Password Provider Bridge}
\p{fnox natively supports 1Password as a provider backend. Secrets stored in 1Password can be accessed through the same \code{\startverb fnox get\stopverb} interface.}

\subtree{
\title{Setup}
\pre{\startverb
# Add 1Password as a provider
fnox provider add op 1password

# Configure vault in fnox.toml
\stopverb}

\pre{\startverb
# fnox.toml
[providers.op]
type = "1password"
vault = "Employee"
\stopverb}
}

\subtree{
\title{Defining 1Password-backed Secrets}
\p{Use \code{\startverb op://\stopverb} secret references as the value:}

\pre{\startverb
[secrets.MY_API_KEY]
provider = "op"
value = "op://Employee/MyAPIKey/password"
\stopverb}
}

\subtree{
\title{Usage (same interface as age secrets)}
\pre{\startverb
# CORRECT - direct pipe, secret never in context
eval $(op signin)
MY_API_KEY=$(fnox get MY_API_KEY --age-key-file ~/.age/key.txt) ./my-command

# Works identically to age-backed secrets
MORPH_API_KEY=$(fnox get MORPH_API_KEY --age-key-file ~/.age/key.txt) \
MY_API_KEY=$(fnox get MY_API_KEY --age-key-file ~/.age/key.txt) \
  python my_script.py
\stopverb}
}

\subtree{
\title{Mixed Provider Architecture}
\pre{\startverb
┌─────────────────────────────────────────────────────────────┐
│  fnox get SECRET_NAME                                        │
│       │                                                      │
│       ├── provider = "myage" ──▶ age decrypt (local/offline) │
│       │                                                      │
│       └── provider = "op" ──▶ op read op://... (1Password)   │
│                                  │                           │
│                                  └── requires eval $(op signin) │
│                                                              │
│  Both paths ──▶ $(...) ──▶ ENV VAR ──▶ SUBPROCESS            │
│                     └──▶ NEVER TO STDOUT/CONTEXT             │
└─────────────────────────────────────────────────────────────┘
\stopverb}
}

\subtree{
\title{When to Use Which Provider}
\pre{\startverb
| Provider | Use Case |
|----------|----------|
| `myage` (age) | Offline access, CI/CD, air-gapped systems |
| `op` (1Password) | Team-shared secrets, credential rotation, audit trail |
\stopverb}
}
}
}