\subtree{
\title{Passage Time as Profunctor}
\pre{\startverb
G: ℤ₊² ↛ ℝ
G(start, end) = max path weight
\stopverb}

\p{Satisfies semi-group property:}

\pre{\startverb
G(a, c) = max_b [G(a, b) + G(b, c)]
\stopverb}
}

