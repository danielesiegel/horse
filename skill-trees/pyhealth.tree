\subtree{
\title{Best Practices}
\subtree{
\title{Data Handling}
\ol{
\li{\strong{Always split by patient}: Prevent data leakage by ensuring no patient appears in multiple splits}
}

\ol{
\li{\strong{Check dataset statistics}: Understand your data before modeling}
}

\ol{
\li{\strong{Use appropriate preprocessing}: Match processors to data types (see \code{\startverb references/preprocessing.md\stopverb})}
}
}

\subtree{
\title{Model Development}
\ol{
\li{\strong{Start with baselines}: Establish baseline performance with simple models}
\li{Logistic Regression for binary/multi-class tasks}
\li{MLP for initial deep learning baseline}
}

\ol{
\li{\strong{Choose task-appropriate models}:}
\li{Interpretability needed → RETAIN, AdaCare}
\li{Drug recommendation → SafeDrug, GAMENet}
\li{Long sequences → Transformer}
\li{Graph relationships → GNN}
}

\ol{
\li{\strong{Monitor validation metrics}: Use appropriate metrics for task and handle class imbalance}
\li{Binary classification: AUROC, AUPRC (especially for rare events)}
\li{Multi-class: macro-F1 (for imbalanced), weighted-F1}
\li{Multi-label: Jaccard, example-F1}
\li{Regression: MAE, RMSE}
}
}

\subtree{
\title{Clinical Deployment}
\ol{
\li{\strong{Calibrate predictions}: Ensure probabilities are reliable (see \code{\startverb references/training_evaluation.md\stopverb})}
}

\ol{
\li{\strong{Assess fairness}: Evaluate across demographic groups to detect bias}
}

\ol{
\li{\strong{Quantify uncertainty}: Provide confidence estimates for predictions}
}

\ol{
\li{\strong{Interpret predictions}: Use attention weights, SHAP, or ChEFER for clinical trust}
}

\ol{
\li{\strong{Validate thoroughly}: Use held-out test sets from different time periods or sites}
}
}
}

\subtree{
\title{Limitations and Considerations}
\subtree{
\title{Data Requirements}
\ul{
\li{\strong{Large datasets}: Deep learning models require sufficient data (thousands of patients)}
\li{\strong{Data quality}: Missing data and coding errors impact performance}
\li{\strong{Temporal consistency}: Ensure train/test split respects temporal ordering when needed}
}
}

\subtree{
\title{Clinical Validation}
\ul{
\li{\strong{External validation}: Test on data from different hospitals/systems}
\li{\strong{Prospective evaluation}: Validate in real clinical settings before deployment}
\li{\strong{Clinical review}: Have clinicians review predictions and interpretations}
\li{\strong{Ethical considerations}: Address privacy (HIPAA/GDPR), fairness, and safety}
}
}

\subtree{
\title{Computational Resources}
\ul{
\li{\strong{GPU recommended}: For training deep learning models efficiently}
\li{\strong{Memory requirements}: Large datasets may require 16GB+ RAM}
\li{\strong{Storage}: Healthcare datasets can be 10s-100s of GB}
}
}
}

\subtree{
\title{Troubleshooting}
\subtree{
\title{Common Issues}
\p{\strong{ImportError for dataset}:}

\ul{
\li{Ensure dataset files are downloaded and path is correct}
\li{Check PyHealth version compatibility}
}

\p{\strong{Out of memory}:}

\ul{
\li{Reduce batch size}
\li{Reduce sequence length (\code{\startverb max_seq_length\stopverb})}
\li{Use gradient accumulation}
\li{Process data in chunks}
}

\p{\strong{Poor performance}:}

\ul{
\li{Check class imbalance and use appropriate metrics (AUPRC vs AUROC)}
\li{Verify preprocessing (normalization, missing data handling)}
\li{Increase model capacity or training epochs}
\li{Check for data leakage in train/test split}
}

\p{\strong{Slow training}:}

\ul{
\li{Use GPU (\code{\startverb device="cuda"\stopverb})}
\li{Increase batch size (if memory allows)}
\li{Reduce sequence length}
\li{Use more efficient model (CNN vs Transformer)}
}
}

