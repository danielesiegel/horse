\subtree{
\title{Integration with Other Skills}
\subtree{
\title{With epistemic-arbitrage}
\p{Roderick's "masters of suspicion" provide the foundational knowledge differential:}

\pre{\startverb
# Arbitrage between naive consciousness and critical theory
propagator = Propagator.new(:suspicion_transfer) do |naive, critical|
  [:marx, :nietzsche, :freud].each do |master|
    critical.merge(:suspicion, naive.unmask(master))
  end
end
\stopverb}
}

\subtree{
\title{With glass-bead-game}
\p{The three lecture series form a perfect triad for interdisciplinary synthesis:}

\pre{\startverb
Philosophy & Human Values ←→ Nietzsche ←→ Self Under Siege
        (MINUS)                (ERGODIC)        (PLUS)
        history                critique         diagnosis
\stopverb}
}

\subtree{
\title{With world-hopping}
\p{Each philosopher represents a possible world:}

\pre{\startverb
d(naive_faith, critical_theory) ≤ d(naive, marx) + d(marx, nietzsche) + d(nietzsche, freud)
\stopverb}
}
}

\subtree{
\title{GF(3) Structure}
\pre{\startverb
| Polarity | Role | Representative |
|----------|------|----------------|
| MINUS (−1) | Destruction of illusion | Nietzsche, Foucault, Derrida |
| ERGODIC (0) | Critical analysis | Marx, Habermas, Roderick himself |
| PLUS (+1) | Reconstruction attempt | Sartre, Marcuse, hope for democracy |
\stopverb}

\p{\strong{Conservation}: Every lecture balances critique (−) with analysis (0) and hope (+).}
}

