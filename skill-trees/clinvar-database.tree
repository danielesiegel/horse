}

\subtree{
\title{Important Limitations and Considerations}
\subtree{
\title{Data Quality}
\ul{
\li{\strong{Not all submissions have equal weight} - Check review status (star ratings)}
\li{\strong{Conflicting interpretations exist} - Require manual evaluation}
\li{\strong{Historical submissions may be outdated} - Newer data may be more accurate}
\li{\strong{VUS classification is not a clinical diagnosis} - Means insufficient evidence}
}
}

\subtree{
\title{Scope Limitations}
\ul{
\li{\strong{Not for direct clinical diagnosis} - Always involve genetics professional}
\li{\strong{Population-specific} - Variant frequencies vary by ancestry}
\li{\strong{Incomplete coverage} - Not all genes or variants are well-studied}
\li{\strong{Version dependencies} - Coordinate genome build (GRCh37/GRCh38) across analyses}
}
}

\subtree{
\title{Technical Limitations}
\ul{
\li{\strong{VCF files exclude large variants} - Variants >10kb not in VCF format}
\li{\strong{Rate limits on API} - 3 req/sec without key, 10 req/sec with API key}
\li{\strong{File sizes} - Full XML releases are multi-GB compressed files}
\li{\strong{No real-time updates} - Website updated weekly, FTP monthly/weekly}
}
}
}

