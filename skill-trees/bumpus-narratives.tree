\subtree{
\title{Core Concepts}
\subtree{
\title{1. Narratives as Sheaves}
\p{Temporal data = sheaf F: I_N → D where:}

\ul{
\li{I_N = time category (intervals [a,b] with inclusions)}
\li{D = data category with pullbacks}
\li{Sheaf condition: F([a,b]) = F([a,p]) ×_{F([p,p])} F([p,b])}
}

\pre{\startverb
F₁³ := {(x,y) ∈ F₁² × F₂³ | f₁,₂²(x) = f₂,₃²(y)}
\stopverb}
}

\subtree{
\title{2. Adhesion Filter (FPT Algorithm)}
\p{For tree decompositions of width w:}

\ul{
\li{Complexity: O(f(w) · n) instead of O(2^n)}
\li{Runs on bag boundaries via pullback checking}
}

\pre{\startverb
function adhesion_filter(sheaf::Sheaf, decomp::TreeDecomp)
    for (bag1, bag2) in edges(decomp)
        adhesion = bag1 ∩ bag2
        if !is_pullback(sheaf, bag1, bag2, adhesion)
            return false
        end
    end
    true
end
\stopverb}
}

\subtree{
\title{3. Cohomological Obstructions}
\p{H⁰ detects local-to-global failure:}

\ul{
\li{H⁰(F) ≠ 0 → obstruction to gluing}
\li{Čech complex on cover of intervals}
}
}
}

\subtree{
\title{Integration with Gay.jl}
\subtree{
\title{Color-Coded Narratives}
\p{Each interval [i,j] gets deterministic color:}

\pre{\startverb
color([i,j]) = gay_color(BUMPUS_SEED ⊻ hash(i,j))
\stopverb}
}

\subtree{
\title{GF(3) Conservation}
\p{Narrative operations preserve triadic balance:}

\ul{
\li{\strong{Restriction} (-1): F([a,b]) → F([a,a])}
\li{\strong{Extension} (+1): F([a,a]) → F([a,b])}
\li{\strong{Pullback} (0): F₁³ := fibered product}
}
}
}

