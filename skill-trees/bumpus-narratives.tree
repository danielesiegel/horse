\subtree{
\title{Example: Ice Cream Companies}
\p{From the Venice ice cream example (Diagram 1):}

\pre{\startverb
Time 1: {a₁, a₂, b, c}  →  Time 2: {a*, b, c}  →  Time 3: {a*, b}
\stopverb}

\p{The sheaf tracks:}

\ul{
\li{Company mergers (a₁, a₂ → a*)}
\li{Company disappearance (c)}
\li{Supplier relationships (graph morphisms)}
}
}

\subtree{
\title{API}
\pre{\startverb
using BumpusNarratives

# Create narrative
n = Narrative(TimeCategory(1:10), FinSet)

# Add snapshots
add_snapshot!(n, 1, Set([:a, :b, :c]))
add_snapshot!(n, 2, Set([:a, :b]))

# Check sheaf condition
is_sheaf(n)  # true if pullbacks exist

# Compute H⁰ obstruction
obstruction = cech_H0(n)
\stopverb}
}

