\subtree{
\title{Ostium DEX Jurisdiction Map}
\p{\strong{Restricted (BLOCKED):}}

\ul{
\li{United States}
\li{Iran, Syria, Cuba, North Korea}
\li{Crimea, Donetsk, Luhansk (Ukraine occupied territories)}
\li{Any jurisdiction under comprehensive US economic sanctions}
}

\p{\strong{Allowed:} Everything else. No whitelist — just the blacklist above.}

\p{\strong{Key facts:}}

\ul{
\li{No KYC, connect via Web3 wallet or email}
\li{Built on Arbitrum, 31+ markets, up to 200x leverage}
\li{VPN circumvention explicitly prohibited in ToS for restricted persons}
\li{Chernivtsi, Kyiv, Lviv, Odesa — all clean Ukrainian cities (not restricted regions)}
}
}

\subtree{
\title{Setup Checklist}
\pre{\startverb
- [ ] Mullvad account (anonymous, pay with crypto)
- [ ] WireGuard config for ua-kyv exit
- [ ] Verify IP: curl -s https://am.i.mullvad.net/json | jq '.ip, .country'
- [ ] Arbitrum wallet funded (bridge from L1 or CEX withdraw to Arbitrum)
- [ ] Connect to app.ostium.com, verify no geo-block
\stopverb}
}

