\title{Hythermal}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{HyThermal Skill}

\subtree{
\title{HyThermal Skill}
\blockquote{Hy + Thermal: Relational ACSet dynamics with Langevin temperature control}

\p{\strong{Version}: 1.0.0 \strong{Trit}: 0 (ERGODIC - bridges relational structure and thermal flow) \strong{Bundle}: dynamics \strong{Fusion of}: \code{\startverb hyjax-relational\stopverb} + \code{\startverb langevin-dynamics\stopverb}}

\subtree{
\title{Overview}
\p{\strong{HyThermal} fuses relational thinking (ACSets/C-Sets) with Langevin dynamics for temperature-controlled exploration of concept spaces. Instead of treating thread analysis as static graphs, HyThermal models concepts as particles in a thermal bath:}

\ul{
\li{\strong{Concepts} = Particles with positions in embedding space}
\li{\strong{Relations} = Potential energy between particles}
\li{\strong{Temperature} = Exploration vs exploitation control}
\li{\strong{Fokker-Planck} = Equilibrium distribution of concept activations}
}
}

\subtree{
\title{Core Equation}
\pre{\startverb
dC(t) = -∇E(C(t)) dt + √(2T) dW(t)

Where:
  C = concept embedding positions
  E = relational energy (sum of edge potentials)
  T = temperature (exploration parameter)
  dW = Brownian motion (seeded via Gay.jl)
\stopverb}

\p{At equilibrium: \code{\startverb p∞(C) ∝ exp(-E(C)/T)\stopverb} — Concepts cluster near low-energy (high-coherence) configurations.}
}

\subtree{
\title{Hy Syntax for Thermal ACSet}
\pre{\startverb
;; Define thermal schema
(defschema ThermalThread
  (Ob Thread Message Concept)
  (Hom thread_msg (-> Message Thread)
       discusses (-> Message Concept)
       related (-> Concept Concept))
  (Attr position (-> Concept R^n)
        temperature (-> Thread Float)
        energy (-> Concept Float)))

;; Langevin step in Hy
(defn thermal-step [acset dt T seed]
  (let [concepts (parts acset :Concept)
        gradient (compute-relational-gradient acset)
        noise (gay-randn seed (len concepts))]
    (for [c concepts]
      (setv (. acset [:position c])
            (+ (. acset [:position c])
               (* (- dt) (get gradient c))
               (* (sqrt (* 2 T dt)) (get noise c)))))))

;; Run to equilibrium
(defn thermal-equilibrate [acset T n-steps seed]
  (for [step (range n-steps)]
    (thermal-step acset 0.01 T (gay-split seed step)))
  acset)
\stopverb}
}

\subtree{
\title{Colored Thermal S-expressions}
\pre{\startverb
(thermal-acset-gold
  (threads-red
    (thread T-001 :temp 0.01 :energy -4.52)
    (thread T-002 :temp 0.1 :energy -2.18))
  (concepts-green
    (concept skill :pos [0.3 0.7] :trit +1)
    (concept MCP :pos [0.5 0.2] :trit 0)
    (concept thermal :pos [0.8 0.9] :trit -1))
  (relations-purple
    (edge skill MCP :weight 2 :potential -0.8)
    (edge MCP thermal :weight 1 :potential -0.3)))
\stopverb}
}

\subtree{
\title{Relational Energy Function}
\pre{\startverb
def relational_energy(acset, positions):
    """
    E(C) = Σ_edges w_ij * d(c_i, c_j)^2 - Σ_hubs hub_score(c)

    Low energy = Concepts tightly connected + high hub scores
    """
    E = 0.0
    for edge in acset.parts('related'):
        i, j = acset.src(edge), acset.tgt(edge)
        w = acset.attr(edge, 'weight')
        E += w * np.linalg.norm(positions[i] - positions[j])**2

    for c in acset.parts('Concept'):
        E -= acset.attr(c, 'hub_score')

    return E
\stopverb}
}

