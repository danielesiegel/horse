\subtree{
\title{Best Practices}
\ol{
\li{\strong{Pre-register analyses} when possible to distinguish confirmatory from exploratory}
\li{\strong{Always check assumptions} before interpreting results}
\li{\strong{Report effect sizes} with confidence intervals}
\li{\strong{Report all planned analyses} including non-significant results}
\li{\strong{Distinguish statistical from practical significance}}
\li{\strong{Visualize data} before and after analysis}
\li{\strong{Check diagnostics} for regression/ANOVA (residual plots, VIF, etc.)}
\li{\strong{Conduct sensitivity analyses} to assess robustness}
\li{\strong{Share data and code} for reproducibility}
\li{\strong{Be transparent} about violations, transformations, and decisions}
}
}

\subtree{
\title{Common Pitfalls to Avoid}
\ol{
\li{\strong{P-hacking}: Don't test multiple ways until something is significant}
\li{\strong{HARKing}: Don't present exploratory findings as confirmatory}
\li{\strong{Ignoring assumptions}: Check them and report violations}
\li{\strong{Confusing significance with importance}: p < .05 ≠ meaningful effect}
\li{\strong{Not reporting effect sizes}: Essential for interpretation}
\li{\strong{Cherry-picking results}: Report all planned analyses}
\li{\strong{Misinterpreting p-values}: They're NOT probability that hypothesis is true}
\li{\strong{Multiple comparisons}: Correct for family-wise error when appropriate}
\li{\strong{Ignoring missing data}: Understand mechanism (MCAR, MAR, MNAR)}
\li{\strong{Overinterpreting non-significant results}: Absence of evidence ≠ evidence of absence}
}
}

\subtree{
\title{Getting Started Checklist}
\p{When beginning a statistical analysis:}

\ul{
\li{[ ] Define research question and hypotheses}
\li{[ ] Determine appropriate statistical test (use test_selection_guide.md)}
\li{[ ] Conduct power analysis to determine sample size}
\li{[ ] Load and inspect data}
\li{[ ] Check for missing data and outliers}
\li{[ ] Verify assumptions using assumption_checks.py}
\li{[ ] Run primary analysis}
\li{[ ] Calculate effect sizes with confidence intervals}
\li{[ ] Conduct post-hoc tests if needed (with corrections)}
\li{[ ] Create visualizations}
\li{[ ] Write results following reporting_standards.md}
\li{[ ] Conduct sensitivity analyses}
\li{[ ] Share data and code}
}
}

