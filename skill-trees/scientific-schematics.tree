\subtree{
\title{Quick Reference Checklist}
\p{Before submitting diagrams, verify:}

\subtree{
\title{Visual Quality}
\ul{
\li{[ ] High-quality image format (PNG from AI generation)}
\li{[ ] No overlapping elements (AI handles automatically)}
\li{[ ] Adequate spacing between all components (AI optimizes)}
\li{[ ] Clean, professional alignment}
\li{[ ] All arrows connect properly to intended targets}
}
}

\subtree{
\title{Accessibility}
\ul{
\li{[ ] Colorblind-safe palette (Okabe-Ito) used}
\li{[ ] Works in grayscale (tested with accessibility checker)}
\li{[ ] Sufficient contrast between elements (verified)}
\li{[ ] Redundant encoding where appropriate (shapes + colors)}
\li{[ ] Colorblind simulation passes all checks}
}
}

\subtree{
\title{Typography and Readability}
\ul{
\li{[ ] Text minimum 7-8 pt at final size}
\li{[ ] All elements labeled clearly and completely}
\li{[ ] Consistent font family and sizing}
\li{[ ] No text overlaps or cutoffs}
\li{[ ] Units included where applicable}
}
}

\subtree{
\title{Publication Standards}
\ul{
\li{[ ] Consistent styling with other figures in manuscript}
\li{[ ] Comprehensive caption written with all abbreviations defined}
\li{[ ] Referenced appropriately in manuscript text}
\li{[ ] Meets journal-specific dimension requirements}
\li{[ ] Exported in required format for journal (PDF/EPS/TIFF)}
}
}

\subtree{
\title{Quality Verification (Required)}
\ul{
\li{[ ] Ran \code{\startverb run_quality_checks()\stopverb} and achieved PASS status}
\li{[ ] Reviewed overlap detection report (zero high-severity overlaps)}
\li{[ ] Passed accessibility verification (grayscale and colorblind)}
\li{[ ] Resolution validated at target DPI (300+ for print)}
\li{[ ] Visual quality report generated and reviewed}
\li{[ ] All quality reports saved with figure files}
}
}

\subtree{
\title{Documentation and Version Control}
\ul{
\li{[ ] Source files (.tex, .py) saved for future revision}
\li{[ ] Quality reports archived in \code{\startverb quality_reports/\stopverb} directory}
\li{[ ] Configuration parameters documented (colors, spacing, sizes)}
\li{[ ] Git commit includes source, output, and quality reports}
\li{[ ] README or comments explain how to regenerate figure}
}
}

\subtree{
\title{Final Integration Check}
\ul{
\li{[ ] Figure displays correctly in compiled manuscript}
\li{[ ] Cross-references work (\code{\startverb \startverb \ref\stopverb{}\stopverb} points to correct figure)}
\li{[ ] Figure number matches text citations}
\li{[ ] Caption appears on correct page relative to figure}
\li{[ ] No compilation warnings or errors related to figure}
}
}
}

