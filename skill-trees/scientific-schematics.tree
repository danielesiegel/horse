\li{Illustrating system architectures and data flow diagrams}
\li{Drawing methodology flowcharts for study design (CONSORT, PRISMA)}
\li{Visualizing algorithm workflows and processing pipelines}
\li{Creating circuit diagrams and electrical schematics}
\li{Depicting biological pathways and molecular interactions}
\li{Generating network topologies and hierarchical structures}
\li{Illustrating conceptual frameworks and theoretical models}
\li{Designing block diagrams for technical papers}
}
}

