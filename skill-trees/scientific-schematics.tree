\subtree{
\title{Best Practices Summary}
\subtree{
\title{Design Principles}
\ol{
\li{\strong{Clarity over complexity} - Simplify, remove unnecessary elements}
\li{\strong{Consistent styling} - Use templates and style files}
\li{\strong{Colorblind accessibility} - Use Okabe-Ito palette, redundant encoding}
\li{\strong{Appropriate typography} - Sans-serif fonts, minimum 7-8 pt}
\li{\strong{Vector format} - Always use PDF/SVG for publication}
}
}

\subtree{
\title{Technical Requirements}
\ol{
\li{\strong{Resolution} - Vector preferred, or 300+ DPI for raster}
\li{\strong{File format} - PDF for LaTeX, SVG for web, PNG as fallback}
\li{\strong{Color space} - RGB for digital, CMYK for print (convert if needed)}
\li{\strong{Line weights} - Minimum 0.5 pt, typical 1-2 pt}
\li{\strong{Text size} - 7-8 pt minimum at final size}
}
}

\subtree{
\title{Integration Guidelines}
\ol{
\li{\strong{Include in LaTeX} - Use \code{\startverb \startverb \includegraphics\stopverb{}\stopverb} for generated images}
\li{\strong{Caption thoroughly} - Describe all elements and abbreviations}
\li{\strong{Reference in text} - Explain diagram in narrative flow}
\li{\strong{Maintain consistency} - Same style across all figures in paper}
\li{\strong{Version control} - Keep prompts and generated images in repository}
}
}
}

\subtree{
\title{Troubleshooting Common Issues}
\subtree{
\title{AI Generation Issues}
\p{\strong{Problem}: Overlapping text or elements}

\ul{
\li{\strong{Solution}: AI generation automatically handles spacing}
\li{\strong{Solution}: Increase iterations: \code{\startverb --iterations 2\stopverb} for better refinement}
}

\p{\strong{Problem}: Elements not connecting properly}

\ul{
\li{\strong{Solution}: Make your prompt more specific about connections and layout}
\li{\strong{Solution}: Increase iterations for better refinement}
}
}

\subtree{
\title{Image Quality Issues}
\p{\strong{Problem}: Export quality poor}

\ul{
\li{\strong{Solution}: AI generation produces high-quality images automatically}
\li{\strong{Solution}: Increase iterations for better results: \code{\startverb --iterations 2\stopverb}}
}

\p{\strong{Problem}: Elements overlap after generation}

\ul{
\li{\strong{Solution}: AI generation automatically handles spacing}
\li{\strong{Solution}: Increase iterations: \code{\startverb --iterations 2\stopverb} for better refinement}
\li{\strong{Solution}: Make your prompt more specific about layout and spacing requirements}
}
}

\subtree{
\title{Quality Check Issues}
\p{\strong{Problem}: False positive overlap detection}

\ul{
\li{\strong{Solution}: Adjust threshold: \code{\startverb detect_overlaps(image_path, threshold=0.98)\stopverb}}
\li{\strong{Solution}: Manually review flagged regions in visual report}
}

\p{\strong{Problem}: Generated image quality is low}

\ul{
\li{\strong{Solution}: AI generation produces high-quality images by default}
\li{\strong{Solution}: Increase iterations for better results: \code{\startverb --iterations 2\stopverb}}
}

\p{\strong{Problem}: Colorblind simulation shows poor contrast}

\ul{
\li{\strong{Solution}: Switch to Okabe-Ito palette explicitly in code}
\li{\strong{Solution}: Add redundant encoding (shapes, patterns, line styles)}
\li{\strong{Solution}: Increase color saturation and lightness differences}
}

\p{\strong{Problem}: High-severity overlaps detected}

\ul{
\li{\strong{Solution}: Review overlap_report.json for exact positions}
\li{\strong{Solution}: Increase spacing in those specific regions}
\li{\strong{Solution}: Re-run with adjusted parameters and verify again}
}

\p{\strong{Problem}: Visual report generation fails}

\ul{
\li{\strong{Solution}: Check Pillow and matplotlib installations}
\li{\strong{Solution}: Ensure image file is readable: \code{\startverb Image.open(path).verify()\stopverb}}
\li{\strong{Solution}: Check sufficient disk space for report generation}
}
}

\subtree{
\title{Accessibility Problems}
\p{\strong{Problem}: Colors indistinguishable in grayscale}

\ul{
\li{\strong{Solution}: Run accessibility checker: \code{\startverb verify_accessibility(image_path)\stopverb}}
\li{\strong{Solution}: Add patterns, shapes, or line styles for redundancy}
\li{\strong{Solution}: Increase contrast between adjacent elements}
}

\p{\strong{Problem}: Text too small when printed}

\ul{
\li{\strong{Solution}: Run resolution validator: \code{\startverb validate_resolution(image_path)\stopverb}}
\li{\strong{Solution}: Design at final size, use minimum 7-8 pt fonts}
\li{\strong{Solution}: Check physical dimensions in resolution report}
}

\p{\strong{Problem}: Accessibility checks consistently fail}

\ul{
\li{\strong{Solution}: Review accessibility_report.json for specific failures}
\li{\strong{Solution}: Increase color contrast by at least 20\%}
\li{\strong{Solution}: Test with actual grayscale conversion before finalizing}
}
}
}

