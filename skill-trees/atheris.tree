\title{Atheris}

\taxon{skill}

\meta{description}{Atheris is a coverage-guided Python fuzzer based on libFuzzer. Use for fuzzing pure Python code and Python C extensions.}

\subtree{
\title{Atheris}
\p{Atheris is a coverage-guided Python fuzzer built on libFuzzer. It enables fuzzing of both pure Python code and Python C extensions with integrated AddressSanitizer support for detecting memory corruption issues.}

\subtree{
\title{When to Use}
\pre{\startverb
| Fuzzer | Best For | Complexity |
|--------|----------|------------|
| Atheris | Python code and C extensions | Low-Medium |
| Hypothesis | Property-based testing | Low |
| python-afl | AFL-style fuzzing | Medium |
\stopverb}

\p{\strong{Choose Atheris when:}}

\ul{
\li{Fuzzing pure Python code with coverage guidance}
\li{Testing Python C extensions for memory corruption}
\li{Integration with libFuzzer ecosystem is desired}
\li{AddressSanitizer support is needed}
}
}

\subtree{
\title{Quick Start}
\pre{\startverb
import sys
import atheris

@atheris.instrument_func
def test_one_input(data: bytes):
    if len(data) == 4:
        if data[0] == 0x46:  # "F"
            if data[1] == 0x55:  # "U"
                if data[2] == 0x5A:  # "Z"
                    if data[3] == 0x5A:  # "Z"
                        raise RuntimeError("You caught me")

def main():
    atheris.Setup(sys.argv, test_one_input)
    atheris.Fuzz()

if __name__ == "__main__":
    main()
\stopverb}

\p{Run:}

\pre{\startverb
python fuzz.py
\stopverb}
}

\subtree{
\title{Installation}
\p{Atheris supports 32-bit and 64-bit Linux, and macOS. We recommend fuzzing on Linux because it's simpler to manage and often faster.}

\subtree{
\title{Prerequisites}
\ul{
\li{Python 3.7 or later}
\li{Recent version of clang (preferably [latest release](https://github.com/llvm/llvm-project/releases))}
\li{For Docker users: [Docker Desktop](https://www.docker.com/products/docker-desktop/)}
}
}

\subtree{
\title{Linux/macOS}
\pre{\startverb
uv pip install atheris
\stopverb}
}

\subtree{
\title{Docker Environment (Recommended)}
\p{For a fully operational Linux environment with all dependencies configured:}

\pre{\startverb
# https://hub.docker.com/_/python
ARG PYTHON_VERSION=3.11

FROM python:$PYTHON_VERSION-slim-bookworm

RUN python --version

RUN apt update && apt install -y \
    ca-certificates \
    wget \
    && rm -rf /var/lib/apt/lists/*

# LLVM builds version 15-19 for Debian 12 (Bookworm)
# https://apt.llvm.org/bookworm/dists/
ARG LLVM_VERSION=19

RUN echo "deb http://apt.llvm.org/bookworm/ llvm-toolchain-bookworm-$LLVM_VERSION main" > /etc/apt/sources.list.d/llvm.list
RUN echo "deb-src http://apt.llvm.org/bookworm/ llvm-toolchain-bookworm-$LLVM_VERSION main" >> /etc/apt/sources.list.d/llvm.list
RUN wget -qO- https://apt.llvm.org/llvm-snapshot.gpg.key > /etc/apt/trusted.gpg.d/apt.llvm.org.asc

RUN apt update && apt install -y \
    build-essential \
    clang-$LLVM_VERSION \
    && rm -rf /var/lib/apt/lists/*

ENV APP_DIR "/app"
RUN mkdir $APP_DIR
WORKDIR $APP_DIR

ENV VIRTUAL_ENV "/opt/venv"
RUN python -m venv $VIRTUAL_ENV
ENV PATH "$VIRTUAL_ENV/bin:$PATH"

# https://github.com/google/atheris/blob/master/native_extension_fuzzing.md#step-1-compiling-your-extension
ENV CC="clang-$LLVM_VERSION"
ENV CFLAGS "-fsanitize=address,fuzzer-no-link"
ENV CXX="clang++-$LLVM_VERSION"
ENV CXXFLAGS "-fsanitize=address,fuzzer-no-link"
ENV LDSHARED="clang-$LLVM_VERSION -shared"
ENV LDSHAREDXX="clang++-$LLVM_VERSION -shared"
ENV ASAN_SYMBOLIZER_PATH="/usr/bin/llvm-symbolizer-$LLVM_VERSION"

# Allow Atheris to find fuzzer sanitizer shared libs
# https://github.com/google/atheris#building-from-source
RUN LIBFUZZER_LIB=$($CC -print-file-name=libclang_rt.fuzzer_no_main-$(uname -m).a) \
    python -m pip install --no-binary atheris atheris

# https://github.com/google/atheris/blob/master/native_extension_fuzzing.md#option-a-sanitizerlibfuzzer-preloads
ENV LD_PRELOAD "$VIRTUAL_ENV/lib/python3.11/site-packages/asan_with_fuzzer.so"

# 1. Skip memory allocation failures for now, they are common, and low impact (DoS)
# 2. https://github.com/google/atheris/blob/master/native_extension_fuzzing.md#leak-detection
ENV ASAN_OPTIONS "allocator_may_return_null=1,detect_leaks=0"

CMD ["/bin/bash"]
\stopverb}

\p{Build and run:}

\pre{\startverb
docker build -t atheris .
docker run -it atheris
\stopverb}
}

\subtree{
\title{Verification}
\pre{\startverb
python -c "import atheris; print(atheris.__version__)"
\stopverb}
}
}

\subtree{
\title{Writing a Harness}
\subtree{
\title{Harness Structure for Pure Python}
\pre{\startverb
import sys
import atheris

@atheris.instrument_func
def test_one_input(data: bytes):
    """
    Fuzzing entry point. Called with random byte sequences.

    Args:
        data: Random bytes generated by the fuzzer
    """
    # Add input validation if needed
    if len(data) < 1:
        return

    # Call your target function
    try:
        your_target_function(data)
    except ValueError:
        # Expected exceptions should be caught
        pass
    # Let unexpected exceptions crash (that's what we're looking for!)

def main():
    atheris.Setup(sys.argv, test_one_input)
    atheris.Fuzz()

if __name__ == "__main__":
    main()
\stopverb}
}

\subtree{
\title{Harness Rules}
\pre{\startverb
| Do | Don't |
|----|-------|
| Use `@atheris.instrument_func` for coverage | Forget to instrument target code |
| Catch expected exceptions | Catch all exceptions indiscriminately |
| Use `atheris.instrument_imports()` for libraries | Import modules after `atheris.Setup()` |
| Keep harness deterministic | Use randomness or time-based behavior |
\stopverb}

\blockquote{\strong{See Also:} For detailed harness writing techniques, patterns for handling complex inputs, and advanced strategies, see the \strong{fuzz-harness-writing} technique skill.}
}
}

\subtree{
\title{Fuzzing Pure Python Code}
\p{For fuzzing broader parts of an application or library, use instrumentation functions:}

\pre{\startverb
import atheris
with atheris.instrument_imports():
    import your_module
    from another_module import target_function

def test_one_input(data: bytes):
    target_function(data)

atheris.Setup(sys.argv, test_one_input)
atheris.Fuzz()
\stopverb}

\p{\strong{Instrumentation Options:}}

\ul{
\li{\code{\startverb atheris.instrument_func\stopverb} - Decorator for single function instrumentation}
\li{\code{\startverb atheris.instrument_imports()\stopverb} - Context manager for instrumenting all imported modules}
\li{\code{\startverb atheris.instrument_all()\stopverb} - Instrument all Python code system-wide}
}
}

\subtree{
\title{Fuzzing Python C Extensions}
\p{Python C extensions require compilation with specific flags for instrumentation and sanitizer support.}

\subtree{
\title{Environment Configuration}
\p{If using the provided Dockerfile, these are already configured. For local setup:}

\pre{\startverb
export CC="clang"
export CFLAGS="-fsanitize=address,fuzzer-no-link"
export CXX="clang++"
export CXXFLAGS="-fsanitize=address,fuzzer-no-link"
export LDSHARED="clang -shared"
\stopverb}
}

\subtree{
\title{Example: Fuzzing cbor2}
\p{Install the extension from source:}

\pre{\startverb
CBOR2_BUILD_C_EXTENSION=1 python -m pip install --no-binary cbor2 cbor2==5.6.4
\stopverb}

\p{The \code{\startverb --no-binary\stopverb} flag ensures the C extension is compiled locally with instrumentation.}

\p{Create \code{\startverb cbor2-fuzz.py\stopverb}:}

\pre{\startverb
import sys
import atheris

# _cbor2 ensures the C library is imported
from _cbor2 import loads

def test_one_input(data: bytes):
    try:
        loads(data)
    except Exception:
        # We're searching for memory corruption, not Python exceptions
        pass

def main():
    atheris.Setup(sys.argv, test_one_input)
    atheris.Fuzz()

if __name__ == "__main__":
    main()
\stopverb}

\p{Run:}

\pre{\startverb
python cbor2-fuzz.py
\stopverb}

\blockquote{\strong{Important:} When running locally (not in Docker), you must [set \code{\startverb LD_PRELOAD\stopverb} manually](https://github.com/google/atheris/blob/master/native_extension_fuzzing.md#option-a-sanitizerlibfuzzer-preloads).}
}
}

\subtree{
\title{Corpus Management}
\subtree{
\title{Creating Initial Corpus}
\pre{\startverb
mkdir corpus
# Add seed inputs
echo "test data" > corpus/seed1
echo '{"key": "value"}' > corpus/seed2
\stopverb}

\p{Run with corpus:}

\pre{\startverb
python fuzz.py corpus/
\stopverb}
}

\subtree{
\title{Corpus Minimization}
\p{Atheris inherits corpus minimization from libFuzzer:}

\pre{\startverb
python fuzz.py -merge=1 new_corpus/ old_corpus/
\stopverb}

\blockquote{\strong{See Also:} For corpus creation strategies, dictionaries, and seed selection, see the \strong{fuzzing-corpus} technique skill.}
}
}

\subtree{
\title{Running Campaigns}
\subtree{
\title{Basic Run}
\pre{\startverb
python fuzz.py
\stopverb}
}

\subtree{
\title{With Corpus Directory}
\pre{\startverb
python fuzz.py corpus/
\stopverb}
}

\subtree{
\title{Common Options}
\pre{\startverb
# Run for 10 minutes
python fuzz.py -max_total_time=600

# Limit input size
python fuzz.py -max_len=1024

# Run with multiple workers
python fuzz.py -workers=4 -jobs=4
\stopverb}
}

\subtree{
\title{Interpreting Output}
\pre{\startverb
| Output | Meaning |
|--------|---------|
| `NEW    cov: X` | Found new coverage, corpus expanded |
| `pulse  cov: X` | Periodic status update |
| `exec/s: X` | Executions per second (throughput) |
| `corp: X/Yb` | Corpus size: X inputs, Y bytes total |
| `ERROR: libFuzzer` | Crash detected |
\stopverb}
}
}

\subtree{
\title{Sanitizer Integration}
\subtree{
\title{AddressSanitizer (ASan)}
\p{AddressSanitizer is automatically integrated when using the provided Docker environment or when compiling with appropriate flags.}

\p{For local setup:}

\pre{\startverb
export CFLAGS="-fsanitize=address,fuzzer-no-link"
export CXXFLAGS="-fsanitize=address,fuzzer-no-link"
\stopverb}

\p{Configure ASan behavior:}

\pre{\startverb
export ASAN_OPTIONS="allocator_may_return_null=1,detect_leaks=0"
\stopverb}
}

\subtree{
\title{LD_PRELOAD Configuration}
\p{For native extension fuzzing:}

\pre{\startverb
export LD_PRELOAD="$(python -c 'import atheris; import os; print(os.path.join(os.path.dirname(atheris.__file__), "asan_with_fuzzer.so"))')"
\stopverb}

\blockquote{\strong{See Also:} For detailed sanitizer configuration, common issues, and advanced flags, see the \strong{address-sanitizer} and \strong{undefined-behavior-sanitizer} technique skills.}
}

\subtree{
\title{Common Sanitizer Issues}
\pre{\startverb
| Issue | Solution |
|-------|----------|
| `LD_PRELOAD` not set | Export `LD_PRELOAD` to point to `asan_with_fuzzer.so` |
| Memory allocation failures | Set `ASAN_OPTIONS=allocator_may_return_null=1` |
| Leak detection noise | Set `ASAN_OPTIONS=detect_leaks=0` |
| Missing symbolizer | Set `ASAN_SYMBOLIZER_PATH` to `llvm-symbolizer` |
\stopverb}
}
}

\subtree{
\title{Advanced Usage}
\subtree{
\title{Tips and Tricks}
\pre{\startverb
| Tip | Why It Helps |
|-----|--------------|
| Use `atheris.instrument_imports()` early | Ensures all imports are instrumented for coverage |
| Start with small `max_len` | Faster initial fuzzing, gradually increase |
| Use dictionaries for structured formats | Helps fuzzer understand format tokens |
| Run multiple parallel instances | Better coverage exploration |
\stopverb}
}

\subtree{
\title{Custom Instrumentation}
\p{Fine-tune what gets instrumented:}

\pre{\startverb
import atheris

# Instrument only specific modules
with atheris.instrument_imports():
    import target_module
# Don't instrument test harness code

def test_one_input(data: bytes):
    target_module.parse(data)
\stopverb}
}

\subtree{
\title{Performance Tuning}
\pre{\startverb
| Setting | Impact |
|---------|--------|
| `-max_len=N` | Smaller values = faster execution |
| `-workers=N -jobs=N` | Parallel fuzzing for faster coverage |
| `ASAN_OPTIONS=fast_unwind_on_malloc=0` | Better stack traces, slower execution |
\stopverb}
}

\subtree{
\title{UndefinedBehaviorSanitizer (UBSan)}
\p{Add UBSan to catch additional bugs:}

\pre{\startverb
export CFLAGS="-fsanitize=address,undefined,fuzzer-no-link"
export CXXFLAGS="-fsanitize=address,undefined,fuzzer-no-link"
\stopverb}

\p{Note: Modify flags in Dockerfile if using containerized setup.}
}
}

\subtree{
\title{Real-World Examples}
\subtree{
\title{Example: Pure Python Parser}
\pre{\startverb
import sys
import atheris
import json

@atheris.instrument_func
def test_one_input(data: bytes):
    try:
        # Fuzz Python's JSON parser
        json.loads(data.decode('utf-8', errors='ignore'))
    except (ValueError, UnicodeDecodeError):
        pass

def main():
    atheris.Setup(sys.argv, test_one_input)
    atheris.Fuzz()

if __name__ == "__main__":
    main()
\stopverb}
}

\subtree{
\title{Example: HTTP Request Parsing}
\pre{\startverb
import sys
import atheris

with atheris.instrument_imports():
    from urllib3 import HTTPResponse
    from io import BytesIO

def test_one_input(data: bytes):
    try:
        # Fuzz HTTP response parsing
        fake_response = HTTPResponse(
            body=BytesIO(data),
            headers={},
            preload_content=False
        )
        fake_response.read()
    except Exception:
        pass

def main():
    atheris.Setup(sys.argv, test_one_input)
    atheris.Fuzz()

if __name__ == "__main__":
    main()
\stopverb}
}
}

\subtree{
\title{Troubleshooting}
\pre{\startverb
| Problem | Cause | Solution |
|---------|-------|----------|
| No coverage increase | Poor seed corpus or target not instrumented | Add better seeds, verify `instrument_imports()` |
| Slow execution | ASan overhead or large inputs | Reduce `max_len`, use `ASAN_OPTIONS=fast_unwind_on_malloc=1` |
| Import errors | Modules imported before instrumentation | Move imports inside `instrument_imports()` context |
| Segfault without ASan output | Missing `LD_PRELOAD` | Set `LD_PRELOAD` to `asan_with_fuzzer.so` path |
| Build failures | Wrong compiler or missing flags | Verify `CC`, `CFLAGS`, and clang version |
\stopverb}
}

