\subtree{
\title{Per-Vat Terminal}
\p{Each Goblins vat gets its own \code{\startverb ghostty_surface_t\stopverb}:}

\pre{\startverb
pub const VatTerminal = struct {
    surface: c.ghostty_surface_t,
    vat_id: []const u8,
    trit: i8, // GF(3) phase
};
\stopverb}
}

