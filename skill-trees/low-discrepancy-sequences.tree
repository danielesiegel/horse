\title{Low Discrepancy Sequences}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{"low-discrepancy-sequences skill"}

\subtree{
\title{Low-Discrepancy Sequences}
\p{Deterministic color generation via low-discrepancy sequences with bijective index recovery.}

\subtree{
\title{Purpose}
\p{Extends beyond the golden angle (φ) with multiple low-discrepancy sequences for uniform color space coverage. All sequences maintain bijectivity: given a color and seed, you can recover the index n.}
}

\subtree{
\title{Sequences Implemented}
\subtree{
\title{1. Golden Angle (φ)}
\ul{
\li{\strong{Dimension}: 1D (hue only)}
\li{\strong{Uniformity}: Optimal for 1D}
\li{\strong{Source}: φ = (1 + √5)/2}
\li{\strong{Formula}: hue = (seed + n/φ) mod 1}
}
}

\subtree{
\title{2. Plastic Constant (φ₂)}
\ul{
\li{\strong{Dimension}: 2D (hue + saturation)}
\li{\strong{Uniformity}: Optimal for 2D}
\li{\strong{Source}: φ₂ ≈ 1.324717... (root of x³ = x + 1)}
\li{\strong{Formula}: }
\li{h = (seed + n/φ₂) mod 1}
\li{s = (seed + n/φ₂²) mod 1}
}
}

\subtree{
\title{3. Halton Sequence}
\ul{
\li{\strong{Dimension}: nD (direct RGB or HSL)}
\li{\strong{Uniformity}: Good for any dimension}
\li{\strong{Source}: Prime bases (2, 3, 5, 7...)}
\li{\strong{Formula}: halton(n, base) = ∑ dᵢ/baseⁱ⁺¹}
}
}

\subtree{
\title{4. R-sequence (Recursive)}
\ul{
\li{\strong{Dimension}: nD}
\li{\strong{Uniformity}: Near-optimal}
\li{\strong{Source}: φ_d (d-dimensional golden ratio)}
\li{\strong{Formula}: α_d = roots of x^(d+1) = x + 1}
}
}

\subtree{
\title{5. Kronecker Sequence}
\ul{
\li{\strong{Dimension}: 1D}
\li{\strong{Uniformity}: Optimal (equidistributed)}
\li{\strong{Source}: Any irrational α}
\li{\strong{Formula}: {nα} mod 1}
}
}

\subtree{
\title{6. Sobol Sequence}
\ul{
\li{\strong{Dimension}: nD (up to 1000+)}
\li{\strong{Uniformity}: Excellent for high dimensions}
\li{\strong{Source}: Direction numbers}
\li{\strong{Formula}: Gray code XOR with direction vectors}
}
}

\subtree{
\title{7. Pisot Sequence}
\ul{
\li{\strong{Dimension}: nD}
\li{\strong{Uniformity}: Quasiperiodic}
\li{\strong{Source}: Pisot-Vijayaraghavan numbers (algebraic integers)}
\li{\strong{Formula}: θⁿ rounded to nearest integer}
}
}

\subtree{
\title{8. Continued Fractions}
\ul{
\li{\strong{Dimension}: 1D}
\li{\strong{Uniformity}: Geodesic in hyperbolic geometry}
\li{\strong{Source}: Continued fraction expansion}
\li{\strong{Formula}: [a₀; a₁, a₂, ...] convergents}
}
}
}

\subtree{
\title{Bijection Property}
\p{All sequences are \strong{bijective on index}: Given (color, seed), you can recover n.}

\p{This enables:}

\ul{
\li{Reafference: "I generated color C at index n"}
\li{Inverse queries: "What index produced this color?"}
\li{Temporal reconstruction: "When did I see this color?"}
}
}

\subtree{
\title{Integration with Gay.jl}
\p{These sequences extend the existing \code{\startverb gay-mcp\stopverb} MCP server tools:}

\ul{
\li{\code{\startverb gay_golden_thread\stopverb}: Current φ-based generation}
\li{\code{\startverb gay_plastic_thread\stopverb}: New φ₂-based 2D generation}
\li{\code{\startverb gay_halton_color\stopverb}: Direct RGB via Halton}
\li{\code{\startverb gay_r_sequence\stopverb}: n-dimensional R-sequence}
\li{\code{\startverb gay_sobol_color\stopverb}: High-dimensional Sobol}
\li{\code{\startverb gay_invert_color\stopverb}: Recover index from color}
}
}

