\subtree{
\title{GF(3) Trit Assignment}
\p{\strong{Trit}: 0 (ERGODIC)}

\p{Low-discrepancy sequences are infrastructure for uniform space coverage - neither generative (+1) nor analytical (-1), but foundational coordination (0).}
}

\subtree{
\title{References}
\ol{
\li{Niederreiter, H. (1992). \em{Random Number Generation and Quasi-Monte Carlo Methods}}
\li{Kuipers, L. & Niederreiter, H. (1974). \em{Uniform Distribution of Sequences}}
\li{Pisot, C. & Salem, R. (1963). \em{Algebraic Numbers and Fourier Analysis}}
\li{Arnoux, P. & Ito, S. (2001). Pisot substitutions and Rauzy fractals}
\li{Series, C. (1985). The geometry of Markoff numbers (continued fractions)}
}
}

\subtree{
\title{Usage Example}
\pre{\startverb
using LowDiscrepancySequences

# Golden angle (current method)
color1 = golden_angle_color(69, seed=42)

# Plastic constant (2D: hue + saturation)
color2 = plastic_color(69, seed=42)

# Halton (direct RGB)
color3 = halton_color(69)

# R-sequence (3D)
color4 = r_sequence_color(69, dim=3, seed=42)

# Invert: recover index
n = invert_color(color2, method=:plastic, seed=42)
@assert n == 69
\stopverb}
}

\subtree{
\title{Connections to Geodesics}
\p{Continued fractions provide \strong{geodesic paths} in hyperbolic geometry (PSL(2,ℝ) action on ℍ²). This connects to:}

\ul{
\li{Geodesic skill representations (shortest execution paths)}
\li{Hyperbolic geometry of skill space}
\li{Non-backtracking paths (prime geodesics)}
}

\p{The Farey sequence F_n = {p/q : gcd(p,q)=1, 0≤p≤q≤n} gives rational approximations to irrationals via continued fractions, mirroring the discrete approximations to geodesic flows.}
}

