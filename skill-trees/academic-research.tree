\title{Academic Research}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{Search academic papers across arXiv, PubMed, Semantic Scholar, bioRxiv, medRxiv, Google Scholar, and more. Get BibTeX citations, download PDFs, analyze citation networks. Use for literature reviews, finding papers, and academic research.}

\subtree{
\title{Academic Research Papers}
\p{Search and retrieve academic papers via multiple MCP servers.}

\subtree{
\title{Available Servers}
\subtree{
\title{paper-search}
\p{Multi-source paper search covering:}

\ul{
\li{arXiv, PubMed, bioRxiv, medRxiv}
\li{Google Scholar, IACR, Semantic Scholar}
\li{BibTeX export support}
}
}

\subtree{
\title{semantic-scholar}
\p{Full Semantic Scholar API access:}

\ul{
\li{Citation network analysis}
\li{Author search}
\li{Paper recommendations}
\li{BibTeX, APA, MLA, Chicago formats}
}
}

\subtree{
\title{arxiv}
\p{arXiv-specific search:}

\ul{
\li{Advanced search filters}
\li{Citation analysis}
\li{BibTeX, JSON, CSV, Markdown export}
}
}
}

\subtree{
\title{When to Use}
\ul{
\li{Literature reviews}
\li{Finding related papers}
\li{Getting BibTeX citations}
\li{Checking who cited a paper}
\li{Finding papers by author}
\li{Searching for specific topics}
}
}

\subtree{
\title{Example Usage}
\subtree{
\title{Search for Papers}
\pre{\startverb
paper_search(query="transformer attention mechanism", sources=["arxiv", "semantic_scholar"])
\stopverb}
}

\subtree{
\title{Get Citations}
\pre{\startverb
semantic_scholar_citations(paper_id="...")
\stopverb}
}

\subtree{
\title{arXiv Specific}
\pre{\startverb
arxiv_search(query="quantum computing", max_results=10)
\stopverb}
}
}

\subtree{
\title{Other Available Servers (Not Installed)}
\p{From your \code{\startverb /Users/alice/worlds/l/mcp_servers.json\stopverb}:}

\ul{
\li{\code{\startverb research-hub-mcp\stopverb} - 11 sources + Unpaywall PDF access}
\li{\code{\startverb zotero-mcp\stopverb} - Connect to Zotero library}
\li{\code{\startverb openalex-mcp\stopverb} - 250M+ works database}
\li{\code{\startverb crossref-mcp\stopverb} - DOI metadata}
}

\p{Add more with:}

\pre{\startverb
"server-name": {
  "command": "npx",
  "args": ["-y", "server-package-name"]
}
\stopverb}
}

