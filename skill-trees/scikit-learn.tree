\subtree{
\title{Best Practices}
\subtree{
\title{Always Use Pipelines}
\p{Pipelines prevent data leakage and ensure consistency:}

\pre{\startverb
# Good: Preprocessing in pipeline
pipeline = Pipeline([
    ('scaler', StandardScaler()),
    ('model', LogisticRegression())
])

# Bad: Preprocessing outside (can leak information)
X_scaled = StandardScaler().fit_transform(X)
\stopverb}
}

\subtree{
\title{Fit on Training Data Only}
\p{Never fit on test data:}

\pre{\startverb
# Good
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)  # Only transform

# Bad
scaler = StandardScaler()
X_all_scaled = scaler.fit_transform(np.vstack([X_train, X_test]))
\stopverb}
}

\subtree{
\title{Use Stratified Splitting for Classification}
\p{Preserve class distribution:}

\pre{\startverb
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.2, stratify=y, random_state=42
)
\stopverb}
}

\subtree{
\title{Set Random State for Reproducibility}
\pre{\startverb
model = RandomForestClassifier(n_estimators=100, random_state=42)
\stopverb}
}

\subtree{
\title{Choose Appropriate Metrics}
\ul{
\li{Balanced data: Accuracy, F1-score}
\li{Imbalanced data: Precision, Recall, ROC AUC, Balanced Accuracy}
\li{Cost-sensitive: Define custom scorer}
}
}

\subtree{
\title{Scale Features When Required}
\p{Algorithms requiring feature scaling:}

\ul{
\li{SVM, KNN, Neural Networks}
\li{PCA, Linear/Logistic Regression with regularization}
\li{K-Means clustering}
}

\p{Algorithms not requiring scaling:}

\ul{
\li{Tree-based models (Decision Trees, Random Forest, Gradient Boosting)}
\li{Naive Bayes}
}
}
}

\subtree{
\title{Troubleshooting Common Issues}
\subtree{
\title{ConvergenceWarning}
\p{\strong{Issue:} Model didn't converge \strong{Solution:} Increase \code{\startverb max_iter\stopverb} or scale features}

\pre{\startverb
model = LogisticRegression(max_iter=1000)
\stopverb}
}

\subtree{
\title{Poor Performance on Test Set}
\p{\strong{Issue:} Overfitting \strong{Solution:} Use regularization, cross-validation, or simpler model}

\pre{\startverb
# Add regularization
model = Ridge(alpha=1.0)

# Use cross-validation
scores = cross_val_score(model, X, y, cv=5)
\stopverb}
}

\subtree{
\title{Memory Error with Large Datasets}
\p{\strong{Solution:} Use algorithms designed for large data}

\pre{\startverb
# Use SGD for large datasets
from sklearn.linear_model import SGDClassifier
model = SGDClassifier()

# Or MiniBatchKMeans for clustering
from sklearn.cluster import MiniBatchKMeans
model = MiniBatchKMeans(n_clusters=8, batch_size=100)
\stopverb}
}
}

