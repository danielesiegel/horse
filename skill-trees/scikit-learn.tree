\subtree{
\title{Performing Clustering Analysis}
\ol{
\li{\strong{Preprocess data}}
}

\p{scaler = StandardScaler() X_scaled = scaler.fit_transform(X)}

\pre{\startverb

2. **Find optimal number of clusters**
\stopverb}

\p{from sklearn.cluster import KMeans from sklearn.metrics import silhouette_score}

\p{scores = [] for k in range(2, 11): kmeans = KMeans(n_clusters=k, random_state=42) labels = kmeans.fit_predict(X_scaled) scores.append(silhouette_score(X_scaled, labels))}

\p{optimal_k = range(2, 11)[np.argmax(scores)]}

\pre{\startverb

3. **Apply clustering**
\stopverb}

\p{model = KMeans(n_clusters=optimal_k, random_state=42) labels = model.fit_predict(X_scaled)}

\pre{\startverb

4. **Visualize with dimensionality reduction**
\stopverb}

\p{from sklearn.decomposition import PCA}

\p{pca = PCA(n_components=2) X_2d = pca.fit_transform(X_scaled)}

\p{plt.scatter(X_2d[:, 0], X_2d[:, 1], c=labels, cmap='viridis')}

\pre{\startverb

\stopverb}
}
