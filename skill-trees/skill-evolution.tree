\p{Avoid local optima via:}

\ul{
\li{Random mutation (try unexpected patterns)}
\li{Recombination (merge with distant skills)}
\li{Environmental change (new agent versions)}
}
}

\subtree{
\title{Implementation}
\pre{\startverb
struct SkillGenome
    name::String
    description::String
    body::String
    metadata::Dict{String,Any}
    fitness::Float64
end

function evolve(population::Vector{SkillGenome}, generations::Int)
    for _ in 1:generations
        # Selection
        survivors = select_fittest(population, 0.5)
        
        # Crossover
        offspring = crossover(survivors)
        
        # Mutation
        mutants = mutate(offspring, rate=0.1)
        
        # Validation filter
        population = filter(validate, vcat(survivors, mutants))
    end
    population
end
\stopverb}
}

