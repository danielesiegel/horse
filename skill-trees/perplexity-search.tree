\subtree{
\title{Best Practices}
\subtree{
\title{Query Design}
\ol{
\li{\strong{Be specific}: Include domain, time frame, and constraints}
\li{\strong{Use terminology}: Domain-appropriate keywords and phrases}
\li{\strong{Specify sources}: Mention preferred publication types or journals}
\li{\strong{Structure questions}: Clear components with explicit context}
\li{\strong{Iterate}: Refine based on initial results}
}
}

\subtree{
\title{Model Selection}
\ol{
\li{\strong{Start with sonar-pro}: Good default for most queries}
\li{\strong{Upgrade for complexity}: Use sonar-pro-search for multi-step analysis}
\li{\strong{Downgrade for simplicity}: Use sonar for basic facts}
\li{\strong{Use reasoning models}: When step-by-step analysis needed}
}
}

\subtree{
\title{Cost Optimization}
\ol{
\li{\strong{Choose appropriate models}: Match model to query complexity}
\li{\strong{Set token limits}: Use \code{\startverb --max-tokens\stopverb} to control costs}
\li{\strong{Monitor usage}: Check OpenRouter dashboard regularly}
\li{\strong{Batch efficiently}: Combine related simple queries when possible}
\li{\strong{Cache results}: Save and reuse results for repeated queries}
}
}

\subtree{
\title{Security}
\ol{
\li{\strong{Protect API keys}: Never commit to version control}
\li{\strong{Use environment variables}: Keep keys separate from code}
\li{\strong{Set spending limits}: Configure in OpenRouter dashboard}
\li{\strong{Monitor usage}: Watch for unexpected activity}
\li{\strong{Rotate keys}: Change keys periodically}
}
}
}

