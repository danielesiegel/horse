\subtree{
\title{Dependencies}
\subtree{
\title{Required}
\pre{\startverb
# LiteLLM for API access
uv pip install litellm
\stopverb}
}

\subtree{
\title{Optional}
\pre{\startverb
# For .env file support
uv pip install python-dotenv

# For JSON processing (usually pre-installed)
uv pip install jq
\stopverb}
}

\subtree{
\title{Environment Variables}
\p{Required:}

\ul{
\li{\code{\startverb OPENROUTER_API_KEY\stopverb}: Your OpenRouter API key}
}

\p{Optional:}

\ul{
\li{\code{\startverb DEFAULT_MODEL\stopverb}: Default model to use (default: sonar-pro)}
\li{\code{\startverb DEFAULT_MAX_TOKENS\stopverb}: Default max tokens (default: 4000)}
\li{\code{\startverb DEFAULT_TEMPERATURE\stopverb}: Default temperature (default: 0.2)}
}
}
}

