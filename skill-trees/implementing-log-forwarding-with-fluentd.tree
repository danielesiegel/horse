\meta{description}{Configure Fluentd and Fluent Bit for centralized log aggregation, routing, filtering, and enrichment across distributed infrastructure}

\subtree{
\title{Implementing Log Forwarding with Fluentd}
\subtree{
\title{Overview}
\p{This skill covers configuring Fluentd and Fluent Bit for centralized log collection, routing, and enrichment. Fluent Bit acts as a lightweight log forwarder on endpoints, while Fluentd serves as the central aggregator and processor. The configuration covers input plugins for syslog, file tailing, and application logs, with output routing to Elasticsearch, S3, and Splunk.}
}

\subtree{
\title{When to Use}
\ul{
\li{When deploying or configuring implementing log forwarding with fluentd capabilities in your environment}
\li{When establishing security controls aligned to compliance requirements}
\li{When building or improving security architecture for this domain}
\li{When conducting security assessments that require this implementation}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Fluentd (td-agent) v1.16+ or Fluent Bit v3.0+}
\li{Python 3.8+ with fluent-logger library}
\li{Elasticsearch or Splunk for log destination}
\li{Network access on port 24224 (Fluentd forward protocol)}
\li{Ruby 2.7+ (for Fluentd plugin development)}
}
}

\subtree{
\title{Steps}
\ol{
\li{\strong{Generate Fluent Bit Configuration} — Create input, filter, and output configuration for endpoint log collection}
\li{\strong{Generate Fluentd Aggregator Configuration} — Configure the central Fluentd instance with forward input, parsing, and multi-output routing}
\li{\strong{Configure Log Filtering and Enrichment} — Add record_transformer and grep filters for log enrichment and noise reduction}
\li{\strong{Validate Configuration Syntax} — Parse and validate Fluentd/Fluent Bit configuration files for syntax errors}
\li{\strong{Test Log Forwarding} — Send test events via fluent-logger Python library and verify delivery}
\li{\strong{Generate Deployment Report} — Produce configuration summary with routing topology and health metrics}
}
}

\subtree{
\title{Expected Output}
\ul{
\li{Fluent Bit and Fluentd configuration files (INI/YAML format)}
\li{Configuration validation report}
\li{Log routing topology diagram (text-based)}
\li{Test event delivery confirmation}
}
}
}