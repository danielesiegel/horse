\subtree{
\title{Troubleshooting}
\p{\strong{Compound Not Found}:}

\ul{
\li{Try alternative names or synonyms}
\li{Use CID if known}
\li{Check spelling and chemical name format}
}

\p{\strong{Timeout Errors}:}

\ul{
\li{Reduce MaxRecords parameter}
\li{Add delays between requests}
\li{Use CIDs instead of names for faster queries}
}

\p{\strong{Empty Property Values}:}

\ul{
\li{Not all properties are available for all compounds}
\li{Check if property exists before accessing: \code{\startverb if compound.xlogp:\stopverb}}
\li{Some properties only available for certain compound types}
}

\p{\strong{Rate Limit Exceeded}:}

\ul{
\li{Implement delays (0.2-0.3 seconds) between requests}
\li{Use batch operations where possible}
\li{Consider caching results locally}
}

\p{\strong{Similarity/Substructure Search Hangs}:}

\ul{
\li{These are asynchronous operations that may take 15-30 seconds}
\li{PubChemPy handles polling automatically}
\li{Reduce MaxRecords if timing out}
}
}

