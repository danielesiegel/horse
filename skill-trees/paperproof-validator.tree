\subtree{
\title{Example: Proving Commutativity of Addition}
\subtree{
\title{Lean 4 Proof}
\pre{\startverb
theorem add_comm (m n : Nat) : m + n = n + m := by
  induction m with
  | zero => simp
  | succ k ih =>
    rw [Nat.succ_add, Nat.add_succ, ih]
\stopverb}
}

\subtree{
\title{Paperproof Visualization}
\p{\strong{Step 1: Base Case (zero)}}

\pre{\startverb
┌─────────────────────────────────────┐
│ Hypotheses:                         │
│  - n : Nat                          │
├─────────────────────────────────────┤
│ Goal: 0 + n = n + 0                 │
├─────────────────────────────────────┤
│ Tactic: simp                        │
│ (simplifies by reflexivity)         │
└─────────────────────────────────────┘
\stopverb}

\p{\strong{Step 2: Inductive Case (succ)}}

\pre{\startverb
┌─────────────────────────────────────────────────┐
│ Hypotheses:                                     │
│  - k : Nat                                      │
│  - n : Nat                                      │
│  - ih : k + n = n + k  [inductive hypothesis]  │
├─────────────────────────────────────────────────┤
│ Goal: succ k + n = n + succ k                   │
├─────────────────────────────────────────────────┤
│ Tactics:                                        │
│  - rw [Nat.succ_add]                            │
│  - rw [Nat.add_succ]                            │
│  - rw [ih]                                      │
│ (rewrites transform goal to reflexivity)        │
└─────────────────────────────────────────────────┘
\stopverb}
}
}

\subtree{
\title{Integration with AI Agents}
\subtree{
\title{Use in Plurigrid}
\p{Paperproof Validator can integrate with AI agent learning:}

\p{\strong{Agent learns by proving theorems}:}

\pre{\startverb
Agent Generates Theorem
         ↓
Lean 4 Verifies Proof
         ↓
Paperproof Visualizes Structure
         ↓
Agent Learns from Visualization
\stopverb}

\p{\strong{Feedback Loop}:}

\pre{\startverb
# Agent proposes proof
proof_sketch = agent.propose_theorem_proof(statement)

# Paperproof validates
validation = paperproof.validate(proof_sketch)

if validation.passes:
    # Extract visualization for learning
    structure = paperproof.extract_structure()
    agent.update_knowledge(structure)
else:
    # Return error visualization to agent
    agent.learn_from_error(validation.error_path)
\stopverb}
}
}

