\subtree{
\title{Height Function as Lens}
\p{The height function h(x,t) forms a \strong{lens} in the polynomial category:}

\pre{\startverb
Height = (SpaceTime, Fluctuation)
get: SpaceTime → Height
put: SpaceTime × Noise → Height
\stopverb}
}

\subtree{
\title{Directed Landscape as Profunctor}
\p{The directed landscape L(x,s; y,t) is a \strong{profunctor}:}

\pre{\startverb
L: Space × Time ↛ Space × Time
L(x,s; y,t) = max passage weight from (x,s) to (y,t)
\stopverb}

\p{This profunctor satisfies metric composition (Yoneda-like):}

\pre{\startverb
L(x,s; y,t) = max_z [L(x,s; z,r) + L(z,r; y,t)]
\stopverb}
}

