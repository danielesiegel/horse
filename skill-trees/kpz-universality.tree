\title{Kpz Universality}

\taxon{skill}

\meta{description}{"KPZ universality class: KPZ fixed point, directed landscape, random interface growth scaling limits. Universal fluctuations for TASEP, PNG, LPP, and polymer models."}

\subtree{
\title{KPZ Universality Skill}
\p{\strong{Status}: ✅ Production Ready \strong{Trit}: 0 (ERGODIC - coordinator/neutral) \strong{Color}: #7B68EE (Medium Slate Blue) \strong{Principle}: Universal scaling limit of random interface growth \strong{Frame}: 1:2:3 scaling (space:time:fluctuation), Tracy-Widom fluctuations}

\subtree{
\title{Overview}
\p{The \strong{Kardar-Parisi-Zhang (KPZ) universality class} describes the universal scaling behavior of random interface growth models. This skill provides:}

\ol{
\li{\strong{KPZ Fixed Point}: The universal Markov process governing height fluctuations}
\li{\strong{Directed Landscape}: The common noise coupling all initial conditions}
\li{\strong{Scaling Theory}: The 1:2:3 exponents and Tracy-Widom limits}
\li{\strong{Model Zoo}: TASEP, PNG, LPP, polymers, random matrices}
}
}

\subtree{
\title{The KPZ Equation (SPDE)}
\pre{\startverb
∂h/∂t = ν∇²h + (λ/2)(∇h)² + √D ξ(x,t)

Where:
  h(x,t) = height function
  ν = diffusion coefficient (smoothing)
  λ = nonlinearity (growth rate)
  D = noise strength
  ξ = space-time white noise
\stopverb}

\subtree{
\title{Mathematical Challenge}
\p{The equation is \strong{ill-posed} due to roughness:}

\ul{
\li{∇h is not a function but a distribution}
\li{(∇h)² is not well-defined}
\li{Requires renormalization or regularity structures (Hairer 2013)}
}
}
}

\subtree{
\title{The KPZ Fixed Point}
\p{The \strong{KPZ fixed point} is the universal Markov process that emerges under scaling:}

\pre{\startverb
h^ε(x,t) = ε^(1/2) h(ε^(-1)x, ε^(-3/2)t) →  KPZ fixed point

Scaling exponents:
  α = 1/2  (roughness)
  β = 1/3  (growth)
  z = 3/2  (dynamic)
  
Relation: α + z = 2, β = α/z
\stopverb}

\subtree{
\title{Tracy-Widom Fluctuations}
\p{For narrow-wedge initial condition:}

\pre{\startverb
P(h(0,t) ≤ s) → F_GUE(s) as t → ∞

Where F_GUE = Tracy-Widom GUE distribution
\stopverb}
}
}

\subtree{
\title{The Directed Landscape}
\p{The \strong{directed landscape} L(x,s; y,t) is the scaling limit of last passage percolation:}

\pre{\startverb
L: {(x,s; y,t) : s < t} → ℝ ∪ {-∞}

Key properties:
1. Metric composition: L(x,s; y,t) = max_z [L(x,s; z,r) + L(z,r; y,t)]
2. Airy sheet initial data: L(x,0; y,1) = Airy sheet
3. Stationarity: L(x+a, s+c; y+a, t+c) =^d L(x,s; y,t)
\stopverb}

\subtree{
\title{Coupling via Directed Landscape}
\p{All KPZ models with same noise can be coupled:}

\pre{\startverb
# Different initial conditions, same noise
h_flat(x, t) = max_y [h₀_flat(y) + L(y, 0; x, t)]
h_wedge(x, t) = max_y [h₀_wedge(y) + L(y, 0; x, t)]
\stopverb}
}
}

\subtree{
\title{Interface with Colored Vertex Models}
\p{The \strong{colored stochastic six-vertex model} connects KPZ to quantum integrable systems:}

\pre{\startverb
Yang-Baxter ← Fusion → Cuboson Weights
     ↓                      ↓
Six-Vertex  ← Gibbs →  Height Function
     ↓                      ↓
KPZ Fixed Point ← Limit → Directed Landscape
\stopverb}

\p{See: yang-baxter-integrability, colored-vertex-model skills.}
}

\subtree{
\title{Core Capabilities}
\subtree{
\title{1. KPZ Height Simulation}
\pre{\startverb
using KPZUniversality

# Simulate KPZ equation via directed polymers
sim = simulate_kpz(
    initial_condition = :wedge,  # or :flat, :stationary
    L = 1000,                    # system size
    T = 100.0,                   # final time
    discretization = :polymer    # or :weakly_asymmetric
)

# Extract height at time T
h = height_at(sim, T)

# Check Tracy-Widom convergence
@test kolmogorov_smirnov(rescaled_fluctuations(h), tracy_widom_gue()) < 0.1
\stopverb}
}

\subtree{
\title{2. Directed Landscape Sampling}
\pre{\startverb
# Sample directed landscape on grid
landscape = sample_directed_landscape(
    x_range = -10:0.1:10,
    t_range = 0:0.1:10,
    resolution = 0.01
)

# Evaluate path weight
weight = landscape(x_start, t_start, x_end, t_end)

# Compute geodesic
geo = geodesic(landscape, (x1, t1), (x2, t2))
\stopverb}
}

\subtree{
\title{3. Last Passage Percolation}
\pre{\startverb
# Geometric LPP (exponential weights)
lpp = geometric_lpp(
    n = 100,              # grid size
    weights = :exponential
)

# Compute passage time
G = passage_time(lpp, (1, 1), (n, n))

# Tracy-Widom rescaling
chi = (G - 4n) / (2^(4/3) * n^(1/3))
\stopverb}
}

\subtree{
\title{4. TASEP Dynamics}
\pre{\startverb
# Totally Asymmetric Simple Exclusion Process
tasep = TASEP(
    L = 100,              # system size
    initial = :step,      # step initial condition
    rate = 1.0
)

# Run simulation
simulate!(tasep, T = 100.0)

# Current fluctuations
J = current(tasep)
\stopverb}
}
}

\subtree{
\title{Integration with Gay-MCP (Colored Projections)}
\p{KPZ models with \strong{colored particles} connect directly to Gay-MCP:}

\pre{\startverb
using GayMCP, KPZUniversality

# Colored TASEP with GF(3) conservation
ctasep = ColoredTASEP(
    n_colors = 3,
    seed = gay_seed(1069)
)

# Project to single color
single_color = project(ctasep, color = 1)
# Result satisfies ordinary TASEP statistics

# Verify GF(3) conservation
@test sum(color_trit.(ctasep.particles)) % 3 == 0
\stopverb}
}

\subtree{
\title{Integration with Langevin-Dynamics}
\p{KPZ equation is a \strong{Langevin equation} for interface growth:}

\pre{\startverb
using LangevinDynamics, KPZUniversality

# Convert KPZ to standard Langevin form
langevin = kpz_to_langevin(
    kpz_params = (ν = 1.0, λ = 2.0, D = 1.0),
    discretization = :imhof_mannella
)

# Solve with instrumented noise
sol, audit = solve_langevin(langevin, seed = gay_seed(42))

# Verify Gibbs property
@test check_gibbs_property(sol, :inter_color)
\stopverb}
}

\subtree{
\title{Integration with Fokker-Planck}
\p{The Fokker-Planck equation for KPZ describes probability flow:}

\pre{\startverb
using FokkerPlanck, KPZUniversality

# Fokker-Planck for height distribution
fp = kpz_fokker_planck(
    initial_distribution = :delta_wedge,
    temperature = T
)

# Stationary measure (Louisville quantum gravity)
stationary = louisville_measure(fp)

# Verify convergence to stationary
@test kl_divergence(evolve(fp, t), stationary) < 0.01
\stopverb}
}

