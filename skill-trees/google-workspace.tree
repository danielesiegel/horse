\title{Google Workspace}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{Google Workspace MCP integration for Gmail, Drive, Calendar, Docs, Sheets, Slides, Forms, Tasks, and Chat. Use when the user wants to read/send emails, manage files, create/edit documents, schedule events, or interact with any Google Workspace service.}

\subtree{
\title{Google Workspace Skill}
\p{Comprehensive MCP integration for all Google Workspace services.}

\subtree{
\title{Denotation}
\blockquote{\strong{Google Workspace tasks map to functional invariants, resulting in consistent email, file, calendar, and task states under Narya condensation and GF(3) conservation.}}

\p{The skill reaches a \strong{fixed point} when all pending operations complete with no H¹ obstructions (gluing failures), and thread/folder trit sums are conserved modulo 3.}
}

\subtree{
\title{Formal Contract}
\pre{\startverb
Effect: Google Workspace → State × Trit
Invariant: ∀ closed workflow: Σ(trit) ≡ 0 (mod 3)
Denotation: ⟦GW⟧ = lim_{n→∞} Condense(Op_n(...Op_1(S_0)))
\stopverb}
}

\subtree{
\title{Required Parameter}
\p{\strong{All tools require \code{\startverb user_google_email\stopverb}} - the user's Google email address.}
}

\subtree{
\title{Services Overview}
\subtree{
\title{📧 Gmail (MINUS -1: Validator)}
\pre{\startverb
| Tool | Description |
|------|-------------|
| `search_gmail_messages` | Search with Gmail query syntax |
| `get_gmail_message_content` | Get full message content |
| `get_gmail_messages_content_batch` | Batch get (max 25) |
| `get_gmail_thread_content` | Get full conversation thread |
| `send_gmail_message` | Send email (supports replies) |
| `draft_gmail_message` | Create draft (supports replies) |
| `modify_gmail_message_labels` | Add/remove labels (archive, delete) |
| `batch_modify_gmail_message_labels` | Bulk label operations |
| `list_gmail_labels` | List all labels with IDs |
| `manage_gmail_label` | Create/update/delete labels |
\stopverb}

\p{\strong{Query syntax examples:}}

\ul{
\li{\code{\startverb from:user@example.com\stopverb} - From specific sender}
\li{\code{\startverb is:unread\stopverb} - Unread messages}
\li{\code{\startverb has:attachment\stopverb} - Has attachments}
\li{\code{\startverb after:2024/01/01\stopverb} - Date filters}
}
}

