\subtree{
\title{Common Workflows}
\subtree{
\title{Email Management}
\pre{\startverb
# Search → Read → Reply
messages = search_gmail_messages(query="from:boss is:unread")
content = get_gmail_message_content(message_id=messages[0].id)
send_gmail_message(
    to="boss@company.com",
    subject="Re: " + content.subject,
    body="Response...",
    thread_id=content.thread_id,
    in_reply_to=content.message_id
)
\stopverb}
}

\subtree{
\title{Document Creation}
\pre{\startverb
# Create → Inspect → Add Table
doc = create_doc(title="Report")
structure = inspect_doc_structure(document_id=doc.id)
create_table_with_data(
    document_id=doc.id,
    index=structure.total_length,
    table_data=[["Header1", "Header2"], ["Data1", "Data2"]]
)
\stopverb}
}

\subtree{
\title{Calendar Scheduling}
\pre{\startverb
# Check availability → Create event with Meet
events = get_events(
    time_min="2024-12-26T09:00:00Z",
    time_max="2024-12-26T17:00:00Z"
)
create_event(
    summary="Team Sync",
    start_time="2024-12-26T14:00:00Z",
    end_time="2024-12-26T15:00:00Z",
    attendees=["team@company.com"],
    add_google_meet=True
)
\stopverb}
}

\subtree{
\title{File Sharing}
\pre{\startverb
# Share with expiration
share_drive_file(
    file_id="abc123",
    share_with="contractor@example.com",
    role="writer",
    expiration_time="2025-01-15T00:00:00Z"
)
\stopverb}
}
}

\subtree{
\title{Authentication}
\p{If tools fail with auth errors, use:}

\pre{\startverb
start_google_auth(service_name="gmail|drive|calendar|docs|sheets|slides|forms|tasks|chat")
\stopverb}
}

\subtree{
\title{Tips}
\ol{
\li{\strong{Batch operations} - Use batch tools for multiple items}
\li{\strong{Table creation} - Always call \code{\startverb inspect_doc_structure\stopverb} first to get safe index}
\li{\strong{Email threading} - Include \code{\startverb thread_id\stopverb}, \code{\startverb in_reply_to\stopverb}, \code{\startverb references\stopverb} for proper replies}
\li{\strong{Drive shared drives} - Use \code{\startverb drive_id\stopverb} parameter for shared drive operations}
\li{\strong{Calendar attachments} - Use Drive file URLs or IDs for event attachments}
}
}

