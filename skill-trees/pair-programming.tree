\title{Pair programming}

\taxon{skill}

\meta{description}{AI-assisted pair programming with multiple modes (driver/navigator/switch), real-time verification, quality monitoring, and comprehensive testing. Supports TDD, debugging, refactoring, and learning sessions. Features automatic role switching, continuous code review, security scanning, and performance optimization with truth-score verification.}

\subtree{
\title{Pair Programming}
\p{Collaborative AI pair programming with intelligent role management, real-time quality monitoring, and comprehensive development workflows.}

\subtree{
\title{What This Skill Does}
\p{This skill provides professional pair programming capabilities with AI assistance, supporting multiple collaboration modes, continuous verification, and integrated testing. It manages driver/navigator roles, performs real-time code review, tracks quality metrics, and ensures high standards through truth-score verification.}

\p{\strong{Key Capabilities:}}

\ul{
\li{\strong{Multiple Modes}: Driver, Navigator, Switch, TDD, Review, Mentor, Debug}
\li{\strong{Real-Time Verification}: Automatic quality scoring with rollback on failures}
\li{\strong{Role Management}: Seamless switching between driver/navigator roles}
\li{\strong{Testing Integration}: Auto-generate tests, track coverage, continuous testing}
\li{\strong{Code Review}: Security scanning, performance analysis, best practice enforcement}
\li{\strong{Session Persistence}: Auto-save, recovery, export, and sharing}
}
}

\subtree{
\title{Prerequisites}
\p{\strong{Required:}}

\ul{
\li{Claude Flow CLI installed (\code{\startverb npm install -g claude-flow@alpha\stopverb})}
\li{Git repository (optional but recommended)}
}

\p{\strong{Recommended:}}

\ul{
\li{Testing framework (Jest, pytest, etc.)}
\li{Linter configured (ESLint, pylint, etc.)}
\li{Code formatter (Prettier, Black, etc.)}
}
}

\subtree{
\title{Quick Start}
\subtree{
\title{Basic Session}
\pre{\startverb
# Start simple pair programming
claude-flow pair --start
\stopverb}
}

\subtree{
\title{TDD Session}
\pre{\startverb
# Test-driven development
claude-flow pair --start \
  --mode tdd \
  --test-first \
  --coverage 90
\stopverb}
}
}

\subtree{
\title{Complete Guide}
\subtree{
\title{Session Control Commands}
\subtree{
\title{Starting Sessions}
\pre{\startverb
# Basic start
claude-flow pair --start

# Expert refactoring session
claude-flow pair --start \
  --agent senior-dev \
  --focus refactor \
  --verify \
  --threshold 0.98

# Debugging session
claude-flow pair --start \
  --agent debugger-expert \
  --focus debug \
  --review

# Learning session
claude-flow pair --start \
  --mode mentor \
  --pace slow \
  --examples
\stopverb}
}

\subtree{
\title{Session Management}
\pre{\startverb
# Check status
claude-flow pair --status

# View history
claude-flow pair --history

# Pause session
/pause [--reason <reason>]

# Resume session
/resume

# End session
claude-flow pair --end [--save] [--report]
\stopverb}
}
}

\subtree{
\title{Available Modes}
\subtree{
\title{Driver Mode}
\p{You write code while AI provides guidance.}

\pre{\startverb
claude-flow pair --start --mode driver
\stopverb}

\p{\strong{Your Responsibilities:}}

\ul{
\li{Write actual code}
\li{Implement solutions}
\li{Make immediate decisions}
\li{Handle syntax and structure}
}

\p{\strong{AI Navigator:}}

\ul{
\li{Strategic guidance}
\li{Spot potential issues}
\li{Suggest improvements}
\li{Real-time review}
\li{Track overall direction}
}

\p{\strong{Best For:}}

\ul{
\li{Learning new patterns}
\li{Implementing familiar features}
\li{Quick iterations}
\li{Hands-on debugging}
}

\p{\strong{Commands:}}

\pre{\startverb
/suggest     - Get implementation suggestions
/review      - Request code review
/explain     - Ask for explanations
/optimize    - Request optimization ideas
/patterns    - Get pattern recommendations
\stopverb}
}

\subtree{
\title{Navigator Mode}
\p{AI writes code while you provide direction.}

\pre{\startverb
claude-flow pair --start --mode navigator
\stopverb}

\p{\strong{Your Responsibilities:}}

\ul{
\li{Provide high-level direction}
\li{Review generated code}
\li{Make architectural decisions}
\li{Ensure business requirements}
}

\p{\strong{AI Driver:}}

\ul{
\li{Write implementation code}
\li{Handle syntax details}
\li{Implement your guidance}
\li{Manage boilerplate}
\li{Execute refactoring}
}

\p{\strong{Best For:}}

\ul{
\li{Rapid prototyping}
\li{Boilerplate generation}
\li{Learning from AI patterns}
\li{Exploring solutions}
}

\p{\strong{Commands:}}

\pre{\startverb
/implement   - Direct implementation
/refactor    - Request refactoring
/test        - Generate tests
/document    - Add documentation
/alternate   - See alternative approaches
\stopverb}
}

\subtree{
\title{Switch Mode}
\p{Automatically alternates roles at intervals.}

\pre{\startverb
# Default 10-minute intervals
claude-flow pair --start --mode switch

# 5-minute intervals (rapid)
claude-flow pair --start --mode switch --interval 5m

# 15-minute intervals (deep focus)
claude-flow pair --start --mode switch --interval 15m
\stopverb}

\p{\strong{Handoff Process:}}

\ol{
\li{30-second warning before switch}
\li{Current driver completes thought}
\li{Context summary generated}
\li{Roles swap smoothly}
\li{New driver continues}
}

\p{\strong{Best For:}}

\ul{
\li{Balanced collaboration}
\li{Knowledge sharing}
\li{Complex features}
\li{Extended sessions}
}
}

\subtree{
\title{Specialized Modes}
\p{\strong{TDD Mode} - Test-Driven Development:}

\pre{\startverb
claude-flow pair --start \
  --mode tdd \
  --test-first \
  --coverage 100
\stopverb}

\p{Workflow: Write failing test → Implement → Refactor → Repeat}

\p{\strong{Review Mode} - Continuous code review:}

\pre{\startverb
claude-flow pair --start \
  --mode review \
  --strict \
  --security
\stopverb}

\p{Features: Real-time feedback, security scanning, performance analysis}

\p{\strong{Mentor Mode} - Learning-focused:}

\pre{\startverb
claude-flow pair --start \
  --mode mentor \
  --explain-all \
  --pace slow
\stopverb}

\p{Features: Detailed explanations, step-by-step guidance, pattern teaching}

\p{\strong{Debug Mode} - Problem-solving:}

\pre{\startverb
claude-flow pair --start \
  --mode debug \
  --verbose \
  --trace
\stopverb}

\p{Features: Issue identification, root cause analysis, fix suggestions}
}
}

\subtree{
\title{In-Session Commands}
\subtree{
\title{Code Commands}
\pre{\startverb
/explain [--level basic|detailed|expert]
  Explain the current code or selection

/suggest [--type refactor|optimize|security|style]
  Get improvement suggestions

/implement <description>
  Request implementation (navigator mode)

/refactor [--pattern <pattern>] [--scope function|file|module]
  Refactor selected code

/optimize [--target speed|memory|both]
  Optimize code for performance

/document [--format jsdoc|markdown|inline]
  Add documentation to code

/comment [--verbose]
  Add inline comments

/pattern <pattern-name> [--example]
  Apply a design pattern
\stopverb}
}

\subtree{
\title{Testing Commands}
\pre{\startverb
/test [--watch] [--coverage] [--only <pattern>]
  Run test suite

/test-gen [--type unit|integration|e2e]
  Generate tests for current code

/coverage [--report html|json|terminal]
  Check test coverage

/mock <target> [--realistic]
  Generate mock data or functions

/test-watch [--on-save]
  Enable test watching

/snapshot [--update]
  Create test snapshots
\stopverb}
}

\subtree{
\title{Review Commands}
\pre{\startverb
/review [--scope current|file|changes] [--strict]
  Perform code review

/security [--deep] [--fix]
  Security analysis

/perf [--profile] [--suggestions]
  Performance analysis

/quality [--detailed]
  Check code quality metrics

/lint [--fix] [--config <config>]
  Run linters

/complexity [--threshold <value>]
  Analyze code complexity
\stopverb}
}

\subtree{
\title{Navigation Commands}
\pre{\startverb
/goto <file>[:line[:column]]
  Navigate to file or location

/find <pattern> [--regex] [--case-sensitive]
  Search in project

/recent [--limit <n>]
  Show recent files

/bookmark [add|list|goto|remove] [<name>]
  Manage bookmarks

/history [--limit <n>] [--filter <pattern>]
  Show command history

/tree [--depth <n>] [--filter <pattern>]
  Show project structure
\stopverb}
}

\subtree{
\title{Git Commands}
\pre{\startverb
/diff [--staged] [--file <file>]
  Show git diff

/commit [--message <msg>] [--amend]
  Commit with verification

/branch [create|switch|delete|list] [<name>]
  Branch operations

/stash [save|pop|list|apply] [<message>]
  Stash operations

/log [--oneline] [--limit <n>]
  View git log

/blame [<file>]
  Show git blame
\stopverb}
}

\subtree{
\title{AI Partner Commands}
\pre{\startverb
/agent [switch|info|config] [<agent-name>]
  Manage AI agent

/teach <preference>
  Teach the AI your preferences

/feedback [positive|negative] <message>
  Provide feedback to AI

/personality [professional|friendly|concise|verbose]
  Adjust AI personality

/expertise [add|remove|list] [<domain>]
  Set AI expertise focus
\stopverb}
}

\subtree{
\title{Metrics Commands}
\pre{\startverb
/metrics [--period today|session|week|all]
  Show session metrics

/score [--breakdown]
  Show quality scores

/productivity [--chart]
  Show productivity metrics

/leaderboard [--personal|team]
  Show improvement leaderboard
\stopverb}
}

\subtree{
\title{Role & Mode Commands}
\pre{\startverb
/switch [--immediate]
  Switch driver/navigator roles

/mode <type>
  Change mode (driver|navigator|switch|tdd|review|mentor|debug)

/role
  Show current role

/handoff
  Prepare role handoff
\stopverb}
}
}

