claude-flow pair --report <session-id>
\stopverb}
}

\subtree{
\title{Background Sessions}
\pre{\startverb
# Start in background
claude-flow pair --start --background

# Monitor background session
claude-flow pair --monitor

# Attach to background session
claude-flow pair --attach <session-id>

# End background session
claude-flow pair --end <session-id>
\stopverb}
}
}

\subtree{
\title{Advanced Features}
\subtree{
\title{Custom Commands}
\p{Define in configuration:}

\pre{\startverb
{
  "customCommands": {
    "tdd": "/test-gen && /test --watch",
    "full-review": "/lint --fix && /test && /review --strict",
    "quick-fix": "/suggest --type fix && /implement && /test"
  }
}
\stopverb}

\p{Use custom commands:}

\pre{\startverb
/custom tdd
/custom full-review
\stopverb}
}

\subtree{
\title{Command Chaining}
\pre{\startverb
/test && /commit && /push
/lint --fix && /test && /review --strict
\stopverb}
}

\subtree{
\title{Session Recording}
\pre{\startverb
# Start with recording
claude-flow pair --start --record

# Replay session
claude-flow pair --replay <session-id>

# Session analytics
claude-flow pair --analytics <session-id>
\stopverb}
}

\subtree{
\title{Integration Options}
\p{\strong{With Git:}}

\pre{\startverb
claude-flow pair --start --git --auto-commit
\stopverb}

\p{\strong{With CI/CD:}}

\pre{\startverb
claude-flow pair --start --ci --non-interactive
\stopverb}

\p{\strong{With IDE:}}

\pre{\startverb
claude-flow pair --start --ide vscode
\stopverb}
}
}

\subtree{
\title{Best Practices}
\subtree{
\title{Session Practices}
\ol{
\li{\strong{Clear Goals} - Define session objectives upfront}
\li{\strong{Appropriate Mode} - Choose based on task type}
\li{\strong{Enable Verification} - For critical code paths}
\li{\strong{Regular Testing} - Maintain quality continuously}
\li{\strong{Session Notes} - Document important decisions}
\li{\strong{Regular Breaks} - Take breaks every 45-60 minutes}
}
}

\subtree{
\title{Code Practices}
\ol{
\li{\strong{Test Early} - Run tests after each change}
\li{\strong{Verify Before Commit} - Check truth scores}
\li{\strong{Review Security} - Always for sensitive code}
\li{\strong{Profile Performance} - Use \code{\startverb /perf\stopverb} for optimization}
\li{\strong{Save Sessions} - For complex work}
\li{\strong{Learn from AI} - Ask questions frequently}
}
}

\subtree{
\title{Mode Selection}
\ul{
\li{\strong{Driver Mode}: When learning, controlling implementation}
\li{\strong{Navigator Mode}: For rapid prototyping, generation}
\li{\strong{Switch Mode}: Long sessions, balanced collaboration}
\li{\strong{TDD Mode}: Building with tests}
\li{\strong{Review Mode}: Quality focus}
\li{\strong{Mentor Mode}: Learning priority}
\li{\strong{Debug Mode}: Fixing issues}
}
}
}

\subtree{
\title{Troubleshooting}
\subtree{
\title{Session Won't Start}
\ul{
\li{Check agent availability}
\li{Verify configuration file syntax}
\li{Ensure clean workspace}
\li{Review log files}
}
}

\subtree{
\title{Session Disconnected}
\ul{
\li{Use \code{\startverb --recover\stopverb} to restore}
\li{Check network connection}
\li{Verify background processes}
\li{Review auto-save files}
}
}

\subtree{
\title{Poor Performance}
\ul{
\li{Reduce verification threshold}
\li{Disable continuous testing}
\li{Check system resources}
\li{Use lighter AI model}
}
}

\subtree{
\title{Configuration Issues}
\ul{
\li{Validate JSON syntax}
\li{Check file permissions}
\li{Review priority order (CLI > env > project > user > global)}
\li{Run \code{\startverb claude-flow pair config validate\stopverb}}
}
}
}

\subtree{
\title{Quality Metrics}
\subtree{
\title{Truth Score Thresholds}
\pre{\startverb
Error:   < 0.90 ❌
Warning: 0.90 - 0.95 ⚠️
Good:    0.95 - 0.98 ✅
Excellent: > 0.98 🌟
\stopverb}
}

\subtree{
\title{Coverage Thresholds}
\pre{\startverb
Error:   < 70% ❌
Warning: 70% - 80% ⚠️
Good:    80% - 90% ✅
Excellent: > 90% 🌟
\stopverb}
}

\subtree{
\title{Complexity Thresholds}
\pre{\startverb
Error:   > 15 ❌
Warning: 10 - 15 ⚠️
Good:    5 - 10 ✅
Excellent: < 5 🌟
\stopverb}
}
}

\subtree{
\title{Environment Variables}
\p{Override configuration via environment:}

\pre{\startverb
export CLAUDE_PAIR_MODE=driver
export CLAUDE_PAIR_VERIFY=true
export CLAUDE_PAIR_THRESHOLD=0.98
export CLAUDE_PAIR_AGENT=senior-dev
export CLAUDE_PAIR_AUTO_TEST=true
\stopverb}
}

\subtree{
\title{Command History}
\p{Navigate history:}

\ul{
\li{\code{\startverb ↑/↓\stopverb} - Navigate through command history}
\li{\code{\startverb Ctrl+R\stopverb} - Search command history}
\li{\code{\startverb !!\stopverb} - Repeat last command}
\li{\code{\startverb !<n>\stopverb} - Run command n from history}
}
}

\subtree{
\title{Keyboard Shortcuts (Configurable)}
\p{Default shortcuts:}

\pre{\startverb
{
  "shortcuts": {
    "switch": "ctrl+shift+s",
    "suggest": "ctrl+space",
    "review": "ctrl+r",
    "test": "ctrl+t"
  }
}
\stopverb}
}

\subtree{
\title{Related Commands}
\ul{
\li{\code{\startverb claude-flow pair --help\stopverb} - Show help}
\li{\code{\startverb claude-flow pair config\stopverb} - Manage configuration}
\li{\code{\startverb claude-flow pair profile\stopverb} - Manage profiles}
\li{\code{\startverb claude-flow pair templates\stopverb} - List templates}
\li{\code{\startverb claude-flow pair agents\stopverb} - List available agents}
}
}
}
}