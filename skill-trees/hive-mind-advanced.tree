\meta{version}{1.0.0}

\meta{description}{Advanced Hive Mind collective intelligence system for queen-led multi-agent coordination with consensus mechanisms and persistent memory}

\subtree{
\title{Hive Mind Advanced Skill}
\p{Master the advanced Hive Mind collective intelligence system for sophisticated multi-agent coordination using queen-led architecture, Byzantine consensus, and collective memory.}

\subtree{
\title{Overview}
\p{The Hive Mind system represents the pinnacle of multi-agent coordination in Claude Flow, implementing a queen-led hierarchical architecture where a strategic queen coordinator directs specialized worker agents through collective decision-making and shared memory.}
}

\subtree{
\title{Core Concepts}
\subtree{
\title{Architecture Patterns}
\p{\strong{Queen-Led Coordination}}

\ul{
\li{Strategic queen agents orchestrate high-level objectives}
\li{Tactical queens manage mid-level execution}
\li{Adaptive queens dynamically adjust strategies based on performance}
}

\p{\strong{Worker Specialization}}

\ul{
\li{Researcher agents: Analysis and investigation}
\li{Coder agents: Implementation and development}
\li{Analyst agents: Data processing and metrics}
\li{Tester agents: Quality assurance and validation}
\li{Architect agents: System design and planning}
\li{Reviewer agents: Code review and improvement}
\li{Optimizer agents: Performance enhancement}
\li{Documenter agents: Documentation generation}
}

\p{\strong{Collective Memory System}}

\ul{
\li{Shared knowledge base across all agents}
\li{LRU cache with memory pressure handling}
\li{SQLite persistence with WAL mode}
\li{Memory consolidation and association}
\li{Access pattern tracking and optimization}
}
}

\subtree{
\title{Consensus Mechanisms}
\p{\strong{Majority Consensus} Simple voting where the option with most votes wins.}

\p{\strong{Weighted Consensus} Queen vote counts as 3x weight, providing strategic guidance.}

\p{\strong{Byzantine Fault Tolerance} Requires 2/3 majority for decision approval, ensuring robust consensus even with faulty agents.}
}
}

\subtree{
\title{Getting Started}
\subtree{
\title{1. Initialize Hive Mind}
\pre{\startverb
# Basic initialization
npx claude-flow hive-mind init

# Force reinitialize
npx claude-flow hive-mind init --force

# Custom configuration
npx claude-flow hive-mind init --config hive-config.json
\stopverb}
}

\subtree{
\title{2. Spawn a Swarm}
\pre{\startverb
# Basic spawn with objective
npx claude-flow hive-mind spawn "Build microservices architecture"

# Strategic queen type
npx claude-flow hive-mind spawn "Research AI patterns" --queen-type strategic

# Tactical queen with max workers
npx claude-flow hive-mind spawn "Implement API" --queen-type tactical --max-workers 12

# Adaptive queen with consensus
npx claude-flow hive-mind spawn "Optimize system" --queen-type adaptive --consensus byzantine

# Generate Claude Code commands
npx claude-flow hive-mind spawn "Build full-stack app" --claude
\stopverb}
}

\subtree{
\title{3. Monitor Status}
\pre{\startverb
# Check hive mind status
npx claude-flow hive-mind status

# Get detailed metrics
npx claude-flow hive-mind metrics

# Monitor collective memory
npx claude-flow hive-mind memory
\stopverb}
}
}

\subtree{
\title{Advanced Workflows}
\subtree{
\title{Session Management}
\p{\strong{Create and Manage Sessions}}

\pre{\startverb
# List active sessions
npx claude-flow hive-mind sessions

# Pause a session
npx claude-flow hive-mind pause <session-id>

# Resume a paused session
npx claude-flow hive-mind resume <session-id>

# Stop a running session
npx claude-flow hive-mind stop <session-id>
\stopverb}

\p{\strong{Session Features}}

\ul{
\li{Automatic checkpoint creation}
\li{Progress tracking with completion percentages}
\li{Parent-child process management}
\li{Session logs with event tracking}
\li{Export/import capabilities}
}
}

\subtree{
\title{Consensus Building}
\p{The Hive Mind builds consensus through structured voting:}

\pre{\startverb
// Programmatic consensus building
const decision = await hiveMind.buildConsensus(
  'Architecture pattern selection',
  ['microservices', 'monolith', 'serverless']
);

// Result includes:
// - decision: Winning option
// - confidence: Vote percentage
// - votes: Individual agent votes
\stopverb}

\p{\strong{Consensus Algorithms}}

\ol{
\li{\strong{Majority} - Simple democratic voting}
\li{\strong{Weighted} - Queen has 3x voting power}
\li{\strong{Byzantine} - 2/3 supermajority required}
}
}

\subtree{
\title{Collective Memory}
\p{\strong{Storing Knowledge}}

\pre{\startverb
// Store in collective memory
await memory.store('api-patterns', {
  rest: { pros: [...], cons: [...] },
  graphql: { pros: [...], cons: [...] }
}, 'knowledge', { confidence: 0.95 });
\stopverb}

\p{\strong{Memory Types}}

\ul{
\li{\code{\startverb knowledge\stopverb}: Permanent insights (no TTL)}
\li{\code{\startverb context\stopverb}: Session context (1 hour TTL)}
\li{\code{\startverb task\stopverb}: Task-specific data (30 min TTL)}
\li{\code{\startverb result\stopverb}: Execution results (permanent, compressed)}
\li{\code{\startverb error\stopverb}: Error logs (24 hour TTL)}
\li{\code{\startverb metric\stopverb}: Performance metrics (1 hour TTL)}
\li{\code{\startverb consensus\stopverb}: Decision records (permanent)}
\li{\code{\startverb system\stopverb}: System configuration (permanent)}
}

\p{\strong{Searching and Retrieval}}

\pre{\startverb
// Search memory by pattern
const results = await memory.search('api*', {
  type: 'knowledge',
  minConfidence: 0.8,
  limit: 50
});

// Get related memories
const related = await memory.getRelated('api-patterns', 10);

// Build associations
await memory.associate('rest-api', 'authentication', 0.9);
\stopverb}
}

\subtree{
\title{Task Distribution}
\p{\strong{Automatic Worker Assignment}}

\p{The system intelligently assigns tasks based on:}

\ul{
\li{Keyword matching with agent specialization}
\li{Historical performance metrics}
\li{Worker availability and load}
\li{Task complexity analysis}
}

\pre{\startverb
// Create task (auto-assigned)
const task = await hiveMind.createTask(
  'Implement user authentication',
  priority: 8,
  { estimatedDuration: 30000 }
);
\stopverb}

\p{\strong{Auto-Scaling}}

\pre{\startverb
// Configure auto-scaling
const config = {
  autoScale: true,
  maxWorkers: 12,
  scaleUpThreshold: 2, // Pending tasks per idle worker
  scaleDownThreshold: 2 // Idle workers above pending tasks
};
\stopverb}
}
}

\subtree{
\title{Integration Patterns}
\subtree{
\title{With Claude Code}
\p{Generate Claude Code spawn commands directly:}

\pre{\startverb
npx claude-flow hive-mind spawn "Build REST API" --claude
\stopverb}

\p{Output:}

\pre{\startverb
Task("Queen Coordinator", "Orchestrate REST API development...", "coordinator")
Task("Backend Developer", "Implement Express routes...", "backend-dev")
Task("Database Architect", "Design PostgreSQL schema...", "code-analyzer")
Task("Test Engineer", "Create Jest test suite...", "tester")
\stopverb}
}

\subtree{
