\subtree{
\title{Common Workflows}
\subtree{
\title{Workflow 1: Gene Annotation Pipeline}
\ol{
\li{Look up gene by symbol to get Ensembl ID}
\li{Retrieve transcript information}
\li{Get protein sequences for all transcripts}
\li{Find orthologs in other species}
\li{Export results}
}
}

\subtree{
\title{Workflow 2: Variant Analysis}
\ol{
\li{Query variant by rsID or coordinates}
\li{Use VEP to predict functional consequences}
\li{Check population frequencies}
\li{Retrieve phenotype associations}
\li{Generate report}
}
}

\subtree{
\title{Workflow 3: Comparative Analysis}
\ol{
\li{Start with gene of interest in reference species}
\li{Find orthologs in target species}
\li{Retrieve sequences for all orthologs}
\li{Compare gene structures and features}
\li{Analyze evolutionary conservation}
}
}
}

\subtree{
\title{Species and Assembly Information}
\p{To query available species and assemblies:}

\pre{\startverb
# List all available species
species_list = client.info_species()

# Get assembly information for a species
assembly_info = client.info_assembly(species='human')
\stopverb}

\p{Common species identifiers:}

\ul{
\li{Human: \code{\startverb homo_sapiens\stopverb} or \code{\startverb human\stopverb}}
\li{Mouse: \code{\startverb mus_musculus\stopverb} or \code{\startverb mouse\stopverb}}
\li{Zebrafish: \code{\startverb danio_rerio\stopverb} or \code{\startverb zebrafish\stopverb}}
\li{Fruit fly: \code{\startverb drosophila_melanogaster\stopverb}}
}
}

