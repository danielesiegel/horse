\subtree{
\title{SDF Interleaving}
\p{\strong{Primary Chapter}: 7. Propagators}

\p{r2frida propagates constraints bidirectionally between static knowledge (what the binary \em{is}) and dynamic observation (what the process \em{does}). The \code{\startverb :\stopverb} command interface is a propagator network where each trace/hook/intercept is a cell that merges information from both directions.}

\subtree{
\title{GF(3) Balanced Triad}
\pre{\startverb
r2frida (0) + SDF.Ch7 (0) + [balancer] (0) = 0
\stopverb}

\p{\strong{Skill Trit}: 0 (ERGODIC - the bridge that makes static and dynamic cohere)}
}
}
}