\title{String Database}

\taxon{skill}

\meta{description}{"Query STRING API for protein-protein interactions (59M proteins, 20B interactions). Network analysis, GO/KEGG enrichment, interaction discovery, 5000+ species, for systems biology."}

\subtree{
\title{STRING Database}
\subtree{
\title{Overview}
\p{STRING is a comprehensive database of known and predicted protein-protein interactions covering 59M proteins and 20B+ interactions across 5000+ organisms. Query interaction networks, perform functional enrichment, discover partners via REST API for systems biology and pathway analysis.}
}

\subtree{
\title{When to Use This Skill}
\p{This skill should be used when:}

\ul{
\li{Retrieving protein-protein interaction networks for single or multiple proteins}
\li{Performing functional enrichment analysis (GO, KEGG, Pfam) on protein lists}
\li{Discovering interaction partners and expanding protein networks}
\li{Testing if proteins form significantly enriched functional modules}
\li{Generating network visualizations with evidence-based coloring}
\li{Analyzing homology and protein family relationships}
\li{Conducting cross-species protein interaction comparisons}
\li{Identifying hub proteins and network connectivity patterns}
}
}

\subtree{
\title{Quick Start}
\p{The skill provides:}

\ol{
\li{Python helper functions (\code{\startverb scripts/string_api.py\stopverb}) for all STRING REST API operations}
\li{Comprehensive reference documentation (\code{\startverb references/string_reference.md\stopverb}) with detailed API specifications}
}

\p{When users request STRING data, determine which operation is needed and use the appropriate function from \code{\startverb scripts/string_api.py\stopverb}.}
}

\subtree{
\title{Core Operations}
\subtree{
\title{1. Identifier Mapping (\code{\startverb string_map_ids\stopverb})}
\p{Convert gene names, protein names, and external IDs to STRING identifiers.}

\p{\strong{When to use}: Starting any STRING analysis, validating protein names, finding canonical identifiers.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.string_api import string_map_ids

# Map single protein
result = string_map_ids('TP53', species=9606)

# Map multiple proteins
result = string_map_ids(['TP53', 'BRCA1', 'EGFR', 'MDM2'], species=9606)

# Map with multiple matches per query
result = string_map_ids('p53', species=9606, limit=5)
\stopverb}

\p{\strong{Parameters}:}

\ul{
\li{\code{\startverb species\stopverb}: NCBI taxon ID (9606 = human, 10090 = mouse, 7227 = fly)}
\li{\code{\startverb limit\stopverb}: Number of matches per identifier (default: 1)}
\li{\code{\startverb echo_query\stopverb}: Include query term in output (default: 1)}
}

\p{\strong{Best practice}: Always map identifiers first for faster subsequent queries.}
}

\subtree{
\title{2. Network Retrieval (\code{\startverb string_network\stopverb})}
\p{Get protein-protein interaction network data in tabular format.}

\p{\strong{When to use}: Building interaction networks, analyzing connectivity, retrieving interaction evidence.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.string_api import string_network

# Get network for single protein
network = string_network('9606.ENSP00000269305', species=9606)

# Get network with multiple proteins
proteins = ['9606.ENSP00000269305', '9606.ENSP00000275493']
network = string_network(proteins, required_score=700)

# Expand network with additional interactors
network = string_network('TP53', species=9606, add_nodes=10, required_score=400)

# Physical interactions only
network = string_network('TP53', species=9606, network_type='physical')
\stopverb}

\p{\strong{Parameters}:}

\ul{
\li{\code{\startverb required_score\stopverb}: Confidence threshold (0-1000)}
\li{150: low confidence (exploratory)}
\li{400: medium confidence (default, standard analysis)}
\li{700: high confidence (conservative)}
\li{900: highest confidence (very stringent)}
\li{\code{\startverb network_type\stopverb}: \code{\startverb 'functional'\stopverb} (all evidence, default) or \code{\startverb 'physical'\stopverb} (direct binding only)}
\li{\code{\startverb add_nodes\stopverb}: Add N most connected proteins (0-10)}
}

\p{\strong{Output columns}: Interaction pairs, confidence scores, and individual evidence scores (neighborhood, fusion, coexpression, experimental, database, text-mining).}
}

\subtree{
\title{3. Network Visualization (\code{\startverb string_network_image\stopverb})}
\p{Generate network visualization as PNG image.}

\p{\strong{When to use}: Creating figures, visual exploration, presentations.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.string_api import string_network_image

# Get network image
proteins = ['TP53', 'MDM2', 'ATM', 'CHEK2', 'BRCA1']
img_data = string_network_image(proteins, species=9606, required_score=700)

# Save image
with open('network.png', 'wb') as f:
    f.write(img_data)

# Evidence-colored network
img = string_network_image(proteins, species=9606, network_flavor='evidence')

# Confidence-based visualization
img = string_network_image(proteins, species=9606, network_flavor='confidence')

# Actions network (activation/inhibition)
img = string_network_image(proteins, species=9606, network_flavor='actions')
\stopverb}

\p{\strong{Network flavors}:}

\ul{
\li{\code{\startverb 'evidence'\stopverb}: Colored lines show evidence types (default)}
\li{\code{\startverb 'confidence'\stopverb}: Line thickness represents confidence}
\li{\code{\startverb 'actions'\stopverb}: Shows activating/inhibiting relationships}
}
}

\subtree{
\title{4. Interaction Partners (\code{\startverb string_interaction_partners\stopverb})}
\p{Find all proteins that interact with given protein(s).}

\p{\strong{When to use}: Discovering novel interactions, finding hub proteins, expanding networks.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.string_api import string_interaction_partners

# Get top 10 interactors of TP53
partners = string_interaction_partners('TP53', species=9606, limit=10)

# Get high-confidence interactors
partners = string_interaction_partners('TP53', species=9606,
                                      limit=20, required_score=700)

# Find interactors for multiple proteins
partners = string_interaction_partners(['TP53', 'MDM2'],
                                      species=9606, limit=15)
\stopverb}

\p{\strong{Parameters}:}

\ul{
\li{\code{\startverb limit\stopverb}: Maximum number of partners to return (default: 10)}
\li{\code{\startverb required_score\stopverb}: Confidence threshold (0-1000)}
}

\p{\strong{Use cases}:}

\ul{
\li{Hub protein identification}
\li{Network expansion from seed proteins}
\li{Discovering indirect connections}
}
}

\subtree{
\title{5. Functional Enrichment (\code{\startverb string_enrichment\stopverb})}
\p{Perform enrichment analysis across Gene Ontology, KEGG pathways, Pfam domains, and more.}

\p{\strong{When to use}: Interpreting protein lists, pathway analysis, functional characterization, understanding biological processes.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.string_enrichment import string_enrichment

# Enrichment for a protein list
proteins = ['TP53', 'MDM2', 'ATM', 'CHEK2', 'BRCA1', 'ATR', 'TP73']
enrichment = string_enrichment(proteins, species=9606)

# Parse results to find significant terms
import pandas as pd
df = pd.read_csv(io.StringIO(enrichment), sep='\t')
significant = df[df['fdr'] < 0.05]
\stopverb}

\p{\strong{Enrichment categories}:}

\ul{
\li{\strong{Gene Ontology}: Biological Process, Molecular Function, Cellular Component}
\li{\strong{KEGG Pathways}: Metabolic and signaling pathways}
\li{\strong{Pfam}: Protein domains}
\li{\strong{InterPro}: Protein families and domains}
\li{\strong{SMART}: Domain architecture}
\li{\strong{UniProt Keywords}: Curated functional keywords}
}

\p{\strong{Output columns}:}

\ul{
\li{\code{\startverb category\stopverb}: Annotation database (e.g., "KEGG Pathways", "GO Biological Process")}
\li{\code{\startverb term\stopverb}: Term identifier}
\li{\code{\startverb description\stopverb}: Human-readable term description}
\li{\code{\startverb number_of_genes\stopverb}: Input proteins with this annotation}
\li{\code{\startverb p_value\stopverb}: Uncorrected enrichment p-value}
\li{\code{\startverb fdr\stopverb}: False discovery rate (corrected p-value)}
}

\p{\strong{Statistical method}: Fisher's exact test with Benjamini-Hochberg FDR correction.}

\p{\strong{Interpretation}: FDR < 0.05 indicates statistically significant enrichment.}
}

\subtree{
\title{6. PPI Enrichment (\code{\startverb string_ppi_enrichment\stopverb})}
\p{Test if a protein network has significantly more interactions than expected by chance.}

\p{\strong{When to use}: Validating if proteins form functional module, testing network connectivity.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.string_api import string_ppi_enrichment
import json

# Test network connectivity
proteins = ['TP53', 'MDM2', 'ATM', 'CHEK2', 'BRCA1']
result = string_ppi_enrichment(proteins, species=9606, required_score=400)

# Parse JSON result
data = json.loads(result)
print(f"Observed edges: {data['number_of_edges']}")
print(f"Expected edges: {data['expected_number_of_edges']}")
print(f"P-value: {data['p_value']}")
\stopverb}

\p{\strong{Output fields}:}

\ul{
\li{\code{\startverb number_of_nodes\stopverb}: Proteins in network}
\li{\code{\startverb number_of_edges\stopverb}: Observed interactions}
\li{\code{\startverb expected_number_of_edges\stopverb}: Expected in random network}
\li{\code{\startverb p_value\stopverb}: Statistical significance}
}

\p{\strong{Interpretation}:}

\ul{
\li{p-value < 0.05: Network is significantly enriched (proteins likely form functional module)}
\li{p-value ≥ 0.05: No significant enrichment (proteins may be unrelated)}
}
}

\subtree{
\title{7. Homology Scores (\code{\startverb string_homology\stopverb})}
\p{Retrieve protein similarity and homology information.}

\p{\strong{When to use}: Identifying protein families, paralog analysis, cross-species comparisons.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.string_api import string_homology

# Get homology between proteins
proteins = ['TP53', 'TP63', 'TP73']  # p53 family
homology = string_homology(proteins, species=9606)
\stopverb}

\p{\strong{Use cases}:}

\ul{
\li{Protein family identification}
\li{Paralog discovery}
\li{Evolutionary analysis}
}
}

\subtree{
\title{8. Version Information (\code{\startverb string_version\stopverb})}
\p{Get current STRING database version.}

\p{\strong{When to use}: Ensuring reproducibility, documenting methods.}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.string_api import string_version

version = string_version()
print(f"STRING version: {version}")
\stopverb}
}
}

\subtree{
\title{Common Analysis Workflows}
\subtree{
\title{Workflow 1: Protein List Analysis (Standard Workflow)}
\p{\strong{Use case}: Analyze a list of proteins from experiment (e.g., differential expression, proteomics).}

\pre{\startverb
from scripts.string_api import (string_map_ids, string_network,
                                string_enrichment, string_ppi_enrichment,
                                string_network_image)

# Step 1: Map gene names to STRING IDs
gene_list = ['TP53', 'BRCA1', 'ATM', 'CHEK2', 'MDM2', 'ATR', 'BRCA2']
mapping = string_map_ids(gene_list, species=9606)

# Step 2: Get interaction network
network = string_network(gene_list, species=9606, required_score=400)

# Step 3: Test if network is enriched
ppi_result = string_ppi_enrichment(gene_list, species=9606)

# Step 4: Perform functional enrichment
enrichment = string_enrichment(gene_list, species=9606)

# Step 5: Generate network visualization
img = string_network_image(gene_list, species=9606,
                          network_flavor='evidence', required_score=400)
with open('protein_network.png', 'wb') as f:
    f.write(img)

# Step 6: Parse and interpret results
\stopverb}
}

\subtree{
\title{Workflow 2: Single Protein Investigation}
\p{\strong{Use case}: Deep dive into one protein's interactions and partners.}

\pre{\startverb
from scripts.string_api import (string_map_ids, string_interaction_partners,
                                string_network_image)

# Step 1: Map protein name
protein = 'TP53'
mapping = string_map_ids(protein, species=9606)

# Step 2: Get all interaction partners
partners = string_interaction_partners(protein, species=9606,
                                      limit=20, required_score=700)

# Step 3: Visualize expanded network
img = string_network_image(protein, species=9606, add_nodes=15,
                          network_flavor='confidence', required_score=700)
with open('tp53_network.png', 'wb') as f:
    f.write(img)
\stopverb}
}

\subtree{
\title{Workflow 3: Pathway-Centric Analysis}
\p{\strong{Use case}: Identify and visualize proteins in a specific biological pathway.}

\pre{\startverb
from scripts.string_api import string_enrichment, string_network

# Step 1: Start with known pathway proteins
dna_repair_proteins = ['TP53', 'ATM', 'ATR', 'CHEK1', 'CHEK2',
                       'BRCA1', 'BRCA2', 'RAD51', 'XRCC1']

# Step 2: Get network
network = string_network(dna_repair_proteins, species=9606,
                        required_score=700, add_nodes=5)

# Step 3: Enrichment to confirm pathway annotation
enrichment = string_enrichment(dna_repair_proteins, species=9606)

# Step 4: Parse enrichment for DNA repair pathways
import pandas as pd
import io
df = pd.read_csv(io.StringIO(enrichment), sep='\t')
dna_repair = df[df['description'].str.contains('DNA repair', case=False)]
\stopverb}
}

\subtree{
\title{Workflow 4: Cross-Species Analysis}
\p{\strong{Use case}: Compare protein interactions across different organisms.}

\pre{\startverb
from scripts.string_api import string_network

# Human network
human_network = string_network('TP53', species=9606, required_score=700)

# Mouse network
mouse_network = string_network('Trp53', species=10090, required_score=700)

# Yeast network (if ortholog exists)
yeast_network = string_network('gene_name', species=4932, required_score=700)
\stopverb}
}

\subtree{
\title{Workflow 5: Network Expansion and Discovery}
\p{\strong{Use case}: Start with seed proteins and discover connected functional modules.}

\pre{\startverb
from scripts.string_api import (string_interaction_partners, string_network,
                                string_enrichment)

# Step 1: Start with seed protein(s)
seed_proteins = ['TP53']

# Step 2: Get first-degree interactors
partners = string_interaction_partners(seed_proteins, species=9606,
                                      limit=30, required_score=700)

# Step 3: Parse partners to get protein list
import pandas as pd
import io
df = pd.read_csv(io.StringIO(partners), sep='\t')
all_proteins = list(set(df['preferredName_A'].tolist() +
                       df['preferredName_B'].tolist()))

# Step 4: Perform enrichment on expanded network
enrichment = string_enrichment(all_proteins[:50], species=9606)

# Step 5: Filter for interesting functional modules
enrichment_df = pd.read_csv(io.StringIO(enrichment), sep='\t')
modules = enrichment_df[enrichment_df['fdr'] < 0.001]
\stopverb}
}
}

\subtree{
\title{Common Species}
\p{When specifying species, use NCBI taxon IDs:}

\pre{\startverb
| Organism | Common Name | Taxon ID |
|----------|-------------|----------|
| Homo sapiens | Human | 9606 |
| Mus musculus | Mouse | 10090 |
| Rattus norvegicus | Rat | 10116 |
| Drosophila melanogaster | Fruit fly | 7227 |
| Caenorhabditis elegans | C. elegans | 6239 |
| Saccharomyces cerevisiae | Yeast | 4932 |
| Arabidopsis thaliana | Thale cress | 3702 |
| Escherichia coli | E. coli | 511145 |
| Danio rerio | Zebrafish | 7955 |
\stopverb}

\p{Full list available at: https://string-db.org/cgi/input?input_page_active_form=organisms}
}

\subtree{
\title{Understanding Confidence Scores}
\p{STRING provides combined confidence scores (0-1000) integrating multiple evidence types:}

\subtree{
\title{Evidence Channels}
\ol{
\li{\strong{Neighborhood (nscore)}: Conserved genomic neighborhood across species}
\li{\strong{Fusion (fscore)}: Gene fusion events}
\li{\strong{Phylogenetic Profile (pscore)}: Co-occurrence patterns across species}
\li{\strong{Coexpression (ascore)}: Correlated RNA expression}
\li{\strong{Experimental (escore)}: Biochemical and genetic experiments}
\li{\strong{Database (dscore)}: Curated pathway and complex databases}
\li{\strong{Text-mining (tscore)}: Literature co-occurrence and NLP extraction}
}
}

\subtree{
\title{Recommended Thresholds}
\p{Choose threshold based on analysis goals:}

\ul{
\li{\strong{150 (low confidence)}: Exploratory analysis, hypothesis generation}
\li{\strong{400 (medium confidence)}: Standard analysis, balanced sensitivity/specificity}
\li{\strong{700 (high confidence)}: Conservative analysis, high-confidence interactions}
\li{\strong{900 (highest confidence)}: Very stringent, experimental evidence preferred}
}

\p{\strong{Trade-offs}:}

\ul{
\li{Lower thresholds: More interactions (higher recall, more false positives)}
\li{Higher thresholds: Fewer interactions (higher precision, more false negatives)}
}
}
}

\subtree{
\title{Network Types}
\subtree{
\title{Functional Networks (Default)}
\p{Includes all evidence types (experimental, computational, text-mining). Represents proteins that are functionally associated, even without direct physical binding.}

\p{\strong{When to use}:}

\ul{
\li{Pathway analysis}
\li{Functional enrichment studies}
\li{Systems biology}
\li{Most general analyses}
}
}

\subtree{
\title{Physical Networks}
\p{Only includes evidence for direct physical binding (experimental data and database annotations for physical interactions).}

\p{\strong{When to use}:}

\ul{
\li{Structural biology studies}
\li{Protein complex analysis}
\li{Direct binding validation}
\li{When physical contact is required}
}
}
}

\subtree{
\title{API Best Practices}
\ol{
\li{\strong{Always map identifiers first}: Use \code{\startverb string_map_ids()\stopverb} before other operations for faster queries}
\li{\strong{Use STRING IDs when possible}: Use format \code{\startverb 9606.ENSP00000269305\stopverb} instead of gene names}
\li{\strong{Specify species for networks >10 proteins}: Required for accurate results}
\li{\strong{Respect rate limits}: Wait 1 second between API calls}
\li{\strong{Use versioned URLs for reproducibility}: Available in reference documentation}
\li{\strong{Handle errors gracefully}: Check for "Error:" prefix in returned strings}
\li{\strong{Choose appropriate confidence thresholds}: Match threshold to analysis goals}
}
}

