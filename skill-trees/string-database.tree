}
}

\subtree{
\title{Troubleshooting}
\p{\strong{No proteins found}:}

\ul{
\li{Verify species parameter matches identifiers}
\li{Try mapping identifiers first with \code{\startverb string_map_ids()\stopverb}}
\li{Check for typos in protein names}
}

\p{\strong{Empty network results}:}

\ul{
\li{Lower confidence threshold (\code{\startverb required_score\stopverb})}
\li{Check if proteins actually interact}
\li{Verify species is correct}
}

\p{\strong{Timeout or slow queries}:}

\ul{
\li{Reduce number of input proteins}
\li{Use STRING IDs instead of gene names}
\li{Split large queries into batches}
}

\p{\strong{"Species required" error}:}

\ul{
\li{Add \code{\startverb species\stopverb} parameter for networks with >10 proteins}
\li{Always include species for consistency}
}

\p{\strong{Results look unexpected}:}

\ul{
\li{Check STRING version with \code{\startverb string_version()\stopverb}}
\li{Verify network_type is appropriate (functional vs physical)}
\li{Review confidence threshold selection}
}
}

