\subtree{
\title{Troubleshooting}
\p{Common issues and solutions:}

\ul{
\li{\strong{API key errors}: Ensure environment variables are set correctly (see \code{\startverb references/llm_configuration.md\stopverb})}
\li{\strong{LaTeX compilation}: Install TeX distribution or use Docker image with pre-installed LaTeX}
\li{\strong{Package conflicts}: Use virtual environments or Docker for isolation}
\li{\strong{Python version}: Requires Python 3.12 or higher}
}
}
}