\title{Ctp Yoneda}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{'CTP-Yoneda Skill'}

\subtree{
\title{CTP-Yoneda Skill}
\blockquote{*"The Yoneda lemma is arguably the most important result in category theory."* — Emily Riehl}

\p{Category Theory in Programming (CTP) by NoahStoryM - Racket tutorial mapping abstract CT concepts to programming constructs with GF(3) colored awareness.}

\subtree{
\title{Overview}
\p{\strong{Source}: [NoahStoryM/ctp](https://github.com/NoahStoryM/ctp) \strong{Docs}: [docs.racket-lang.org/ctp](https://docs.racket-lang.org/ctp/index.html) \strong{Local}: \code{\startverb .topos/ctp/\stopverb}}
}

