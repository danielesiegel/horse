\subtree{
\title{Colored Awareness Protocol}
\p{When reading CTP files, each touched file gets a deterministic color:}

\pre{\startverb
# Track file access with Gay.jl colors
seed = 1069
files_touched = []

def touch_file(path, index)
  color = gay_color_at(seed, index)
  files_touched << { path: path, color: color, trit: color[:trit] }
end
\stopverb}

\p{Current session colors (seed=1069):}

\ol{
\li{\code{\startverb #E67F86\stopverb} (+1) - info.rkt}
\li{\code{\startverb #D06546\stopverb} (-1) - main.rkt  }
\li{\code{\startverb #1316BB\stopverb} (0) - ctp.scrbl}
\li{\code{\startverb #BA2645\stopverb} (+1) - category/main.scrbl}
\li{\code{\startverb #49EE54\stopverb} (-1) - functor/main.scrbl}
\li{\code{\startverb #11C710\stopverb} (0) - natural transformation/}
\li{\code{\startverb #76B0F0\stopverb} (+1) - code examples}
}
}

