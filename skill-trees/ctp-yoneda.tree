\subtree{
\title{Core Concepts}
\subtree{
\title{Category (Chapter 1)}
\ul{
\li{Objects, morphisms, composition, identity}
\li{Digraphs → Free categories}
\li{Subcategories, product/coproduct categories}
\li{Quotient categories, congruence relations}
}
}

\subtree{
\title{Functor (Chapter 2)}
\ul{
\li{Structure-preserving maps between categories}
\li{Constant, opposite, binary functors}
\li{Hom functors (covariant/contravariant)}
\li{Free monoid/category functors}
\li{Finite automata as functors (DFA, NFA, TDFA)}
}
}

\subtree{
\title{Natural Transformation (Chapter 3)}
\ul{
\li{Morphisms between functors}
\li{Functor categories}
\li{Vertical/horizontal composition}
\li{Whiskering}
}
}

\subtree{
\title{Yoneda Lemma (Key Insight)}
\pre{\startverb
Nat(Hom(A, -), F) ≅ F(A)
\stopverb}

\p{Every object is completely determined by its relationships to all other objects.}
}
}

