}
}
}

\subtree{
\title{Racket Integration}
\pre{\startverb
# Install CTP package
cd .topos/ctp && raco pkg install

# Build documentation
raco setup --doc-index ctp

# Open docs
open doc/ctp/index.html
\stopverb}
}

