\title{Analyzing Threat Landscape With Misp}

\taxon{skill}

\tag{analyzing}

\tag{threat}

\tag{landscape}

\tag{with}

\meta{version}{"1.0"}

\meta{description}{>-}

\subtree{
\title{Analyzing Threat Landscape with MISP}
\subtree{
\title{When to Use}
\ul{
\li{When investigating security incidents that require analyzing threat landscape with misp}
\li{When building detection rules or threat hunting queries for this domain}
\li{When SOC analysts need structured procedures for this analysis type}
\li{When validating security monitoring coverage for related attack techniques}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Familiarity with threat intelligence concepts and tools}
\li{Access to a test or lab environment for safe execution}
\li{Python 3.8+ with required dependencies installed}
\li{Appropriate authorization for any testing activities}
}
}

\subtree{
\title{Instructions}
\ol{
\li{Install dependencies: \code{\startverb pip install pymisp\stopverb}}
\li{Configure MISP URL and API key.}
\li{Run the agent to generate threat landscape analysis:}
\li{Pull event statistics by threat level and date range}
\li{Analyze attribute type distributions (IP, domain, hash, URL)}
\li{Identify top MITRE ATT&CK techniques from event tags}
\li{Track threat actor activity via galaxy clusters}
\li{Generate temporal trend analysis of IOC submissions}
}

\pre{\startverb
python scripts/agent.py --misp-url https://misp.local --api-key YOUR_KEY --days 90 --output landscape_report.json
\stopverb}
}

\subtree{
\title{Examples}
\subtree{
\title{Threat Landscape Summary}
\pre{\startverb
Period: Last 90 days
Events analyzed: 1,247
Top threat level: High (43%)
Top attribute type: ip-dst (31%), domain (22%), sha256 (18%)
Top MITRE technique: T1566 Phishing (89 events)
Top threat actor: APT28 (34 events)
\stopverb}
}
}
}