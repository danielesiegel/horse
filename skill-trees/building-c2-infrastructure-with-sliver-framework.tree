\li{\strong{T1090.002} - Proxy: External Proxy (Redirectors)}
\li{\strong{T1105} - Ingress Tool Transfer}
\li{\strong{T1132.001} - Data Encoding: Standard Encoding}
\li{\strong{T1572} - Protocol Tunneling}
}
}

