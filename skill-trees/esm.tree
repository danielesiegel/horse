\subtree{
\title{Best Practices}
\p{\strong{For generation tasks:}}

\ul{
\li{Start with smaller models for prototyping (\code{\startverb esm3-sm-open-v1\stopverb})}
\li{Use temperature parameter to control diversity (0.0 = deterministic, 1.0 = diverse)}
\li{Implement iterative refinement with chain-of-thought for complex designs}
\li{Validate generated sequences with structure prediction or wet-lab experiments}
}

\p{\strong{For embedding tasks:}}

\ul{
\li{Batch process sequences when possible for efficiency}
\li{Cache embeddings for repeated analyses}
\li{Normalize embeddings when computing similarities}
\li{Use appropriate model size based on downstream task requirements}
}

\p{\strong{For production deployment:}}

\ul{
\li{Use Forge API for scalability and latest models}
\li{Implement error handling and retry logic for API calls}
\li{Monitor token usage and implement rate limiting}
\li{Consider AWS SageMaker deployment for dedicated infrastructure}
}
}

