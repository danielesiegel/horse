\subtree{
\title{Rate Limiting and Best Practices}
\subtree{
\title{Rate Limit Compliance}
\pre{\startverb
import time

def rate_limited_request(url, params=None, delay=0.5):
    """Make API request with rate limiting (2 req/sec max)"""
    response = requests.get(url, params=params)
    time.sleep(delay)  # Wait 0.5 seconds between requests
    return response

# Use in loops
genes = ["CYP2D6", "CYP2C19", "CYP2C9"]
for gene in genes:
    response = rate_limited_request(
        "https://api.clinpgx.org/v1/gene/" + gene
    )
    data = response.json()
\stopverb}
}

\subtree{
\title{Error Handling}
\pre{\startverb
def safe_api_call(url, params=None, max_retries=3):
    """API call with error handling and retries"""
    for attempt in range(max_retries):
        try:
            response = requests.get(url, params=params, timeout=10)

            if response.status_code == 200:
                return response.json()
            elif response.status_code == 429:
                # Rate limit exceeded
                wait_time = 2 ** attempt  # Exponential backoff
                print(f"Rate limit hit. Waiting {wait_time}s...")
                time.sleep(wait_time)
            else:
                response.raise_for_status()

        except requests.exceptions.RequestException as e:
            print(f"Attempt {attempt + 1} failed: {e}")
            if attempt == max_retries - 1:
                raise
            time.sleep(1)
\stopverb}
}

\subtree{
\title{Caching Results}
\pre{\startverb
import json
from pathlib import Path

def cached_query(cache_file, api_func, *args, **kwargs):
    """Cache API results to avoid repeated queries"""
    cache_path = Path(cache_file)

    if cache_path.exists():
        with open(cache_path) as f:
            return json.load(f)

    result = api_func(*args, **kwargs)

    with open(cache_path, 'w') as f:
        json.dump(result, f, indent=2)

    return result

# Usage
gene_data = cached_query(
    'cyp2d6_cache.json',
    rate_limited_request,
    "https://api.clinpgx.org/v1/gene/CYP2D6"
)
\stopverb}
}
}

\subtree{
\title{PharmDOG Tool}
\p{PharmDOG (formerly DDRx) is ClinPGx's clinical decision support tool for interpreting pharmacogenomic test results:}

\p{\strong{Key features}:}

\ul{
\li{\strong{Phenoconversion calculator}: Adjusts phenotype predictions for drug-drug interactions affecting CYP2D6}
\li{\strong{Custom genotypes}: Input patient genotypes to get phenotype predictions}
\li{\strong{QR code sharing}: Generate shareable patient reports}
\li{\strong{Flexible guidance sources}: Select which guidelines to apply (CPIC, DPWG, FDA)}
\li{\strong{Multi-drug analysis}: Assess multiple medications simultaneously}
}

\p{\strong{Access}: Available at https://www.clinpgx.org/pharmacogenomic-decision-support}

\p{\strong{Use cases}:}

\ul{
\li{Clinical interpretation of PGx panel results}
\li{Medication review for patients with known genotypes}
\li{Patient education materials}
\li{Point-of-care decision support}
}
}

\subtree{
\title{Resources}
\subtree{
\title{scripts/query_clinpgx.py}
\p{Python script with ready-to-use functions for common ClinPGx queries:}

\ul{
\li{\code{\startverb get_gene_info(gene_symbol)\stopverb} - Retrieve gene details}
\li{\code{\startverb get_drug_info(drug_name)\stopverb} - Get drug information}
\li{\code{\startverb get_gene_drug_pairs(gene, drug)\stopverb} - Query gene-drug interactions}
\li{\code{\startverb get_cpic_guidelines(gene, drug)\stopverb} - Retrieve CPIC guidelines}
\li{\code{\startverb get_alleles(gene)\stopverb} - Get all alleles for a gene}
\li{\code{\startverb get_clinical_annotations(gene, drug, evidence_level)\stopverb} - Query literature annotations}
\li{\code{\startverb get_drug_labels(drug)\stopverb} - Retrieve pharmacogenomic drug labels}
\li{\code{\startverb search_variants(rsid)\stopverb} - Search by variant rsID}
\li{\code{\startverb export_to_dataframe(data)\stopverb} - Convert results to pandas DataFrame}
}

\p{Consult this script for implementation examples with proper rate limiting and error handling.}
}

