\subtree{
\title{Important Notes}
\subtree{
\title{Data Sources and Integration}
\p{ClinPGx consolidates multiple authoritative sources:}

\ul{
\li{\strong{PharmGKB}: Curated pharmacogenomics knowledge base (now part of ClinPGx)}
\li{\strong{CPIC}: Evidence-based clinical implementation guidelines}
\li{\strong{PharmCAT}: Allele calling and phenotype interpretation tool}
\li{\strong{DPWG}: Dutch pharmacogenetics guidelines}
\li{\strong{FDA/EMA labels}: Regulatory pharmacogenomic information}
}

\p{As of July 2025, all PharmGKB URLs redirect to corresponding ClinPGx pages.}
}

\subtree{
\title{Clinical Implementation Considerations}
\ul{
\li{\strong{Evidence levels}: Always check evidence strength before clinical application}
\li{\strong{Population differences}: Allele frequencies vary significantly across populations}
\li{\strong{Phenoconversion}: Consider drug-drug interactions that affect enzyme activity}
\li{\strong{Multi-gene effects}: Some drugs affected by multiple pharmacogenes}
\li{\strong{Non-genetic factors}: Age, organ function, drug interactions also affect response}
\li{\strong{Testing limitations}: Not all clinically relevant alleles detected by all assays}
}
}

\subtree{
\title{Data Updates}
\ul{
\li{ClinPGx continuously updates with new evidence and guidelines}
\li{Check publication dates for clinical annotations}
\li{Monitor ClinPGx Blog (https://blog.clinpgx.org/) for announcements}
\li{CPIC guidelines updated as new evidence emerges}
\li{PharmVar provides nomenclature updates for allele definitions}
}
}

\subtree{
\title{API Stability}
\ul{
\li{API endpoints are relatively stable but may change during development}
\li{Parameters and response formats subject to modification}
\li{Monitor API changelog and ClinPGx blog for updates}
\li{Consider version pinning for production applications}
\li{Test API changes in development before production deployment}
}
}
}

\subtree{
\title{Common Use Cases}
\subtree{
\title{Pre-emptive Pharmacogenomic Testing}
\p{Query all clinically actionable gene-drug pairs to guide panel selection:}

\pre{\startverb
# Get all CPIC guideline pairs
response = requests.get("https://api.clinpgx.org/v1/geneDrugPair",
                       params={"cpicLevel": "A"})  # Level A recommendations
actionable_pairs = response.json()
\stopverb}
}

\subtree{
\title{Medication Therapy Management}
\p{Review patient medications against known genotypes:}

\pre{\startverb
patient_genes = {"CYP2C19": "*1/*2", "CYP2D6": "*1/*1", "SLCO1B1": "*1/*5"}
medications = ["clopidogrel", "simvastatin", "escitalopram"]

for med in medications:
    for gene in patient_genes:
        response = requests.get("https://api.clinpgx.org/v1/geneDrugPair",
                               params={"gene": gene, "drug": med})
        # Check for interactions and dosing guidance
\stopverb}
}

\subtree{
\title{Clinical Trial Eligibility}
\p{Screen for pharmacogenomic contraindications:}

\pre{\startverb
# Check for HLA-B*57:01 before abacavir trial
response = requests.get("https://api.clinpgx.org/v1/geneDrugPair",
                       params={"gene": "HLA-B", "drug": "abacavir"})
pair_info = response.json()
# CPIC: Do not use if HLA-B*57:01 positive
\stopverb}
}
}

