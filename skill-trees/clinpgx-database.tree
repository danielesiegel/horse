\title{Clinpgx Database}

\taxon{skill}

\meta{description}{"Access ClinPGx pharmacogenomics data (successor to PharmGKB). Query gene-drug interactions, CPIC guidelines, allele functions, for precision medicine and genotype-guided dosing decisions."}

\subtree{
\title{ClinPGx Database}
\subtree{
\title{Overview}
\p{ClinPGx (Clinical Pharmacogenomics Database) is a comprehensive resource for clinical pharmacogenomics information, successor to PharmGKB. It consolidates data from PharmGKB, CPIC, and PharmCAT, providing curated information on how genetic variation affects medication response. Access gene-drug pairs, clinical guidelines, allele functions, and drug labels for precision medicine applications.}
}

\subtree{
\title{When to Use This Skill}
\p{This skill should be used when:}

\ul{
\li{\strong{Gene-drug interactions}: Querying how genetic variants affect drug metabolism, efficacy, or toxicity}
\li{\strong{CPIC guidelines}: Accessing evidence-based clinical practice guidelines for pharmacogenetics}
\li{\strong{Allele information}: Retrieving allele function, frequency, and phenotype data}
\li{\strong{Drug labels}: Exploring FDA and other regulatory pharmacogenomic drug labeling}
\li{\strong{Pharmacogenomic annotations}: Accessing curated literature on gene-drug-disease relationships}
\li{\strong{Clinical decision support}: Using PharmDOG tool for phenoconversion and custom genotype interpretation}
\li{\strong{Precision medicine}: Implementing pharmacogenomic testing in clinical practice}
\li{\strong{Drug metabolism}: Understanding CYP450 and other pharmacogene functions}
\li{\strong{Personalized dosing}: Finding genotype-guided dosing recommendations}
\li{\strong{Adverse drug reactions}: Identifying genetic risk factors for drug toxicity}
}
}

\subtree{
\title{Installation and Setup}
\subtree{
\title{Python API Access}
\p{The ClinPGx REST API provides programmatic access to all database resources. Basic setup:}

\pre{\startverb
uv pip install requests
\stopverb}
}

\subtree{
\title{API Endpoint}
\pre{\startverb
BASE_URL = "https://api.clinpgx.org/v1/"
\stopverb}

\p{\strong{Rate Limits}:}

\ul{
\li{2 requests per second maximum}
\li{Excessive requests will result in HTTP 429 (Too Many Requests) response}
}

\p{\strong{Authentication}: Not required for basic access}

\p{\strong{Data License}: Creative Commons Attribution-ShareAlike 4.0 International License}

\p{For substantial API use, notify the ClinPGx team at api@clinpgx.org}
}
}

\subtree{
\title{Core Capabilities}
\subtree{
\title{1. Gene Queries}
\p{\strong{Retrieve gene information} including function, clinical annotations, and pharmacogenomic significance:}

\pre{\startverb
import requests

# Get gene details
response = requests.get("https://api.clinpgx.org/v1/gene/CYP2D6")
gene_data = response.json()

# Search for genes by name
response = requests.get("https://api.clinpgx.org/v1/gene",
                       params={"q": "CYP"})
genes = response.json()
\stopverb}

\p{\strong{Key pharmacogenes}:}

\ul{
\li{\strong{CYP450 enzymes}: CYP2D6, CYP2C19, CYP2C9, CYP3A4, CYP3A5}
\li{\strong{Transporters}: SLCO1B1, ABCB1, ABCG2}
\li{\strong{Other metabolizers}: TPMT, DPYD, NUDT15, UGT1A1}
\li{\strong{Receptors}: OPRM1, HTR2A, ADRB1}
\li{\strong{HLA genes}: HLA-B, HLA-A}
}
}

\subtree{
\title{2. Drug and Chemical Queries}
\p{\strong{Retrieve drug information} including pharmacogenomic annotations and mechanisms:}

\pre{\startverb
# Get drug details
response = requests.get("https://api.clinpgx.org/v1/chemical/PA448515")  # Warfarin
drug_data = response.json()

# Search drugs by name
response = requests.get("https://api.clinpgx.org/v1/chemical",
                       params={"name": "warfarin"})
drugs = response.json()
\stopverb}

\p{\strong{Drug categories with pharmacogenomic significance}:}

\ul{
\li{Anticoagulants (warfarin, clopidogrel)}
\li{Antidepressants (SSRIs, TCAs)}
\li{Immunosuppressants (tacrolimus, azathioprine)}
\li{Oncology drugs (5-fluorouracil, irinotecan, tamoxifen)}
\li{Cardiovascular drugs (statins, beta-blockers)}
\li{Pain medications (codeine, tramadol)}
\li{Antivirals (abacavir)}
}
}

\subtree{
\title{3. Gene-Drug Pair Queries}
\p{\strong{Access curated gene-drug relationships} with clinical annotations:}

\pre{\startverb
# Get gene-drug pair information
response = requests.get("https://api.clinpgx.org/v1/geneDrugPair",
                       params={"gene": "CYP2D6", "drug": "codeine"})
pair_data = response.json()

# Get all pairs for a gene
response = requests.get("https://api.clinpgx.org/v1/geneDrugPair",
                       params={"gene": "CYP2C19"})
all_pairs = response.json()
\stopverb}

\p{\strong{Clinical annotation sources}:}

\ul{
\li{CPIC (Clinical Pharmacogenetics Implementation Consortium)}
\li{DPWG (Dutch Pharmacogenetics Working Group)}
\li{FDA (Food and Drug Administration) labels}
\li{Peer-reviewed literature summary annotations}
}
}

\subtree{
\title{4. CPIC Guidelines}
\p{\strong{Access evidence-based clinical practice guidelines}:}

\pre{\startverb
# Get CPIC guideline
response = requests.get("https://api.clinpgx.org/v1/guideline/PA166104939")
guideline = response.json()

# List all CPIC guidelines
response = requests.get("https://api.clinpgx.org/v1/guideline",
                       params={"source": "CPIC"})
guidelines = response.json()
\stopverb}

\p{\strong{CPIC guideline components}:}

\ul{
\li{Gene-drug pairs covered}
\li{Clinical recommendations by phenotype}
\li{Evidence levels and strength ratings}
\li{Supporting literature}
\li{Downloadable PDFs and supplementary materials}
\li{Implementation considerations}
}

\p{\strong{Example guidelines}:}

\ul{
\li{CYP2D6-codeine (avoid in ultra-rapid metabolizers)}
\li{CYP2C19-clopidogrel (alternative therapy for poor metabolizers)}
\li{TPMT-azathioprine (dose reduction for intermediate/poor metabolizers)}
\li{DPYD-fluoropyrimidines (dose adjustment based on activity)}
\li{HLA-B*57:01-abacavir (avoid if positive)}
}
}

\subtree{
\title{5. Allele and Variant Information}
\p{\strong{Query allele function and frequency data}:}

\pre{\startverb
# Get allele information
response = requests.get("https://api.clinpgx.org/v1/allele/CYP2D6*4")
allele_data = response.json()

# Get all alleles for a gene
response = requests.get("https://api.clinpgx.org/v1/allele",
                       params={"gene": "CYP2D6"})
alleles = response.json()
\stopverb}

\p{\strong{Allele information includes}:}

\ul{
\li{Functional status (normal, decreased, no function, increased, uncertain)}
\li{Population frequencies across ethnic groups}
\li{Defining variants (SNPs, indels, CNVs)}
\li{Phenotype assignment}
\li{References to PharmVar and other nomenclature systems}
}

\p{\strong{Phenotype categories}:}

\ul{
\li{\strong{Ultra-rapid metabolizer} (UM): Increased enzyme activity}
\li{\strong{Normal metabolizer} (NM): Normal enzyme activity}
\li{\strong{Intermediate metabolizer} (IM): Reduced enzyme activity}
\li{\strong{Poor metabolizer} (PM): Little to no enzyme activity}
}
}

\subtree{
\title{6. Variant Annotations}
\p{\strong{Access clinical annotations for specific genetic variants}:}

\pre{\startverb
# Get variant information
response = requests.get("https://api.clinpgx.org/v1/variant/rs4244285")
variant_data = response.json()

# Search variants by position (if supported)
response = requests.get("https://api.clinpgx.org/v1/variant",
                       params={"chromosome": "10", "position": "94781859"})
variants = response.json()
\stopverb}

\p{\strong{Variant data includes}:}

\ul{
\li{rsID and genomic coordinates}
\li{Gene and functional consequence}
\li{Allele associations}
\li{Clinical significance}
\li{Population frequencies}
\li{Literature references}
}
}

\subtree{
\title{7. Clinical Annotations}
\p{\strong{Retrieve curated literature annotations} (formerly PharmGKB clinical annotations):}

\pre{\startverb
# Get clinical annotations
response = requests.get("https://api.clinpgx.org/v1/clinicalAnnotation",
                       params={"gene": "CYP2D6"})
annotations = response.json()

# Filter by evidence level
response = requests.get("https://api.clinpgx.org/v1/clinicalAnnotation",
                       params={"evidenceLevel": "1A"})
high_evidence = response.json()
\stopverb}

\p{\strong{Evidence levels} (from highest to lowest):}

\ul{
\li{\strong{Level 1A}: High-quality evidence, CPIC/FDA/DPWG guidelines}
\li{\strong{Level 1B}: High-quality evidence, not yet guideline}
\li{\strong{Level 2A}: Moderate evidence from well-designed studies}
\li{\strong{Level 2B}: Moderate evidence with some limitations}
\li{\strong{Level 3}: Limited or conflicting evidence}
\li{\strong{Level 4}: Case reports or weak evidence}
}
}

\subtree{
\title{8. Drug Labels}
\p{\strong{Access pharmacogenomic information from drug labels}:}

\pre{\startverb
# Get drug labels with PGx information
response = requests.get("https://api.clinpgx.org/v1/drugLabel",
                       params={"drug": "warfarin"})
labels = response.json()

# Filter by regulatory source
response = requests.get("https://api.clinpgx.org/v1/drugLabel",
                       params={"source": "FDA"})
fda_labels = response.json()
\stopverb}

\p{\strong{Label information includes}:}

\ul{
\li{Testing recommendations}
\li{Dosing guidance by genotype}
\li{Warnings and precautions}
\li{Biomarker information}
\li{Regulatory source (FDA, EMA, PMDA, etc.)}
}
}

\subtree{
\title{9. Pathways}
\p{\strong{Explore pharmacokinetic and pharmacodynamic pathways}:}

\pre{\startverb
# Get pathway information
response = requests.get("https://api.clinpgx.org/v1/pathway/PA146123006")  # Warfarin pathway
pathway_data = response.json()

# Search pathways by drug
response = requests.get("https://api.clinpgx.org/v1/pathway",
                       params={"drug": "warfarin"})
pathways = response.json()
\stopverb}

\p{\strong{Pathway diagrams} show:}

\ul{
\li{Drug metabolism steps}
\li{Enzymes and transporters involved}
\li{Gene variants affecting each step}
\li{Downstream effects on efficacy/toxicity}
\li{Interactions with other pathways}
}
}
}

