\subtree{
\title{Key Reminders}
\ol{
\li{\strong{Data orientation matters:} Count matrices typically load as genes × samples but need to be samples × genes. Always transpose with \code{\startverb .T\stopverb} if needed.}
}

\ol{
\li{\strong{Sample filtering:} Remove samples with missing metadata before analysis to avoid errors.}
}

\ol{
\li{\strong{Gene filtering:} Filter low-count genes (e.g., < 10 total reads) to improve power and reduce computational time.}
}

\ol{
\li{\strong{Design formula order:} Put adjustment variables before the variable of interest (e.g., \code{\startverb "~batch + condition"\stopverb} not \code{\startverb "~condition + batch"\stopverb}).}
}

\ol{
\li{\strong{LFC shrinkage timing:} Apply shrinkage after statistical testing and only for visualization/ranking purposes. P-values remain based on unshrunken estimates.}
}

\ol{
\li{\strong{Result interpretation:} Use \code{\startverb padj < 0.05\stopverb} for significance, not raw p-values. The Benjamini-Hochberg procedure controls false discovery rate.}
}

\ol{
\li{\strong{Contrast specification:} The format is \code{\startverb [variable, test_level, reference_level]\stopverb} where test_level is compared against reference_level.}
}

\ol{
\li{\strong{Save intermediate objects:} Use pickle to save DeseqDataSet objects for later use or additional analyses without re-running the expensive fitting step.}
}
}

