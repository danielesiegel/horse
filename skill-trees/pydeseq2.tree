\title{Installation and Requirements}
\pre{\startverb
uv pip install pydeseq2
\stopverb}

\p{\strong{System requirements:}}

\ul{
\li{Python 3.10-3.11}
\li{pandas 1.4.3+}
\li{numpy 1.23.0+}
\li{scipy 1.11.0+}
\li{scikit-learn 1.1.1+}
\li{anndata 0.8.0+}
}

\p{\strong{Optional for visualization:}}

\ul{
\li{matplotlib}
\li{seaborn}
}
}

