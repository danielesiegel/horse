\subtree{
\title{Common Workflow Patterns}
\subtree{
\title{Complete RNA-seq Pipeline}
\pre{\startverb
from latch import workflow, small_task, large_task
from latch.types import LatchFile, LatchDir

@small_task
def quality_control(fastq: LatchFile) -> LatchFile:
    """Run FastQC"""
    return qc_output

@large_task
def alignment(fastq: LatchFile, genome: str) -> LatchFile:
    """STAR alignment"""
    return bam_output

@small_task
def quantification(bam: LatchFile) -> LatchFile:
    """featureCounts"""
    return counts

@workflow
def rnaseq_pipeline(
    input_fastq: LatchFile,
    genome: str,
    output_dir: LatchDir
) -> LatchFile:
    """RNA-seq analysis pipeline"""
    qc = quality_control(fastq=input_fastq)
    aligned = alignment(fastq=qc, genome=genome)
    return quantification(bam=aligned)
\stopverb}
}

\subtree{
\title{GPU-Accelerated Workflow}
\pre{\startverb
from latch import workflow, small_task, large_gpu_task
from latch.types import LatchFile

@small_task
def preprocess(input_file: LatchFile) -> LatchFile:
    """Prepare data"""
    return processed

@large_gpu_task
def gpu_computation(data: LatchFile) -> LatchFile:
    """GPU-accelerated analysis"""
    return results

@workflow
def gpu_pipeline(input_file: LatchFile) -> LatchFile:
    """Pipeline with GPU tasks"""
    preprocessed = preprocess(input_file=input_file)
    return gpu_computation(data=preprocessed)
\stopverb}
}

\subtree{
\title{Registry-Integrated Workflow}
\pre{\startverb
from latch import workflow, small_task
from latch.registry.table import Table
from latch.registry.record import Record
from latch.types import LatchFile

@small_task
def process_and_track(sample_id: str, table_id: str) -> str:
    """Process sample and update Registry"""
    # Get sample from registry
    table = Table.get(table_id=table_id)
    records = Record.list(table_id=table_id, filter={"sample_id": sample_id})
    sample = records[0]

    # Process
    input_file = sample.values["fastq_file"]
    output = process(input_file)

    # Update registry
    sample.update(values={"status": "completed", "result": output})
    return "Success"

@workflow
def registry_workflow(sample_id: str, table_id: str):
    """Workflow integrated with Registry"""
    return process_and_track(sample_id=sample_id, table_id=table_id)
\stopverb}
}
}

\subtree{
\title{Best Practices}
\subtree{
\title{Workflow Design}
\ol{
\li{Use type annotations for all parameters}
\li{Write clear docstrings (appear in UI)}
\li{Start with standard task decorators, scale up if needed}
\li{Break complex workflows into modular tasks}
\li{Implement proper error handling}
}
}

\subtree{
\title{Data Management}
\ol{
\li{Use consistent folder structures}
\li{Define Registry schemas before bulk entry}
\li{Use linked records for relationships}
\li{Store metadata in Registry for traceability}
}
}

\subtree{
\title{Resource Configuration}
\ol{
\li{Right-size resources (don't over-allocate)}
\li{Use GPU only when algorithms support it}
\li{Monitor execution metrics and optimize}
\li{Design for parallel execution when possible}
}
}

\subtree{
\title{Development Workflow}
\ol{
\li{Test locally with Docker before registration}
\li{Use version control for workflow code}
\li{Document resource requirements}
\li{Profile workflows to determine actual needs}
}
}
}

\subtree{
\title{Troubleshooting}
\subtree{
\title{Common Issues}
\p{\strong{Registration Failures:}}

\ul{
\li{Ensure Docker is running}
\li{Check authentication with \code{\startverb latch login\stopverb}}
\li{Verify all dependencies in Dockerfile}
\li{Use \code{\startverb --verbose\stopverb} flag for detailed logs}
}

\p{\strong{Resource Problems:}}

\ul{
\li{Out of memory: Increase memory in task decorator}
\li{Timeouts: Increase timeout parameter}
\li{Storage issues: Increase ephemeral storage_gib}
}

\p{\strong{Data Access:}}

\ul{
\li{Use correct \code{\startverb latch:///\stopverb} path format}
\li{Verify file exists in workspace}
\li{Check permissions for shared workspaces}
}

\p{\strong{Type Errors:}}

\ul{
\li{Add type annotations to all parameters}
\li{Use LatchFile/LatchDir for file/directory parameters}
\li{Ensure workflow return type matches actual return}
}
}
}

