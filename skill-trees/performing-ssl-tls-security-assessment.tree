\title{Performing Ssl Tls Security Assessment}

\taxon{skill}

\tag{network-security}

\tag{ssl}

\tag{tls}

\tag{sslyze}

\tag{certificate}

\tag{cipher-suites}

\tag{vulnerability-assessment}

\meta{version}{"1.0"}

\meta{description}{Assess SSL/TLS server configurations using the sslyze Python library to evaluate cipher suites, certificate chains, protocol versions, HSTS headers, and known vulnerabilities like Heartbleed and ROBOT.}

\subtree{
\title{Performing SSL/TLS Security Assessment}
\subtree{
\title{Overview}
\p{Assess SSL/TLS server configurations using sslyze, a fast Python-based scanning library. This skill covers evaluating supported protocol versions (SSLv2/3, TLS 1.0-1.3), cipher suite strength, certificate chain validation, HSTS enforcement, OCSP stapling, and scanning for known vulnerabilities including Heartbleed, ROBOT, and session renegotiation weaknesses.}
}

\subtree{
\title{When to Use}
\ul{
\li{When conducting security assessments that involve performing ssl tls security assessment}
\li{When following incident response procedures for related security events}
\li{When performing scheduled security testing or auditing activities}
\li{When validating security controls through hands-on testing}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Python 3.9+ with \code{\startverb sslyze\stopverb} library (pip install sslyze)}
\li{Network access to target HTTPS servers on port 443}
\li{Understanding of TLS protocol versions and cipher suite classifications}
}
}

\subtree{
\title{Steps}
\subtree{
\title{Step 1: Configure Server Scan}
\p{Create ServerScanRequest with ServerNetworkLocation specifying target hostname and port.}
}

\subtree{
\title{Step 2: Execute TLS Scan}
\p{Use sslyze Scanner to queue and execute scans for all TLS check commands concurrently.}
}

\subtree{
\title{Step 3: Analyze Results}
\p{Evaluate accepted cipher suites, certificate validity, protocol versions, and vulnerability scan results.}
}

\subtree{
\title{Step 4: Generate Security Report}
\p{Produce a JSON report with compliance findings and remediation recommendations.}
}
}

\subtree{
\title{Expected Output}
\p{JSON report with supported protocols, accepted cipher suites, certificate details, vulnerability results (Heartbleed, ROBOT), and HSTS status.}
}
}