\subtree{
\title{Best Practices}
\ol{
\li{\strong{Use HDF5 or Apache Arrow formats} for optimal performance with large datasets}
\li{\strong{Leverage virtual columns} instead of materializing data to save memory}
\li{\strong{Batch operations} using \code{\startverb delay=True\stopverb} when performing multiple calculations}
\li{\strong{Export to efficient formats} rather than keeping data in CSV}
\li{\strong{Use expressions} for complex calculations without intermediate storage}
\li{\strong{Profile with \code{\startverb df.stat()\stopverb}} to understand memory usage and optimize operations}
}
}

\subtree{
\title{Common Patterns}
\subtree{
\title{Pattern: Converting Large CSV to HDF5}
\pre{\startverb
import vaex

# Open large CSV (processes in chunks automatically)
df = vaex.from_csv('large_file.csv')

# Export to HDF5 for faster future access
df.export_hdf5('large_file.hdf5')

# Future loads are instant
df = vaex.open('large_file.hdf5')
\stopverb}
}

\subtree{
\title{Pattern: Efficient Aggregations}
\pre{\startverb
# Use delay=True to batch multiple operations
mean_x = df.x.mean(delay=True)
std_y = df.y.std(delay=True)
sum_z = df.z.sum(delay=True)

# Execute all at once
results = vaex.execute([mean_x, std_y, sum_z])
\stopverb}
}

\subtree{
\title{Pattern: Virtual Columns for Feature Engineering}
\pre{\startverb
# No memory overhead - computed on the fly
df['age_squared'] = df.age ** 2
df['full_name'] = df.first_name + ' ' + df.last_name
df['is_adult'] = df.age >= 18
\stopverb}
}
}

