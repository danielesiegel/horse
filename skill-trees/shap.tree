\subtree{
\title{Key Concepts}
\subtree{
\title{SHAP Values}
\p{\strong{Definition}: SHAP values quantify each feature's contribution to a prediction, measured as the deviation from the expected model output (baseline).}

\p{\strong{Properties}:}

\ul{
\li{\strong{Additivity}: SHAP values sum to difference between prediction and baseline}
\li{\strong{Fairness}: Based on Shapley values from game theory}
\li{\strong{Consistency}: If a feature becomes more important, its SHAP value increases}
}

\p{\strong{Interpretation}:}

\ul{
\li{Positive SHAP value → Feature pushes prediction higher}
\li{Negative SHAP value → Feature pushes prediction lower}
\li{Magnitude → Strength of feature's impact}
\li{Sum of SHAP values → Total prediction change from baseline}
}

\p{\strong{Example}:}

\pre{\startverb
Baseline (expected value): 0.30
Feature contributions (SHAP values):
  Age: +0.15
  Income: +0.10
  Education: -0.05
Final prediction: 0.30 + 0.15 + 0.10 - 0.05 = 0.50
\stopverb}
}

\subtree{
\title{Background Data / Baseline}
\p{\strong{Purpose}: Represents "typical" input to establish baseline expectations}

\p{\strong{Selection}:}

\ul{
\li{Random sample from training data (50-1000 samples)}
\li{Or use kmeans to select representative samples}
\li{For DeepExplainer/KernelExplainer: 100-1000 samples balances accuracy and speed}
}

\p{\strong{Impact}: Baseline affects SHAP value magnitudes but not relative importance}
}

\subtree{
\title{Model Output Types}
\p{\strong{Critical Consideration}: Understand what your model outputs}

\ul{
\li{\strong{Raw output}: For regression or tree margins}
\li{\strong{Probability}: For classification probability}
\li{\strong{Log-odds}: For logistic regression (before sigmoid)}
}

\p{\strong{Example}: XGBoost classifiers explain margin output (log-odds) by default. To explain probabilities, use \code{\startverb model_output="probability"\stopverb} in TreeExplainer.}
}
}

\subtree{
\title{Common Patterns}
\subtree{
\title{Pattern 1: Complete Model Analysis}
\pre{\startverb
# 1. Setup
explainer = shap.TreeExplainer(model)
shap_values = explainer(X_test)

# 2. Global importance
shap.plots.beeswarm(shap_values)
shap.plots.bar(shap_values)

# 3. Top feature relationships
top_features = X_test.columns[np.abs(shap_values.values).mean(0).argsort()[-5:]]
for feature in top_features:
    shap.plots.scatter(shap_values[:, feature])

# 4. Example predictions
for i in range(5):
    shap.plots.waterfall(shap_values[i])
\stopverb}
}

\subtree{
\title{Pattern 2: Cohort Comparison}
\pre{\startverb
# Define cohorts
cohort1_mask = X_test['Group'] == 'A'
cohort2_mask = X_test['Group'] == 'B'

# Compare feature importance
shap.plots.bar({
    "Group A": shap_values[cohort1_mask],
    "Group B": shap_values[cohort2_mask]
})
\stopverb}
}

\subtree{
\title{Pattern 3: Debugging Errors}
\pre{\startverb
# Find errors
errors = model.predict(X_test) != y_test
error_indices = np.where(errors)[0]

# Explain errors
for idx in error_indices[:5]:
    print(f"Sample {idx}:")
    shap.plots.waterfall(shap_values[idx])

    # Investigate key features
    shap.plots.scatter(shap_values[:, "Suspicious_Feature"])
\stopverb}
}
}

\subtree{
\title{Performance Optimization}
\subtree{
\title{Speed Considerations}
\p{\strong{Explainer Speed} (fastest to slowest):}

\ol{
\li{\code{\startverb LinearExplainer\stopverb} - Nearly instantaneous}
\li{\code{\startverb TreeExplainer\stopverb} - Very fast}
\li{\code{\startverb DeepExplainer\stopverb} - Fast for neural networks}
\li{\code{\startverb GradientExplainer\stopverb} - Fast for neural networks}
\li{\code{\startverb KernelExplainer\stopverb} - Slow (use only when necessary)}
\li{\code{\startverb PermutationExplainer\stopverb} - Very slow but accurate}
}
}

\subtree{
\title{Optimization Strategies}
\p{\strong{For Large Datasets}:}

\pre{\startverb
# Compute SHAP for subset
shap_values = explainer(X_test[:1000])

# Or use batching
batch_size = 100
all_shap_values = []
for i in range(0, len(X_test), batch_size):
    batch_shap = explainer(X_test[i:i+batch_size])
    all_shap_values.append(batch_shap)
\stopverb}

\p{\strong{For Visualizations}:}

\pre{\startverb
# Sample subset for plots
shap.plots.beeswarm(shap_values[:1000])

# Adjust transparency for dense plots
shap.plots.scatter(shap_values[:, "Feature"], alpha=0.3)
\stopverb}

\p{\strong{For Production}:}

\pre{\startverb
# Cache explainer
import joblib
joblib.dump(explainer, 'explainer.pkl')
explainer = joblib.load('explainer.pkl')

# Pre-compute for batch predictions
# Only compute top N features for API responses
\stopverb}
}
}

\subtree{
\title{Troubleshooting}
\subtree{
\title{Issue: Wrong explainer choice}
\p{\strong{Problem}: Using KernelExplainer for tree models (slow and unnecessary) \strong{Solution}: Always use TreeExplainer for tree-based models}
}

\subtree{
\title{Issue: Insufficient background data}
\p{\strong{Problem}: DeepExplainer/KernelExplainer with too few background samples \strong{Solution}: Use 100-1000 representative samples}
}

\subtree{
\title{Issue: Confusing units}
\p{\strong{Problem}: Interpreting log-odds as probabilities \strong{Solution}: Check model output type; understand whether values are probabilities, log-odds, or raw outputs}
}

\subtree{
\title{Issue: Plots don't display}
\p{\strong{Problem}: Matplotlib backend issues \strong{Solution}: Ensure backend is set correctly; use \code{\startverb plt.show()\stopverb} if needed}
}

\subtree{
\title{Issue: Too many features cluttering plots}
\p{\strong{Problem}: Default max_display=10 may be too many or too few \strong{Solution}: Adjust \code{\startverb max_display\stopverb} parameter or use feature clustering}
}

\subtree{
\title{Issue: Slow computation}
\p{\strong{Problem}: Computing SHAP for very large datasets \strong{Solution}: Sample subset, use batching, or ensure using specialized explainer (not KernelExplainer)}
}
}

