\subtree{
\title{Best Practices Summary}
\ol{
\li{\strong{Choose the right explainer}: Use specialized explainers (TreeExplainer, DeepExplainer, LinearExplainer) when possible; avoid KernelExplainer unless necessary}
}

\ol{
\li{\strong{Start global, then go local}: Begin with beeswarm/bar plots for overall understanding, then dive into waterfall/scatter plots for details}
}

\ol{
\li{\strong{Use multiple visualizations}: Different plots reveal different insights; combine global (beeswarm) + local (waterfall) + relationship (scatter) views}
}

\ol{
\li{\strong{Select appropriate background data}: Use 50-1000 representative samples from training data}
}

\ol{
\li{\strong{Understand model output units}: Know whether explaining probabilities, log-odds, or raw outputs}
}

\ol{
\li{\strong{Validate with domain knowledge}: SHAP shows model behavior; use domain expertise to interpret and validate}
}

\ol{
\li{\strong{Optimize for performance}: Sample subsets for visualization, batch for large datasets, cache explainers in production}
}

\ol{
\li{\strong{Check for data leakage}: Unexpectedly high feature importance may indicate data quality issues}
}

\ol{
\li{\strong{Consider feature correlations}: Use TreeExplainer's correlation-aware options or feature clustering for redundant features}
}

\ol{
\li{\strong{Remember SHAP shows association, not causation}: Use domain knowledge for causal interpretation}
}
}

