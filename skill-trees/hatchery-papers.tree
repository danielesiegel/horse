\subtree{
\title{SRFI-194: Random Data Generators (Final 2020)}
\pre{\startverb
;; From SRFI-194
(import (srfi 194))

;; Custom generator for SplitMixTernary
(define (make-ternary-generator seed)
  (let ((rng (make-splitmix64 seed)))
    (lambda () (splitmix-ternary rng))))
\stopverb}
}

