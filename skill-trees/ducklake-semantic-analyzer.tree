\subtree{
\title{Functions}
\subtree{
\title{classify_intent(mention: str) -> str}
\p{Classify semantic intent of a mention.}

\pre{\startverb
intent = classify_intent("ducklake temporal query optimization")
# Returns: "implementation"

intent = classify_intent("see ducklake schema documentation")
# Returns: "reference"
\stopverb}

\p{\strong{Categories:}}

\ul{
\li{\code{\startverb reference\stopverb} (45.5\%) - Passive mentions}
\li{\code{\startverb documentation\stopverb} (17.6\%) - Formal documentation}
\li{\code{\startverb implementation\stopverb} (5.9\%) - Active code}
\li{\code{\startverb testing\stopverb} (6.7\%) - Tests and validation}
\li{\code{\startverb query_discussion\stopverb} (9.8\%) - SQL query discussions}
}

\p{\strong{Implementation:}}

\pre{\startverb
import json
import re

INTENT_PATTERNS = {
    "implementation": r"(implement|create|build|optimize|develop)",
    "documentation": r"(document|explain|describe|guide|reference)",
    "testing": r"(test|verify|validate|check|assert)",
    "query_discussion": r"(query|select|from|where|sql)",
    "reference": r".*"  # Default
}

def classify_intent(mention: str) -> str:
    mention_lower = mention.lower()
    for intent, pattern in INTENT_PATTERNS.items():
        if re.search(pattern, mention_lower):
            return intent
    return "reference"
\stopverb}
}

