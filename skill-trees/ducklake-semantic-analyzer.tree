\title{compute_cooccurrence(term1: str, term2: str) -> dict}
\p{Compute co-occurrence relationship strength.}

\pre{\startverb
result = compute_cooccurrence("duckdb", "lake")
# Returns: {
#   "cooccurrence": 100,
#   "significance": "DuckLake is fundamentally a DuckDB-based system",
#   "mentions": 255
# }
\stopverb}

\p{\strong{High Co-occurrence Pairs:}}

\ul{
\li{\code{\startverb lake\stopverb} + \code{\startverb duckdb\stopverb}: 100\% (always together)}
\li{\code{\startverb color\stopverb} + \code{\startverb gay\stopverb}: 62\% (color via GAY seed)}
\li{\code{\startverb temporal\stopverb} + \code{\startverb versioning\stopverb}: 28\%}
\li{\code{\startverb parallel\stopverb} + \code{\startverb thread\stopverb}: 34\%}
\li{\code{\startverb seed\stopverb} + \code{\startverb deterministic\stopverb}: 36\%}
}
}

\subtree{
\title{extract_context_window(mention: str, lines: int = 5) -> str}
