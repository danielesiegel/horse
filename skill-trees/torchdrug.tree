\subtree{
\title{Common Workflows}
\subtree{
\title{Workflow 1: Molecular Property Prediction}
\p{\strong{Scenario:} Predict blood-brain barrier penetration for drug candidates.}

\p{\strong{Steps:}}

\ol{
\li{Load dataset: \code{\startverb datasets.BBBP()\stopverb}}
\li{Choose model: GIN for molecular graphs}
\li{Define task: \code{\startverb PropertyPrediction\stopverb} with binary classification}
\li{Train with scaffold split for realistic evaluation}
\li{Evaluate using AUROC and AUPRC}
}

\p{\strong{Navigation:} \code{\startverb references/molecular_property_prediction.md\stopverb} → Dataset selection → Model selection → Training}
}

\subtree{
\title{Workflow 2: Protein Function Prediction}
\p{\strong{Scenario:} Predict enzyme function from sequence.}

\p{\strong{Steps:}}

\ol{
\li{Load dataset: \code{\startverb datasets.EnzymeCommission()\stopverb}}
\li{Choose model: ESM (pre-trained) or GearNet (with structure)}
\li{Define task: \code{\startverb PropertyPrediction\stopverb} with multi-class classification}
\li{Fine-tune pre-trained model or train from scratch}
\li{Evaluate using accuracy and per-class metrics}
}

\p{\strong{Navigation:} \code{\startverb references/protein_modeling.md\stopverb} → Model selection (sequence vs structure) → Pre-training strategies}
}

\subtree{
\title{Workflow 3: Drug Repurposing via Knowledge Graphs}
\p{\strong{Scenario:} Find new disease treatments in Hetionet.}

\p{\strong{Steps:}}

\ol{
\li{Load dataset: \code{\startverb datasets.Hetionet()\stopverb}}
\li{Choose model: RotatE or ComplEx}
\li{Define task: \code{\startverb KnowledgeGraphCompletion\stopverb}}
\li{Train with negative sampling}
\li{Query for "Compound-treats-Disease" predictions}
\li{Filter by plausibility and mechanism}
}

\p{\strong{Navigation:} \code{\startverb references/knowledge_graphs.md\stopverb} → Hetionet dataset → Model selection → Biomedical applications}
}

\subtree{
\title{Workflow 4: De Novo Molecule Generation}
\p{\strong{Scenario:} Generate drug-like molecules optimized for target binding.}

\p{\strong{Steps:}}

\ol{
\li{Train property predictor on activity data}
\li{Choose generation approach: GCPN for RL-based optimization}
\li{Define reward function combining affinity, drug-likeness, synthesizability}
\li{Generate candidates with property constraints}
\li{Validate chemistry and filter by drug-likeness}
\li{Rank by multi-objective scoring}
}

\p{\strong{Navigation:} \code{\startverb references/molecular_generation.md\stopverb} → Conditional generation → Multi-objective optimization}
}

\subtree{
\title{Workflow 5: Retrosynthesis Planning}
\p{\strong{Scenario:} Plan synthesis route for target molecule.}

\p{\strong{Steps:}}

\ol{
\li{Load dataset: \code{\startverb datasets.USPTO50k()\stopverb}}
\li{Train center identification model (RGCN)}
\li{Train synthon completion model (GIN)}
\li{Combine into end-to-end retrosynthesis pipeline}
\li{Apply recursively for multi-step planning}
\li{Check commercial availability of building blocks}
}

\p{\strong{Navigation:} \code{\startverb references/retrosynthesis.md\stopverb} → Task types → Multi-step planning}
}
}

\subtree{
\title{Integration Patterns}
\subtree{
\title{With RDKit}
\p{Convert between TorchDrug molecules and RDKit:}

\pre{\startverb
from torchdrug import data
from rdkit import Chem

# SMILES → TorchDrug molecule
smiles = "CCO"
mol = data.Molecule.from_smiles(smiles)

# TorchDrug → RDKit
rdkit_mol = mol.to_molecule()

# RDKit → TorchDrug
rdkit_mol = Chem.MolFromSmiles(smiles)
mol = data.Molecule.from_molecule(rdkit_mol)
\stopverb}
}

\subtree{
\title{With AlphaFold/ESM}
\p{Use predicted structures:}

\pre{\startverb
from torchdrug import data

# Load AlphaFold predicted structure
protein = data.Protein.from_pdb("AF-P12345-F1-model_v4.pdb")

# Build graph with spatial edges
graph = protein.residue_graph(
    node_position="ca",
    edge_types=["sequential", "radius"],
    radius_cutoff=10.0
)
\stopverb}
}

\subtree{
\title{With PyTorch Lightning}
\p{Wrap tasks for Lightning training:}

\pre{\startverb
import pytorch_lightning as pl

class LightningTask(pl.LightningModule):
    def __init__(self, torchdrug_task):
        super().__init__()
        self.task = torchdrug_task

    def training_step(self, batch, batch_idx):
        return self.task(batch)

    def validation_step(self, batch, batch_idx):
        pred = self.task.predict(batch)
        target = self.task.target(batch)
        return {"pred": pred, "target": target}

    def configure_optimizers(self):
        return torch.optim.Adam(self.parameters(), lr=1e-3)
\stopverb}
}
}

