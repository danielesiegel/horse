\title{Torchdrug}

\taxon{skill}

\meta{description}{"Graph-based drug discovery toolkit. Molecular property prediction (ADMET), protein modeling, knowledge graph reasoning, molecular generation, retrosynthesis, GNNs (GIN, GAT, SchNet), 40+ datasets, for PyTorch-based ML on molecules, proteins, and biomedical graphs."}

\subtree{
\title{TorchDrug}
\subtree{
\title{Overview}
\p{TorchDrug is a comprehensive PyTorch-based machine learning toolbox for drug discovery and molecular science. Apply graph neural networks, pre-trained models, and task definitions to molecules, proteins, and biological knowledge graphs, including molecular property prediction, protein modeling, knowledge graph reasoning, molecular generation, retrosynthesis planning, with 40+ curated datasets and 20+ model architectures.}
}

\subtree{
\title{When to Use This Skill}
\p{This skill should be used when working with:}

\p{\strong{Data Types:}}

\ul{
\li{SMILES strings or molecular structures}
\li{Protein sequences or 3D structures (PDB files)}
\li{Chemical reactions and retrosynthesis}
\li{Biomedical knowledge graphs}
\li{Drug discovery datasets}
}

\p{\strong{Tasks:}}

\ul{
\li{Predicting molecular properties (solubility, toxicity, activity)}
\li{Protein function or structure prediction}
\li{Drug-target binding prediction}
\li{Generating new molecular structures}
\li{Planning chemical synthesis routes}
\li{Link prediction in biomedical knowledge bases}
\li{Training graph neural networks on scientific data}
}

\p{\strong{Libraries and Integration:}}

\ul{
\li{TorchDrug is the primary library}
\li{Often used with RDKit for cheminformatics}
\li{Compatible with PyTorch and PyTorch Lightning}
\li{Integrates with AlphaFold and ESM for proteins}
}
}

\subtree{
\title{Getting Started}
\subtree{
\title{Installation}
\pre{\startverb
uv pip install torchdrug
# Or with optional dependencies
uv pip install torchdrug[full]
\stopverb}
}

\subtree{
\title{Quick Example}
\pre{\startverb
from torchdrug import datasets, models, tasks
from torch.utils.data import DataLoader

# Load molecular dataset
dataset = datasets.BBBP("~/molecule-datasets/")
train_set, valid_set, test_set = dataset.split()

# Define GNN model
model = models.GIN(
    input_dim=dataset.node_feature_dim,
    hidden_dims=[256, 256, 256],
    edge_input_dim=dataset.edge_feature_dim,
    batch_norm=True,
    readout="mean"
)

# Create property prediction task
task = tasks.PropertyPrediction(
    model,
    task=dataset.tasks,
    criterion="bce",
    metric=["auroc", "auprc"]
)

# Train with PyTorch
optimizer = torch.optim.Adam(task.parameters(), lr=1e-3)
train_loader = DataLoader(train_set, batch_size=32, shuffle=True)

for epoch in range(100):
    for batch in train_loader:
        loss = task(batch)
        optimizer.zero_grad()
        loss.backward()
        optimizer.step()
\stopverb}
}
}

\subtree{
\title{Core Capabilities}
\subtree{
\title{1. Molecular Property Prediction}
\p{Predict chemical, physical, and biological properties of molecules from structure.}

\p{\strong{Use Cases:}}

\ul{
\li{Drug-likeness and ADMET properties}
\li{Toxicity screening}
\li{Quantum chemistry properties}
\li{Binding affinity prediction}
}

\p{\strong{Key Components:}}

\ul{
\li{20+ molecular datasets (BBBP, HIV, Tox21, QM9, etc.)}
\li{GNN models (GIN, GAT, SchNet)}
\li{PropertyPrediction and MultipleBinaryClassification tasks}
}

