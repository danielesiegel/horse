\li{Run static analysis}
\li{Start fixing issues}
}

\p{\strong{1 week before audit}:}

\ul{
\li{Increase test coverage}
\li{Remove dead code}
\li{Freeze stable version}
\li{Start documentation}
}

\p{\strong{Few days before audit}:}

\ul{
\li{Complete documentation}
\li{Verify build instructions}
\li{Create final checklist}
\li{Send package to auditors}
}
}

