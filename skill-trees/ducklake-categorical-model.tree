\subtree{
\title{GF(3) Color Distribution}
\p{For 18 mentions with balanced ternary:}

\ul{
\li{RED (trit=1): 6 mentions}
\li{GREEN (trit=0): 6 mentions}
\li{BLUE (trit=-1): 6 mentions}
\li{Sum: 6×1 + 6×0 + 6×(-1) = 0 ≡ 0 (mod 3) ✓}
}
}

\subtree{
\title{Categorical Laws}
\subtree{
\title{Composition}
\pre{\startverb
∀ f: A → B, g: B → C:
  compose(f, g): A → C
\stopverb}
}

\subtree{
\title{Associativity}
\pre{\startverb
compose(compose(f, g), h) = compose(f, compose(g, h))
\stopverb}
}

\subtree{
\title{Identity}
\pre{\startverb
compose(id_A, f) = f = compose(f, id_B)
\stopverb}
}
}

\subtree{
\title{Example Queries}
\pre{\startverb
# Find all mentions in a session
session_id = 1
mentions = incident(graph, session_id, :belongs_to)

# Find project for a mention
mention_id = 5
project = graph[mention_id, :in_project]

# Verify composition
for m in 1:nparts(graph, :DucklakeMention)
    session = graph[m, :belongs_to]
    proj_direct = graph[m, :in_project]
    proj_composed = graph[session, :session_to_project]
    @assert proj_direct == proj_composed
end
\stopverb}
}

