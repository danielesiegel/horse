\subtree{
\title{Mathematical Foundation}
\subtree{
\title{Douady-Couder Inhibition Model}
\p{New primordium placement at angle θ* that maximizes auxin:}

\pre{\startverb
θ* = argmax_θ [ A(θ) - Σᵢ α · exp(-d(θ, pᵢ)² / (2λ²)) ]
\stopverb}

\p{Where:}

\ul{
\li{A(θ) = ambient auxin field}
\li{α = inhibition strength (optimal: 2.0)}
\li{λ = inhibition range (optimal: 0.08)}
\li{d(θ, pᵢ) = Euclidean distance from candidate to primordium i}
}
}

\subtree{
\title{Golden Angle as Nash Equilibrium}
\p{Two adjacent leaves compete for light. Strategies: angular deviations from current position. Payoff: light capture = 1 - overlap penalty.}

\p{The Nash equilibrium IS the golden angle: no leaf can unilaterally improve its light capture by deviating from 137.508° divergence.}
}

\subtree{
\title{Auxin Chemotaxis = Affective Taxis}
\p{From affective-taxis.jl: \code{\startverb auxin_density(x)\stopverb} maps to \code{\startverb attractant_density(z)\stopverb}, and \code{\startverb auxin_gradient(x)\stopverb} maps to \code{\startverb grad_log_density(z)\stopverb}. The Langevin dynamics are identical:}

\pre{\startverb
dz/dt = ∇_z log γ(z; β) + √2 dσ(t)
\stopverb}

\p{Where z = primordium position, γ = auxin concentration, β = temperature.}
}

\subtree{
\title{GF(3) Conservation}
\p{Index-based trit assignment ensures perfect balance:}

\pre{\startverb
classify_trit(i) = { +1 if i mod 3 = 0, 0 if i mod 3 = 1, -1 if i mod 3 = 2 }
\stopverb}

\p{For N primordia: N mod 3 = 0 → perfect 7/7/7 balance (21 primordia).}
}
}

\subtree{
\title{Implementations}
\subtree{
\title{Julia: \code{\startverb succulents.jl\stopverb} (~550 LOC)}
\p{Full continuous simulation with BCI integration:}

\pre{\startverb
# Grow 21 primordia
M = Meristem(λ=0.08, α=2.0, plastochron=6)
for _ in 1:136; tick!(M); end

# Results: 9.49° golden deviation, GF(3) 7/8/7 BALANCED
verify_conservation(M)  # ✓

# BCI modulation
ps = PhenomenalState(φ=0.8, valence=0.6, entropy=1.5, trit=PLUS)
modulate_growth!(M, ps)

# Taxis bridge
AL = AuxinLandscape(M)
classify_valence(auxin_gradient(AL, θ))  # → PLUS/ERGODIC/MINUS
\stopverb}

\p{Optimal parameters (from sweep): λ=0.08, α=2.0 → 9.49° deviation from golden angle.}
}

\subtree{
\title{TypeScript: Nashator stress-games.ts}
\p{Game-theoretic formulation as OpenGame instances:}

\pre{\startverb
leafLightCompetition(5)   // 5-strategy light competition game
auxinCompetition(7)       // 7-position auxin inhibition game
rosetteLifecycle()        // seq(auxin ; light ; water) — GF(3) balanced

// Solve via propagator network
solvePropagator(leafLightCompetition(5), { maxRounds: 2000 })
// → golden angle offset = high-weight strategy
\stopverb}
}

\subtree{
\title{Scheme: Goblins rosette-actor.scm (~300 LOC)}
\p{Actor-based concurrent rosette growth:}

\pre{\startverb
(define garden (spawn ^rosette-garden))
($ garden plant! "echeveria")
($ garden plant! "sempervivum")
($ garden grow-all! 21)
($ garden garden-gf3)           ; → balanced
($ garden modulate-all! 0.8 0.6 1.5)  ; BCI modulation
\stopverb}

\p{Plugin spec for ^vat-bridge integration: plant/grow/modulate/gf3 actions.}
}
}

