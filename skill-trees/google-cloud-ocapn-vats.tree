\title{Google Cloud Ocapn Vats}

\taxon{skill}

\meta{description}{"Google Cloud Platform project and API management for plurigrid.com org. Use when enabling GCP APIs, managing org policies, creating service accounts or API keys, or working with Google Cloud projects."}

\subtree{
\title{Google Cloud — plurigrid.com}
\subtree{
\title{Org & Project Structure}
\pre{\startverb
| Field | Value |
|-------|-------|
| Org | `plurigrid.com` -- ID `737292068572` |
| Project | `native` -- ID `merovingians` (number `302712368086`) |
| Old Project | `oldest` -- ID `midyear-glazing-487407-t2` (number `321807517301`) |
