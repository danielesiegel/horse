\subtree{
\title{Principles}
\ul{
\li{\strong{Compliance}: Never ignore the PR template. It exists for a reason.}
\li{\strong{Completeness}: Fill out all relevant sections.}
\li{\strong{Accuracy}: Don't check boxes for tasks you haven't done.}
}
}
}