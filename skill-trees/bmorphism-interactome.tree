\title{Bmorphism Interactome}

\taxon{skill}

\meta{description}{GitHub interactome explorer for bmorphism/plurigrid ecosystem. Maps collaborations across AlgebraicJulia, Topos Institute, Anthropic, and MCP servers. Use for discovering cobordisms between research communities.}

\subtree{
\title{bmorphism-interactome Skill}
\blockquote{\em{Mapping the cobordisms between research communities via shared contributors}}

