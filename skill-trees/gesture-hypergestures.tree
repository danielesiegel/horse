\title{Gesture Hypergestures}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{Gesture Hypergestures Skill}

\subtree{
\title{Gesture Hypergestures Skill}
\blockquote{*"A gesture is a continuous curve in a topological category."* — Guerino Mazzola, Topos of Music III: Gestures}

\p{\strong{Trit}: +1 (PLUS - generative) \strong{Color}: #C42990 (from seed 137508, index 23) \strong{Foundation}: Mazzola's Diamond Conjecture}

\subtree{
\title{Overview}
\p{\strong{Gestures} are the missing link between structure (forms/denotators) and performance (physical action). This skill implements Mazzola's gesture theory from \em{Topos of Music III}.}

\pre{\startverb
Form (static) → Gesture (dynamic) → Performance (physical)
    ↓              ↓                    ↓
 Denotator    Hypergesture           Sound wave
\stopverb}
}

\subtree{
\title{Core Concepts}
\subtree{
\title{Gesture Definition}
\p{A gesture is a continuous curve \code{\startverb γ: [0,1] → X\stopverb} in a topological category:}

\pre{\startverb
struct Gesture{T}
    domain::Interval      # [0, 1] or [a, b]
    target::T             # Topological space
    curve::Function       # t → target
end

# Example: pitch gesture (glissando)
glissando = Gesture(
    (0.0, 1.0),
    PitchSpace,
    t -> 60 + 12 * t  # C4 to C5
)
\stopverb}
}

\subtree{
\title{Hypergestures}
\p{A \strong{hypergesture} is a gesture of gestures - a higher-order curve:}

\pre{\startverb
struct Hypergesture{T}
    base_gestures::Vector{Gesture{T}}
    interpolation::Function  # Gesture × Gesture → Gesture
end

# Hypergesture: morphing between two melodic contours
melody_morph = Hypergesture(
    [melody_a, melody_b],
    (g1, g2, t) -> interpolate_gesture(g1, g2, t)
)
\stopverb}
}

\subtree{
\title{Diamond Conjecture}
\p{The fundamental theorem relating local to global:}

\pre{\startverb
H^n(Gesture) ≅ H^n(Skeleton) ⊗ H^n(Body)

Local gesture fragments glue iff cohomology obstructions vanish.
\stopverb}
}
}

\subtree{
\title{Integration with Loaded Skills}
\subtree{
\title{Gestures ↔ topos-of-music}
\p{Gestures extend the Form/Denotator framework:}

\pre{\startverb
# Form → Gesture
NoteGestureForm = GestureForm(NoteForm)

# Denotator → Gestured Denotator
performed_note = GesturedDenotator(
    note,
    timing_gesture,   # Micro-timing
    dynamics_gesture  # Expression curve
)
\stopverb}
}

\subtree{
\title{Gestures ↔ catsharp-sonification}
\p{Sonify gesture trajectories:}

\pre{\startverb
function sonify_gesture(g::Gesture, seed::Int)
    Gay.gay_seed!(seed)
    for t in 0:0.1:1
        point = g.curve(t)
        color = Gay.next_color()
        freq = pitch_to_freq(point)
        trit = hue_to_trit(Gay.hue(color))
        play_tone(freq, waveform_for_trit(trit))
    end
end
\stopverb}
}

\subtree{
\title{Gestures ↔ persistent-homology}
\p{Track gesture stability across filtrations:}

\pre{\startverb
# Gesture persistence: which contours survive simplification?
filtration = [ε for ε in 0.1:0.1:1.0]
persistence = compute_gesture_persistence(gesture_space, filtration)

# Stable gestures = robust performance features
stable_gestures = filter(g -> g.persistence > 0.5, all_gestures)
\stopverb}
}

\subtree{
\title{Gestures ↔ sheaf-cohomology}
\p{Verify gesture gluing conditions:}

\pre{\startverb
# Local gesture patches
left_hand = Gesture(...)
right_hand = Gesture(...)

# Check if they glue into coherent performance
H1 = compute_gesture_cohomology([left_hand, right_hand])
if H1 == 0
    println("Gestures glue correctly!")
else
    println("Obstruction detected: hands don't coordinate")
end
\stopverb}
}

\subtree{
\title{Gestures ↔ interaction-nets}
\p{Gesture composition as net reduction:}

\pre{\startverb
    ┌──────┐     ┌──────┐
    │ G1   ├─────┤ G2   │
    └──┬───┘     └───┬──┘
       │             │
       └──────┬──────┘
              │
         ┌────┴────┐
         │ G1;G2   │  (composed gesture)
         └─────────┘
\stopverb}
}

\subtree{
\title{Gestures ↔ stellogen}
\p{Gestures as continuous star trajectories:}

\pre{\startverb
' Gesture as constellation with time parameter
(def gesture_star
  [(+time T) (+pitch (interp P0 P1 T)) (-note N)])

' Hypergesture: nest gestures
(def hyper
  [(+meta_time S) 
   (+gesture (gesture_star S))
   (-performance P)])
\stopverb}
}
}

\subtree{
\title{Mathematical Structure}
\subtree{
\title{Gesture Category}
\pre{\startverb
Objects: Topological spaces (pitch, dynamics, timing, ...)
Morphisms: Continuous curves γ: I → X
Composition: Path concatenation (up to homotopy)
\stopverb}
}

\subtree{
\title{Hypergesture Homology}
\pre{\startverb
H_0(G) = Connected components of gesture space
H_1(G) = Loops in gesture space (repeating patterns)
H_n(G) = Higher-dimensional voids (complex structures)
\stopverb}
}

\subtree{
\title{Diamond Diagram}
\pre{\startverb
           Skeleton
              ↑
    Body ←─── G ───→ Gesture
              ↓
           Performance

G = Gesture object relating all three domains
\stopverb}
}
}

\subtree{
\title{Commands}
\pre{\startverb
# Create gesture from MIDI
just gesture-from-midi performance.mid

# Interpolate between gestures
just gesture-interpolate g1.json g2.json --steps 10

# Verify hypergesture cohomology
just gesture-h1 hypergesture.json

# Sonify gesture trajectory
just gesture-sonify contour.json --seed 137508

# Visualize gesture space
just gesture-viz --output gesture.svg
\stopverb}
}

