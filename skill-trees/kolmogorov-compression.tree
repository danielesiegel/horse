\p{As \strong{Validator (-1)}, kolmogorov-compression:}

\ul{
\li{Measures true complexity (validates claims)}
\li{Filters noise from signal}
\li{Provides lower bound on description}
}
}

\subtree{
\title{Connection to Theorem Proving}
\pre{\startverb
For proof P of theorem T:
  K(T) ≈ min |P| over all proofs P

Short proofs = Simple theorems
Long proofs = Complex theorems (but still provable)

Gödel: Some true statements have K(T) = ∞ (unprovable)
\stopverb}
}

