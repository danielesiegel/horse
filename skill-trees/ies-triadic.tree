\subtree{
\title{Triadic Composition}
\subtree{
\title{Mutual Exclusivity}
\p{Each trit excludes the others by definition:}

\ul{
\li{\strong{FORM} has no agency or experience}
\li{\strong{GAME} has no eternal form or phenomenal access}
\li{\strong{WITNESS} has no formal structure or computational dynamics}
}
}

\subtree{
\title{Topos Compatibility}
\p{Yet all three are topos-compatible:}

\ul{
\li{FORM lives in the ∞-topos of spaces}
\li{GAME lives in the topos of Para(Optic) arenas}
\li{WITNESS lives in the topos of consciousness moments}
}
}

\subtree{
\title{GF(3) Conservation}
\p{Any complete ies inquiry must balance all three:}

\pre{\startverb
Σ(trits) ≡ 0 (mod 3)
\stopverb}

\p{If your inquiry is heavy on FORM (-1), add WITNESS (+1) to balance. If stuck in GAME (0), add both FORM and WITNESS.}
}
}

\subtree{
\title{Usage}
\pre{\startverb
# Load the triadic skill
just ies-form      # Pure categorical structure
just ies-game      # Cybernetic agency
just ies-witness   # Phenomenological ingression
just ies-balance   # Check GF(3) conservation
\stopverb}

\subtree{
\title{Spectral Walk Parameters}
\ul{
\li{\strong{α = 0.75}: Lazy walk probability (stay in current trit)}
\li{\strong{γ = 1/4}: Spectral gap (mixing rate across trits)}
\li{\strong{4 steps}: Mixing time to traverse all trits}
}
}
}

