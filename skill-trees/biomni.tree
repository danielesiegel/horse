\subtree{
\title{Troubleshooting}
\subtree{
\title{Common Issues}
\p{\strong{Data download fails}}

\pre{\startverb
# Manually trigger data lake download
agent = A1(path='./data', llm='your-llm')
# First .go() call will download data
\stopverb}

\p{\strong{API key errors}}

\pre{\startverb
# Verify environment variables
echo $ANTHROPIC_API_KEY
# Or check .env file in working directory
\stopverb}

\p{\strong{Timeout on complex tasks}}

\pre{\startverb
from biomni.config import default_config
default_config.timeout_seconds = 3600  # 1 hour
\stopverb}

\p{\strong{Memory issues with large datasets}}

\ul{
\li{Use streaming for large files}
\li{Process data in chunks}
\li{Increase system memory allocation}
}
}

