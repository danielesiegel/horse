\title{Rank Polymorphism}

\taxon{skill}

\meta{trit}{1}

\meta{description}{'APL/BQN rank polymorphism: implicit iteration via array rank, no explicit}

\subtree{
\title{Rank Polymorphism Skill}
\blockquote{*"Loops are for peasants. Rank is for kings."*}

\subtree{
\title{Core Concept}
\p{In rank-polymorphic languages:}

\ol{
\li{\strong{Operations apply to arrays automatically}}
\li{\strong{Rank} (number of dimensions) determines how operations distribute}
\li{\strong{No explicit loops} — shape determines iteration}
\li{\strong{Composition} replaces control flow}
}

\pre{\startverb
      1 2 3 + 10 20 30     ⍝ Vectorized: 11 22 33
      +/ 1 2 3 4           ⍝ Reduce: 10
      1 2 ∘.× 3 4 5        ⍝ Outer product: 2×3 matrix
\stopverb}
}

\subtree{
\title{Why It's Strange}
\ol{
\li{\strong{No for-loops} — operations "just work" on any shape}
\li{\strong{Rank as type} — scalar, vector, matrix, tensor treated uniformly}
\li{\strong{Tacit programming} — point-free, no variable names}
\li{\strong{Right-to-left} — \code{\startverb 3×2+1\stopverb} = \code{\startverb 3×(2+1)\stopverb} = 9}
}
}

\subtree{
\title{APL Basics}
\pre{\startverb
⍝ Scalar extension
2 + 1 2 3          ⍝ → 3 4 5

⍝ Vector operations  
1 2 3 + 4 5 6      ⍝ → 5 7 9

⍝ Reduction
+/ 1 2 3 4         ⍝ → 10 (sum)
×/ 1 2 3 4         ⍝ → 24 (product)

⍝ Scan (cumulative)
+\ 1 2 3 4         ⍝ → 1 3 6 10

⍝ Outer product
1 2 ∘.× 3 4 5      ⍝ → 2×3 matrix: 3 4 5 / 6 8 10

⍝ Inner product
1 2 3 +.× 4 5 6    ⍝ → 1×4 + 2×5 + 3×6 = 32
\stopverb}
}

\subtree{
\title{BQN (Modern APL)}
\pre{\startverb
# Cleaner syntax, same ideas
+´ 1‿2‿3‿4         # Sum: 10
×˝ 2‿3⥊⟨1,2,3,4,5,6⟩  # Product of rows

# Rank operator (⎉)
+⎉1 mat            # Apply + to rank-1 cells (rows)

# Under (⌾) - apply, transform, unapply
10 ⌾(2⊸⊑) 1‿2‿3    # → 1‿10‿3 (modify at index 2)
\stopverb}
}

\subtree{
\title{Rank Operator}
\p{The \strong{rank operator} \code{\startverb ⍤\stopverb} (APL) or \code{\startverb ⎉\stopverb} (BQN) controls how functions distribute:}

\pre{\startverb
      f⍤0 ⍝ Apply to scalars (rank 0)
      f⍤1 ⍝ Apply to vectors (rank 1)  
      f⍤2 ⍝ Apply to matrices (rank 2)
\stopverb}

\p{Example:}

\pre{\startverb
      mat ← 3 4 ⍴ ⍳12       ⍝ 3×4 matrix
      +/⍤1 mat              ⍝ Sum each row: 10 26 42
      +/⍤2 mat              ⍝ Sum entire matrix: 78
\stopverb}
}

\subtree{
\title{Leading Axis Theory}
\p{Arrays are organized by \strong{leading axes}:}

\pre{\startverb
Shape: 2 3 4 5
       │ │ │ └─ Innermost (columns)
       │ │ └─── Third axis
       │ └───── Second axis (rows)
       └─────── Leading axis (frames)

Rank-1 cells: 5-vectors
Rank-2 cells: 4×5 matrices
Rank-3 cells: 3×4×5 cubes
\stopverb}
}

\subtree{
\title{J Language}
\pre{\startverb
   +/ 1 2 3 4           NB. 10
   */ 1 2 3 4           NB. 24
   1 2 */ 3 4 5         NB. Outer product
   
   NB. Tacit (point-free)
   mean =: +/ % #        NB. sum divided by count
   mean 1 2 3 4 5        NB. 3
\stopverb}
}

\subtree{
\title{Implementation Strategy}
\pre{\startverb
import numpy as np

def rank_apply(f, k, arr):
    """Apply f to rank-k cells of arr."""
    if arr.ndim <= k:
        return f(arr)
    
    # Split into cells, apply, recombine
    result = np.array([rank_apply(f, k, cell) for cell in arr])
    return result

# Example
mat = np.arange(12).reshape(3, 4)
row_sums = rank_apply(np.sum, 1, mat)  # Sum each row
\stopverb}
}

\subtree{
\title{Key Combinators}
\pre{\startverb
| APL | BQN | J | Meaning |
|-----|-----|---|---------|
| `/` | `´` | `/` | Reduce (fold) |
| `\` | `` ` `` | `\` | Scan (cumulative) |
| `¨` | `¨` | `"0` | Each (map) |
| `∘.` | `⌜` | `*/` | Outer product |
| `⍤` | `⎉` | `"` | Rank |
| `⍥` | `○` | `&.:` | Under |
| `⍣` | `⍟` | `^:` | Power (iterate) |
\stopverb}
}

\subtree{
\title{Example: Game of Life}
\pre{\startverb
⍝ APL Game of Life in one line
life ← {↑1 ⍵∨.∧3 4=+/,¯1 0 1∘.⊖¯1 0 1∘.⌽⊂⍵}
\stopverb}

\p{No loops! The neighbor sum and rule application happen via rank.}
}

\subtree{
\title{Why No Loops?}
\pre{\startverb
⍝ Instead of:
⍝   for i in range(n):
⍝       for j in range(m):
⍝           result[i,j] = f(a[i], b[j])

⍝ Just write:
a ∘.f b            ⍝ Outer product

⍝ Instead of:
⍝   total = 0
⍝   for x in arr:
⍝       total += x

⍝ Just write:
+/ arr             ⍝ Reduce
\stopverb}
}

