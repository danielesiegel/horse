\title{Analyzing Malicious Pdf With Peepdf}

\taxon{skill}

\tag{malware-analysis}

\tag{pdf}

\tag{peepdf}

\tag{pdfid}

\tag{pdf-parser}

\tag{static-analysis}

\tag{reverse-engineering}

\tag{dfir}

\meta{version}{"1.0"}

\meta{description}{Perform static analysis of malicious PDF documents using peepdf, pdfid, and pdf-parser to extract embedded JavaScript, shellcode, and suspicious objects.}

\subtree{
\title{Analyzing Malicious PDF with peepdf}
\subtree{
\title{When to Use}
\ul{
\li{When triaging suspicious PDF attachments from phishing emails}
\li{During malware analysis of PDF-based exploit documents}
\li{When extracting embedded JavaScript, shellcode, or executables from PDFs}
\li{For forensic examination of weaponized document artifacts}
\li{When building detection signatures for PDF-based threats}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Python 3.8+ with peepdf-3 installed (pip install peepdf-3)}
\li{pdfid.py and pdf-parser.py from Didier Stevens suite}
\li{Isolated analysis environment (VM or sandbox)}
\li{Optional: PyV8 for JavaScript emulation within peepdf}
\li{Optional: Pylibemu for shellcode analysis}
}
}

\subtree{
\title{Workflow}
\ol{
\li{\strong{Triage with pdfid}: Scan PDF for suspicious keywords (/JS, /JavaScript, /OpenAction, /Launch, /EmbeddedFile).}
\li{\strong{Interactive Analysis}: Open PDF in peepdf interactive mode to explore object structure.}
\li{\strong{Identify Suspicious Objects}: Locate objects containing JavaScript, streams, or encoded data.}
\li{\strong{Extract Content}: Dump suspicious streams and decode filters (FlateDecode, ASCIIHexDecode).}
\li{\strong{Deobfuscate JavaScript}: Analyze extracted JS for shellcode, heap sprays, or exploit code.}
\li{\strong{Check VirusTotal}: Use peepdf vtcheck to cross-reference file hash with AV detections.}
\li{\strong{Generate IOCs}: Extract URLs, domains, hashes, and shellcode signatures.}
}
}

\subtree{
\title{Key Concepts}
\pre{\startverb
| Concept | Description |
|---------|-------------|
| /OpenAction | Automatic action executed when PDF is opened |
| /JavaScript /JS | Embedded JavaScript code in PDF objects |
| /Launch | Action that launches external applications |
| /EmbeddedFile | File embedded within the PDF structure |
| FlateDecode | zlib compression filter used to hide content |
| Object Streams | PDF objects stored in compressed streams |
\stopverb}
}

\subtree{
\title{Tools & Systems}
\pre{\startverb
| Tool | Purpose |
|------|---------|
| peepdf / peepdf-3 | Interactive PDF analysis with JS emulation |
| pdfid.py | Quick triage scanning for suspicious keywords |
| pdf-parser.py | Deep object-level PDF parsing |
| VirusTotal | Hash lookup and AV detection cross-reference |
| CyberChef | Decode and transform extracted payloads |
\stopverb}
}

\subtree{
\title{Output Format}
\pre{\startverb
Analysis Report: PDF-MAL-[DATE]-[SEQ]
File: [filename.pdf]
SHA-256: [hash]
Suspicious Keywords: [/JS, /OpenAction, etc.]
Objects with JavaScript: [Object IDs]
Extracted URLs: [List]
Shellcode Detected: [Yes/No]
Embedded Files: [Count and types]
VirusTotal Detections: [X/Y engines]
Risk Level: [Critical/High/Medium/Low]
\stopverb}
}
}