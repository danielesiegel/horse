\title{Analyzing Tls Certificate Transparency Logs}

\taxon{skill}

\tag{analyzing}

\tag{tls}

\tag{certificate}

\tag{transparency}

\meta{version}{"1.0"}

\meta{description}{Queries Certificate Transparency logs via crt.sh and pycrtsh to detect phishing domains, unauthorized certificate issuance, and shadow IT. Monitors newly issued certificates for typosquatting and brand impersonation using Levenshtein distance. Use for proactive phishing domain detection and certificate monitoring.}

\subtree{
\title{Analyzing TLS Certificate Transparency Logs}
\subtree{
\title{When to Use}
\ul{
\li{When investigating security incidents that require analyzing tls certificate transparency logs}
\li{When building detection rules or threat hunting queries for this domain}
\li{When SOC analysts need structured procedures for this analysis type}
\li{When validating security monitoring coverage for related attack techniques}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Familiarity with security operations concepts and tools}
\li{Access to a test or lab environment for safe execution}
\li{Python 3.8+ with required dependencies installed}
\li{Appropriate authorization for any testing activities}
}
}

\subtree{
\title{Instructions}
\p{Query crt.sh Certificate Transparency database to find certificates issued for domains similar to your organization's brand, detecting phishing infrastructure.}

\pre{\startverb
from pycrtsh import Crtsh

c = Crtsh()
# Search for certificates matching a domain
certs = c.search("example.com")
for cert in certs:
    print(cert["id"], cert["name_value"])

# Get full certificate details
details = c.get(certs[0]["id"], type="id")
\stopverb}

\p{Key analysis steps:}

\ol{
\li{Query crt.sh for all certificates matching your domain pattern}
\li{Identify certificates with typosquatting variations (Levenshtein distance)}
\li{Flag certificates from unexpected CAs}
\li{Monitor for wildcard certificates on suspicious subdomains}
\li{Cross-reference with known phishing infrastructure}
}
}

\subtree{
\title{Examples}
\pre{\startverb
from pycrtsh import Crtsh
c = Crtsh()
certs = c.search("%.example.com")
for cert in certs:
    print(f"Issuer: {cert.get('issuer_name')}, Domain: {cert.get('name_value')}")
\stopverb}
}
}