\li{\strong{web-api}: RESTful APIs and microservices}
\li{\strong{frontend}: React, Vue, Angular applications}
\li{\strong{full-stack}: Complete end-to-end applications}
\li{\strong{cli-tools}: Command-line utilities}
\li{\strong{data-processing}: ETL pipelines and analytics}
