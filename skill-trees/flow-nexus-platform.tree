\li{\strong{Daily Practice}: Complete daily challenges for bonus credits}
\li{\strong{Community}: Engage with discussions and learn from others}
\li{\strong{Track Progress}: Monitor achievements and leaderboard position}
\li{\strong{Experiment}: Try multiple approaches to problems}
}
}
}

\subtree{
\title{Storage & Real-time}
\subtree{
\title{File Storage}
\p{\strong{Upload File}}

\pre{\startverb
mcp__flow-nexus__storage_upload({
  bucket: "my-bucket", // public, private, shared, temp
  path: "data/users.json",
  content: JSON.stringify(userData, null, 2),
  content_type: "application/json"
})
\stopverb}

\p{\strong{List Files}}

\pre{\startverb
mcp__flow-nexus__storage_list({
  bucket: "my-bucket",
  path: "data/", // prefix filter
  limit: 100
})
\stopverb}

\p{\strong{Get Public URL}}

\pre{\startverb
mcp__flow-nexus__storage_get_url({
  bucket: "my-bucket",
  path: "data/report.pdf",
  expires_in: 3600 // seconds (default: 1 hour)
})
\stopverb}

\p{\strong{Delete File}}

\pre{\startverb
mcp__flow-nexus__storage_delete({
  bucket: "my-bucket",
  path: "data/old-file.json"
})
\stopverb}
}

\subtree{
\title{Storage Buckets}
\ul{
\li{\strong{public}: Publicly accessible files (CDN-backed)}
\li{\strong{private}: User-only access with authentication}
\li{\strong{shared}: Team collaboration with ACL}
\li{\strong{temp}: Auto-deleted after 24 hours}
}
}

\subtree{
\title{Real-time Subscriptions}
\p{\strong{Subscribe to Database Changes}}

\pre{\startverb
mcp__flow-nexus__realtime_subscribe({
  table: "tasks",
  event: "INSERT", // INSERT, UPDATE, DELETE, *
  filter: "status=eq.pending AND priority=eq.high"
})
\stopverb}

\p{\strong{List Active Subscriptions}}

\pre{\startverb
mcp__flow-nexus__realtime_list()
\stopverb}

\p{\strong{Unsubscribe}}

\pre{\startverb
mcp__flow-nexus__realtime_unsubscribe({
  subscription_id: "subscription_id"
})
\stopverb}
}

\subtree{
\title{Execution Monitoring}
\p{\strong{Subscribe to Execution Stream}}

\pre{\startverb
mcp__flow-nexus__execution_stream_subscribe({
  stream_type: "claude-flow-swarm", // claude-code, claude-flow-swarm, claude-flow-hive-mind, github-integration
  deployment_id: "deployment_id",
  sandbox_id: "sandbox_id" // alternative
})
\stopverb}

\p{\strong{Get Stream Status}}

\pre{\startverb
mcp__flow-nexus__execution_stream_status({
  stream_id: "stream_id"
})
\stopverb}

\p{\strong{List Generated Files}}

\pre{\startverb
mcp__flow-nexus__execution_files_list({
  stream_id: "stream_id",
  created_by: "claude-flow", // claude-code, claude-flow, git-clone, user
  file_type: "javascript" // filter by extension
})
\stopverb}

\p{\strong{Get File Content from Execution}}

\pre{\startverb
mcp__flow-nexus__execution_file_get({
  file_id: "file_id",
  file_path: "/path/to/file.js" // alternative
})
\stopverb}
}
}

\subtree{
\title{System Utilities}
\subtree{
\title{Queen Seraphina AI Assistant}
