\li{Tool usage for hands-on assistance}
}
}

\subtree{
\title{System Health & Monitoring}
\p{\strong{Check System Health}}

\pre{\startverb
mcp__flow-nexus__system_health()
\stopverb}

\p{\strong{View Audit Logs}}

\pre{\startverb
mcp__flow-nexus__audit_log({
  user_id: "your_user_id", // optional filter
  limit: 100
})
\stopverb}
}

\subtree{
\title{Authentication Management}
\p{\strong{Initialize Authentication}}

\pre{\startverb
mcp__flow-nexus__auth_init({
  mode: "user" // user, service
})
\stopverb}
}
}

\subtree{
\title{Quick Start Guide}
\subtree{
\title{Step 1: Register & Login}
\pre{\startverb
// Register
mcp__flow-nexus__user_register({
  email: "dev@example.com",
  password: "SecurePass123!",
  full_name: "Developer Name"
})

// Login
mcp__flow-nexus__user_login({
  email: "dev@example.com",
  password: "SecurePass123!"
})

// Check auth status
mcp__flow-nexus__auth_status({ detailed: true })
\stopverb}
}

\subtree{
\title{Step 2: Configure Billing}
\pre{\startverb
// Check current balance
mcp__flow-nexus__check_balance()

// Add credits
const paymentLink = mcp__flow-nexus__create_payment_link({
  amount: 50 // $50
})

// Setup auto-refill
mcp__flow-nexus__configure_auto_refill({
  enabled: true,
  threshold: 100,
  amount: 50
})
\stopverb}
}

\subtree{
\title{Step 3: Create Your First Sandbox}
\pre{\startverb
// Create development sandbox
const sandbox = mcp__flow-nexus__sandbox_create({
  template: "node",
  name: "dev-environment",
  install_packages: ["express", "dotenv"],
  env_vars: {
    NODE_ENV: "development"
  }
})

// Execute code
mcp__flow-nexus__sandbox_execute({
  sandbox_id: sandbox.id,
  code: 'console.log("Hello Flow Nexus!")',
  language: "javascript"
})
\stopverb}
}

\subtree{
\title{Step 4: Deploy an App}
\pre{\startverb
// Browse templates
mcp__flow-nexus__template_list({
  category: "backend",
  featured: true
})

// Deploy template
mcp__flow-nexus__template_deploy({
  template_name: "express-api-starter",
  deployment_name: "my-api",
  variables: {
    database_url: "postgres://..."
  }
})
\stopverb}
}

\subtree{
\title{Step 5: Complete a Challenge}
\pre{\startverb
// Find challenges
mcp__flow-nexus__challenges_list({
  difficulty: "beginner",
  category: "algorithms"
})

// Submit solution
mcp__flow-nexus__challenge_submit({
  challenge_id: "fizzbuzz",
  user_id: "your_id",
  solution_code: "...",
  language: "javascript"
})
\stopverb}
}
}

\subtree{
\title{Best Practices}
\subtree{
\title{Security}
\ol{
\li{Never hardcode API keys - use environment variables}
\li{Enable 2FA when available}
\li{Regularly rotate passwords and tokens}
\li{Use private buckets for sensitive data}
\li{Review audit logs periodically}
\li{Set appropriate file expiration times}
}
}

\subtree{
\title{Performance}
\ol{
\li{Clean up unused sandboxes to save credits}
\li{Use smaller sandbox templates when possible}
\li{Optimize storage by deleting old files}
\li{Batch operations to reduce API calls}
\li{Monitor usage via \code{\startverb user_stats\stopverb}}
\li{Use temp buckets for transient data}
}
}

\subtree{
\title{Development}
\ol{
\li{Start with sandbox testing before deployment}
\li{Version your applications semantically}
\li{Document all templates thoroughly}
\li{Include tests in published apps}
\li{Use execution monitoring for debugging}
\li{Leverage real-time subscriptions for live updates}
}
}

\subtree{
\title{Cost Management}
\ol{
\li{Set auto-refill thresholds carefully}
\li{Monitor credit usage regularly}
\li{Complete daily challenges for bonus credits}
\li{Publish templates to earn passive credits}
\li{Use free-tier resources when appropriate}
\li{Schedule heavy jobs during off-peak times}
}
}
}

\subtree{
\title{Troubleshooting}
\subtree{
\title{Authentication Issues}
\ul{
\li{\strong{Login Failed}: Check email/password, verify email first}
\li{\strong{Token Expired}: Re-login to get fresh tokens}
\li{\strong{Permission Denied}: Check tier limits, upgrade if needed}
}
}

\subtree{
\title{Sandbox Issues}
\ul{
\li{\strong{Sandbox Won't Start}: Check template compatibility, verify credits}
\li{\strong{Execution Timeout}: Increase timeout parameter or optimize code}
\li{\strong{Out of Memory}: Use larger template or optimize memory usage}
\li{\strong{Package Install Failed}: Check package name, verify npm/pip availability}
}
}

\subtree{
\title{Payment Issues}
\ul{
\li{\strong{Payment Failed}: Check payment method, sufficient funds}
\li{\strong{Credits Not Applied}: Allow 5-10 minutes for processing}
\li{\strong{Auto-refill Not Working}: Verify payment method on file}
}
}

\subtree{
\title{Challenge Issues}
\ul{
\li{\strong{Submission Rejected}: Check code syntax, ensure all tests pass}
\li{\strong{Wrong Answer}: Review test cases, check edge cases}
\li{\strong{Performance Too Slow}: Optimize algorithm complexity}
}
}
}

\subtree{
\title{Support & Resources}
\ul{
\li{\strong{Documentation}: https://docs.flow-nexus.ruv.io}
\li{\strong{API Reference}: https://api.flow-nexus.ruv.io/docs}
\li{\strong{Status Page}: https://status.flow-nexus.ruv.io}
\li{\strong{Community Forum}: https://community.flow-nexus.ruv.io}
\li{\strong{GitHub Issues}: https://github.com/ruvnet/flow-nexus/issues}
\li{\strong{Discord}: https://discord.gg/flow-nexus}
\li{\strong{Email Support}: support@flow-nexus.ruv.io (Pro/Enterprise only)}
}
}

\subtree{
\title{Progressive Disclosure}
\p{<details> <summary><strong>Advanced Sandbox Configuration</strong></summary>}

\subtree{
\title{Custom Docker Images}
\pre{\startverb
mcp__flow-nexus__sandbox_create({
  template: "base",
  name: "custom-environment",
  startup_script: `
    apt-get update
    apt-get install -y custom-package
    git clone https://github.com/user/repo
    cd repo && npm install
  `
})
\stopverb}
}

\subtree{
\title{Multi-Stage Execution}
\pre{\startverb
// Stage 1: Setup
mcp__flow-nexus__sandbox_execute({
  sandbox_id: "id",
  code: "npm install && npm run build"
})

// Stage 2: Run
mcp__flow-nexus__sandbox_execute({
  sandbox_id: "id",
  code: "npm start",
  working_dir: "/app/dist"
})
\stopverb}

\p{</details>}

\p{<details> <summary><strong>Advanced Storage Patterns</strong></summary>}
}

\subtree{
\title{Large File Upload (Chunked)}
\pre{\startverb
const chunkSize = 5 * 1024 * 1024 // 5MB chunks
for (let i = 0; i < chunks.length; i++) {
  await mcp__flow-nexus__storage_upload({
    bucket: "private",
    path: `large-file.bin.part${i}`,
    content: chunks[i]
  })
}
\stopverb}
}

\subtree{
\title{Storage Lifecycle}
\pre{\startverb
// Upload to temp for processing
mcp__flow-nexus__storage_upload({
  bucket: "temp",
  path: "processing/data.json",
  content: data
})

// Move to permanent storage after processing
mcp__flow-nexus__storage_upload({
  bucket: "private",
  path: "archive/processed-data.json",
  content: processedData
})
\stopverb}

\p{</details>}

\p{<details> <summary><strong>Advanced Real-time Patterns</strong></summary>}
}

\subtree{
\title{Multi-Table Sync}
\pre{\startverb
const tables = ["users", "tasks", "notifications"]
tables.forEach(table => {
  mcp__flow-nexus__realtime_subscribe({
    table,
    event: "*",
    filter: `user_id=eq.${userId}`
  })
})
\stopverb}
}

\subtree{
\title{Event-Driven Workflows}
\pre{\startverb
// Subscribe to task completion
mcp__flow-nexus__realtime_subscribe({
  table: "tasks",
  event: "UPDATE",
  filter: "status=eq.completed"
})

// Trigger notification workflow on event
// (handled by your application logic)
\stopverb}

\p{</details>}
}
}

