\subtree{
\title{Authentication & User Management}
\subtree{
\title{Registration & Login}
\p{\strong{Register New Account}}

\pre{\startverb
mcp__flow-nexus__user_register({
  email: "user@example.com",
  password: "secure_password",
  full_name: "Your Name",
  username: "unique_username" // optional
})
\stopverb}

\p{\strong{Login}}

\pre{\startverb
mcp__flow-nexus__user_login({
  email: "user@example.com",
  password: "your_password"
})
\stopverb}

\p{\strong{Check Authentication Status}}

\pre{\startverb
mcp__flow-nexus__auth_status({ detailed: true })
\stopverb}

\p{\strong{Logout}}

\pre{\startverb
mcp__flow-nexus__user_logout()
\stopverb}
}

\subtree{
\title{Password Management}
\p{\strong{Request Password Reset}}

\pre{\startverb
mcp__flow-nexus__user_reset_password({
  email: "user@example.com"
})
\stopverb}

\p{\strong{Update Password with Token}}

\pre{\startverb
mcp__flow-nexus__user_update_password({
  token: "reset_token_from_email",
  new_password: "new_secure_password"
})
\stopverb}

\p{\strong{Verify Email}}

\pre{\startverb
mcp__flow-nexus__user_verify_email({
  token: "verification_token_from_email"
})
\stopverb}
}

\subtree{
\title{Profile Management}
\p{\strong{Get User Profile}}

\pre{\startverb
mcp__flow-nexus__user_profile({
  user_id: "your_user_id"
})
\stopverb}

\p{\strong{Update Profile}}

\pre{\startverb
mcp__flow-nexus__user_update_profile({
  user_id: "your_user_id",
  updates: {
    full_name: "Updated Name",
    bio: "AI Developer and researcher",
    github_username: "yourusername",
    twitter_handle: "@yourhandle"
  }
})
\stopverb}

\p{\strong{Get User Statistics}}

\pre{\startverb
mcp__flow-nexus__user_stats({
  user_id: "your_user_id"
})
\stopverb}

\p{\strong{Upgrade User Tier}}

\pre{\startverb
mcp__flow-nexus__user_upgrade({
  user_id: "your_user_id",
  tier: "pro" // pro, enterprise
})
\stopverb}
}
}

\subtree{
\title{Sandbox Management}
\subtree{
\title{Create & Configure Sandboxes}
\p{\strong{Create Sandbox}}

\pre{\startverb
mcp__flow-nexus__sandbox_create({
  template: "node", // node, python, react, nextjs, vanilla, base, claude-code
  name: "my-sandbox",
  env_vars: {
    API_KEY: "your_api_key",
    NODE_ENV: "development",
    DATABASE_URL: "postgres://..."
  },
  install_packages: ["express", "cors", "dotenv"],
  startup_script: "npm run dev",
  timeout: 3600, // seconds
  metadata: {
    project: "my-project",
    environment: "staging"
  }
})
\stopverb}

\p{\strong{Configure Existing Sandbox}}

\pre{\startverb
mcp__flow-nexus__sandbox_configure({
  sandbox_id: "sandbox_id",
  env_vars: {
    NEW_VAR: "value"
  },
  install_packages: ["axios", "lodash"],
  run_commands: ["npm run migrate", "npm run seed"],
  anthropic_key: "sk-ant-..." // For Claude Code integration
})
\stopverb}
}

\subtree{
\title{Execute Code}
\p{\strong{Run Code in Sandbox}}

\pre{\startverb
mcp__flow-nexus__sandbox_execute({
  sandbox_id: "sandbox_id",
  code: `
    console.log('Hello from sandbox!');
    const result = await fetch('https://api.example.com/data');
    const data = await result.json();
    return data;
  `,
  language: "javascript",
  capture_output: true,
  timeout: 60, // seconds
  working_dir: "/app",
  env_vars: {
    TEMP_VAR: "override"
  }
})
\stopverb}
}

\subtree{
\title{Manage Sandboxes}
\p{\strong{List Sandboxes}}

\pre{\startverb
mcp__flow-nexus__sandbox_list({
  status: "running" // running, stopped, all
})
\stopverb}

\p{\strong{Get Sandbox Status}}

\pre{\startverb
mcp__flow-nexus__sandbox_status({
  sandbox_id: "sandbox_id"
})
\stopverb}

\p{\strong{Upload File to Sandbox}}

\pre{\startverb
mcp__flow-nexus__sandbox_upload({
  sandbox_id: "sandbox_id",
  file_path: "/app/config/database.json",
  content: JSON.stringify(databaseConfig, null, 2)
})
\stopverb}

\p{\strong{Get Sandbox Logs}}

\pre{\startverb
mcp__flow-nexus__sandbox_logs({
  sandbox_id: "sandbox_id",
  lines: 100 // max 1000
})
\stopverb}

\p{\strong{Stop Sandbox}}

\pre{\startverb
mcp__flow-nexus__sandbox_stop({
  sandbox_id: "sandbox_id"
})
\stopverb}

\p{\strong{Delete Sandbox}}

\pre{\startverb
mcp__flow-nexus__sandbox_delete({
  sandbox_id: "sandbox_id"
})
\stopverb}
}

\subtree{
\title{Sandbox Templates}
\ul{
\li{\strong{node}: Node.js environment with npm}
\li{\strong{python}: Python 3.x with pip}
\li{\strong{react}: React development setup}
\li{\strong{nextjs}: Next.js full-stack framework}
\li{\strong{vanilla}: Basic HTML/CSS/JS}
\li{\strong{base}: Minimal Linux environment}
\li{\strong{claude-code}: Claude Code integrated environment}
}
}

\subtree{
\title{Common Sandbox Patterns}
\p{\strong{API Development Sandbox}}

\pre{\startverb
mcp__flow-nexus__sandbox_create({
  template: "node",
  name: "api-development",
  install_packages: [
    "express",
    "cors",
    "helmet",
    "dotenv",
    "jsonwebtoken",
    "bcrypt"
  ],
  env_vars: {
    PORT: "3000",
    NODE_ENV: "development"
  },
  startup_script: "npm run dev"
})
\stopverb}

\p{\strong{Machine Learning Sandbox}}

\pre{\startverb
mcp__flow-nexus__sandbox_create({
  template: "python",
  name: "ml-training",
  install_packages: [
    "numpy",
    "pandas",
    "scikit-learn",
    "matplotlib",
    "tensorflow"
  ],
  env_vars: {
    CUDA_VISIBLE_DEVICES: "0"
  }
})
\stopverb}

\p{\strong{Full-Stack Development}}

\pre{\startverb
mcp__flow-nexus__sandbox_create({
  template: "nextjs",
  name: "fullstack-app",
  install_packages: [
    "prisma",
    "@prisma/client",
    "next-auth",
    "zod"
  ],
  env_vars: {
    DATABASE_URL: "postgresql://...",
    NEXTAUTH_SECRET: "secret"
  }
})
\stopverb}
}
}

\subtree{
\title{App Store & Deployment}
\subtree{
\title{Browse & Search}
\p{\strong{Search Applications}}

\pre{\startverb
