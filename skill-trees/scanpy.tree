\subtree{
\title{assets/analysis_template.py}
\p{Complete analysis template providing a full workflow from data loading through cell type annotation. Copy and customize this template for new analyses:}

\pre{\startverb
cp assets/analysis_template.py my_analysis.py
# Edit parameters and run
python my_analysis.py
\stopverb}

\p{The template includes all standard steps with configurable parameters and helpful comments.}
}
}

