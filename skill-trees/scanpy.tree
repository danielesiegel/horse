\subtree{
\title{Tips for Effective Analysis}
\ol{
\li{\strong{Start with the template}: Use \code{\startverb assets/analysis_template.py\stopverb} as a starting point}
\li{\strong{Run QC script first}: Use \code{\startverb scripts/qc_analysis.py\stopverb} for initial filtering}
\li{\strong{Consult references as needed}: Load workflow and API references into context}
\li{\strong{Iterate on clustering}: Try multiple resolutions and visualization methods}
\li{\strong{Validate biologically}: Check marker genes match expected cell types}
\li{\strong{Document parameters}: Record QC thresholds and analysis settings}
\li{\strong{Save checkpoints}: Write intermediate results at key steps}
}
}
}