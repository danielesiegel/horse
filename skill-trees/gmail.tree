\title{Gmail}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{Fetch Gmail using existing Google Workspace credentials at ~/.google_workspace_mcp/credentials/greenteatree01@gmail.com.json}

\subtree{
\title{Gmail Skill}
\p{Fetches Gmail using existing Google Workspace OAuth credentials.}

\subtree{
\title{Prerequisites}
\p{Credentials file exists at:}

\pre{\startverb
~/.google_workspace_mcp/credentials/greenteatree01@gmail.com.json
\stopverb}
}

\subtree{
\title{Usage}
\p{Fetch most recent email:}

\pre{\startverb
uvx --from google-auth --with google-api-python-client --with google-auth-oauthlib python3 ~/.claude/skills/gmail/fetch.py
\stopverb}

\p{Fetch with options:}

\pre{\startverb
# Fetch N most recent emails
uvx --from google-auth --with google-api-python-client --with google-auth-oauthlib python3 ~/.claude/skills/gmail/fetch.py --count 5

# Search emails
uvx --from google-auth --with google-api-python-client --with google-auth-oauthlib python3 ~/.claude/skills/gmail/fetch.py --query "from:someone@example.com"
\stopverb}
}

\subtree{
\title{Credential Location}
\p{The working credentials are at:}

\pre{\startverb
~/.google_workspace_mcp/credentials/greenteatree01@gmail.com.json
\stopverb}

\p{These contain a refresh token with full Gmail scopes (readonly, compose, send, modify).}
}
}