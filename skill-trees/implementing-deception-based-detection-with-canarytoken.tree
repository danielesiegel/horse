\meta{version}{"1.0"}

\meta{description}{Deploy and monitor Canary Tokens via the Thinkst Canary API for deception-based breach detection using web bug tokens, DNS tokens, document tokens, and AWS key tokens.}

\subtree{
\title{Implementing Deception-Based Detection with Canarytoken}
\subtree{
\title{Overview}
\p{Canary Tokens are lightweight tripwire mechanisms that alert when an attacker accesses a resource. This skill uses the Thinkst Canary REST API to programmatically create tokens (web bugs, DNS tokens, MS Word documents, AWS API keys), deploy them to strategic locations, monitor for triggered alerts, and generate deception coverage reports.}
}

\subtree{
\title{When to Use}
\ul{
\li{When deploying or configuring implementing deception based detection with canarytoken capabilities in your environment}
\li{When establishing security controls aligned to compliance requirements}
\li{When building or improving security architecture for this domain}
\li{When conducting security assessments that require this implementation}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Thinkst Canary Console or canarytokens.org account}
\li{API auth token from Canary Console}
\li{Python 3.9+ with \code{\startverb requests\stopverb}}
\li{File system access for deploying document and file tokens}
}
}

\subtree{
\title{Steps}
\ol{
\li{Authenticate to the Canary Console API using auth_token}
\li{Create web bug (HTTP) tokens for embedding in documents and web pages}
\li{Create DNS tokens for monitoring DNS resolution attempts}
\li{Create MS Word document tokens for file share deployment}
\li{List all active tokens and their trigger history}
\li{Query recent alerts for triggered token events}
\li{Generate deception coverage report with deployment recommendations}
}
}

\subtree{
\title{Expected Output}
\ul{
\li{JSON report listing all deployed Canary Tokens, trigger history, alert details, and coverage analysis}
\li{Deployment map showing token types across network segments}
}
}
}