\title{Sveltekit Structure}

\taxon{skill}

\meta{description}{SvelteKit structure guidance. Use for routing, layouts, error handling, SSR, or svelte:boundary. Covers file naming, nested layouts, error boundaries, pending UI, and hydration.}

\subtree{
\title{SvelteKit Structure}
\subtree{
\title{Quick Start}
\p{\strong{File types:} \code{\startverb +page.svelte\stopverb} (page) | \code{\startverb +layout.svelte\stopverb} (wrapper) | \code{\startverb +error.svelte\stopverb} (error boundary) | \code{\startverb +server.ts\stopverb} (API endpoint)}

\p{\strong{Routes:} \code{\startverb src/routes/about/+page.svelte\stopverb} → \code{\startverb /about\stopverb} | \code{\startverb src/routes/posts/[id]/+page.svelte\stopverb} → \code{\startverb /posts/123\stopverb}}

\p{\strong{Layouts:} Apply to all child routes. \code{\startverb +layout.svelte\stopverb} at any level wraps descendants.}
}

\subtree{
\title{Example}
\pre{\startverb
src/routes/
├── +layout.svelte              # Root layout (all pages)
├── +page.svelte                # Homepage /
├── about/+page.svelte          # /about
└── dashboard/
    ├── +layout.svelte          # Dashboard layout (dashboard pages only)
    ├── +page.svelte            # /dashboard
    └── settings/+page.svelte   # /dashboard/settings
\stopverb}

\pre{\startverb
<!-- +layout.svelte -->
<script>
	let { children } = $props();
</script>

<nav><!-- Navigation --></nav>
<main>{@render children()}</main>
<footer><!-- Footer --></footer>
\stopverb}
}

\subtree{
\title{Reference Files}
\ul{
\li{[file-naming.md](references/file-naming.md) - File naming}
\li{[layout-patterns.md](references/layout-patterns.md) - Nested layouts}
\li{[error-handling.md](references/error-handling.md) - +error.svelte}
\li{[svelte-boundary.md](references/svelte-boundary.md) -}
\li{[ssr-hydration.md](references/ssr-hydration.md) - SSR and}
}
}

\subtree{
\title{Notes}
\ul{
\li{Layouts: \code{\startverb {@render children()}\stopverb} | Errors: +error.svelte _above_}
\li{Groups: \code{\startverb (name)\stopverb} folders don't affect URL | Client-only: check}
\li{\strong{Last verified:} 2025-01-11}
}

