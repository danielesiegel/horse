}
\stopverb}
}

\subtree{
\title{Storage}
\ul{
\li{\strong{Threads:} \code{\startverb ~/.local/share/amp/threads/*.json\stopverb}}
\li{\strong{Continuations:} \code{\startverb ~/.local/share/amp/continuations/*.json\stopverb}}
\li{\strong{Exports:} \code{\startverb ~/.local/share/amp/exports/\stopverb}}
}
}

\subtree{
\title{Performance}
\ul{
\li{Thread load: O(1) per thread (disk lookup)}
\li{Export markdown: O(n) where n = total messages}
\li{Continuation fork: O(1) with work-stealing queue}
\li{Parallelism: 8x speedup with 8 workers on GF(3) branching}
}
}

