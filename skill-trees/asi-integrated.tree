just asi-schedule 0x42D 10

# Disperse skills to all agents
just asi-disperse ~/.claude/skills/

# Verify GF(3) conservation
just asi-verify

# Play glass bead synthesis
just asi-synthesize a b p t

# World hop between letters
just asi-hop a t
\stopverb}
}

