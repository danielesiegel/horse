\subtree{
\title{QuickCheck/Adhesive Rewriting Integration}
\p{Property-based testing connects to ASI through \strong{autopoietic generators}:}

\pre{\startverb
# QuickCheck-style recursive generator with GF(3) conservation
function autopoietic_tree(seed::UInt64, depth::Int)
    rng = SplitMix64(seed)
    trit = mod(next_u64!(rng), 3) - 1
    
    if depth == 0 || trit == -1  # MINUS = terminate
        return Leaf(color_at(seed))
    else
        left_seed, right_seed = split(rng)
        return Node(
            trit = trit,
            left  = autopoietic_tree(left_seed, depth-1),
            right = autopoietic_tree(right_seed, depth-1)
        )
    end
end
\stopverb}

\subtree{
\title{Shrinking as Adhesive Complement}
\p{QuickCheck shrinking = finding minimal ∼Q_G in adhesive categories:}

\ul{
\li{\strong{Decomposition}: Q ≅ Q_G +_{Q_L} Q_R}
\li{\strong{Complement}: ∼A is smallest subobject where X = A ∨ ∼A}
\li{\strong{Shrunk value} = complement of failed portion}
}
}

\subtree{
\title{Transitive Closure (Kris Brown)}
\p{From [Incremental Query Updating in Adhesive Categories](https://topos.institute/blog/2025-08-15-incremental-adhesive/):}

\pre{\startverb
path(X,Z) :- path(X,Y), edge(Y,Z).

Incremental update: When we apply rule to add path(a,b),
new matches = outgoing edges from b (rooted search)
\stopverb}
}
}

