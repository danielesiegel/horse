}

\subtree{
\title{Validation}
\ul{
\li{SPF record passes validation at mxtoolbox.com}
\li{DKIM signature verified on test emails}
\li{DMARC record properly formatted and reporting enabled}
\li{Test emails pass all three checks in recipient's Authentication-Results header}
}
}
}