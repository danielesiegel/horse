\title{Mcp Builder}

\taxon{skill}

\meta{description}{Guide for creating high-quality MCP (Model Context Protocol) servers}

\subtree{
\title{MCP Server Development Guide}
\p{Create MCP servers that enable LLMs to interact with external services through well-designed tools.}

\subtree{
\title{High-Level Workflow}
\subtree{
\title{Phase 1: Research and Planning}
\p{\strong{Understand Modern MCP Design:}}

\ul{
\li{Balance comprehensive API coverage with specialized workflow tools}
\li{Use clear, descriptive tool names with consistent prefixes (e.g., \code{\startverb github_create_issue\stopverb})}
\li{Design tools that return focused, relevant data}
\li{Provide actionable error messages}
}

\p{\strong{Study MCP Protocol:}}

\ul{
\li{Start with sitemap: \code{\startverb https://modelcontextprotocol.io/sitemap.xml\stopverb}}
\li{Key pages: specification, transport mechanisms, tool definitions}
}
}

\subtree{
\title{Phase 2: Implementation}
\p{\strong{Recommended Stack:}}

\ul{
\li{\strong{Language}: TypeScript (best SDK support)}
\li{\strong{Transport}: Streamable HTTP for remote, stdio for local}
}

\p{\strong{Project Structure:}}

\pre{\startverb
my-mcp-server/
├── src/
│   ├── index.ts      # Server entry point
│   ├── tools/        # Tool implementations
│   └── utils/        # Shared utilities
├── package.json
└── tsconfig.json
\stopverb}

\p{\strong{Tool Implementation Pattern:}}

\pre{\startverb
server.registerTool({
  name: "github_create_issue",
  description: "Create a new GitHub issue",
  inputSchema: z.object({
    repo: z.string().describe("Repository name (owner/repo)"),
    title: z.string().describe("Issue title"),
    body: z.string().optional().describe("Issue body")
  }),
  outputSchema: z.object({
    id: z.number(),
    url: z.string()
  }),
  annotations: {
    readOnlyHint: false,
    destructiveHint: false,
    idempotentHint: false
  },
  handler: async (input) => {
    // Implementation
    return { id: 123, url: "https://..." };
  }
});
\stopverb}
}

\subtree{
\title{Phase 3: Test}
\pre{\startverb
# TypeScript
npm run build
npx @modelcontextprotocol/inspector

# Python
python -m py_compile your_server.py
\stopverb}
}

\subtree{
\title{Phase 4: Create Evaluations}
\p{Create 10 complex, realistic questions to test your MCP server:}

\pre{\startverb
<evaluation>
  <qa_pair>
    <question>Find all open issues labeled 'bug' in the repo</question>
    <answer>5</answer>
  </qa_pair>
</evaluation>
\stopverb}
}
}

\subtree{
\title{Tool Design Best Practices}
\ul{
\li{Use Zod (TS) or Pydantic (Python) for schemas}
\li{Include constraints and examples in field descriptions}
\li{Define \code{\startverb outputSchema\stopverb} for structured data}
\li{Support pagination where applicable}
\li{Add tool annotations (readOnly, destructive, idempotent)}
}
}
}