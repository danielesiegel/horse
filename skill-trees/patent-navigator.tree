\title{Patent Navigator}

\taxon{skill}

\meta{version}{1.0.0}

\meta{trit}{0}

\meta{description}{Navigate patent law for protecting software work (open-source and proprietary)}

\subtree{
\title{CRITICAL: NO DEMOS}
\p{Loading this skill ≠ executing demonstration code. Execute ONLY on explicit user request.}
}

\subtree{
\title{Patent Navigator}
\p{Protect software work through strategic patent filings and defensive disclosure.}

\subtree{
\title{Core Strategies}
\subtree{
\title{1. Provisional Patent Application (PPA)}
\ul{
\li{\startverb **Cost**: ~$320 (micro entity)\stopverb}
\li{\strong{Duration}: 12 months to file full patent}
\li{\strong{Benefit}: Establishes priority date, "Patent Pending" status}
\li{\strong{Use case}: Novel algorithms, architectures, methods in your repos}
}
}

\subtree{
\title{2. Defensive Publication (Open Source)}
\ul{
\li{\strong{Cost}: Free (GitHub commits as prior art)}
\li{\strong{Effect}: Prevents others from patenting your work}
\li{\strong{Platforms}: arXiv, Zenodo, GitHub with clear timestamps}
\li{\strong{Use case}: When you want to keep it open, not exclusive}
}
}

\subtree{
\title{3. Trade Secret + Patent Hybrid (Proprietary)}
\ul{
\li{\strong{Trade secret}: Keep implementation details private}
\li{\strong{Patent}: Protect the method/system publicly}
\li{\strong{Use case}: Proprietary software where you want both exclusivity and enforcement rights}
}
}

\subtree{
\title{4. Provisional → PCT → National Phase}
\ul{
\li{\strong{Timeline}: 12mo (provisional) → 30mo (PCT) → national filings}
\li{\strong{Cost}: Escalates significantly at each phase}
\li{\strong{Use case}: International protection for high-value innovations}
}
}
}

\subtree{
\title{USPTO Requirements (2025)}
\subtree{
\title{Micro Entity Status}
\ul{
\li{< 4 prior patents}
\li{\startverb < 3x median household income (~$250k)\stopverb}
\li{\startverb 80% fee reduction\stopverb}
}
}

\subtree{
\title{Claims Structure}
\ul{
\li{Independent claims: Broadest protection}
\li{Dependent claims: Fallback positions}
\li{Method claims: Process/algorithm protection}
\li{System claims: Implementation protection}
}
}
}

\subtree{
\title{Workflow by Context}
\subtree{
\title{Public Repos}
\pre{\startverb
1. Identify patentable subject matter
2. File provisional BEFORE public commit (or within 1-year grace)
3. Document: problem, solution, advantages, embodiments
4. Continue development openly
5. Within 12 months: decide full patent vs abandon
\stopverb}
}

\subtree{
\title{Private/Proprietary}
\pre{\startverb
1. Identify patentable subject matter
2. Assess: patent vs trade secret vs both
3. File provisional to lock priority date
4. Keep implementation as trade secret if desired
5. Patent claims cover method/system, not code
\stopverb}
}
}

\subtree{
\title{Prior Art Search}
\p{Before filing, search:}

\ul{
\li{USPTO Patent Full-Text (patents.google.com)}
\li{arXiv, Semantic Scholar (academic prior art)}
\li{GitHub code search (implementation prior art)}
}
}

\subtree{
\title{Key Dates (2025 USPTO Changes)}
\ul{
\li{IPR tightening: Harder to challenge granted patents}
\li{Fee increases: File before rate changes}
\li{AI inventorship: Still requires human inventor}
}
}

\subtree{
\title{SF Bay Area IP Firms}
\ul{
\li{Fenwick & West (tech-focused)}
\li{Wilson Sonsini (startup-friendly)}
\li{Knobbe Martens (patent prosecution)}
\li{Fish & Richardson (litigation strength)}
}
}

\subtree{
\title{References}
\ul{
\li{35 U.S.C. § 102 (Novelty)}
\li{35 U.S.C. § 103 (Non-obviousness)}
\li{35 U.S.C. § 112 (Written description)}
\li{MPEP 2106 (Patent-eligible subject matter)}
}
}
}