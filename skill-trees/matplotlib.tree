\subtree{
\title{Integration with Other Tools}
\p{Matplotlib integrates well with:}

\ul{
\li{\strong{NumPy/Pandas} - Direct plotting from arrays and DataFrames}
\li{\strong{Seaborn} - High-level statistical visualizations built on matplotlib}
\li{\startverb **Jupyter** - Interactive plotting with `%matplotlib inline` or `%matplotlib widget`\stopverb}
\li{\strong{GUI frameworks} - Embedding in Tkinter, Qt, wxPython applications}
}
}

\subtree{
\title{Common Gotchas}
\ol{
\li{\strong{Overlapping elements}: Use \code{\startverb constrained_layout=True\stopverb} or \code{\startverb tight_layout()\stopverb}}
\li{\strong{State confusion}: Use OO interface to avoid pyplot state machine issues}
\li{\strong{Memory issues with many figures}: Close figures explicitly with \code{\startverb plt.close(fig)\stopverb}}
\li{\strong{Font warnings}: Install fonts or suppress warnings with \code{\startverb plt.rcParams['font.sans-serif']\stopverb}}
\li{\strong{DPI confusion}: Remember that figsize is in inches, not pixels: \code{\startverb pixels = dpi * inches\stopverb}}
}
}

