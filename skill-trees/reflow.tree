\subtree{
\title{Reflow as Functor}
\pre{\startverb
F : Context → Context
F(content) = reflowed content
F(gf3) = gf3  (invariant preserved)

η : F_α → F_β  (natural transformation)
\stopverb}

\p{The naturality condition ensures GF(3) conservation across all perspectives.}
}

\subtree{
\title{Pun Connection}
\p{A pun is a reflow where:}

\ul{
\li{\strong{Source}: Surface form with default parse}
\li{\strong{Target}: Same surface form with alternate parse}
\li{\strong{Invariant}: The phonetic surface (preserved)}
\li{\strong{Humor}: The unexpected context switch}
}

\pre{\startverb
pun_reflow = {
  surface: "time flies",
  source_parse: { flies: :verb, like: :prep },
  target_parse: { flies: :noun, like: :verb },
  gf3_conserved: true  # Same surface!
}
\stopverb}
}

\subtree{
\title{Usage}
\subtree{
\title{Ruby}
\pre{\startverb
require 'xip_reflow'
content = XIP::Reflow::Content.new(data: "...", source_context: XIP::Reflow::Context::FORMAL)
op = XIP::Reflow::Operator.new
result = op.reflow_to_clojure(content)
puts result[:gf3_conserved]  # => true
\stopverb}
}

\subtree{
\title{Clojure/NATS}
\pre{\startverb
(require '[agents.reflow-nats :as r])
(def content (r/create-content "data" :formal))
(r/reflow content :clojure :structure)
\stopverb}
}

\subtree{
\title{Move}
\pre{\startverb
use adversarial::reflow;
reflow::tracked_reflow(account, CONTEXT_CLOJURE, PRESERVE_STRUCTURE);
\stopverb}
}
}

