\subtree{
\title{Information Reflow Skill (ERGODIC 0)}
\blockquote{*"Decomposition of etymological kind leads to compositionality of meaning."*}

\subtree{
\title{Core Insight}
\p{Reflow is \strong{collapse with conservation}. Content exists in superposition until measured by context, then collapses while preserving GF(3) = 0.}

\pre{\startverb
reflow : (Content × SourceContext × TargetContext) → Content'
such that GF(3)(Content) = GF(3)(Content')
\stopverb}
}

