\subtree{
\title{Common Pitfalls to Avoid}
\ol{
\li{\strong{Forgetting constant term}: Always use \code{\startverb sm.add_constant()\stopverb} unless no intercept desired}
\li{\strong{Ignoring assumptions}: Check residuals, heteroskedasticity, autocorrelation}
\li{\strong{Wrong model for outcome type}: Binary→Logit/Probit, Count→Poisson/NB, not OLS}
\li{\strong{Not checking convergence}: Look for optimization warnings}
\li{\strong{Misinterpreting coefficients}: Remember link functions (log, logit, etc.)}
\li{\strong{Using Poisson with overdispersion}: Check dispersion, use Negative Binomial if needed}
\li{\strong{Not using robust SEs}: When heteroskedasticity or clustering present}
\li{\strong{Overfitting}: Too many parameters relative to sample size}
\li{\strong{Data leakage}: Fitting on test data or using future information}
\li{\strong{Not validating predictions}: Always check out-of-sample performance}
\li{\strong{Comparing non-nested models}: Use AIC/BIC, not LR test}
\li{\strong{Ignoring influential observations}: Check Cook's distance and leverage}
\li{\strong{Multiple testing}: Correct p-values when testing many hypotheses}
\li{\strong{Not differencing time series}: Fit ARIMA on non-stationary data}
\li{\strong{Confusing prediction vs confidence intervals}: Prediction intervals are wider}
}
}

