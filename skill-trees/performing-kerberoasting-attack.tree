\meta{description}{Kerberoasting is a post-exploitation technique that targets service accounts in Active Directory by requesting Kerberos TGS (Ticket Granting Service) tickets for accounts with Service Principal Names}

\subtree{
\title{Performing Kerberoasting Attack}
\blockquote{\strong{Legal Notice:} This skill is for authorized security testing and educational purposes only. Unauthorized use against systems you do not own or have written permission to test is illegal and may violate computer fraud laws.}

\subtree{
\title{Overview}
\p{Kerberoasting is a post-exploitation technique that targets service accounts in Active Directory by requesting Kerberos TGS (Ticket Granting Service) tickets for accounts with Service Principal Names (SPNs) set. These tickets are encrypted with the service account's NTLM hash, allowing offline brute-force cracking without generating failed login events. It is one of the most common privilege escalation paths in AD environments because any domain user can request TGS tickets.}
}

\subtree{
\title{When to Use}
\ul{
\li{When conducting security assessments that involve performing kerberoasting attack}
\li{When following incident response procedures for related security events}
\li{When performing scheduled security testing or auditing activities}
\li{When validating security controls through hands-on testing}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Familiarity with red teaming concepts and tools}
\li{Access to a test or lab environment for safe execution}
\li{Python 3.8+ with required dependencies installed}
\li{Appropriate authorization for any testing activities}
}
}

\subtree{
\title{MITRE ATT&CK Mapping}
\ul{
\li{\strong{T1558.003} - Steal or Forge Kerberos Tickets: Kerberoasting}
\li{\strong{T1087.002} - Account Discovery: Domain Account}
\li{\strong{T1069.002} - Permission Groups Discovery: Domain Groups}
}
}

\subtree{
\title{Workflow}
\subtree{
\title{Phase 1: SPN Enumeration}
\ol{
\li{Enumerate accounts with SPNs using LDAP queries}
\li{Filter for user accounts (not computer accounts)}
\li{Identify accounts with elevated privileges (adminCount=1)}
\li{Prioritize accounts with weak password policies}
}
}

\subtree{
\title{Phase 2: TGS Ticket Request}
\ol{
\li{Request TGS tickets for identified SPN accounts}
\li{Extract ticket data in crackable format (hashcat/john compatible)}
\li{Ensure RC4 encryption is requested when possible (easier to crack)}
\li{Document all requested tickets}
}
}

\subtree{
\title{Phase 3: Offline Cracking}
\ol{
\li{Use hashcat mode 13100 (Kerberos 5 TGS-REP etype 23) for RC4 tickets}
\li{Use hashcat mode 19700 (Kerberos 5 TGS-REP etype 17) for AES-128}
\li{Use hashcat mode 19800 (Kerberos 5 TGS-REP etype 18) for AES-256}
\li{Apply targeted wordlists and rules based on password policy}
}
}

\subtree{
\title{Phase 4: Credential Validation}
\ol{
\li{Validate cracked credentials against domain}
\li{Assess access level of compromised accounts}
\li{Map accounts to BloodHound attack paths}
\li{Document for engagement report}
}
}
}

\subtree{
\title{Tools and Resources}
\pre{\startverb
| Tool | Purpose | Platform |
|------|---------|----------|
| Rubeus | Kerberoasting and ticket manipulation | Windows (.NET) |
| Impacket GetUserSPNs.py | Remote Kerberoasting | Linux/Python |
| PowerView | SPN enumeration | Windows (PowerShell) |
| hashcat | Offline password cracking | Cross-platform |
| John the Ripper | Offline password cracking | Cross-platform |
\stopverb}
}

\subtree{
\title{Detection Indicators}
\ul{
\li{Event ID 4769: Kerberos Service Ticket Request with RC4 encryption (0x17)}
\li{Anomalous TGS requests from a single account in short timeframe}
\li{TGS requests for services the user normally does not access}
\li{Honeypot SPN accounts with alerting on ticket requests}
}
}

\subtree{
\title{Validation Criteria}
\ul{
\li{[ ] SPN accounts enumerated and documented}
\li{[ ] TGS tickets extracted in crackable format}
\li{[ ] Offline cracking attempted with appropriate wordlists}
\li{[ ] Cracked credentials validated}
\li{[ ] Access level of compromised accounts assessed}
}
}
}