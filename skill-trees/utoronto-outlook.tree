\title{Utoronto Outlook}

\taxon{skill}

\meta{version}{1.1.0}

\meta{description}{Headless University of Toronto Outlook email access via IMAP/SMTP with OAuth2. Uses Thunderbird's pre-authorized client ID to bypass admin consent requirements (AADSTS65002). Device code flow for initial auth, macOS Keychain for token cache.}

\subtree{
\title{UofT Outlook Skill}
\p{Headless access to University of Toronto alumni/student Outlook via IMAP/SMTP with OAuth2.}

\p{\strong{Trit}: -1 (MINUS - validator/consumer) \strong{Principle}: Thunderbird Client ID → Device Code Auth → Keychain Cache → IMAP/SMTP \strong{Implementation}: IMAP OAuth2 (XOAUTH2) + Thunderbird Pre-Authorized Client ID}

\subtree{
\title{The AADSTS65002 Problem}
\p{University tenants block third-party OAuth apps:}

\pre{\startverb
AADSTS65002: Consent between first party application and first party resource 
must be configured via preauthorization
\stopverb}

\p{\strong{Solution}: Use Thunderbird's pre-authorized client ID \code{\startverb 9e5f94bc-e8a4-4e73-b8be-63364c29d753\stopverb} which Microsoft has pre-approved for IMAP/SMTP access on all tenants.}
}

\subtree{
\title{Authentication Architecture}
\pre{\startverb
┌─────────────────────────────────────────────────────────────────────┐
│               THUNDERBIRD CLIENT ID BYPASS                          │
├─────────────────────────────────────────────────────────────────────┤
│                                                                     │
│  [Problem: Graph API blocked]                                       │
│  ┌──────────┐     Graph API      ┌───────────────┐                 │
│  │  Agent   │ ────────────────▶  │ MS Entra ID   │                 │
│  └──────────┘                    └───────────────┘                 │
│       │                                 │                           │
│       │                                 ▼                           │
│       │                    ❌ AADSTS65002 Error                     │
│       │                    "Admin consent required"                 │
│                                                                     │
│  [Solution: Thunderbird IMAP]                                       │
│  ┌──────────┐  Thunderbird ID    ┌───────────────┐                 │
│  │  Agent   │ ─────────────────▶ │ MS Entra ID   │                 │
│  └──────────┘  9e5f94bc-...      └───────────────┘                 │
│       │                                 │                           │
│       │ Device code flow                │ Pre-authorized ✓         │
│       ▼                                 ▼                           │
│  "Enter code XXXXXX at microsoft.com/devicelogin"                  │
│       │                                                             │
│       │ User authenticates (one-time)                               │
│       ▼                                                             │
│  ┌──────────────────────────────────────────────────┐              │
│  │           macOS Keychain (secure storage)        │              │
│  │  outlook-university: access + refresh tokens    │              │
│  └──────────────────────────────────────────────────┘              │
│       │                                                             │
│       │ XOAUTH2 authentication                                      │
│       ▼                                                             │
│  ┌───────────────────────────────────────────────┐                 │
│  │  outlook.office365.com:993 (IMAP)             │                 │
│  │  smtp.office365.com:587 (SMTP)                │                 │
│  └───────────────────────────────────────────────┘                 │
└─────────────────────────────────────────────────────────────────────┘
\stopverb}
}

\subtree{
\title{Key Constants}
\pre{\startverb
# Thunderbird's pre-authorized client ID (public, safe to commit)
THUNDERBIRD_CLIENT_ID = "9e5f94bc-e8a4-4e73-b8be-63364c29d753"

# IMAP OAuth2 scopes (NOT Graph API scopes!)
IMAP_SCOPES = [
    "https://outlook.office.com/IMAP.AccessAsUser.All",
    "https://outlook.office.com/SMTP.Send",
    "offline_access",
    "openid", "profile", "email"
]

# Servers
IMAP_SERVER = "outlook.office365.com"  # Port 993 SSL
SMTP_SERVER = "smtp.office365.com"      # Port 587 STARTTLS
\stopverb}
}

\subtree{
\title{Usage}
\subtree{
\title{Initial Authentication (One-Time)}
\pre{\startverb
cd ~/.claude/skills/utoronto-outlook
uv run python outlook_university.py auth

# Output:
# ============================================================
# OUTLOOK UNIVERSITY - DEVICE CODE AUTHENTICATION
# ============================================================
#   Code: XXXXXXXXX
#   Go to: https://microsoft.com/devicelogin
#   (Uses Thunderbird's pre-authorized client ID)
# ============================================================
\stopverb}
}

\subtree{
\title{Headless Operations}
\pre{\startverb
# Check login
uv run python outlook_university.py whoami
# Logged in as: yulia.zubak@alumni.utoronto.ca

# List messages
uv run python outlook_university.py list 10

# Read message
uv run python outlook_university.py read 42

# Search
uv run python outlook_university.py search "professor"

# List folders
uv run python outlook_university.py folders
\stopverb}
}

\subtree{
\title{Python API}
\pre{\startverb
from outlook_university import OutlookClient

client = OutlookClient()

# List recent emails
messages = client.list_messages(limit=10)

# Get unread
unread = client.get_unread()

# Read full message (body truncated to 2000 chars for context safety)
msg = client.get_message("42")

# Search
results = client.search("grades")

# Send email
client.send(
    to=["recipient@example.com"],
    subject="Test",
    body="Hello from headless Outlook!"
)

client.close()
\stopverb}
}
}

\subtree{
\title{XOAUTH2 Authentication}
\p{The critical implementation detail for IMAP OAuth2:}

\pre{\startverb
# Build XOAUTH2 string per RFC 7628
auth_string = f"user={email}\x01auth=Bearer {access_token}\x01\x01"

# IMAP authenticate callback returns raw bytes
conn.authenticate("XOAUTH2", lambda x: auth_string.encode())
\stopverb}
}

\subtree{
\title{GF(3) Verb Typing}
\pre{\startverb
| Operation | Trit | Description |
|-----------|------|-------------|
| `list_messages` | -1 | Consume/read inbox (MINUS) |
| `get_message` | -1 | Read specific message (MINUS) |
| `get_unread` | -1 | Query unread (MINUS) |
| `search` | -1 | Query messages (MINUS) |
| `list_folders` | 0 | Metadata access (ERGODIC) |
| `send` | +1 | Generate output (PLUS) |
\stopverb}
}

\subtree{
\title{Security Notes}
\ul{
\li{\strong{Thunderbird Client ID}: Public, safe to commit (used by Mozilla Thunderbird)}
\li{\strong{Tokens}: Stored in macOS Keychain (encrypted), never in files}
\li{\strong{Body Truncation}: Email bodies truncated to 2000 chars to prevent context overflow}
\li{\strong{No Credentials}: No passwords stored; OAuth2 refresh tokens only}
\li{\strong{Terminal Sanitization}: ANSI escape codes stripped from output}
}
}
}