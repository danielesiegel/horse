\subtree{
\title{Response Formats and Data Fields}
\p{\strong{Key Fields in Association Records:}}

\ul{
\li{\code{\startverb rsId\stopverb}: Variant identifier (rs number)}
\li{\code{\startverb strongestAllele\stopverb}: Risk allele for the association}
\li{\code{\startverb pvalue\stopverb}: Association p-value}
\li{\code{\startverb pvalueText\stopverb}: P-value as text (may include inequality)}
\li{\code{\startverb orPerCopyNum\stopverb}: Odds ratio or beta coefficient}
\li{\code{\startverb betaNum\stopverb}: Effect size (for quantitative traits)}
\li{\code{\startverb betaUnit\stopverb}: Unit of measurement for beta}
\li{\code{\startverb range\stopverb}: Confidence interval}
\li{\code{\startverb efoTrait\stopverb}: Associated trait name}
\li{\code{\startverb mappedLabel\stopverb}: EFO-mapped trait term}
}

\p{\strong{Study Metadata Fields:}}

\ul{
\li{\code{\startverb accessionId\stopverb}: GCST study identifier}
\li{\code{\startverb pubmedId\stopverb}: PubMed ID}
\li{\code{\startverb author\stopverb}: First author}
\li{\code{\startverb publicationDate\stopverb}: Publication date}
\li{\code{\startverb ancestryInitial\stopverb}: Discovery population ancestry}
\li{\code{\startverb ancestryReplication\stopverb}: Replication population ancestry}
\li{\code{\startverb sampleSize\stopverb}: Total sample size}
}

\p{\strong{Pagination:} Results are paginated (default 20 items per page). Navigate using:}

\ul{
\li{\code{\startverb size\stopverb} parameter: Number of results per page}
\li{\code{\startverb page\stopverb} parameter: Page number (0-indexed)}
\li{\code{\startverb _links\stopverb} in response: URLs for next/previous pages}
}
}

\subtree{
\title{Best Practices}
\subtree{
\title{Query Strategy}
\ul{
\li{Start with web interface to identify relevant EFO terms and study accessions}
\li{Use API for bulk data extraction and automated analyses}
\li{Implement pagination handling for large result sets}
\li{Cache API responses to minimize redundant requests}
}
}

\subtree{
\title{Data Interpretation}
\ul{
\li{Always check p-value thresholds (genome-wide: 5×10⁻⁸)}
\li{Review ancestry information for population applicability}
\li{Consider sample size when assessing evidence strength}
\li{Check for replication across independent studies}
\li{Be aware of winner's curse in effect size estimates}
}
}

\subtree{
\title{Rate Limiting and Ethics}
\ul{
\li{Respect API usage guidelines (no excessive requests)}
\li{Use summary statistics downloads for genome-wide analyses}
\li{Implement appropriate delays between API calls}
\li{Cache results locally when performing iterative analyses}
\li{Cite the GWAS Catalog in publications}
}
}

\subtree{
\title{Data Quality Considerations}
\ul{
\li{GWAS Catalog curates published associations (may contain inconsistencies)}
\li{Effect sizes reported as published (may need harmonization)}
\li{Some studies report conditional or joint associations}
\li{Check for study overlap when combining results}
\li{Be aware of ascertainment and selection biases}
}
}
}

\subtree{
\title{Python Integration Example}
\p{Complete workflow for querying and analyzing GWAS data:}

\pre{\startverb
import requests
import pandas as pd
from time import sleep

def query_gwas_catalog(trait_id, p_threshold=5e-8):
    """
    Query GWAS Catalog for trait associations

    Args:
        trait_id: EFO trait identifier (e.g., 'EFO_0001360')
        p_threshold: P-value threshold for filtering

    Returns:
        pandas DataFrame with association results
    """
    base_url = "https://www.ebi.ac.uk/gwas/rest/api"
    url = f"{base_url}/efoTraits/{trait_id}/associations"

    headers = {"Content-Type": "application/json"}
    results = []
    page = 0

    while True:
        params = {"page": page, "size": 100}
        response = requests.get(url, params=params, headers=headers)

        if response.status_code != 200:
            break

        data = response.json()
        associations = data.get('_embedded', {}).get('associations', [])

        if not associations:
            break

        for assoc in associations:
            pvalue = assoc.get('pvalue')
            if pvalue and float(pvalue) <= p_threshold:
                results.append({
                    'variant': assoc.get('rsId'),
                    'pvalue': pvalue,
                    'risk_allele': assoc.get('strongestAllele'),
                    'or_beta': assoc.get('orPerCopyNum') or assoc.get('betaNum'),
                    'trait': assoc.get('efoTrait'),
                    'pubmed_id': assoc.get('pubmedId')
                })

        page += 1
        sleep(0.1)  # Rate limiting

    return pd.DataFrame(results)

# Example usage
df = query_gwas_catalog('EFO_0001360')  # Type 2 diabetes
print(df.head())
print(f"\nTotal associations: {len(df)}")
print(f"Unique variants: {df['variant'].nunique()}")
\stopverb}
}

