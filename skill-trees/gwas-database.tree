\subtree{
\title{Important Notes}
\subtree{
\title{Data Updates}
\ul{
\li{The GWAS Catalog is updated regularly with new publications}
\li{Re-run queries periodically for comprehensive coverage}
\li{Summary statistics are added as studies release data}
\li{EFO mappings may be updated over time}
}
}

\subtree{
\title{Citation Requirements}
\p{When using GWAS Catalog data, cite:}

\ul{
\li{Sollis E, et al. (2023) The NHGRI-EBI GWAS Catalog: knowledgebase and deposition resource. Nucleic Acids Research. PMID: 37953337}
\li{Include access date and version when available}
\li{Cite original studies when discussing specific findings}
}
}

\subtree{
\title{Limitations}
\ul{
\li{Not all GWAS publications are included (curation criteria apply)}
\li{Full summary statistics available for subset of studies}
\li{Effect sizes may require harmonization across studies}
\li{Population diversity is growing but historically limited}
\li{Some associations represent conditional or joint effects}
}
}

\subtree{
\title{Data Access}
\ul{
\li{Web interface: Free, no registration required}
\li{REST APIs: Free, no API key needed}
\li{FTP downloads: Open access}
\li{Rate limiting applies to API (be respectful)}
}
}
}

