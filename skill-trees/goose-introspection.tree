\subtree{
\title{Key Tables}
\subtree{
\title{reafference_sessions}
\p{Tracks all sessions with discovery metadata:}

\pre{\startverb
| Column | Type | Description |
|--------|------|-------------|
| session_id | VARCHAR | Primary key, e.g., 20260108_22 |
| discovered_at | TIMESTAMP | When session was added to tracking |
| provider | VARCHAR | anthropic, openai, google, openrouter |
| model | VARCHAR | e.g., claude-opus-4-5-20251101 |
| working_dir | VARCHAR | Working directory of session |
| session_name | VARCHAR | Auto-generated or user-set name |
| original_created_at | TIMESTAMP | When session was first created |
| message_count | BIGINT | Number of messages in session |
| total_tokens | BIGINT | Total tokens used |
| is_origin_session | BOOLEAN | TRUE for the session that created this DB |
| notes | VARCHAR | Optional notes about the session |
\stopverb}
}

\subtree{
\title{reafference_metadata}
\p{Key-value store for origin information.}
}

\subtree{
\title{sessions (copied from source)}
\p{Full session data for offline queries.}
}

\subtree{
\title{messages (copied from source)}
\p{Full message history for content analysis.}
}
}

\subtree{
\title{Key Views}
\subtree{
\title{reafference_origin}
\p{Returns the session that created this database.}
}

\subtree{
\title{sessions_by_date}
\p{Aggregated daily statistics.}
}

\subtree{
\title{searchable_sessions}
\p{Join of sessions with user messages for content search.}
}
