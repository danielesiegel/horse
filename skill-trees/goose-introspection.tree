\title{Goose Introspection}

\taxon{skill}

\meta{version}{1.0.0}

\meta{trit}{0}

\meta{description}{Goose session introspection and self-discovery via DuckDB reafference database. Query past sessions, find self, and enable cross-session awareness.}

\subtree{
\title{Skill: Goose Introspection}
\p{\strong{Category}: Agent Self-Discovery | Session Analysis | Reafference Testing \strong{Level}: Core (Required for agent self-awareness) \strong{Status}: OPERATIONAL \strong{Trit Assignment}: 0 (ERGODIC) - Coordinates between past and future sessions \strong{Propagates To}: goose, amp, claude, cursor}

\subtree{
\title{Overview}
\p{Implements \strong{reafference-based self-discovery} for goose sessions. This skill enables any goose instance to:}

\ol{
\li{\strong{Find itself} in the session history}
\li{\strong{Query past sessions} for context and continuity}
\li{\strong{Track session evolution} across providers and models}
\li{\strong{Enable cross-session awareness} through DuckDB persistence}
}

\p{\strong{Core Principle}: > An agent that cannot find itself in its own history cannot truly understand its context.}
}

