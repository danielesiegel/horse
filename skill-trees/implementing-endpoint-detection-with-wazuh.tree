\title{Implementing Endpoint Detection With Wazuh}

\taxon{skill}

\tag{siem}

\tag{xdr}

\tag{wazuh}

\tag{endpoint-detection}

\tag{custom-rules}

\tag{incident-response}

\meta{version}{"1.0"}

\meta{description}{Deploy and configure Wazuh SIEM/XDR for endpoint detection including agent management, custom decoder and rule XML creation, alert querying via the Wazuh REST API, and automated response actions.}

\subtree{
\title{Implementing Endpoint Detection with Wazuh}
\subtree{
\title{Overview}
\p{Wazuh is an open-source SIEM and XDR platform for endpoint monitoring, threat detection, and compliance. This skill covers managing agents via the Wazuh REST API, creating custom decoders and rules in XML for organization-specific detections, querying alerts, and testing rule logic using the logtest endpoint.}
}

\subtree{
\title{When to Use}
\ul{
\li{When deploying or configuring implementing endpoint detection with wazuh capabilities in your environment}
\li{When establishing security controls aligned to compliance requirements}
\li{When building or improving security architecture for this domain}
\li{When conducting security assessments that require this implementation}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Wazuh Manager 4.x deployed with API enabled}
\li{Python 3.9+ with \code{\startverb requests\stopverb} library}
\li{API credentials (username/password for JWT authentication)}
\li{Understanding of Wazuh decoder and rule XML syntax}
}
}

\subtree{
\title{Steps}
\subtree{
\title{Step 1: Authenticate to Wazuh API}
\p{Obtain JWT token via POST to /security/user/authenticate.}
}

\subtree{
\title{Step 2: List and Monitor Agents}
\p{Query agent status, versions, and last keep-alive via /agents endpoint.}
}

\subtree{
\title{Step 3: Query Security Alerts}
\p{Search alerts by rule ID, severity, agent, or time range.}
}

\subtree{
\title{Step 4: Test Custom Rules with Logtest}
\p{Use the /logtest endpoint to validate decoder and rule logic against sample log lines.}
}
}

\subtree{
\title{Expected Output}
\p{JSON report with agent inventory, alert statistics, rule coverage, and logtest validation results.}
}
}