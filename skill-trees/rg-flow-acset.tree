\subtree{
\title{RG Flow Semantics}
\p{The morphism chain \code{\startverb Trace → EquivalenceClass → RGStep → FixedPoint\stopverb} implements:}

\ol{
\li{\strong{condenses_to}: Traces coarse-grain to equivalence classes (irrelevant operators drop)}
\li{\strong{transforms_via}: Equivalence classes evolve under RG transformation}
\li{\strong{flows_to}: RG steps converge to fixed points (universality)}
}
}

\subtree{
\title{GF(3) Conservation}
\p{Triadic colors sum to 0 (mod 3):}

\ul{
\li{\code{\startverb #23C8B3\stopverb} → trit 0 (identity)}
\li{\code{\startverb #AA22BE\stopverb} → trit +1 (creation)}
\li{\code{\startverb #E0CE51\stopverb} → trit -1 (annihilation)}
}

\p{Net charge: 0 + 1 + (-1) = 0 ✓}
}

\subtree{
\title{Usage}
\pre{\startverb
using ACSets

@acset_type RGFlowACSet(SchRGFlow)

# Create instance at BKT transition
rg = @acset RGFlowACSet begin
  Trace = 4
  EquivalenceClass = 2
  RGStep = 1
  FixedPoint = 1
  condenses_to = [1, 1, 2, 2]
  transforms_via = [1, 1]
  flows_to = [1]
  tau = [0.5]
  net_charge = [0]
  hue = [172.0, 292.0]
end
\stopverb}
}

