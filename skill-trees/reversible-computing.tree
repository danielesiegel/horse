| **Theseus** | Type-safe reversible |
\stopverb}
}

\subtree{
\title{Example: Reversible Fibonacci}
\pre{\startverb
procedure fib(int n, int x1, int x2)
    from x1 = 1 вҲ§ x2 = 0 do
        x1 += x2
        x1 <=> x2    // swap
        n -= 1
    until n = 0
    
// call fib(10, x1, x2)  вҶ’ x1 = 55, x2 = 89
// uncall fib(10, x1, x2) вҶ’ x1 = 1, x2 = 0
\stopverb}
}

