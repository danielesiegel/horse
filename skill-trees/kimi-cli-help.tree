\title{Kimi Cli Help}

\taxon{skill}

\meta{description}{Answer Kimi Code CLI usage, configuration, and troubleshooting questions. Use when user asks about Kimi Code CLI installation, setup, configuration, slash commands, keyboard shortcuts, MCP integration, providers, environment variables, how something works internally, or any questions about Kimi Code CLI itself.}

\subtree{
\title{Kimi Code CLI Help}
\p{Help users with Kimi Code CLI questions by consulting documentation and source code.}

\subtree{
\title{Strategy}
\ol{
\li{\strong{Prefer official documentation} for most questions}
\li{\strong{Read local source} when in kimi-cli project itself, or when user is developing with kimi-cli as a library (e.g., importing from \code{\startverb kimi_cli\stopverb} in their code)}
\li{\strong{Clone and explore source} for complex internals not covered in docs - \strong{ask user for confirmation first}}
}
}

\subtree{
\title{Documentation}
\p{Base URL: \code{\startverb https://moonshotai.github.io/kimi-cli/\stopverb}}

\p{Fetch documentation index to find relevant pages:}

\pre{\startverb
https://moonshotai.github.io/kimi-cli/llms.txt
\stopverb}

\subtree{
\title{Page URL Pattern}
\ul{
\li{English: \code{\startverb https://moonshotai.github.io/kimi-cli/en/...\stopverb}}
\li{Chinese: \code{\startverb https://moonshotai.github.io/kimi-cli/zh/...\stopverb}}
}
}

\subtree{
\title{Topic Mapping}
\pre{\startverb
| Topic | Page |
|-------|------|
| Installation, first run | `/en/guides/getting-started.md` |
| Config files | `/en/configuration/config-files.md` |
| Providers, models | `/en/configuration/providers.md` |
| Environment variables | `/en/configuration/env-vars.md` |
| Slash commands | `/en/reference/slash-commands.md` |
| CLI flags | `/en/reference/kimi-command.md` |
| Keyboard shortcuts | `/en/reference/keyboard.md` |
| MCP | `/en/customization/mcp.md` |
| Agents | `/en/customization/agents.md` |
| Skills | `/en/customization/skills.md` |
| FAQ | `/en/faq.md` |
\stopverb}
}
}

\subtree{
\title{Source Code}
\p{Repository: \code{\startverb https://github.com/MoonshotAI/kimi-cli\stopverb}}

\p{When to read source:}

\ul{
\li{In kimi-cli project directory (check \code{\startverb pyproject.toml\stopverb} for \code{\startverb name = "kimi-cli"\stopverb})}
\li{User is importing \code{\startverb kimi_cli\stopverb} as a library in their project}
\li{Question about internals not covered in docs (ask user before cloning)}
}
}
}