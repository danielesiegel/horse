\title{Analyzing Kubernetes Audit Logs}

\taxon{skill}

\tag{analyzing}

\tag{kubernetes}

\tag{audit}

\tag{logs}

\meta{version}{"1.0"}

\meta{description}{Parses Kubernetes API server audit logs (JSON lines) to detect exec-into-pod, secret access, RBAC modifications, privileged pod creation, and anonymous API access. Builds threat detection rules from audit event patterns. Use when investigating Kubernetes cluster compromise or building k8s-specific SIEM detection rules.}

\subtree{
\title{Analyzing Kubernetes Audit Logs}
\subtree{
\title{When to Use}
\ul{
\li{When investigating security incidents that require analyzing kubernetes audit logs}
\li{When building detection rules or threat hunting queries for this domain}
