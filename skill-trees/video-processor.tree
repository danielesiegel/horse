\title{Video Processor}

\taxon{skill}

\meta{description}{"Automated video processing: metadata extraction, thumbnails, transcoding, audio extraction with DuckDB tracking"}

\subtree{
\title{Video Processor Skill}
\p{\strong{Trit}: 0 (ERGODIC - pipeline coordinator) \strong{Foundation}: Babashka + FFmpeg + DuckDB}

\subtree{
\title{Overview}
\p{Automated video processing pipeline that:}

\ol{
\li{Extracts metadata via \code{\startverb ffprobe\stopverb}}
\li{Generates thumbnails at 5s mark}
\li{Transcodes to web-friendly H.264/AAC}
\li{Extracts audio as MP3}
\li{Records processing to DuckDB with Gay.jl coloring}
}
}

\subtree{
\title{When to Use}
\ul{
\li{Processing downloaded videos for analysis}
\li{Extracting frames for multimodal understanding}
\li{Preparing videos for web playback}
\li{Building searchable video metadata indexes}
\li{Automated video ingestion pipelines}
}
}

\subtree{
\title{Supported Formats}
\pre{\startverb
(def video-extensions
  #{"mp4" "mov" "mkv" "webm" "avi" "m4v" "flv" "wmv" "mpg" "mpeg"})
\stopverb}
}

\subtree{
\title{Usage}
\subtree{
\title{Process Single Video}
\pre{\startverb
bb video-processor.bb /path/to/video.mp4
\stopverb}
}

\subtree{
\title{Watch Directory}
\pre{\startverb
bb video-processor.bb /path/to/watch/dir
\stopverb}
}

\subtree{
\title{Environment Variables}
\pre{\startverb
| Variable | Default | Description |
|----------|---------|-------------|
| `VIDEO_OUTPUT_DIR` | `/tmp/processed_videos` | Output directory |
| `AMP_THREAD_ID` | `video-processor` | Session ID for DuckDB |
\stopverb}
}
}

\subtree{
\title{Pipeline Stages}
\subtree{
\title{1. Metadata Extraction}
\pre{\startverb
(defn extract-metadata [path]
  (shell {:out :string}
         "ffprobe" "-v" "quiet"
         "-print_format" "json"
         "-show_format" "-show_streams"
         path))
\stopverb}

\p{Returns JSON with duration, codec, bitrate, resolution.}
}

\subtree{
\title{2. Thumbnail Generation}
\pre{\startverb
(defn generate-thumbnail [input output]
  (shell "ffmpeg" "-y" "-i" input
         "-ss" "00:00:05" "-vframes" "1"
         "-vf" "scale=320:-1"
         output))
\stopverb}

\p{Creates 320px wide JPEG at 5 second mark.}
}

\subtree{
\title{3. Web Transcoding}
\pre{\startverb
(defn transcode-web [input output]
  (shell "ffmpeg" "-y" "-i" input
         "-c:v" "libx264" "-preset" "fast" "-crf" "23"
         "-c:a" "aac" "-b:a" "128k"
         "-movflags" "+faststart"
         output))
\stopverb}

\p{H.264/AAC with fast-start for streaming.}
}

\subtree{
\title{4. Audio Extraction}
\pre{\startverb
(defn extract-audio [input output]
  (shell "ffmpeg" "-y" "-i" input
         "-vn" "-c:a" "libmp3lame" "-q:a" "2"
         output))
\stopverb}

\p{High-quality MP3 (VBR ~190kbps).}
}

\subtree{
\title{5. DuckDB Recording}
\pre{\startverb
(defn record-processing! [path metadata outputs]
  (shell "duckdb" db-path
         (format "INSERT INTO fs_events
                  (path, event_type, size, checksum, session_id)
                  VALUES ('%s', 'video_processed', %s, '%s', '%s')"
                 path size checksum session-id)))
\stopverb}
}
}

\subtree{
\title{Output Structure}
\pre{\startverb
/tmp/processed_videos/
├── video_thumb.jpg      # Thumbnail
├── video_web.mp4        # Transcoded (if needed)
└── video_audio.mp3      # Extracted audio
\stopverb}
}

\subtree{
\title{DuckDB Schema}
\pre{\startverb
CREATE TABLE IF NOT EXISTS fs_events (
    path VARCHAR,
    event_type VARCHAR,
    size BIGINT,
    checksum VARCHAR,
    session_id VARCHAR,
    timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Query processed videos
SELECT * FROM fs_events
WHERE event_type = 'video_processed'
ORDER BY timestamp DESC;
\stopverb}
}

