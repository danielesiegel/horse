\subtree{
\title{Best Practices}
\subtree{
\title{Rate Limit Management}
\p{The API has a rate limit of approximately 50 requests per minute. For bulk data retrieval:}

\ol{
\li{Use maximum page size (1000) to minimize requests}
\li{Implement exponential backoff on rate limit errors (429 status)}
\li{Add delays between requests for large-scale data collection}
}

\pre{\startverb
import time
import requests

def search_with_rate_limit(params):
    try:
        response = requests.get("https://clinicaltrials.gov/api/v2/studies", params=params)
        response.raise_for_status()
        return response.json()
    except requests.exceptions.HTTPError as e:
        if e.response.status_code == 429:
            print("Rate limited. Waiting 60 seconds...")
            time.sleep(60)
            return search_with_rate_limit(params)  # Retry
        raise
\stopverb}
}

\subtree{
\title{Data Structure Navigation}
\p{The API response has a nested structure. Key paths to common information:}

\ul{
\li{\strong{NCT ID}: \code{\startverb study['protocolSection']['identificationModule']['nctId']\stopverb}}
\li{\strong{Title}: \code{\startverb study['protocolSection']['identificationModule']['briefTitle']\stopverb}}
\li{\strong{Status}: \code{\startverb study['protocolSection']['statusModule']['overallStatus']\stopverb}}
\li{\strong{Phase}: \code{\startverb study['protocolSection']['designModule']['phases']\stopverb}}
\li{\strong{Eligibility}: \code{\startverb study['protocolSection']['eligibilityModule']\stopverb}}
\li{\strong{Locations}: \code{\startverb study['protocolSection']['contactsLocationsModule']['locations']\stopverb}}
\li{\strong{Interventions}: \code{\startverb study['protocolSection']['armsInterventionsModule']['interventions']\stopverb}}
}
}

\subtree{
\title{Error Handling}
\p{Always implement proper error handling for network requests:}

\pre{\startverb
import requests

try:
    response = requests.get(url, params=params, timeout=30)
    response.raise_for_status()
    data = response.json()
except requests.exceptions.HTTPError as e:
    print(f"HTTP error: {e.response.status_code}")
except requests.exceptions.RequestException as e:
    print(f"Request failed: {e}")
except ValueError as e:
    print(f"JSON decode error: {e}")
\stopverb}
}

\subtree{
\title{Handling Missing Data}
\p{Not all trials have complete information. Always check for field existence:}

\pre{\startverb
# Safe navigation with .get()
phases = study['protocolSection'].get('designModule', {}).get('phases', [])
enrollment = study['protocolSection'].get('designModule', {}).get('enrollmentInfo', {}).get('count', 'N/A')

# Check before accessing
if 'resultsSection' in study:
    # Process results
    pass
\stopverb}
}
}

\subtree{
\title{Technical Specifications}
\ul{
\li{\strong{Base URL}: \code{\startverb https://clinicaltrials.gov/api/v2\stopverb}}
\li{\strong{Authentication}: Not required (public API)}
\li{\strong{Rate Limit}: ~50 requests/minute per IP}
\li{\strong{Response Formats}: JSON (default), CSV}
\li{\strong{Max Page Size}: 1000 studies per request}
\li{\strong{Date Format}: ISO 8601}
\li{\strong{Text Format}: CommonMark Markdown for rich text fields}
\li{\strong{API Version}: 2.0 (released March 2024)}
\li{\strong{API Specification}: OpenAPI 3.0}
}

\p{For complete technical details, see \code{\startverb references/api_reference.md\stopverb}.}
}
}