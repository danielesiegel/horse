\stopverb}
}

\subtree{
\title{Block-STM Compatibility}
\p{WEV is designed for Aptos Block-STM:}

\ul{
\li{Speculative parallel execution}
\li{Automatic conflict detection}
\li{Deterministic final state regardless of execution order}
}
}

