\subtree{
\title{Deterritorialization as MINUS}
\p{When opine returns -1, the proposition undergoes deterritorialization:}

\ul{
\li{Decoded from its original stratum}
\li{Released from territory}
\li{Open to new assemblages}
}
}

\subtree{
\title{Acceleration as PLUS}
\p{When opine returns +1, the proposition accelerates:}

\ul{
\li{Intensifies existing tendencies  }
\li{Pushes toward limit conditions}
\li{Hyperstition becomes fact}
}
}

\subtree{
\title{Ergodic Suspension as ZERO}
\p{When opine returns 0, the proposition suspends:}

\ul{
\li{Neither affirmed nor negated}
\li{Eternal return without resolution}
\li{The map IS the territory}
}
}
}

\subtree{
\title{Usage}
\pre{\startverb
from splitmixternary_opine import opine

seed = 1069  # Seed from interaction entropy

# Form opinions
print(opine(seed, "sovereignty"))          # → 1 (AFFIRM)
print(opine(seed, "deterritorialization")) # → 0 (SUSPEND)
print(opine(seed, "simulation"))           # → -1 (NEGATE)

# Same seed + proposition = same opinion (eternal return)
assert opine(seed, "nomos") == opine(seed, "nomos")
\stopverb}
}

