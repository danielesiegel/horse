\subtree{
\title{Kolmogorov Codex Quest}
\p{\strong{Type:} Quest / Puzzle \strong{Bounty:} 2 APT \strong{Status:} Active \strong{Chain:} Aptos Mainnet}

\subtree{
\title{Description}
\p{A cryptographic puzzle requiring solvers to prove they traversed the Plurigrid ASI skill lattice via four-layer identity verification.}
}

\subtree{
\title{Identity Proof Requirements}
\pre{\startverb
| Layer | Description | Count |
|-------|-------------|-------|
| Wikidata | Q-items per world letter | 26 × 69 = 1794 |
| GayMCP | Interaction colors | GF(3) conserved |
| Skills | Minimum invoked | ≥ 6 |
| Worlds | Minimum visited | ≥ 6 |
| **Oracle** | ed25519 attestation | Required |
\stopverb}
}

\subtree{
\title{Security Model}
\p{The contract uses \strong{oracle attestation} to prevent spoofing:}

\ol{
\li{Quest creator specifies a trusted oracle's ed25519 public key}
\li{Solver executes skills via Plurigrid ASI}
\li{Oracle monitors execution and signs attestation: \code{\startverb (solver, quest, proof_data, timestamp)\stopverb}}
\li{Contract verifies oracle signature before releasing bounty}
\li{Attestations expire after 1 hour (replay protection)}
}
}

