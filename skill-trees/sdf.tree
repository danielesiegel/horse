\subtree{
\title{Combinator as Polynomial Functor}
\p{Each SDF combinator corresponds to a polynomial functor operation:}

\ul{
\li{\code{\startverb compose\stopverb} → functor composition}
\li{\code{\startverb parallel-combine\stopverb} → product}
\li{\code{\startverb spread-combine\stopverb} → coproduct + product}
}
}

