\subtree{
\title{Chapter 4: Pattern Matching (+1)}
\ul{
\li{Unification as composition}
\li{Segment variables and pattern operators}
\li{Match combinators}
}

\pre{\startverb
(define (match:element variable)
  (lambda (data dictionary succeed)
    (let ((binding (assq variable dictionary)))
      (if binding
          (and (equal? (cdr binding) data)
               (succeed dictionary))
          (succeed (cons (cons variable data)
                        dictionary))))))
\stopverb}
}

