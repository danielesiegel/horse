\subtree{
\title{Part IV: Flexibility through Abstraction [ERGODIC]}
\subtree{
\title{Chapter 9: Generic Procedures (0)}
\ul{
\li{Multi-method dispatch}
\li{Predicate dispatch}
\li{Inheritance vs composition}
}

\pre{\startverb
(define generic-+
  (simple-generic-procedure '+ 2
    (lambda (a b)
      (error "No method for +" a b))))

(define-generic-procedure-handler generic-+
  (match-args number? number?)
  +)

(define-generic-procedure-handler generic-+
  (match-args symbol? symbol?)
  (lambda (a b) `(+ ,a ,b)))
\stopverb}
}

