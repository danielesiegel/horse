\title{Sdf}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{"Software Design for Flexibility: Sussman & Hanson's additive programming, combinators, propagators, and generic dispatch for evolvable systems"}

\subtree{
\title{SDF Skill: Software Design for Flexibility}
\blockquote{*"It is better to have 100 functions operate on one data structure than 10 functions on 10 data structures."* — Alan Perlis (via Sussman & Hanson)}

\p{Geometric morphism from the MIT Press 2021 text, preserving the compositional structure as an ACSet with GF(3) coloring for trifurcated processing.}

\subtree{
\title{Overview}
\p{\strong{Software Design for Flexibility} by Chris Hanson and Gerald Jay Sussman MIT Press, 2021 ISBN: 978-0262045490}

\p{The successor to SICP focused on \strong{additive programming}—building systems that can evolve by adding new capabilities without modifying existing code.}
}

\subtree{
\title{Core Principles}
\subtree{
\title{The Flexibility Mandate}
\ol{
\li{\strong{Additive over Modificative}: New features via addition, not mutation}
\li{\strong{Generic over Specific}: Operations that work across types}
\li{\strong{Compositional over Monolithic}: Small combinable pieces}
\li{\strong{Declarative over Imperative}: Constraints over control flow}
}
}
}

