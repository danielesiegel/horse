\subtree{
\title{Part III: Flexibility through Modularity [PLUS]}
\subtree{
\title{Chapter 6: Layering (+1)}
\ul{
\li{Layered data with metadata}
\li{Provenance tracking}
\li{Units and dimensions}
}

\pre{\startverb
(define (make-layered-datum base-value . layers)
  (cons base-value layers))

(define (layered-datum-value datum)
  (car datum))

(define (layered-datum-layers datum)
  (cdr datum))
\stopverb}
}

\subtree{
\title{Chapter 7: Propagators (0)}
\ul{
\li{Bidirectional constraint networks}
\li{Cells and propagators}
\li{Partial information lattices}
\li{Truth Maintenance Systems (TMS)}
}

\p{\strong{The Propagator Model:}}

\pre{\startverb
     ┌─────────┐
     │  Cell   │ ← Accumulates partial information
     └────┬────┘
          │ (neighbors)
    ┌─────┼─────┐
    ▼     ▼     ▼
┌──────┐┌──────┐┌──────┐
│Prop A││Prop B││Prop C│  ← Transform information
└──────┘└──────┘└──────┘
\stopverb}

\p{Key insight: \strong{Information flows bidirectionally}. A cell for \code{\startverb x²=4\stopverb} can deduce \code{\startverb x=±2\stopverb} OR given \code{\startverb x=2\stopverb}, confirm the equation.}
}

