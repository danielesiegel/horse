\title{Svelte Runes}

\taxon{skill}

\meta{description}{Svelte runes guidance. Use for reactive state, props, effects, or migration. Covers $state, $derived, $effect, $props, $bindable. Prevents reactivity mistakes.}

\subtree{
\title{Svelte Runes}
\subtree{
\title{Quick Start}
\p{\strong{Which rune?} Props: \code{\startverb $props()\stopverb} | Bindable: \code{\startverb $bindable()\stopverb} | Computed: \code{\startverb $derived()\stopverb} | Side effect: \code{\startverb $effect()\stopverb} | State: \code{\startverb $state()\stopverb}}

\p{\strong{Key rules:} Runes are top-level only. $derived can be overridden (use \code{\startverb const\stopverb} for read-only). Don't mix Svelte 4/5 syntax. Objects/arrays are deeply reactive by default.}
}

\subtree{
\title{Example}
\pre{\startverb
<script>
	let count = $state(0); // Mutable state
	const doubled = $derived(count * 2); // Computed (const = read-only)

	$effect(() => {
		console.log(`Count is ${count}`); // Side effect
	});
</script>

<button onclick={() => count++}>
	{count} (doubled: {doubled})
</button>
\stopverb}
}

\subtree{
\title{Reference Files}
