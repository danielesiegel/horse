}

\blockquote{For \code{\startverb @attach\stopverb} and other template directives, see the \strong{svelte-template-directives} skill.}
}

\subtree{
\title{Notes}
\ul{
\li{Use \code{\startverb onclick\stopverb} not \code{\startverb on:click\stopverb}, \code{\startverb {@render children()}\stopverb} in layouts}
\li{\code{\startverb $derived\stopverb} can be reassigned (5.25+) - use \code{\startverb const\stopverb} for read-only}
\li{\strong{Last verified:} 2025-01-11}
}

