\subtree{
\title{Pipeline}
\p{All scripts live in \code{\startverb ~/worlds/n/\stopverb}:}

\pre{\startverb
# Generate flashcards from a single notebook
hy n/nblm_flashcards.hy --notebook-id <UUID> --per-source 10 --batch-size 5

# Backfill: create notebooks for uncovered repos
bb n/nblm_backfill.bb              # create + add sources
bb n/nblm_backfill.bb --status     # check ingestion
bb n/nblm_backfill.bb --generate   # generate flashcards per notebook

# Merge all decks
bb n/nblm_merge.bb

# Drill in Emacs
emacs -nw --load ~/worlds/n/nblm-drill.el
# M-x nblm-drill-all    (full merged deck)
# M-x nblm-drill-repo   (filter by org/repo)
\stopverb}
}

\subtree{
\title{Key Parameters}
\pre{\startverb
| Arg | Default | What |
|-----|---------|------|
| `--per-source` | 10 | Flashcards per notebook source |
| `--batch-size` | 5 | Sources per Gemini call (50 cards/call sweet spot) |
| `--difficulty` | hard | easy / medium / hard |
| `--model` | gemini-2.5-flash | Vertex AI model |
\stopverb}
}

\subtree{
\title{Architecture}
\ul{
\li{Token auto-refreshes every 30 min (gcloud tokens expire at 1hr)}
\li{Truncated JSON repaired by finding last complete \code{\startverb }\stopverb} and closing array}
\li{Discovery Engine \code{\startverb v1alpha\stopverb} for notebook source listing}
\li{Gemini via Vertex AI REST (\code{\startverb generateContent\stopverb}), region \code{\startverb us-central1\stopverb}}
\li{\code{\startverb maxOutputTokens: 65536\stopverb}, \code{\startverb temperature: 0.7\stopverb}}
\li{GCP project: \code{\startverb merovingians\stopverb} (302712368086)}
}
}

