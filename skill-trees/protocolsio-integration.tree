\subtree{
\title{Troubleshooting}
\p{\strong{Authentication Issues:}}

\ul{
\li{Verify token is valid and not expired}
\li{Check Authorization header format: \code{\startverb Bearer YOUR_TOKEN\stopverb}}
\li{Ensure appropriate token type (CLIENT vs OAUTH)}
}

\p{\strong{Rate Limiting:}}

\ul{
\li{Implement exponential backoff for 429 errors}
\li{Monitor request frequency}
\li{Consider caching frequent requests}
}

\p{\strong{Permission Errors:}}

\ul{
\li{Verify workspace/protocol access permissions}
\li{Check user role in workspace}
\li{Ensure protocol is not private if accessing without permission}
}

\p{\strong{File Upload Failures:}}

\ul{
\li{Check file size against workspace limits}
\li{Verify file type is supported}
\li{Ensure multipart/form-data encoding is correct}
}

\p{For detailed troubleshooting guidance, refer to the specific reference files covering each capability area.}
}
}