\subtree{
\title{Getting Started}
\subtree{
\title{Step 1: Authentication Setup}
\p{Before using any protocols.io API functionality:}

\ol{
\li{Obtain an access token (CLIENT_ACCESS_TOKEN or OAUTH_ACCESS_TOKEN)}
\li{Read \code{\startverb references/authentication.md\stopverb} for detailed authentication procedures}
\li{Store the token securely}
\li{Include in all requests as: \code{\startverb Authorization: Bearer YOUR_TOKEN\stopverb}}
}
}

\subtree{
\title{Step 2: Identify Your Use Case}
\p{Determine which capability area addresses your needs:}

\ul{
\li{\strong{Working with protocols?} → Read \code{\startverb references/protocols_api.md\stopverb}}
\li{\strong{Managing team protocols?} → Read \code{\startverb references/workspaces.md\stopverb}}
\li{\strong{Handling comments/feedback?} → Read \code{\startverb references/discussions.md\stopverb}}
\li{\strong{Uploading files/data?} → Read \code{\startverb references/file_manager.md\stopverb}}
\li{\strong{Tracking experiments or profiles?} → Read \code{\startverb references/additional_features.md\stopverb}}
}
}

\subtree{
\title{Step 3: Implement Integration}
\p{Follow the guidance in the relevant reference files:}

\ul{
\li{Each reference includes detailed endpoint documentation}
\li{API parameters and request/response formats are specified}
\li{Common use cases and workflows are provided with examples}
\li{Best practices and error handling guidance included}
}
}
}

\subtree{
\title{Base URL and Request Format}
\p{All API requests use the base URL:}

\pre{\startverb
https://protocols.io/api/v3
\stopverb}

\p{All requests require the Authorization header:}

\pre{\startverb
Authorization: Bearer YOUR_ACCESS_TOKEN
\stopverb}

\p{Most endpoints support JSON request/response format with \code{\startverb Content-Type: application/json\stopverb}.}
}

\subtree{
\title{Content Format Options}
\p{Many endpoints support a \code{\startverb content_format\stopverb} parameter to control how protocol content is returned:}

\ul{
\li{\code{\startverb json\stopverb}: Draft.js JSON format (default)}
\li{\code{\startverb html\stopverb}: HTML format}
\li{\code{\startverb markdown\stopverb}: Markdown format}
}

\p{Include as query parameter: \code{\startverb ?content_format=html\stopverb}}
}

\subtree{
\title{Rate Limiting}
\p{Be aware of API rate limits:}

\ul{
\li{\strong{Standard endpoints}: 100 requests per minute per user}
\li{\strong{PDF endpoint}: 5 requests/minute (signed-in), 3 requests/minute (unsigned)}
}

\p{Implement exponential backoff for rate limit errors (HTTP 429).}
}

\subtree{
\title{Common Workflows}
\subtree{
\title{Workflow 1: Import and Analyze Protocol}
\p{To analyze an existing protocol from protocols.io:}

\ol{
\li{\strong{Search}: Use \code{\startverb GET /protocols\stopverb} with keywords to find relevant protocols}
\li{\strong{Retrieve}: Get full details with \code{\startverb GET /protocols/{protocol_id}\stopverb}}
\li{\strong{Extract}: Parse steps, materials, and metadata for analysis}
\li{\strong{Review discussions}: Check \code{\startverb GET /protocols/{id}/comments\stopverb} for user feedback}
\li{\strong{Export}: Generate PDF if needed for offline reference}
}

\p{\strong{Reference files}: \code{\startverb protocols_api.md\stopverb}, \code{\startverb discussions.md\stopverb}}
}

\subtree{
\title{Workflow 2: Create and Publish Protocol}
\p{To create a new protocol and publish with DOI:}

\ol{
\li{\strong{Authenticate}: Ensure you have valid access token (see \code{\startverb authentication.md\stopverb})}
\li{\strong{Create}: Use \code{\startverb POST /protocols\stopverb} with title and description}
\li{\strong{Add steps}: For each step, use \code{\startverb POST /protocols/{id}/steps\stopverb}}
\li{\strong{Add materials}: Document reagents in step components}
\li{\strong{Review}: Verify all content is complete and accurate}
\li{\strong{Publish}: Issue DOI with \code{\startverb POST /protocols/{id}/publish\stopverb}}
}

\p{\strong{Reference files}: \code{\startverb protocols_api.md\stopverb}, \code{\startverb authentication.md\stopverb}}
}

\subtree{
\title{Workflow 3: Collaborative Lab Workspace}
\p{To set up team protocol management:}

\ol{
\li{\strong{Create/join workspace}: Access or request workspace membership (see \code{\startverb workspaces.md\stopverb})}
\li{\strong{Organize structure}: Create folder hierarchy for lab protocols (see \code{\startverb file_manager.md\stopverb})}
\li{\strong{Create protocols}: Use \code{\startverb POST /workspaces/{id}/protocols\stopverb} for team protocols}
\li{\strong{Upload files}: Add experimental data and images}
\li{\strong{Enable discussions}: Team members can comment and provide feedback}
\li{\strong{Track experiments}: Document protocol executions with experiment records}
}

\p{\strong{Reference files}: \code{\startverb workspaces.md\stopverb}, \code{\startverb file_manager.md\stopverb}, \code{\startverb protocols_api.md\stopverb}, \code{\startverb discussions.md\stopverb}, \code{\startverb additional_features.md\stopverb}}
}

\subtree{
\title{Workflow 4: Experiment Documentation}
\p{To track protocol executions and results:}

\ol{
\li{\strong{Execute protocol}: Perform protocol in laboratory}
\li{\strong{Upload data}: Use File Manager API to upload results (see \code{\startverb file_manager.md\stopverb})}
\li{\strong{Create record}: Document execution with \code{\startverb POST /protocols/{id}/runs\stopverb}}
\li{\strong{Link files}: Reference uploaded data files in experiment record}
\li{\strong{Note modifications}: Document any protocol deviations or optimizations}
\li{\strong{Analyze}: Review multiple runs for reproducibility assessment}
}

\p{\strong{Reference files}: \code{\startverb additional_features.md\stopverb}, \code{\startverb file_manager.md\stopverb}, \code{\startverb protocols_api.md\stopverb}}
}

\subtree{
\title{Workflow 5: Protocol Discovery and Citation}
\p{To find and cite protocols in research:}

\ol{
\li{\strong{Search}: Query published protocols with \code{\startverb GET /publications\stopverb}}
\li{\strong{Filter}: Use category and keyword filters for relevant protocols}
\li{\strong{Review}: Read protocol details and community comments}
\li{\strong{Bookmark}: Save useful protocols with \code{\startverb POST /protocols/{id}/bookmarks\stopverb}}
\li{\strong{Cite}: Use protocol DOI in publications (proper attribution)}
\li{\strong{Export PDF}: Generate formatted PDF for offline reference}
}

\p{\strong{Reference files}: \code{\startverb protocols_api.md\stopverb}, \code{\startverb additional_features.md\stopverb}}
}
}

\subtree{
\title{Python Request Examples}
\subtree{
\title{Basic Protocol Search}
\pre{\startverb
import requests

token = "YOUR_ACCESS_TOKEN"
headers = {"Authorization": f"Bearer {token}"}

# Search for CRISPR protocols
response = requests.get(
    "https://protocols.io/api/v3/protocols",
    headers=headers,
    params={
        "filter": "public",
        "key": "CRISPR",
        "page_size": 10,
        "content_format": "html"
    }
)

protocols = response.json()
for protocol in protocols["items"]:
    print(f"{protocol['title']} - {protocol['doi']}")
\stopverb}
}

\subtree{
\title{Create New Protocol}
\pre{\startverb
import requests

token = "YOUR_ACCESS_TOKEN"
headers = {
    "Authorization": f"Bearer {token}",
    "Content-Type": "application/json"
}

# Create protocol
data = {
    "title": "CRISPR-Cas9 Gene Editing Protocol",
    "description": "Comprehensive protocol for CRISPR gene editing",
    "tags": ["CRISPR", "gene editing", "molecular biology"]
}

response = requests.post(
    "https://protocols.io/api/v3/protocols",
    headers=headers,
    json=data
)

protocol_id = response.json()["item"]["id"]
print(f"Created protocol: {protocol_id}")
\stopverb}
}

\subtree{
\title{Upload File to Workspace}
\pre{\startverb
import requests

token = "YOUR_ACCESS_TOKEN"
headers = {"Authorization": f"Bearer {token}"}

# Upload file
with open("data.csv", "rb") as f:
    files = {"file": f}
    data = {
        "folder_id": "root",
        "description": "Experimental results",
        "tags": "experiment,data,2025"
    }

    response = requests.post(
        "https://protocols.io/api/v3/workspaces/12345/files/upload",
        headers=headers,
        files=files,
        data=data
    )

file_id = response.json()["item"]["id"]
print(f"Uploaded file: {file_id}")
\stopverb}
}
}

\subtree{
\title{Error Handling}
\p{Implement robust error handling for API requests:}

\pre{\startverb
import requests
import time

def make_request_with_retry(url, headers, max_retries=3):
    for attempt in range(max_retries):
        try:
            response = requests.get(url, headers=headers)

            if response.status_code == 200:
                return response.json()
            elif response.status_code == 429:  # Rate limit
                retry_after = int(response.headers.get('Retry-After', 60))
                time.sleep(retry_after)
                continue
            elif response.status_code >= 500:  # Server error
                time.sleep(2 ** attempt)  # Exponential backoff
                continue
            else:
                response.raise_for_status()

        except requests.exceptions.RequestException as e:
            if attempt == max_retries - 1:
                raise
            time.sleep(2 ** attempt)

    raise Exception("Max retries exceeded")
\stopverb}
}

