\subtree{
\title{Best Practices}
\subtree{
\title{1. Clear and Specific Prompts}
\p{\strong{Good:}}

\pre{\startverb
"Analyze authentication.js for SQL injection vulnerabilities"
\stopverb}

\p{\strong{Avoid:}}

\pre{\startverb
"Check security"
\stopverb}
}

\subtree{
\title{2. Logical Progression}
\p{Order prompts to build on previous outputs:}

\pre{\startverb
1. "Identify the problem"
2. "Analyze root causes"
3. "Design solution"
4. "Implement solution"
5. "Verify implementation"
\stopverb}
}

\subtree{
\title{3. Appropriate Timeouts}
\ul{
\li{Simple tasks: 30 seconds (default)}
\li{Analysis tasks: 45-60 seconds}
\li{Implementation tasks: 60-90 seconds}
\li{Complex workflows: 90-120 seconds}
}
}

\subtree{
\title{4. Verification Steps}
\p{Include validation in your chains:}

\pre{\startverb
claude-flow stream-chain run \
  "Implement feature X" \
  "Write tests for feature X" \
  "Verify tests pass and cover edge cases"
\stopverb}
}

\subtree{
\title{5. Iterative Refinement}
\p{Use chains for iterative improvement:}

\pre{\startverb
claude-flow stream-chain run \
  "Generate initial implementation" \
  "Review and identify issues" \
  "Refine based on issues found" \
  "Final quality check"
\stopverb}
}
}

\subtree{
\title{Integration with Claude Flow}
\subtree{
\title{Combine with Swarm Coordination}
\pre{\startverb
# Initialize swarm for coordination
claude-flow swarm init --topology mesh

# Execute stream chain with swarm agents
claude-flow stream-chain run \
  "Agent 1: Research task" \
  "Agent 2: Implement solution" \
  "Agent 3: Test implementation" \
  "Agent 4: Review and refine"
\stopverb}
}

\subtree{
\title{Memory Integration}
\p{Stream chains automatically store context in memory for cross-session persistence:}

\pre{\startverb
# Execute chain with memory
claude-flow stream-chain run \
  "Analyze requirements" \
  "Design architecture" \
  --verbose

# Results stored in .claude-flow/memory/stream-chain/
\stopverb}
}

\subtree{
\title{Neural Pattern Training}
\p{Successful chains train neural patterns for improved performance:}

\pre{\startverb
# Enable neural training
claude-flow stream-chain pipeline optimize --debug

# Patterns learned and stored for future optimizations
\stopverb}
}
}

\subtree{
\title{Troubleshooting}
\subtree{
\title{Chain Timeout}
\p{If steps timeout, increase timeout value:}

\pre{\startverb
claude-flow stream-chain run "complex task" --timeout 120
\stopverb}
}

\subtree{
\title{Context Loss}
\p{If context not flowing properly, use \code{\startverb --debug\stopverb}:}

\pre{\startverb
claude-flow stream-chain run "step 1" "step 2" --debug
\stopverb}
}

\subtree{
\title{Pipeline Not Found}
\p{Verify pipeline name and custom definitions:}

\pre{\startverb
# Check available pipelines
cat .claude-flow/config.json | grep -A 10 "streamChain"
\stopverb}
}
}

\subtree{
\title{Performance Characteristics}
\ul{
\li{\strong{Throughput}: 2-5 steps per minute (varies by complexity)}
\li{\strong{Context Size}: Up to 100K tokens per step}
\li{\strong{Memory Usage}: ~50MB per active chain}
\li{\strong{Concurrency}: Supports parallel chain execution}
}
}

