\meta{version}{"1.0"}

\meta{description}{Perform GCP security testing using GCPBucketBrute for storage bucket enumeration, gcloud IAM privilege escalation path analysis, and service account permission auditing}

\subtree{
\title{Performing GCP Penetration Testing with GCPBucketBrute}
\subtree{
\title{Overview}
\p{This skill covers Google Cloud Platform security testing using GCPBucketBrute for storage bucket enumeration and access permission testing, combined with gcloud CLI IAM enumeration to identify privilege escalation paths. The approach tests for publicly accessible buckets, overly permissive IAM bindings, and service account key exposure.}
}

\subtree{
\title{When to Use}
\ul{
\li{When conducting security assessments that involve performing gcp penetration testing with gcpbucketbrute}
\li{When following incident response procedures for related security events}
\li{When performing scheduled security testing or auditing activities}
\li{When validating security controls through hands-on testing}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Python 3.8+ with google-cloud-storage library}
\li{GCPBucketBrute installed from RhinoSecurityLabs GitHub}
\li{gcloud CLI authenticated with test credentials}
\li{Authorized penetration testing scope for target GCP project}
\li{google-api-python-client and google-auth libraries}
}
}

\subtree{
\title{Steps}
\ol{
\li{\strong{Enumerate Storage Buckets} — Use GCPBucketBrute with keyword permutations to discover accessible GCP storage buckets}
\li{\strong{Test Bucket Permissions} — Call TestIamPermissions API on each discovered bucket to determine read/write/admin access levels}
\li{\strong{Audit IAM Bindings} — Enumerate project-level IAM policies to identify overly permissive role bindings}
\li{\strong{Check Service Account Keys} — Identify service accounts with user-managed keys and test for privilege escalation via impersonation}
\li{\strong{Test Privilege Escalation Paths} — Check for iam.serviceAccounts.actAs, setIamPolicy, and other privilege escalation vectors}
\li{\strong{Generate Findings Report} — Produce a structured security assessment with risk severity ratings}
}
}

\subtree{
\title{Expected Output}
\ul{
\li{JSON report of discovered buckets with permission levels}
\li{IAM privilege escalation path analysis}
\li{Service account security assessment}
\li{Risk-scored findings with remediation recommendations}
}
}
}