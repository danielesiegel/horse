\title{Captp}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{'CapTP: Capability Transfer Protocol'}

\subtree{
\title{CapTP: Capability Transfer Protocol}
\p{\strong{Trit}: 0 (ERGODIC - transports capabilities without amplification) \strong{Color}: #46F27F (Coordinator stream) \strong{Source}: Spritely Goblins (codeberg.org/spritely/goblins)}

\subtree{
\title{Overview}
\p{CapTP (Capability Transfer Protocol) enables distributed object programming with capability security. Objects can live anywhere on the network; CapTP abstracts location so programmers focus on object interaction, not protocol architecture.}

\p{\strong{Core principle}: Capabilities are unforgeable references. You can only invoke what you've been given.}
}

\subtree{
\title{Key Concepts}
\subtree{
\title{Vats (Actor Containers)}
\pre{\startverb
;; Guile Goblins
(define vat (spawn-vat))
(define greeter (vat-spawn vat ^greeter))
\stopverb}

\pre{\startverb
| Concept | Description | Trit Mapping |
|---------|-------------|--------------|
| **Vat** | Transactional actor container | 0 (ergodic boundary) |
| **Actor** | Encapsulated object with behavior | +1 (generative) |
| **Capability** | Unforgeable reference | -1 (constraining) |
\stopverb}
}

\subtree{
\title{Promise Pipelining}
\pre{\startverb
;; Don't wait for result - pipeline through promises
(<- (<- alice 'get-friend) 'greet "Hello")
\stopverb}

\p{Reduces round-trips: send message to promise, network resolves.}
}

\subtree{
\title{Sturdy vs Live References}
\pre{\startverb
| Reference | Persistence | Use Case |
|-----------|-------------|----------|
| **Live** | Session only | Active communication |
| **Sturdy** | Survives restart | Reconnection, storage |
\stopverb}
}
}

\subtree{
\title{CapTP Message Types}
\pre{\startverb
op:deliver-only  → Fire-and-forget message
op:deliver       → Message expecting response
op:pick          → Select from multiple promises
op:abort         → Cancel pending operation
op:listen        → Subscribe to updates
op:gc            → Garbage collection hint
\stopverb}
}

