\subtree{
\title{Installation}
\pre{\startverb
uv pip install scvi-tools
# For GPU support
uv pip install scvi-tools[cuda]
\stopverb}
}

\subtree{
\title{Best Practices}
\ol{
\li{\strong{Use raw counts}: Always provide unnormalized count data to models}
\li{\strong{Filter genes}: Remove low-count genes before analysis (e.g., \code{\startverb min_counts=3\stopverb})}
\li{\strong{Register covariates}: Include known technical factors (batch, donor, etc.) in \code{\startverb setup_anndata\stopverb}}
\li{\strong{Feature selection}: Use highly variable genes for improved performance}
\li{\strong{Model saving}: Always save trained models to avoid retraining}
\li{\strong{GPU usage}: Enable GPU acceleration for large datasets (\code{\startverb accelerator="gpu"\stopverb})}
\li{\strong{Scanpy integration}: Store outputs in AnnData objects for downstream analysis}
}
}
}