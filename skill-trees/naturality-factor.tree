\subtree{
\title{Mathematical Foundation}
\subtree{
\title{Defect Calculation}
\p{For transformation η with conservation law C:}

\pre{\startverb
defect = C.combine(charge(left_path), -charge(right_path))
factor = defect == identity ? 1.0 : 1.0 / (1.0 + |defect|)
\stopverb}
}

\subtree{
\title{Conservation Laws Supported}
\pre{\startverb
| Law | Modulus | Use Case |
|-----|---------|----------|
| GF(3) | 3 | Trit balance |
| Chromatic | 12 | Pitch classes |
| Diatonic | 7 | Scale degrees |
| Parity | 2 | XOR operations |
| Integer | ∞ | Unbounded |
\stopverb}
}
}

