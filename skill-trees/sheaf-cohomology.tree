\subtree{
\title{Mathematical Foundation}
\subtree{
\title{Čech Complex}
\pre{\startverb
C⁰ = ∏_i F(U_i)
C¹ = ∏_{i<j} F(U_i ∩ U_j)
C² = ∏_{i<j<k} F(U_i ∩ U_j ∩ U_k)
\stopverb}
}

\subtree{
\title{Differential Maps}
\pre{\startverb
d⁰: C⁰ → C¹:  (d⁰s)_{ij} = s_j|_{U_ij} - s_i|_{U_ij}
d¹: C¹ → C²:  (d¹g)_{ijk} = g_jk - g_ik + g_ij
\stopverb}
}

\subtree{
\title{Cocycle Condition}
\pre{\startverb
g ∈ Z¹(U, F) ⟺ d¹g = 0 ⟺ g_ij + g_jk = g_ik on triple overlaps
\stopverb}
}
}

