\title{Sheaf Cohomology}

\taxon{skill}

\meta{description}{Čech cohomology for local-to-global consistency verification in code}

\subtree{
\title{Sheaf Cohomology Skill: Local-to-Global Verification}
\p{\strong{Status}: ✅ Production Ready \strong{Trit}: -1 (MINUS - validator/constraint) \strong{Color}: #2626D8 (Blue) \strong{Principle}: Local consistency → Global correctness \strong{Frame}: Čech cohomology with descent conditions}

\subtree{
\title{Overview}
\p{\strong{Sheaf Cohomology} validates that locally consistent data/code patches glue correctly into globally consistent structures. Uses:}

\ol{
\li{\strong{Čech cohomology}: H^n(U, F) obstruction classes}
\li{\strong{Nerve of coverage}: N(U) simplicial complex from open cover}
\li{\strong{Descent conditions}: Cocycle conditions for morphisms}
\li{\strong{tree-sitter integration}: AST-level local consistency}
}

\p{\strong{Correct by construction}: If local patches satisfy cocycle conditions, global structure is guaranteed.}
}

\subtree{
\title{Core Formula}
\pre{\startverb
H⁰(U, F) = ker(d⁰)           # Global sections (agree everywhere)
H¹(U, F) = ker(d¹)/im(d⁰)    # Obstruction to gluing
H²(U, F) = ker(d²)/im(d¹)    # Higher obstructions
\stopverb}

\p{For code verification:}

\pre{\startverb
# Three patches (files/modules) are consistent iff:
# On U_ij ∩ U_jk ∩ U_ik: g_ij ∘ g_jk = g_ik  (cocycle condition)

cocycle_satisfied?(patch_i, patch_j, patch_k)
  == (compose(g_ij, g_jk) == g_ik)
\stopverb}
}

\subtree{
\title{Why Sheaf Cohomology for Code?}
\ol{
\li{\strong{Module boundaries}: Each module is an "open set"}
\li{\strong{Import/export}: Transition functions between patches}
\li{\strong{Type consistency}: Cocycle = type compatibility}
\li{\strong{Refactoring safety}: H¹ = 0 means safe global transform}
}
}

\subtree{
\title{Gadgets}
\subtree{
\title{1. ČechCoverVerifier}
\p{Verify local consistency across code patches:}

\pre{\startverb
verifier = SheafCohomology::CechCoverVerifier.new(
  coverage: [:module_a, :module_b, :module_c]
)
verifier.add_transition(:module_a, :module_b, transition_ab)
verifier.add_transition(:module_b, :module_c, transition_bc)
verifier.add_transition(:module_a, :module_c, transition_ac)

verifier.cocycle_satisfied?  # => true if g_ab ∘ g_bc = g_ac
verifier.h1_obstruction      # => 0 if globally consistent
\stopverb}
}

\subtree{
\title{2. NerveConstructor}
\p{Build simplicial complex from coverage:}

\pre{\startverb
nerve = SheafCohomology::NerveConstructor.new(
  opens: file_modules,
  intersections: shared_interfaces
)
nerve.simplices(0)  # => vertices (modules)
nerve.simplices(1)  # => edges (shared interfaces)
nerve.simplices(2)  # => triangles (triple overlaps)
nerve.euler_characteristic  # => χ(N(U))
\stopverb}
}

\subtree{
\title{3. DescentVerifier}
\p{Check morphism descent conditions:}

\pre{\startverb
descent = SheafCohomology::DescentVerifier.new
descent.add_local_section(:patch_a, section_a)
descent.add_local_section(:patch_b, section_b)
descent.verify_descent!  # => raises if descent fails
descent.global_section   # => glued global section
\stopverb}
}

\subtree{
\title{4. TreeSitterSheaf}
\p{Integration with tree-sitter for AST verification:}

\pre{\startverb
sheaf = SheafCohomology::TreeSitterSheaf.new(
  language: :clojure,
  coverage: :function_boundaries
)
sheaf.parse_file("src/core.clj")
sheaf.local_consistency_check  # => per-function type consistency
sheaf.global_gluing_check      # => cross-function compatibility
sheaf.h1_obstructions          # => list of gluing failures
\stopverb}
}
}

\subtree{
\title{Commands}
\pre{\startverb
# Verify sheaf consistency
just sheaf-check

# Check specific coverage
just sheaf-coverage src/

# Compute cohomology obstructions
just sheaf-h1

# Integration with tree-sitter
just sheaf-ast src/*.clj
\stopverb}
}

\subtree{
\title{API}
\pre{\startverb
require 'sheaf_cohomology'

# Create verifier
verifier = SheafCohomology::Verifier.new(
  trit: -1,
  coverage_strategy: :ast_boundaries
)

# Add patches from tree-sitter
verifier.add_patches_from_ast(parsed_files)

# Check consistency
result = verifier.verify!
result[:h0]  # Global sections (fully consistent)
result[:h1]  # Gluing obstructions
result[:h2]  # Higher obstructions
result[:gf3_conserved]  # GF(3) sum = 0 with triad
\stopverb}
}

