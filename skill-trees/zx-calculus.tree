\title{Zx Calculus}

\taxon{skill}

\meta{trit}{-1}

\meta{description}{"Coecke's ZX-calculus for quantum circuit reasoning via string diagrams with Z-spiders (green) and X-spiders (red)"}

\subtree{
\title{ZX-Calculus}
\p{\strong{Trit}: -1 (MINUS - foundational/classical notation) \strong{Origin}: Coecke & Duncan (2008) \strong{Principle}: Quantum computation via string diagram rewriting}

\subtree{
\title{Overview}
\p{ZX-calculus is a graphical language for quantum computing where:}

\ul{
\li{\strong{Z-spiders} (green): Phase gates in computational basis}
\li{\strong{X-spiders} (red): Phase gates in Hadamard basis}
\li{\strong{Wires}: Qubits}
\li{\strong{Rewrite rules}: Simplify circuits}
}
}

\subtree{
\title{Basic Elements}
\pre{\startverb
Z-spider (green):        X-spider (red):         Hadamard:
    тФВ                        тФВ                      тХ▓ тХ▒
  тФМтФАтФ┤тФАтФР                    тФМтФАтФ┤тФАтФР                     тФА
  тФВ ╬▒ тФВ  = e^{i╬▒}|0тЯйтЯи0|    тФВ ╬▒ тФВ  = H┬╖Z(╬▒)┬╖H        тФА
  тФФтФАтФмтФАтФШ    + |1тЯйтЯи1|        тФФтФАтФмтФАтФШ                    тХ▒ тХ▓
    тФВ                        тФВ
\stopverb}
}

\subtree{
\title{GF(3) Color Assignment}
\pre{\startverb
| Spider | Color | Trit | Basis |
|--------|-------|------|-------|
| Z | Green #26D826 | 0 | Computational |
| X | Red #D82626 | +1 | Hadamard |
| H-edge | Blue #2626D8 | -1 | Transition |
\stopverb}

\p{\strong{Conservation}: Green(0) + Red(+1) + Blue(-1) = 0 тЬУ}
}

