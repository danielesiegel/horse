\subtree{
\title{DisCoPy Implementation}
\pre{\startverb
from discopy.quantum.zx import Z, X, H, Id, SWAP, Cap, Cup

# Bell state preparation
bell = Cap(Z(0), Z(0)) >> (Id(1) @ H) >> CNOT

# ZX diagram
diagram = Z(1, 2, phase=0.5) >> (X(1, 1, phase=0.25) @ Z(1, 1))

# Simplify via rewrite rules
simplified = diagram.normal_form()

# Extract circuit
circuit = simplified.to_circuit()
\stopverb}
}

\subtree{
\title{Musical Notation (Quantum Guitar)}
\p{From Abdyssagin & Coecke's "Bell" composition:}

\pre{\startverb
Staff 1 (Piano):     Staff 2 (Quantum Guitar):
    тФМтФАZтФАтФР                 тФМтФАXтФАтФР
    тФВ   тФВ                 тФВ   тФВ
тФАтФАтФАтФАтФ┤тФАтФАтФАтФ┤тФАтФАтФАтФА        тФАтФАтФАтФАтФАтФ┤тФАтФАтФАтФ┤тФАтФАтФАтФАтФА
    Bell pair            Measurement
\stopverb}
}

\subtree{
\title{PyZX Integration}
\pre{\startverb
import pyzx as zx

# Create circuit
circuit = zx.Circuit(2)
circuit.add_gate("H", 0)
circuit.add_gate("CNOT", 0, 1)

# Convert to ZX graph
graph = circuit.to_graph()

# Simplify
zx.simplify.full_reduce(graph)

# Extract optimized circuit
optimized = zx.extract_circuit(graph)
print(f"T-count: {optimized.tcount()}")
\stopverb}
}

