\meta{version}{"1.0"}

\meta{description}{Design and implement Privileged Access Workstations (PAWs) with device hardening, just-in-time access, and integration with CyberArk or BeyondTrust for secure administrative operations.}

\subtree{
\title{Implementing Privileged Access Workstation}
\subtree{
\title{Overview}
\p{A Privileged Access Workstation (PAW) is a hardened device dedicated to performing sensitive administrative tasks. This skill covers PAW design using the tiered administration model, device compliance enforcement via Microsoft Intune or Group Policy, just-in-time (JIT) access provisioning, and integration with privileged access management (PAM) platforms like CyberArk and BeyondTrust.}
}

\subtree{
\title{When to Use}
\ul{
\li{When deploying or configuring implementing privileged access workstation capabilities in your environment}
\li{When establishing security controls aligned to compliance requirements}
\li{When building or improving security architecture for this domain}
\li{When conducting security assessments that require this implementation}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Windows 10/11 Enterprise with Virtualization Based Security (VBS)}
\li{Microsoft Intune or Active Directory Group Policy}
\li{CyberArk Privileged Access Security or BeyondTrust Password Safe (optional)}
\li{Python 3.9+ with \code{\startverb requests\stopverb}, \code{\startverb subprocess\stopverb}, \code{\startverb json\stopverb}}
\li{Administrative access to target endpoints}
}
}

\subtree{
\title{Steps}
\ol{
\li{Audit current privileged access patterns and identify Tier 0/1/2 assets}
\li{Configure device hardening baselines (AppLocker, Credential Guard, Device Guard)}
\li{Enforce compliance policies via Intune or GPO}
\li{Implement just-in-time access with time-limited admin group membership}
\li{Integrate with CyberArk/BeyondTrust for credential vaulting}
\li{Validate PAW configuration against CIS and Microsoft PAW guidance}
\li{Monitor privileged sessions and generate compliance reports}
}
}

\subtree{
\title{Expected Output}
\ul{
\li{JSON report listing device compliance status, hardening checks, JIT access windows, and PAM integration verification}
\li{Risk scoring per workstation with remediation recommendations}
}
}
}