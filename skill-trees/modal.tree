\subtree{
\title{Best Practices}
\ol{
\li{\strong{Pin dependencies} in \code{\startverb .uv_pip_install()\stopverb} for reproducible builds}
\li{\strong{Use appropriate GPU types} - L40S for inference, H100/A100 for training}
\li{\strong{Leverage caching} - Use Volumes for model weights and datasets}
\li{\strong{Configure autoscaling} - Set \code{\startverb max_containers\stopverb} and \code{\startverb min_containers\stopverb} based on workload}
\li{\strong{Import packages in function body} if not available locally}
\li{\strong{Use \code{\startverb .map()\stopverb} for parallel processing} instead of sequential loops}
\li{\strong{Store secrets securely} - Never hardcode API keys}
\li{\strong{Monitor costs} - Check Modal dashboard for usage and billing}
}
}

\subtree{
\title{Troubleshooting}
\p{\strong{"Module not found" errors:}}

\ul{
\li{Add packages to image with \code{\startverb .uv_pip_install("package-name")\stopverb}}
\li{Import packages inside function body if not available locally}
}

\p{\strong{GPU not detected:}}

\ul{
\li{Verify GPU specification: \code{\startverb @app.function(gpu="A100")\stopverb}}
\li{Check CUDA availability: \code{\startverb torch.cuda.is_available()\stopverb}}
}

\p{\strong{Function timeout:}}

\ul{
\li{Increase timeout: \code{\startverb @app.function(timeout=3600)\stopverb}}
\li{Default timeout is 5 minutes}
}

\p{\strong{Volume changes not persisting:}}

\ul{
\li{Call \code{\startverb volume.commit()\stopverb} after writing files}
\li{Verify volume mounted correctly in function decorator}
}

\p{For additional help, see Modal documentation at https://modal.com/docs or join Modal Slack community.}
}
}