\title{Neuropixels Analysis}

\taxon{skill}

\meta{description}{"Neuropixels neural recording analysis. Load SpikeGLX/OpenEphys data, preprocess, motion correction, Kilosort4 spike sorting, quality metrics, Allen/IBL curation, AI-assisted visual analysis, for Neuropixels 1.0/2.0 extracellular electrophysiology. Use when working with neural recordings, spike sorting, extracellular electrophysiology, or when the user mentions Neuropixels, SpikeGLX, Open Ephys, Kilosort, quality metrics, or unit curation."}

\subtree{
\title{Neuropixels Data Analysis}
\subtree{
\title{Overview}
\p{Comprehensive toolkit for analyzing Neuropixels high-density neural recordings using current best practices from SpikeInterface, Allen Institute, and International Brain Laboratory (IBL). Supports the full workflow from raw data to publication-ready curated units.}
}

\subtree{
\title{When to Use This Skill}
\p{This skill should be used when:}

\ul{
\li{Working with Neuropixels recordings (.ap.bin, .lf.bin, .meta files)}
\li{Loading data from SpikeGLX, Open Ephys, or NWB formats}
\li{Preprocessing neural recordings (filtering, CAR, bad channel detection)}
\li{Detecting and correcting motion/drift in recordings}
\li{Running spike sorting (Kilosort4, SpykingCircus2, Mountainsort5)}
\li{Computing quality metrics (SNR, ISI violations, presence ratio)}
\li{Curating units using Allen/IBL criteria}
\li{Creating visualizations of neural data}
\li{Exporting results to Phy or NWB}
}
}

\subtree{
\title{Supported Hardware & Formats}
\pre{\startverb
| Probe | Electrodes | Channels | Notes |
|-------|-----------|----------|-------|
| Neuropixels 1.0 | 960 | 384 | Requires phase_shift correction |
| Neuropixels 2.0 (single) | 1280 | 384 | Denser geometry |
| Neuropixels 2.0 (4-shank) | 5120 | 384 | Multi-region recording |
\stopverb}

\pre{\startverb
| Format | Extension | Reader |
|--------|-----------|--------|
| SpikeGLX | `.ap.bin`, `.lf.bin`, `.meta` | `si.read_spikeglx()` |
| Open Ephys | `.continuous`, `.oebin` | `si.read_openephys()` |
| NWB | `.nwb` | `si.read_nwb()` |
\stopverb}
}

\subtree{
\title{Quick Start}
\subtree{
\title{Basic Import and Setup}
\pre{\startverb
import spikeinterface.full as si
import neuropixels_analysis as npa

# Configure parallel processing
job_kwargs = dict(n_jobs=-1, chunk_duration='1s', progress_bar=True)
\stopverb}
}

\subtree{
\title{Loading Data}
\pre{\startverb
# SpikeGLX (most common)
recording = si.read_spikeglx('/path/to/data', stream_id='imec0.ap')

# Open Ephys (common for many labs)
recording = si.read_openephys('/path/to/Record_Node_101/')

# Check available streams
streams, ids = si.get_neo_streams('spikeglx', '/path/to/data')
print(streams)  # ['imec0.ap', 'imec0.lf', 'nidq']

# For testing with subset of data
recording = recording.frame_slice(0, int(60 * recording.get_sampling_frequency()))
\stopverb}
}

\subtree{
\title{Complete Pipeline (One Command)}
\pre{\startverb
# Run full analysis pipeline
results = npa.run_pipeline(
    recording,
    output_dir='output/',
    sorter='kilosort4',
    curation_method='allen',
)

# Access results
sorting = results['sorting']
metrics = results['metrics']
labels = results['labels']
\stopverb}
}
}

\subtree{
\title{Standard Analysis Workflow}
\subtree{
\title{1. Preprocessing}
\pre{\startverb
# Recommended preprocessing chain
rec = si.highpass_filter(recording, freq_min=400)
rec = si.phase_shift(rec)  # Required for Neuropixels 1.0
bad_ids, _ = si.detect_bad_channels(rec)
rec = rec.remove_channels(bad_ids)
rec = si.common_reference(rec, operator='median')

# Or use our wrapper
rec = npa.preprocess(recording)
\stopverb}
}

\subtree{
\title{2. Check and Correct Drift}
\pre{\startverb
# Check for drift (always do this!)
motion_info = npa.estimate_motion(rec, preset='kilosort_like')
npa.plot_drift(rec, motion_info, output='drift_map.png')

# Apply correction if needed
if motion_info['motion'].max() > 10:  # microns
    rec = npa.correct_motion(rec, preset='nonrigid_accurate')
\stopverb}
}

\subtree{
\title{3. Spike Sorting}
\pre{\startverb
# Kilosort4 (recommended, requires GPU)
sorting = si.run_sorter('kilosort4', rec, folder='ks4_output')

# CPU alternatives
sorting = si.run_sorter('tridesclous2', rec, folder='tdc2_output')
sorting = si.run_sorter('spykingcircus2', rec, folder='sc2_output')
sorting = si.run_sorter('mountainsort5', rec, folder='ms5_output')

# Check available sorters
print(si.installed_sorters())
\stopverb}
}

\subtree{
\title{4. Postprocessing}
\pre{\startverb
# Create analyzer and compute all extensions
analyzer = si.create_sorting_analyzer(sorting, rec, sparse=True)

analyzer.compute('random_spikes', max_spikes_per_unit=500)
analyzer.compute('waveforms', ms_before=1.0, ms_after=2.0)
analyzer.compute('templates', operators=['average', 'std'])
analyzer.compute('spike_amplitudes')
analyzer.compute('correlograms', window_ms=50.0, bin_ms=1.0)
analyzer.compute('unit_locations', method='monopolar_triangulation')
analyzer.compute('quality_metrics')

metrics = analyzer.get_extension('quality_metrics').get_data()
\stopverb}
}

\subtree{
\title{5. Curation}
\pre{\startverb
# Allen Institute criteria (conservative)
good_units = metrics.query("""
    presence_ratio > 0.9 and
    isi_violations_ratio < 0.5 and
    amplitude_cutoff < 0.1
""").index.tolist()

# Or use automated curation
labels = npa.curate(metrics, method='allen')  # 'allen', 'ibl', 'strict'
\stopverb}
}

\subtree{
\title{6. AI-Assisted Curation (For Uncertain Units)}
\p{When using this skill with Claude Code, Claude can directly analyze waveform plots and provide expert curation decisions. For programmatic API access:}

\pre{\startverb
from anthropic import Anthropic

# Setup API client
client = Anthropic()

# Analyze uncertain units visually
uncertain = metrics.query('snr > 3 and snr < 8').index.tolist()

for unit_id in uncertain:
    result = npa.analyze_unit_visually(analyzer, unit_id, api_client=client)
    print(f"Unit {unit_id}: {result['classification']}")
    print(f"  Reasoning: {result['reasoning'][:100]}...")
\stopverb}

\p{\strong{Claude Code Integration}: When running within Claude Code, ask Claude to examine waveform/correlogram plots directly - no API setup required.}
}

\subtree{
\title{7. Generate Analysis Report}
\pre{\startverb
# Generate comprehensive HTML report with visualizations
report_dir = npa.generate_analysis_report(results, 'output/')
# Opens report.html with summary stats, figures, and unit table

# Print formatted summary to console
npa.print_analysis_summary(results)
\stopverb}
}

\subtree{
\title{8. Export Results}
\pre{\startverb
# Export to Phy for manual review
si.export_to_phy(analyzer, output_folder='phy_export/',
                 compute_pc_features=True, compute_amplitudes=True)

# Export to NWB
from spikeinterface.exporters import export_to_nwb
export_to_nwb(rec, sorting, 'output.nwb')

# Save quality metrics
metrics.to_csv('quality_metrics.csv')
\stopverb}
}
}

\subtree{
\title{Common Pitfalls and Best Practices}
\ol{
\li{\strong{Always check drift} before spike sorting - drift > 10μm significantly impacts quality}
\li{\strong{Use phase_shift} for Neuropixels 1.0 probes (not needed for 2.0)}
\li{\strong{Save preprocessed data} to avoid recomputing - use \code{\startverb rec.save(folder='preprocessed/')\stopverb}}
\li{\strong{Use GPU} for Kilosort4 - it's 10-50x faster than CPU alternatives}
\li{\strong{Review uncertain units manually} - automated curation is a starting point}
\li{\strong{Combine metrics with AI} - use metrics for clear cases, AI for borderline units}
\li{\strong{Document your thresholds} - different analyses may need different criteria}
\li{\strong{Export to Phy} for critical experiments - human oversight is valuable}
}
}

\subtree{
\title{Key Parameters to Adjust}
\subtree{
\title{Preprocessing}
\ul{
\li{\code{\startverb freq_min\stopverb}: Highpass cutoff (300-400 Hz typical)}
\li{\code{\startverb detect_threshold\stopverb}: Bad channel detection sensitivity}
}
}

\subtree{
\title{Motion Correction}
\ul{
\li{\code{\startverb preset\stopverb}: 'kilosort_like' (fast) or 'nonrigid_accurate' (better for severe drift)}
}
}

\subtree{
\title{Spike Sorting (Kilosort4)}
\ul{
\li{\code{\startverb batch_size\stopverb}: Samples per batch (30000 default)}
\li{\code{\startverb nblocks\stopverb}: Number of drift blocks (increase for long recordings)}
\li{\code{\startverb Th_learned\stopverb}: Detection threshold (lower = more spikes)}
}
}

\subtree{
\title{Quality Metrics}
\ul{
\li{\code{\startverb snr_threshold\stopverb}: Signal-to-noise cutoff (3-5 typical)}
\li{\code{\startverb isi_violations_ratio\stopverb}: Refractory violations (0.01-0.5)}
\li{\code{\startverb presence_ratio\stopverb}: Recording coverage (0.5-0.95)}
}
}
}

\subtree{
\title{Bundled Resources}
\subtree{
\title{scripts/preprocess_recording.py}
\p{Automated preprocessing script:}

\pre{\startverb
python scripts/preprocess_recording.py /path/to/data --output preprocessed/
\stopverb}
}

\subtree{
\title{scripts/run_sorting.py}
\p{Run spike sorting:}

\pre{\startverb
python scripts/run_sorting.py preprocessed/ --sorter kilosort4 --output sorting/
\stopverb}
}

\subtree{
\title{scripts/compute_metrics.py}
\p{Compute quality metrics and apply curation:}

\pre{\startverb
python scripts/compute_metrics.py sorting/ preprocessed/ --output metrics/ --curation allen
\stopverb}
}

\subtree{
\title{scripts/export_to_phy.py}
\p{Export to Phy for manual curation:}

\pre{\startverb
python scripts/export_to_phy.py metrics/analyzer --output phy_export/
\stopverb}
}

\subtree{
\title{assets/analysis_template.py}
\p{Complete analysis template. Copy and customize:}

\pre{\startverb
cp assets/analysis_template.py my_analysis.py
# Edit parameters and run
python my_analysis.py
\stopverb}
}

