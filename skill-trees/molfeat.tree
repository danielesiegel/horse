\subtree{
\title{Troubleshooting}
\subtree{
\title{Invalid Molecules}
\p{Enable error handling to skip invalid SMILES:}

\pre{\startverb
transformer = MoleculeTransformer(
    calc,
    ignore_errors=True,
    verbose=True
)
\stopverb}
}

\subtree{
\title{Memory Issues with Large Datasets}
\p{Process in chunks or use streaming approaches for datasets > 100K molecules.}
}

\subtree{
\title{Pretrained Model Dependencies}
\p{Some models require additional packages. Install specific extras:}

\pre{\startverb
uv pip install "molfeat[transformer]"  # For ChemBERTa/ChemGPT
uv pip install "molfeat[dgl]"          # For GIN models
\stopverb}
}

\subtree{
\title{Reproducibility}
\p{Save exact configurations and document versions:}

\pre{\startverb
transformer.to_state_yaml_file("config.yml")
import molfeat
print(f"molfeat version: {molfeat.__version__}")
\stopverb}
}
}

