\subtree{
\title{Installation Requirements}
\pre{\startverb
uv pip install zeep requests pandas matplotlib seaborn
\stopverb}
}

\subtree{
\title{Authentication Setup}
\p{BRENDA requires authentication credentials:}

\ol{
\li{\strong{Create .env file}:}
}

\pre{\startverb
BRENDA_EMAIL=your.email@example.com
BRENDA_PASSWORD=your_brenda_password
\stopverb}

\ol{
\li{\strong{Or set environment variables}:}
}

\pre{\startverb
export BRENDA_EMAIL="your.email@example.com"
export BRENDA_PASSWORD="your_brenda_password"
\stopverb}

\ol{
\li{\strong{Register for BRENDA access}:}
\li{Visit https://www.brenda-enzymes.org/}
\li{Create an account}
\li{Check your email for credentials}
\li{Note: There's also \code{\startverb BRENDA_EMIAL\stopverb} (note the typo) for legacy support}
}
}

