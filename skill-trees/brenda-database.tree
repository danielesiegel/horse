\subtree{
\title{Troubleshooting}
\p{\strong{Authentication Errors}:}

\ul{
\li{Verify BRENDA_EMAIL and BRENDA_PASSWORD in .env file}
\li{Check for correct spelling (note BRENDA_EMIAL legacy support)}
\li{Ensure BRENDA account is active and has API access}
}

\p{\strong{No Results Returned}:}

\ul{
\li{Try broader searches with wildcards (*)}
\li{Check EC number format (e.g., "1.1.1.1" not "1.1.1")}
\li{Verify substrate spelling and naming}
\li{Some enzymes may have limited data in BRENDA}
}

\p{\strong{Rate Limiting}:}

\ul{
\li{Add delays between requests (0.5-1 second)}
\li{Cache results locally}
\li{Use more specific queries to reduce data volume}
\li{Consider batch operations for multiple queries}
}

\p{\strong{Network Errors}:}

\ul{
\li{Check internet connection}
\li{BRENDA server may be temporarily unavailable}
\li{Try again after a few minutes}
\li{Consider using VPN if geo-restricted}
}

\p{\strong{Data Format Issues}:}

\ul{
\li{Use the provided parsing functions in scripts}
\li{BRENDA data can be inconsistent in formatting}
\li{Handle missing fields gracefully}
\li{Validate parsed data before use}
}

\p{\strong{Performance Issues}:}

\ul{
\li{Large queries can be slow; limit search scope}
\li{Use specific organism or substrate filters}
\li{Consider asynchronous processing for batch operations}
\li{Monitor memory usage with large datasets}
}
}

