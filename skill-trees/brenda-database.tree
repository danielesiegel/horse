\title{Brenda Database}

\taxon{skill}

\meta{description}{"Access BRENDA enzyme database via SOAP API. Retrieve kinetic parameters (Km, kcat), reaction equations, organism data, and substrate-specific enzyme information for biochemical research and metabolic pathway analysis."}

\subtree{
\title{BRENDA Database}
\subtree{
\title{Overview}
\p{BRENDA (BRaunschweig ENzyme DAtabase) is the world's most comprehensive enzyme information system, containing detailed enzyme data from scientific literature. Query kinetic parameters (Km, kcat), reaction equations, substrate specificities, organism information, and optimal conditions for enzymes using the official SOAP API. Access over 45,000 enzymes with millions of kinetic data points for biochemical research, metabolic engineering, and enzyme discovery.}
}

\subtree{
\title{When to Use This Skill}
\p{This skill should be used when:}

\ul{
\li{Searching for enzyme kinetic parameters (Km, kcat, Vmax)}
\li{Retrieving reaction equations and stoichiometry}
\li{Finding enzymes for specific substrates or reactions}
\li{Comparing enzyme properties across different organisms}
\li{Investigating optimal pH, temperature, and conditions}
\li{Accessing enzyme inhibition and activation data}
\li{Supporting metabolic pathway reconstruction and retrosynthesis}
\li{Performing enzyme engineering and optimization studies}
\li{Analyzing substrate specificity and cofactor requirements}
}
}

\subtree{
\title{Core Capabilities}
\subtree{
\title{1. Kinetic Parameter Retrieval}
\p{Access comprehensive kinetic data for enzymes:}

\p{\strong{Get Km Values by EC Number}:}

\pre{\startverb
from brenda_client import get_km_values

# Get Km values for all organisms
km_data = get_km_values("1.1.1.1")  # Alcohol dehydrogenase

# Get Km values for specific organism
km_data = get_km_values("1.1.1.1", organism="Saccharomyces cerevisiae")

# Get Km values for specific substrate
km_data = get_km_values("1.1.1.1", substrate="ethanol")
\stopverb}

\p{\strong{Parse Km Results}:}

\pre{\startverb
for entry in km_data:
    print(f"Km: {entry}")
    # Example output: "organism*Homo sapiens#substrate*ethanol#kmValue*1.2#commentary*"
\stopverb}

\p{\strong{Extract Specific Information}:}

\pre{\startverb
from scripts.brenda_queries import parse_km_entry, extract_organism_data

for entry in km_data:
    parsed = parse_km_entry(entry)
    organism = extract_organism_data(entry)
    print(f"Organism: {parsed['organism']}")
    print(f"Substrate: {parsed['substrate']}")
    print(f"Km value: {parsed['km_value']}")
    print(f"pH: {parsed.get('ph', 'N/A')}")
    print(f"Temperature: {parsed.get('temperature', 'N/A')}")
\stopverb}
}

\subtree{
\title{2. Reaction Information}
\p{Retrieve reaction equations and details:}

\p{\strong{Get Reactions by EC Number}:}

\pre{\startverb
from brenda_client import get_reactions

# Get all reactions for EC number
reactions = get_reactions("1.1.1.1")

# Filter by organism
reactions = get_reactions("1.1.1.1", organism="Escherichia coli")

# Search specific reaction
reactions = get_reactions("1.1.1.1", reaction="ethanol + NAD+")
\stopverb}

\p{\strong{Process Reaction Data}:}

\pre{\startverb
from scripts.brenda_queries import parse_reaction_entry, extract_substrate_products

for reaction in reactions:
    parsed = parse_reaction_entry(reaction)
    substrates, products = extract_substrate_products(reaction)

    print(f"Reaction: {parsed['reaction']}")
    print(f"Organism: {parsed['organism']}")
    print(f"Substrates: {substrates}")
    print(f"Products: {products}")
\stopverb}
}

\subtree{
\title{3. Enzyme Discovery}
\p{Find enzymes for specific biochemical transformations:}

\p{\strong{Find Enzymes by Substrate}:}

\pre{\startverb
from scripts.brenda_queries import search_enzymes_by_substrate

# Find enzymes that act on glucose
enzymes = search_enzymes_by_substrate("glucose", limit=20)

for enzyme in enzymes:
    print(f"EC: {enzyme['ec_number']}")
    print(f"Name: {enzyme['enzyme_name']}")
    print(f"Reaction: {enzyme['reaction']}")
\stopverb}

\p{\strong{Find Enzymes by Product}:}

\pre{\startverb
from scripts.brenda_queries import search_enzymes_by_product

# Find enzymes that produce lactate
enzymes = search_enzymes_by_product("lactate", limit=10)
\stopverb}

\p{\strong{Search by Reaction Pattern}:}

\pre{\startverb
from scripts.brenda_queries import search_by_pattern

# Find oxidation reactions
enzymes = search_by_pattern("oxidation", limit=15)
\stopverb}
}

\subtree{
\title{4. Organism-Specific Enzyme Data}
\p{Compare enzyme properties across organisms:}

\p{\strong{Get Enzyme Data for Multiple Organisms}:}

\pre{\startverb
