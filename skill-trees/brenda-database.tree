\li{\code{\startverb get_cofactor_requirements(ec_number)\stopverb}: Get cofactor information}
\li{\code{\startverb get_substrate_specificity(ec_number)\stopverb}: Analyze substrate preferences}
\li{\code{\startverb get_inhibitors(ec_number)\stopverb}: Get enzyme inhibition data}
\li{\code{\startverb get_activators(ec_number)\stopverb}: Get enzyme activation data}
\li{\code{\startverb find_thermophilic_homologs(ec_number, min_temp)\stopverb}: Find heat-stable variants}
\li{\code{\startverb get_modeling_parameters(ec_number, substrate)\stopverb}: Get parameters for kinetic modeling}
\li{\code{\startverb export_kinetic_data(ec_number, format, filename)\stopverb}: Export data to file}
}

\p{\strong{Usage}:}

\pre{\startverb
from scripts.brenda_queries import search_enzymes_by_substrate, compare_across_organisms

# Search for enzymes
