\subtree{
\title{Part 10: Validation Checklist for Medical Device Firmware}
\p{Before clinical deployment:}

\ul{
\li{✓ All sensor readings include HMAC integrity tags}
\li{✓ Device attestation via ECDSA signature (from secure element)}
\li{✓ BLE encryption enabled (AES-128-CCM per Bluetooth 5.0 spec)}
\li{✓ Firmware signed with trusted key (in ATECC608A)}
\li{✓ Capability advertisement via skill registry (agentskills validation)}
\li{✓ FHIR output validated against schema (gateway WASI runtime)}
\li{✓ IEC 62443 Secure Development Practices applied}
\li{✓ Binary audit log enabled (tamper-resistant storage on secure element)}
\li{✓ 21 CFR Part 11 audit trail (gateway logs all device events)}
}
