\li{\strong{\code{\startverb model_diagnostics.py\stopverb}}: Automated diagnostic checking and report generation. Functions: \code{\startverb check_diagnostics()\stopverb} for quick checks, \code{\startverb create_diagnostic_report()\stopverb} for comprehensive analysis with plots.}
}

\ul{
\li{\strong{\code{\startverb model_comparison.py\stopverb}}: Model comparison utilities using LOO/WAIC. Functions: \code{\startverb compare_models()\stopverb}, \code{\startverb check_loo_reliability()\stopverb}, \code{\startverb model_averaging()\stopverb}.}
}
}

\subtree{
