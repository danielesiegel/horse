from scripts.model_comparison import compare_models
compare_models({'m1': idata1, 'm2': idata2}, ic='loo')
\stopverb}
}

\subtree{
\title{Predictions}
\pre{\startverb
with model:
    pm.set_data({'X': X_new})
    pred = pm.sample_posterior_predictive(idata.posterior)
\stopverb}
}
}

\subtree{
\title{Additional Notes}
\ul{
\li{PyMC integrates with ArviZ for visualization and diagnostics}
\li{Use \code{\startverb pm.model_to_graphviz(model)\stopverb} to visualize model structure}
\li{Save results with \code{\startverb idata.to_netcdf('results.nc')\stopverb}}
\li{Load with \code{\startverb az.from_netcdf('results.nc')\stopverb}}
\li{For very large models, consider minibatch ADVI or data subsampling}
}
}
}