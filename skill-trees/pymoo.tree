\subtree{
\title{Additional Notes}
\p{\strong{Installation:}}

\pre{\startverb
uv pip install pymoo
\stopverb}

\p{\strong{Dependencies:} NumPy, SciPy, matplotlib, autograd (optional for gradient-based)}

\p{\strong{Documentation:} https://pymoo.org/}

\p{\strong{Version:} This skill is based on pymoo 0.6.x}

\p{\strong{Common patterns:}}

\ul{
\li{Always use \code{\startverb ElementwiseProblem\stopverb} for custom problems}
\li{Constraints formulated as \code{\startverb g(x) <= 0\stopverb} and \code{\startverb h(x) = 0\stopverb}}
\li{Reference directions required for NSGA-III}
\li{Normalize objectives before MCDM}
\li{Use appropriate termination: \code{\startverb ('n_gen', N)\stopverb} or \code{\startverb get_termination("f_tol", tol=0.001)\stopverb}}
}
}
}