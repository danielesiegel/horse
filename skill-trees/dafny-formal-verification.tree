\subtree{
\title{Mathematical Guarantees}
\subtree{
\title{Galois Connection (spi_galois.dfy)}
\p{A \strong{Galois connection} between two ordered sets:}

\ul{
\li{α: Event → Color (abstraction, surjective)}
\li{γ: Color → Event (concretization)}
}

\p{\strong{Properties:}}

\ol{
\li{\strong{Closure}: α(γ(c)) = c (every color recoverable)}
\li{\strong{Determinism}: α(e₁) = α(e₂) if e₁ and e₂ have same hash}
\li{\strong{Consistency}: Device-independent color assignment}
}
}

\subtree{
\title{p-adic Arithmetic (padic.dfy)}
\p{p-adic numbers form an \strong{ultrametric space} where:}

\ul{
\li{Distance: d(x,y) = p^(-v_p(x-y))}
\li{\strong{Non-Archimedean}: No boundary effects}
\li{\strong{Canonical form}: Unique representation (no denormals)}
\li{\strong{Totally disconnected}: Every point is isolated}
}

\p{Benefits over IEEE 754 floats:}

\ul{
\li{✓ Exact representation (no rounding)}
\li{✓ Unique canonical form}
\li{✓ No boundary clipping issues}
\li{✓ Hierarchical structure (depth-based matching)}
}
}

\subtree{
\title{Ring Topology (spi_galois.dfy)}
\p{Distributed computation model where:}

\ul{
\li{Devices form a ring topology}
\li{Each device handles layer partition [start, end]}
\li{Partitions contiguous and non-overlapping}
\li{XOR fingerprints order-independent}
}

\p{\strong{Fault Detection:}}

\ul{
\li{Single bit flip always detected (changes XOR)}
\li{False positive rate: 0\%}
}
}
}

