\subtree{
\title{Audit Methodology}
\subtree{
\title{Phase 1: RF Reconnaissance}
\ul{
\li{Perform broadband spectrum sweep (SDR + GQRX/SDR++)}
\li{Identify active frequencies, modulations, duty cycles}
\li{Catalog all wireless interfaces on target devices}
\li{Map wireless network topology and access points}
\li{Document regulatory bands in use and transmission power}
}
}

\subtree{
\title{Phase 2: Protocol Enumeration}
\ul{
\li{Identify protocols on discovered frequencies (WiFi, BLE, Zigbee, proprietary)}
\li{Enumerate advertised services (GATT, SSIDs, PAN IDs, device names)}
\li{Fingerprint firmware versions and chipset identifiers}
\li{Map protocol state machines and message sequences}
\li{Identify supported security modes and negotiation behavior}
}
}

\subtree{
\title{Phase 3: Authentication Analysis}
\ul{
\li{Test pairing and association mechanisms for weaknesses}
\li{Attempt default/well-known key access (Zigbee HA key, HID iClass standard)}
\li{Evaluate key derivation and entropy (PRNG seeding, key length negotiation)}
\li{Test credential storage on device (flash dump, JTAG/SWD extraction)}
\li{Assess mutual authentication requirements (or lack thereof)}
}
}

\subtree{
\title{Phase 4: Traffic Analysis}
\ul{
\li{Capture and decode protocol traffic (Wireshark, URH, rtl_433)}
\li{Identify cleartext or weakly encrypted data transmissions}
\li{Analyze session management (frame counters, sequence numbers, nonces)}
\li{Look for information leakage in metadata, headers, or advertisements}
\li{Correlate traffic patterns with device behavior}
}
}

\subtree{
\title{Phase 5: Injection & Manipulation}
\ul{
\li{Replay captured frames and assess acceptance (replay protection)}
\li{Inject crafted packets to test input validation}
\li{Attempt protocol downgrade attacks (WPA3→WPA2, S2→S0, BLE SC→Legacy)}
\li{Fuzz protocol parsers with malformed frames}
\li{Test jamming resilience and failover behavior}
}
}

\subtree{
\title{Phase 6: Persistence & Lateral Movement}
\ul{
\li{Assess post-compromise persistence on wireless devices (firmware implants)}
\li{Test pivot from wireless to wired network segments}
\li{Evaluate OTA update mechanisms for hijacking potential}
\li{Check for mesh network propagation of compromised keys}
\li{Document trust relationships between wireless components}
}
}
}

\subtree{
\title{Code Review Patterns}
\p{When reviewing source code for RF/wireless implementations, flag:}

\ul{
\li{\strong{Hardcoded Keys}: Encryption keys, PINs, or network credentials in source/firmware}
\li{\strong{Weak Randomness}: Use of \code{\startverb rand()\stopverb}, \code{\startverb millis()\stopverb}, or predictable seeds for nonces/keys}
\li{\strong{Missing Replay Protection}: No frame counter, sequence number, or timestamp validation}
\li{\strong{Cleartext Transmission}: Sensitive data sent without encryption over RF}
\li{\strong{Weak Key Derivation}: Short keys, no KDF, or insufficient PBKDF2/scrypt rounds}
\li{\strong{Missing Mutual Authentication}: Device trusts any peer without verifying identity}
\li{\strong{No Firmware Signature Verification}: OTA updates accepted without code signing}
\li{\strong{Static Session Keys}: ABP-style fixed keys that survive device reboot}
\li{\strong{Insufficient Key Rotation}: Long-lived symmetric keys without renegotiation}
\li{\strong{Debug Interfaces Left Open}: JTAG/SWD/UART enabled in production firmware}
}
}

