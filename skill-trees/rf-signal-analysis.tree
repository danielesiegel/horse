\title{Related Skills}
\ul{
\li{\code{\startverb reverse-engineering\stopverb} — Firmware extraction, binary analysis, protocol RE}
\li{\code{\startverb entry-point-analyzer\stopverb} — Identify attack entry points across system boundaries}
\li{\code{\startverb iot-device-provisioning\stopverb} — Secure device onboarding and credential management}
}
}