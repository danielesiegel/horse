\title{Nhero Nurse}

\taxon{skill}

\tag{nhero}

\tag{nurse}

\tag{email}

\tag{approval}

\tag{gmail}

\tag{automation}

\meta{version}{0.1.0}

\meta{trit}{1}

\meta{description}{Nurse approval email automation for nhero controlled substance slots. Gmail MCP integration with scrambled slot names — nurse sees only slot letters, never medication names. Dual-address routing to mantissa@gmail.com (primary) and ies@plurigrid.com (backup).}

\subtree{
\title{nhero-nurse}
\p{Nurse approval workflow. Scrambled. Email-automated.}

\subtree{
\title{Flow}
\pre{\startverb
killdispenser(slot, HOLD) → queue nurse request
  → Gmail MCP creates draft (from mantissa@plurigrid.com)
  → Sent to mantissa@gmail.com (cc: ies@plurigrid.com)
  → Nurse replies APPROVED / DENIED
  → hero_email_monitor.py parses reply
  → killdispenser(slot, DISPENSE) or remains HOLD
\stopverb}
}

\subtree{
\title{Privacy}
\p{The nurse email contains:}

\ul{
\li{Slot letter (e.g., "Q")}
\li{Proposed dosage (e.g., "30.0mg")}
\li{Supply assessment}
}

\p{The nurse email does NOT contain:}

\ul{
\li{Medication name}
\li{Patient identity}
\li{Diagnosis}
}
}

\subtree{
\title{Email Architecture}
\pre{\startverb
| Role | Address |
|------|---------|
| Hero registration | `mantissa+hero-h@plurigrid.com` |
| Nurse approval TO | `mantissa@gmail.com` |
| Nurse backup CC | `ies@plurigrid.com` |
| Automation FROM | `mantissa@plurigrid.com` |
\stopverb}
}

\subtree{
\title{Parent}
\p{Part of the [nhero](../nhero/SKILL.md) hierarchy.}
}
}