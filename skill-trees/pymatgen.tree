\subtree{
\title{Common Workflows}
\subtree{
\title{High-Throughput Structure Generation}
\pre{\startverb
from pymatgen.transformations.standard_transformations import SubstitutionTransformation
from pymatgen.io.vasp.sets import MPRelaxSet

# Generate doped structures
base_struct = Structure.from_file("POSCAR")
dopants = ["Mn", "Co", "Ni", "Cu"]

for dopant in dopants:
    trans = SubstitutionTransformation({"Fe": dopant})
    doped_struct = trans.apply_transformation(base_struct)

    # Generate VASP inputs
    vasp_input = MPRelaxSet(doped_struct)
    vasp_input.write_input(f"./calcs/Fe_{dopant}")
\stopverb}
}

\subtree{
\title{Band Structure Calculation Workflow}
\pre{\startverb
# 1. Relaxation
relax = MPRelaxSet(struct)
relax.write_input("./1_relax")

# 2. Static (after relaxation)
relaxed = Structure.from_file("1_relax/CONTCAR")
static = MPStaticSet(relaxed)
static.write_input("./2_static")

# 3. Band structure (non-self-consistent)
nscf = MPNonSCFSet(relaxed, mode="line")
nscf.write_input("./3_bandstructure")

# 4. Analysis
from pymatgen.io.vasp import Vasprun
vasprun = Vasprun("3_bandstructure/vasprun.xml")
bs = vasprun.get_band_structure()
bs.get_band_gap()
\stopverb}
}

\subtree{
\title{Surface Energy Calculation}
\pre{\startverb
# 1. Get bulk energy
bulk_vasprun = Vasprun("bulk/vasprun.xml")
bulk_E_per_atom = bulk_vasprun.final_energy / len(bulk)

# 2. Generate and calculate slabs
slabgen = SlabGenerator(bulk, (1,1,1), 10, 15)
slab = slabgen.get_slabs()[0]

MPRelaxSet(slab).write_input("./slab_calc")

# 3. Calculate surface energy (after calculation)
slab_vasprun = Vasprun("slab_calc/vasprun.xml")
E_surf = (slab_vasprun.final_energy - len(slab) * bulk_E_per_atom) / (2 * slab.surface_area)
E_surf *= 16.021766  # Convert eV/Ų to J/m²
\stopverb}

\p{\strong{More workflows:} See \code{\startverb references/transformations_workflows.md\stopverb} for 10 detailed workflow examples.}
}
}

\subtree{
\title{Best Practices}
\subtree{
\title{Structure Handling}
\ol{
\li{\strong{Use automatic format detection}: \code{\startverb Structure.from_file()\stopverb} handles most formats}
\li{\strong{Prefer immutable structures}: Use \code{\startverb IStructure\stopverb} when structure shouldn't change}
\li{\strong{Check symmetry}: Use \code{\startverb SpacegroupAnalyzer\stopverb} to reduce to primitive cell}
\li{\strong{Validate structures}: Check for overlapping atoms or unreasonable bond lengths}
}
}

\subtree{
\title{File I/O}
\ol{
\li{\strong{Use convenience methods}: \code{\startverb from_file()\stopverb} and \code{\startverb to()\stopverb} are preferred}
\li{\strong{Specify formats explicitly}: When automatic detection fails}
\li{\strong{Handle exceptions}: Wrap file I/O in try-except blocks}
\li{\strong{Use serialization}: \code{\startverb as_dict()\stopverb}/\code{\startverb from_dict()\stopverb} for version-safe storage}
}
}

\subtree{
\title{Materials Project API}
\ol{
\li{\strong{Use context manager}: Always use \code{\startverb with MPRester() as mpr:\stopverb}}
\li{\strong{Batch queries}: Request multiple items at once}
\li{\strong{Cache results}: Save frequently used data locally}
\li{\strong{Filter effectively}: Use property filters to reduce data transfer}
}
}

\subtree{
\title{Computational Workflows}
\ol{
\li{\strong{Use input sets}: Prefer \code{\startverb MPRelaxSet\stopverb}, \code{\startverb MPStaticSet\stopverb} over manual INCAR}
\li{\strong{Check convergence}: Always verify calculations converged}
\li{\strong{Track transformations}: Use \code{\startverb TransformedStructure\stopverb} for provenance}
\li{\strong{Organize calculations}: Use clear directory structures}
}
}

\subtree{
\title{Performance}
\ol{
\li{\strong{Reduce symmetry}: Use primitive cells when possible}
\li{\strong{Limit neighbor searches}: Specify reasonable cutoff radii}
\li{\strong{Use appropriate methods}: Different analysis tools have different speed/accuracy tradeoffs}
\li{\strong{Parallelize when possible}: Many operations can be parallelized}
}
}
}

\subtree{
\title{Units and Conventions}
\p{Pymatgen uses atomic units throughout:}

\ul{
\li{\strong{Lengths}: Angstroms (Å)}
\li{\strong{Energies}: Electronvolts (eV)}
\li{\strong{Angles}: Degrees (°)}
\li{\strong{Magnetic moments}: Bohr magnetons (μB)}
\li{\strong{Time}: Femtoseconds (fs)}
}

\p{Convert units using \code{\startverb pymatgen.core.units\stopverb} when needed.}
}

\subtree{
\title{Integration with Other Tools}
\p{Pymatgen integrates seamlessly with:}

\ul{
\li{\strong{ASE} (Atomic Simulation Environment)}
\li{\strong{Phonopy} (phonon calculations)}
\li{\strong{BoltzTraP} (transport properties)}
\li{\strong{Atomate/Fireworks} (workflow management)}
\li{\strong{AiiDA} (provenance tracking)}
\li{\strong{Zeo++} (pore analysis)}
\li{\strong{OpenBabel} (molecule conversion)}
}
}

\subtree{
\title{Troubleshooting}
\p{\strong{Import errors}: Install missing dependencies}

\pre{\startverb
uv pip install pymatgen[analysis,vis]
\stopverb}

\p{\strong{API key not found}: Set MP_API_KEY environment variable}

\pre{\startverb
export MP_API_KEY="your_key_here"
\stopverb}

\p{\strong{Structure read failures}: Check file format and syntax}

\pre{\startverb
# Try explicit format specification
struct = Structure.from_file("file.txt", fmt="cif")
\stopverb}

\p{\strong{Symmetry analysis fails}: Structure may have numerical precision issues}

\pre{\startverb
# Increase tolerance
from pymatgen.symmetry.analyzer import SpacegroupAnalyzer
sga = SpacegroupAnalyzer(struct, symprec=0.1)
\stopverb}
}

