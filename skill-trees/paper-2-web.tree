\subtree{
\title{Basic Usage}
\p{\strong{Generate All Components} (website + poster + video):}

\pre{\startverb
python pipeline_all.py \
  --input-dir "path/to/paper" \
  --output-dir "path/to/output" \
  --model-choice 1
\stopverb}

\p{\strong{Generate Website Only}:}

\pre{\startverb
python pipeline_all.py \
  --input-dir "path/to/paper" \
  --output-dir "path/to/output" \
  --model-choice 1 \
  --generate-website
\stopverb}

\p{\strong{Generate Poster with Custom Size}:}

\pre{\startverb
python pipeline_all.py \
  --input-dir "path/to/paper" \
  --output-dir "path/to/output" \
  --model-choice 1 \
  --generate-poster \
  --poster-width-inches 60 \
  --poster-height-inches 40
\stopverb}

\p{\strong{Generate Video} (lightweight pipeline):}

\pre{\startverb
python pipeline_light.py \
  --model_name_t gpt-4.1 \
  --model_name_v gpt-4.1 \
  --result_dir "path/to/output" \
  --paper_latex_root "path/to/paper"
\stopverb}

\p{→ \strong{See \code{\startverb references/usage_examples.md\stopverb} for comprehensive workflow examples}}
}
}

\subtree{
\title{Workflow Decision Tree}
\p{Use this decision tree to determine which components to generate:}

\pre{\startverb
User needs promotional materials for paper?
│
├─ Need permanent online presence?
│  └─→ Generate Paper2Web (interactive website)
│
├─ Need physical conference materials?
│  ├─→ Poster session? → Generate Paper2Poster
│  └─→ Oral presentation? → Generate Paper2Video
│
├─ Need video content?
│  ├─→ Journal video abstract? → Generate Paper2Video (5-10 min)
│  ├─→ Conference talk? → Generate Paper2Video (15-20 min)
│  └─→ Social media? → Generate Paper2Video (1-3 min)
│
└─ Need complete package?
   └─→ Generate all three components
\stopverb}
}

\subtree{
\title{Input Requirements}
\subtree{
\title{Supported Input Formats}
\p{\strong{1. LaTeX Source} (Recommended):}

\pre{\startverb
paper_directory/
├── main.tex              # Main paper file
├── sections/             # Optional: split sections
├── figures/              # All figure files
├── tables/               # Table files
└── bibliography.bib      # References
\stopverb}

\p{\strong{2. PDF}:}

\ul{
\li{High-quality PDF with embedded fonts}
\li{Selectable text (not scanned images)}
\li{High-resolution figures (300+ DPI preferred)}
}
}

\subtree{
\title{Input Organization}
\p{\strong{Single Paper}:}

\pre{\startverb
input/
└── paper_name/
    ├── main.tex (or paper.pdf)
    ├── figures/
    └── bibliography.bib
\stopverb}

\p{\strong{Multiple Papers} (batch processing):}

\pre{\startverb
input/
├── paper1/
│   └── main.tex
├── paper2/
│   └── main.tex
└── paper3/
    └── main.tex
\stopverb}
}
}

\subtree{
\title{Common Parameters}
\subtree{
\title{Model Selection}
\ul{
\li{\code{\startverb --model-choice 1\stopverb}: GPT-4 (best balance of quality and cost)}
\li{\code{\startverb --model-choice 2\stopverb}: GPT-4.1 (latest features, higher cost)}
\li{\code{\startverb --model_name_t gpt-3.5-turbo\stopverb}: Faster, lower cost (acceptable quality)}
}
}

\subtree{
\title{Component Selection}
\ul{
\li{\code{\startverb --generate-website\stopverb}: Enable website generation}
\li{\code{\startverb --generate-poster\stopverb}: Enable poster generation}
\li{\code{\startverb --generate-video\stopverb}: Enable video generation}
\li{\code{\startverb --enable-talking-head\stopverb}: Add talking-head to video (requires GPU)}
}
}

\subtree{
\title{Customization}
\ul{
\li{\code{\startverb --poster-width-inches [width]\stopverb}: Custom poster width}
\li{\code{\startverb --poster-height-inches [height]\stopverb}: Custom poster height}
\li{\code{\startverb --video-duration [seconds]\stopverb}: Target video length}
\li{\code{\startverb --enable-logo-search\stopverb}: Automatic institution logo discovery}
}
}
}

\subtree{
\title{Output Structure}
\p{Generated outputs are organized by paper and component:}

\pre{\startverb
output/
└── paper_name/
    ├── website/
    │   ├── index.html
    │   ├── styles.css
    │   └── assets/
    ├── poster/
    │   ├── poster_final.pdf
    │   ├── poster_final.png
    │   └── poster_source/
    └── video/
        ├── final_video.mp4
        ├── slides/
        ├── audio/
        └── subtitles/
\stopverb}
}

\subtree{
\title{Best Practices}
\subtree{
\title{Input Preparation}
\ol{
\li{\strong{Use LaTeX when possible}: Provides best content extraction and structure}
\li{\strong{Organize files properly}: Keep all assets (figures, tables, bibliography) in paper directory}
\li{\strong{High-quality figures}: Use vector formats (PDF, SVG) or high-resolution rasters (300+ DPI)}
\li{\strong{Clean LaTeX}: Remove compilation artifacts, ensure source compiles successfully}
}
}

\subtree{
\title{Model Selection Strategy}
\ul{
\li{\strong{GPT-4}: Best for production-quality outputs, conferences, publications}
\li{\strong{GPT-4.1}: Use when you need latest features or best possible quality}
\li{\strong{GPT-3.5-turbo}: Use for quick drafts, testing, or simple papers}
}
}

\subtree{
\title{Component Priority}
\p{For tight deadlines, generate in this order:}

\ol{
\li{\strong{Website} (fastest, most versatile, ~15-30 min)}
\li{\strong{Poster} (moderate speed, for print deadlines, ~10-20 min)}
\li{\strong{Video} (slowest, can be generated later, ~20-60 min)}
}
}

\subtree{
\title{Quality Assurance}
\p{Before finalizing outputs:}

\ol{
\li{\strong{Website}: Test on multiple devices, verify all links work, check figure quality}
\li{\strong{Poster}: Print test page, verify text readability from 3-6 feet, check colors}
\li{\strong{Video}: Watch entire video, verify audio synchronization, test on different devices}
}
}
}

\subtree{
\title{Resource Requirements}
\subtree{
\title{Processing Time}
\ul{
\li{\strong{Website}: 15-30 minutes per paper}
\li{\strong{Poster}: 10-20 minutes per paper}
\li{\strong{Video (no talking-head)}: 20-60 minutes per paper}
\li{\strong{Video (with talking-head)}: 60-120 minutes per paper}
}
}

\subtree{
\title{Computational Requirements}
\ul{
\li{\strong{CPU}: Multi-core processor for parallel processing}
\li{\strong{RAM}: 16GB minimum, 32GB recommended for large papers}
\li{\strong{GPU}: Optional for standard outputs, required for talking-head (NVIDIA A6000 48GB)}
\li{\strong{Storage}: 1-5GB per paper depending on components and quality settings}
}
}

\subtree{
\title{API Costs (Approximate)}
\ul{
\li{\startverb **Website**: $0.50-2.00 per paper (GPT-4)\stopverb}
\li{\startverb **Poster**: $0.30-1.00 per paper (GPT-4)\stopverb}
\li{\startverb **Video**: $1.00-3.00 per paper (GPT-4)\stopverb}
\li{\startverb **Complete package**: $2.00-6.00 per paper (GPT-4)\stopverb}
}
}
}

\subtree{
\title{Troubleshooting}
\subtree{
\title{Common Issues}
\p{\strong{LaTeX parsing errors}:}

\ul{
\li{Ensure LaTeX source compiles successfully: \code{\startverb pdflatex main.tex\stopverb}}
\li{Check all referenced files are present}
\li{Verify no custom packages prevent parsing}
}

\p{\strong{Poor figure quality}:}

\ul{
\li{Use vector formats (PDF, SVG, EPS) instead of rasters}
\li{Ensure raster images are 300+ DPI}
\li{Check figures render correctly in compiled PDF}
}

\p{\strong{Video generation failures}:}

\ul{
\li{Verify sufficient disk space (5GB+ recommended)}
\li{Check all dependencies installed (LibreOffice, Poppler)}
\li{Review error logs in output directory}
}

\p{\strong{Poster layout issues}:}

\ul{
\li{Verify poster dimensions are reasonable (24"-72" range)}
\li{Check content length (very long papers may need manual curation)}
\li{Ensure figures have appropriate resolution for poster size}
}

\p{\strong{API errors}:}

\ul{
\li{Verify API keys in \code{\startverb .env\stopverb} file}
\li{Check API credit balance}
\li{Ensure no rate limiting (wait and retry)}
}
}
}

\subtree{
\title{Platform-Specific Features}
\subtree{
\title{Social Media Optimization}
\p{The system auto-detects target platforms:}

\p{\strong{Twitter/X} (English, numeric folder names):}

\pre{\startverb
mkdir -p input/001_twitter/
# Generates English promotional content
\stopverb}

\p{\strong{Xiaohongshu/小红书} (Chinese, alphanumeric folder names):}

\pre{\startverb
mkdir -p input/xhs_paper/
# Generates Chinese promotional content
\stopverb}
}

\subtree{
\title{Conference-Specific Formatting}
\p{Specify conference requirements:}

\ul{
\li{Standard poster sizes (4'×3', 5'×4', A0, A1)}
\li{Video abstract length limits (typically 3-5 minutes)}
\li{Institution branding requirements}
\li{Color scheme preferences}
}
}
}

