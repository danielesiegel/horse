\li{\strong{Social media}: Twitter, LinkedIn, ResearchGate}
}
}
}

\subtree{
\title{Advanced Usage}
\subtree{
\title{Batch Processing}
\p{Process multiple papers efficiently:}

\pre{\startverb
# Organize papers in batch directory
for paper in paper1 paper2 paper3; do
    python pipeline_all.py \
      --input-dir input/$paper \
      --output-dir output/$paper \
      --model-choice 1 &
done
wait
\stopverb}
}

\subtree{
\title{Custom Branding}
\p{Apply institution or lab branding:}

\ul{
\li{Provide logo files in paper directory}
\li{Specify color schemes in configuration}
\li{Use custom templates (advanced)}
\li{Match conference theme requirements}
}
}

\subtree{
\title{Multi-Language Support}
\p{Generate content in different languages:}

\ul{
\li{Specify target language in configuration}
\li{System translates content appropriately}
\li{Selects appropriate voice for video narration}
\li{Adapts design conventions to culture}
}
}
}

