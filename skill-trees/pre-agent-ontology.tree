\title{Pre Agent Ontology}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{'Pre-Agent Ontology Skill'}

\subtree{
\title{Pre-Agent Ontology Skill}
\p{\strong{Trit}: 0 (ERGODIC - coordinates the ontology)}

\p{Foundational 5-layer ontology for agent-o-rama. Agents are not primitives—they emerge from derivations, stalks, and sections when gluing succeeds.}

\subtree{
\title{Related Skills}
\ul{
\li{\strong{unworld}: Derivational succession (Layer 1)}
\li{\strong{sheaf-cohomology}: Gluing verification (Layer 2)}
\li{\strong{bisimulation-game}: Observational equivalence (Layer 2)}
\li{\strong{acsets}: Categorical database structure (Layer 2)}
}
}

\subtree{
\title{5-Layer Hierarchy}
\pre{\startverb
Layer 4: EMERGENT        agent, skill, experiment
            ↑
Layer 3: OPERATIONAL     node, emit, aggregation, result
            ↑
Layer 2: SHEAF           stalk, section, cohomology
            ↑
Layer 1: DERIVATIONAL    derivation, chain
            ↑
Layer 0: PRE-ONTOLOGICAL seed, trit, γ (gamma)
\stopverb}

\subtree{
\title{Layer 0: Pre-Ontological (Absolute Primitives)}
\pre{\startverb
| Term | Type | Definition |
|------|------|------------|
| seed | uint64 | Deterministic state replacing time |
| trit | {-1, 0, +1} | GF(3) charge element |
| γ | constant | 0x9E3779B97F4A7C15 (golden ratio bits) |
\stopverb}
}

\subtree{
\title{Layer 1: Derivational}
\pre{\startverb
| Term | Type | Definition |
|------|------|------------|
| derivation | (Seed × Trit) → (Seed × Section) | Fundamental computation unit |
| chain | [Seed] | Sequence of derived seeds |
\stopverb}

\p{\strong{Rule}: \code{\startverb seed_{n+1} = splitmix64(seed_n ⊕ (trit_n × γ))\stopverb}}
}

\subtree{
\title{Layer 2: Sheaf-Theoretic}
\pre{\startverb
| Term | Type | Definition |
|------|------|------------|
| stalk | Set(Section) | Collection of sections over one trit |
| section | local data | Output of derivation, can glue |
| cohomology | (H⁰, H¹) | Global sections and obstructions |
\stopverb}

\p{\strong{Stalk Distribution (2-3-2)}:}

\pre{\startverb
MINUS:   2 elements, trit=-1, role=validator
ERGODIC: 3 elements, trit=0,  role=coordinator
PLUS:    2 elements, trit=+1, role=generator

Verification: 2(-1) + 3(0) + 2(+1) = 0 ✓
\stopverb}
}

\subtree{
\title{Layer 3: Operational}
\pre{\startverb
| Term | Sheaf Correspondence |
|------|---------------------|
| node | section-producer |
| emit | stalk transition |
| aggregation | gluing (cocycle check) |
| result | global section (H⁰ element) |
\stopverb}
}

\subtree{
\title{Layer 4: Emergent}
\pre{\startverb
| Term | Definition |
|------|------------|
| agent | Fiber bundle over trit poset {-1, 0, +1} |
| skill | Executable section (self-contained knowledge) |
| experiment | Derivation chain evaluation |
\stopverb}

\p{\strong{Key}: \code{\startverb Agent = Observation(Bundle(Stalk₋₁, Stalk₀, Stalk₊₁))\stopverb}}
}
}

\subtree{
\title{5 Stability Invariants}
\pre{\startverb
| ID | Invariant | Formula | Verified By |
|----|-----------|---------|-------------|
| I1 | GF(3) Conservation | `Σ trits ≡ 0 (mod 3)` | aggregation, trifurcate |
| I2 | Determinism | `derive(s,t) = derive(s,t)` | seed chaining |
| I3 | Order Independence (SPI) | `parallel(f) = sequential(f)` | spi-parallel-verify |
| I4 | Gluing (Cocycle) | `g_ij ∘ g_jk = g_ik` | cohomology check |
| I5 | Bisimulation | `A ~ B ⟺ ∀obs. obs(A) = obs(B)` | bisimulation-game |
\stopverb}
}

\subtree{
\title{Key Primitives}
\subtree{
\title{Seed}
\p{64-bit unsigned integer replacing temporal state. Same seed → identical derivation chains.}
}

\subtree{
\title{Trit}
\p{GF(3) element in {-1, 0, +1}. Forms a field under modular arithmetic.}
}

\subtree{
\title{Derivation}
\p{Fundamental computation: \code{\startverb (Seed × Trit) → (Seed × Section)\stopverb}}

\p{Replaces temporal succession with seed-based chaining.}
}

\subtree{
\title{Stalk}
\p{Collection of sections over a single trit value. Organized as fiber bundle.}
}

\subtree{
\title{Section}
\p{Local data produced by derivation. Sections glue to form global sections when cocycle condition holds.}
}
}

\subtree{
\title{Trifurcation Pattern (MANDATORY)}
\p{Every operation MUST split into three sub-derivations:}

\pre{\startverb
             intent
                │
       ┌────────┼────────┐
       ▼        ▼        ▼
    MINUS    ERGODIC   PLUS
    (-1)      (0)      (+1)
   validate  coordinate generate
       │        │        │
       └────────┼────────┘
                ▼
           aggregate
         (verify Σ=0)
\stopverb}

\pre{\startverb
| Sub-Agent | Trit | Role | Skills |
|-----------|------|------|--------|
| MINUS | -1 | Validator | spi-parallel-verify, bisimulation-game |
| ERGODIC | 0 | Coordinator | glass-bead-game, triad-interleave |
| PLUS | +1 | Generator | gflownet, self-evolving-agent |
\stopverb}
}

\subtree{
\title{Clojure Implementation}
\subtree{
\title{Constants}
\pre{\startverb
(def GENESIS-SEED 0x42D)
(def GAMMA 0x9E3779B97F4A7C15)
(def MIX1 0xBF58476D1CE4E5B9)
(def MIX2 0x94D049BB133111EB)
\stopverb}
}

\subtree{
\title{Derivation}
\pre{\startverb
(defn derive-seed [seed trit]
  (let [adjusted (bit-xor seed (* trit GAMMA))]
    (splitmix64-next adjusted)))

(defn derivation-chain [genesis-seed trits]
  (reductions derive-seed genesis-seed trits))
\stopverb}
}

\subtree{
\title{GF(3) Arithmetic}
\pre{\startverb
(defn gf3-add [a b]
  (let [sum (+ a b)]
    (cond (> sum 1)  (- sum 3)
          (< sum -1) (+ sum 3)
          :else      sum)))

(defn gf3-conserved? [trits]
  (zero? (reduce gf3-add 0 trits)))
\stopverb}
}

\subtree{
\title{Trifurcate Pattern}
\pre{\startverb
;; Scatter: emit three roles
(aor/agg-start-node
 "scatter"
 "execute-role"
 (fn [agent-node {:keys [intent]}]
   (aor/emit! agent-node "execute-role" {:intent intent :role :minus})
   (aor/emit! agent-node "execute-role" {:intent intent :role :ergodic})
   (aor/emit! agent-node "execute-role" {:intent intent :role :plus})))

;; Gather: verify conservation
(aor/agg-node
 "execute-role"
 nil
 aggs/+vec-agg
 (fn [agent-node requests _]
   (let [results (mapv execute-role requests)
         trits (mapv :trit results)
         conserved? (gf3-conserved? trits)]
     (aor/result! agent-node {:conserved conserved? :trits trits}))))
\stopverb}
}
}

\subtree{
\title{Verification Checklist}
\p{Before any operation completes:}

\ul{
\li{[ ] GF(3) sum ≡ 0 (mod 3)}
\li{[ ] All three trits represented (trifurcation)}
\li{[ ] Cocycle condition satisfied (sections glue)}
\li{[ ] Deterministic (same seed → same result)}
\li{[ ] Order-independent (SPI holds)}
}
}

