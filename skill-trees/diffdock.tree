\subtree{
\title{Best Practices}
\ol{
\li{\strong{Always verify environment} with \code{\startverb setup_check.py\stopverb} before starting large jobs}
\li{\strong{Validate batch CSVs} with \code{\startverb prepare_batch_csv.py\stopverb} to catch errors early}
\li{\strong{Start with defaults} then tune parameters based on system-specific needs}
\li{\strong{Generate multiple samples} (10-40) for robust predictions}
\li{\strong{Visual inspection} of top poses before downstream analysis}
\li{\strong{Combine with scoring} functions for affinity assessment}
\li{\strong{Use confidence scores} for initial ranking, not final decisions}
\li{\strong{Pre-compute embeddings} for virtual screening campaigns}
\li{\strong{Document parameters} used for reproducibility}
\li{\strong{Validate results} experimentally when possible}
}
}

