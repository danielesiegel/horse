\meta{description}{Zeroth Bot - 3D-printed open-source humanoid robot platform for sim-to-real and RL research. Affordable entry point for humanoid robotics.}

\subtree{
\title{Zeroth Bot Skill}
\p{\strong{Trit}: -1 (MINUS - specification/verification) \strong{Color}: #8CC136 (Lime Green) \strong{URI}: skill://zeroth-bot#8CC136}

\subtree{
\title{Overview}
\p{Zeroth Bot (Z-Bot) is a 3D-printed open-source humanoid robot platform designed for sim-to-real research and RL experimentation. An affordable entry point for humanoid robotics.}
}

\subtree{
\title{Specifications}
\pre{\startverb
┌────────────────────────────────────────────────────────────────┐
│                      ZEROTH BOT (Z-BOT)                        │
├────────────────────────────────────────────────────────────────┤
│                                                                 │
│  Height: ~40cm                                                 │
│  Weight: ~2kg                                                  │
│  DOF: 12 joints                                                │
│                                                                 │
│  Frame: 3D printed (PLA/PETG)                                  │
│  Actuators: Servo motors                                        │
│  Cost: ~$500 BOM                                               │
│                                                                 │
│  Ideal for:                                                     │
│  ├── Learning sim-to-real transfer                             │
│  ├── Testing RL policies at low cost                           │
│  ├── Educational robotics                                      │
│  └── Rapid prototyping                                         │
│                                                                 │
└────────────────────────────────────────────────────────────────┘
\stopverb}
}

\subtree{
\title{Hardware BOM}
\pre{\startverb
| Component | Quantity | Notes |
|-----------|----------|-------|
| Servo motors | 12 | Standard hobby servos |
| 3D printed parts | Full set | STL files provided |
| MCU | 1 | ESP32 or Teensy |
| IMU | 1 | MPU6050 or similar |
| Power | 1 | 2S-3S LiPo |
\stopverb}
}

\subtree{
\title{Training Pipeline}
\pre{\startverb
from ksim.robots.zbot import ZBotConfig
from ksim import PPOTask

class ZBotWalking(PPOTask):
    robot = ZBotConfig(
        model_path="zbot.mjcf",
        servo_config={
            "kp": 50.0,
            "kd": 5.0,
            "torque_limit": 5.0,  # Smaller than K-Bot
        }
    )
    
    # Faster training due to simpler robot
    training_config = {
        "num_envs": 2048,
        "learning_rate": 5e-4,
    }
\stopverb}
}

