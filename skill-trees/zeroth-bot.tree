\subtree{
\title{Web Frontend}
\p{Z-Bot has a web-based control interface:}

\ul{
\li{Real-time telemetry visualization}
\li{Manual joint control}
\li{Policy deployment interface}
}

\pre{\startverb
// From zbot-web-frontend
import { ZBotController } from '@kscale/zbot-web';

const controller = new ZBotController({
  endpoint: 'ws://zbot.local:8080',
});

await controller.connect();
await controller.setJointPositions({
  hip_pitch_l: 0.5,
  knee_l: -0.3,
});
\stopverb}
}

