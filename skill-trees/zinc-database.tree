\subtree{
\title{Important Disclaimers}
\subtree{
\title{Data Reliability}
\p{ZINC explicitly states: \strong{"We do not guarantee the quality of any molecule for any purpose and take no responsibility for errors arising from the use of this database."}}

\ul{
\li{Compound availability may change without notice}
\li{Structure representations may contain errors}
\li{Supplier information should be verified independently}
\li{Use appropriate validation before experimental work}
}
}

\subtree{
\title{Appropriate Use}
\ul{
\li{ZINC is intended for academic and research purposes in drug discovery}
\li{Verify licensing terms for commercial use}
\li{Respect intellectual property when working with patented compounds}
\li{Follow your institution's guidelines for compound procurement}
}
}
}

