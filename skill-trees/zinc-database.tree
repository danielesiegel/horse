\subtree{
\title{Output Fields}
\p{Customize API responses with the \code{\startverb output_fields\stopverb} parameter:}

\p{\strong{Available fields}:}

\ul{
\li{\code{\startverb zinc_id\stopverb}: ZINC identifier}
\li{\code{\startverb smiles\stopverb}: SMILES string representation}
\li{\code{\startverb sub_id\stopverb}: Internal substance ID}
\li{\code{\startverb supplier_code\stopverb}: Vendor catalog number}
\li{\code{\startverb catalogs\stopverb}: List of suppliers offering the compound}
\li{\code{\startverb tranche\stopverb}: Encoded molecular properties (H-count, LogP, MW, reactivity phase)}
}

\p{\strong{Example}:}

\pre{\startverb
curl "https://cartblanche22.docking.org/substances.txt:zinc_id=ZINC000000000001&output_fields=zinc_id,smiles,catalogs,tranche"
\stopverb}
}

\subtree{
\title{Tranche System}
\p{ZINC organizes compounds into "tranches" based on molecular properties:}

\p{\strong{Format}: \code{\startverb H##P###M###-phase\stopverb}}

\ul{
\li{\strong{H##}: Number of hydrogen bond donors (00-99)}
\li{\strong{P###}: LogP × 10 (e.g., P035 = LogP 3.5)}
\li{\strong{M###}: Molecular weight in Daltons (e.g., M400 = 400 Da)}
\li{\strong{phase}: Reactivity classification}
}

\p{\strong{Example tranche}: \code{\startverb H05P035M400-0\stopverb}}

\ul{
\li{5 H-bond donors}
\li{LogP = 3.5}
\li{MW = 400 Da}
\li{Reactivity phase 0}
}

\p{Use tranche data to filter compounds by drug-likeness criteria.}
}

\subtree{
\title{Downloading 3D Structures}
\p{For molecular docking, 3D structures are available via file repositories:}

\p{\strong{File repository}: https://files.docking.org/zinc22/}

\p{Structures are organized by tranches and available in multiple formats:}

\ul{
\li{MOL2: Multi-molecule format with 3D coordinates}
\li{SDF: Structure-data file format}
\li{DB2.GZ: Compressed database format for DOCK}
}

\p{Refer to ZINC documentation at https://wiki.docking.org for downloading protocols and batch access methods.}
}

\subtree{
\title{Python Integration}
\subtree{
\title{Using curl with Python}
\pre{\startverb
import subprocess
import json

def query_zinc_by_id(zinc_id, output_fields="zinc_id,smiles,catalogs"):
    """Query ZINC22 by ZINC ID."""
    url = f"https://cartblanche22.docking.org/[email protected]_id={zinc_id}&output_fields={output_fields}"
    result = subprocess.run(['curl', url], capture_output=True, text=True)
    return result.stdout

def search_by_smiles(smiles, dist=0, adist=0, output_fields="zinc_id,smiles"):
    """Search ZINC22 by SMILES with optional distance parameters."""
    url = f"https://cartblanche22.docking.org/smiles.txt:smiles={smiles}&dist={dist}&adist={adist}&output_fields={output_fields}"
    result = subprocess.run(['curl', url], capture_output=True, text=True)
    return result.stdout

def get_random_compounds(count=100, subset=None, output_fields="zinc_id,smiles,tranche"):
    """Get random compounds from ZINC22."""
    url = f"https://cartblanche22.docking.org/substance/random.txt:count={count}&output_fields={output_fields}"
    if subset:
        url += f"&subset={subset}"
    result = subprocess.run(['curl', url], capture_output=True, text=True)
    return result.stdout
\stopverb}
}

\subtree{
\title{Parsing Results}
\pre{\startverb
import pandas as pd
from io import StringIO

# Query ZINC and parse as DataFrame
result = query_zinc_by_id("ZINC000000000001")
df = pd.read_csv(StringIO(result), sep='\t')

# Extract tranche properties
def parse_tranche(tranche_str):
    """Parse ZINC tranche code to extract properties."""
    # Format: H##P###M###-phase
    import re
    match = re.match(r'H(\d+)P(\d+)M(\d+)-(\d+)', tranche_str)
    if match:
        return {
            'h_donors': int(match.group(1)),
            'logP': int(match.group(2)) / 10.0,
            'mw': int(match.group(3)),
            'phase': int(match.group(4))
        }
    return None

df['tranche_props'] = df['tranche'].apply(parse_tranche)
\stopverb}
}
}

\subtree{
\title{Best Practices}
\subtree{
\title{Query Optimization}
\ul{
\li{\strong{Start specific}: Begin with exact searches before expanding to similarity searches}
\li{\strong{Use appropriate distance parameters}: Small dist values (1-3) for close analogs, larger (5-10) for diverse analogs}
\li{\strong{Limit output fields}: Request only necessary fields to reduce data transfer}
\li{\strong{Batch queries}: Combine multiple ZINC IDs in a single API call when possible}
}
}

\subtree{
\title{Performance Considerations}
\ul{
\li{\strong{Rate limiting}: Respect server resources; avoid rapid consecutive requests}
\li{\strong{Caching}: Store frequently accessed compounds locally}
\li{\strong{Parallel downloads}: When downloading 3D structures, use parallel wget or aria2c for file repositories}
\li{\strong{Subset filtering}: Use lead-like, drug-like, or fragment subsets to reduce search space}
}
}

\subtree{
\title{Data Quality}
\ul{
\li{\strong{Verify availability}: Supplier catalogs change; confirm compound availability before large orders}
\li{\strong{Check stereochemistry}: SMILES may not fully specify stereochemistry; verify 3D structures}
\li{\strong{Validate structures}: Use cheminformatics tools (RDKit, OpenBabel) to verify structure validity}
\li{\strong{Cross-reference}: When possible, cross-check with other databases (PubChem, ChEMBL)}
}
}
}

