\subtree{
\title{Theorem}
\p{\strong{Accessible Worlds Theorem}:}

\p{For any world W with visual representation V:}

\pre{\startverb
π_visual(W) ≅ π_tactile(W) ≅ π_auditory(W) ≅ π_haptic(W)
\stopverb}

\p{where all projections π preserve GF(3) conservation:}

\pre{\startverb
∀ modality m: Σ(trits(π_m(W))) ≡ 0 (mod 3)
\stopverb}

\p{*"The most unlike skills are the most essential - they bridge what others cannot reach."*}
}

