\subtree{
\title{Build System}
\subtree{
\title{Lake Configuration}
\pre{\startverb
[package]
name = "music-topos"
version = "0.1.0"

[dependencies]
mathlib = { version = "v4.14.0" }
\stopverb}
}

\subtree{
\title{Build Commands}
\pre{\startverb
# Build all proofs
lake build

# Check specific module
lake env lean MusicTopos/SpectralGap.lean

# Generate documentation
lake doc

# Extract to Haskell
lake build --target haskell

# Extract to Wasm
lake build --target wasm
\stopverb}
}
}

\subtree{
\title{Performance}
\ul{
\li{\strong{Type-checking time}: ~10-30 seconds (full system)}
\li{\strong{Proof verification}: < 1 second per theorem}
\li{\strong{Compilation to Haskell}: 3-5 seconds}
\li{\strong{Memory}: ~100MB for full lakefile build}
}
}

