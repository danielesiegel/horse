\subtree{
\title{Mathematical Foundation}
\subtree{
\title{Blume-Capel Model}
\ul{
\li{Tricritical point at β = ln(1 + √2) ≈ 0.881}
\li{Spectral gap λ₂ = 1/4 (exactly)}
\li{Mixing time = 4 iterations}
\li{Applied to SPI color convergence}
}
}

\subtree{
\title{Color Space (CIEDE2000)}
\ul{
\li{LCH coordinates: L* (lightness), C* (chroma), h (hue)}
\li{ΔE = √[(ΔL/kL·SL)² + (ΔC/kC·SC)² + (ΔH/kH·SH)²]}
\li{Perceptual equivalence: ΔE < 0.3}
}
}

\subtree{
\title{CRDT Properties}
\ul{
\li{\strong{Associativity}: (a ⊔ b) ⊔ c = a ⊔ (b ⊔ c)}
\li{\strong{Commutativity}: a ⊔ b = b ⊔ a}
\li{\strong{Idempotence}: a ⊔ a = a}
\li{\strong{Monotonicity}: a ≤ (a ⊔ b)}
}
}

\subtree{
\title{p-adic Color Matching}
\ul{
\li{Valuation v₃(n) = highest power of 3 dividing n}
\li{Colors match at depth d iff v₃(c₁ - c₂) ≥ d}
\li{Hierarchical matching (depth = precision)}
}
}
}

