\subtree{
\title{Filter Operators}
\p{ChEMBL supports Django-style query filters:}

\ul{
\li{\code{\startverb __exact\stopverb} - Exact match}
\li{\code{\startverb __iexact\stopverb} - Case-insensitive exact match}
\li{\code{\startverb \strong{contains\stopverb} / \code{\startverb }icontains\stopverb} - Substring matching}
\li{\code{\startverb \strong{startswith\stopverb} / \code{\startverb }endswith\stopverb} - Prefix/suffix matching}
\li{\code{\startverb \strong{gt\stopverb}, \code{\startverb }gte\stopverb}, \code{\startverb \strong{lt\stopverb}, \code{\startverb }lte\stopverb} - Numeric comparisons}
\li{\code{\startverb __range\stopverb} - Value in range}
\li{\code{\startverb __in\stopverb} - Value in list}
\li{\code{\startverb __isnull\stopverb} - Null/not null check}
}
}

\subtree{
\title{Data Export and Analysis}
\p{Convert results to pandas DataFrame for analysis:}

\pre{\startverb
import pandas as pd

activities = new_client.activity.filter(target_chembl_id='CHEMBL203')
df = pd.DataFrame(list(activities))

# Analyze results
print(df['standard_value'].describe())
print(df.groupby('standard_type').size())
\stopverb}
}

\subtree{
\title{Performance Optimization}
\subtree{
\title{Caching}
\p{The client automatically caches results for 24 hours. Configure caching:}

\pre{\startverb
from chembl_webresource_client.settings import Settings

# Disable caching
Settings.Instance().CACHING = False

# Adjust cache expiration (seconds)
Settings.Instance().CACHE_EXPIRE = 86400
\stopverb}
}

\subtree{
\title{Lazy Evaluation}
\p{Queries execute only when data is accessed. Convert to list to force execution:}

\pre{\startverb
# Query is not executed yet
results = molecule.filter(pref_name__icontains='aspirin')

# Force execution
results_list = list(results)
\stopverb}
}

\subtree{
\title{Pagination}
\p{Results are paginated automatically. Iterate through all results:}

\pre{\startverb
for activity in new_client.activity.filter(target_chembl_id='CHEMBL203'):
    # Process each activity
    print(activity['molecule_chembl_id'])
\stopverb}
}
}

\subtree{
\title{Common Use Cases}
\subtree{
\title{Find Kinase Inhibitors}
\pre{\startverb
# Identify kinase targets
kinases = new_client.target.filter(
    target_type='SINGLE PROTEIN',
    pref_name__icontains='kinase'
)

# Get potent inhibitors
for kinase in kinases[:5]:  # First 5 kinases
    activities = new_client.activity.filter(
        target_chembl_id=kinase['target_chembl_id'],
        standard_type='IC50',
        standard_value__lte=50
    )
\stopverb}
}

\subtree{
\title{Explore Drug Repurposing}
\pre{\startverb
# Get approved drugs
drugs = new_client.drug.filter()

# For each drug, find all targets
for drug in drugs[:10]:
    mechanisms = new_client.mechanism.filter(
        molecule_chembl_id=drug['molecule_chembl_id']
    )
\stopverb}
}

\subtree{
\title{Virtual Screening}
\pre{\startverb
# Find compounds with desired properties
candidates = new_client.molecule.filter(
    molecule_properties__mw_freebase__range=[300, 500],
    molecule_properties__alogp__lte=5,
    molecule_properties__hba__lte=10,
    molecule_properties__hbd__lte=5
)
\stopverb}
}
}

