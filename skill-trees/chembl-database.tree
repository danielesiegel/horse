\subtree{
\title{Important Notes}
\subtree{
\title{Data Reliability}
\ul{
\li{ChEMBL data is manually curated but may contain inconsistencies}
\li{Always check \code{\startverb data_validity_comment\stopverb} field in activity records}
\li{Be aware of \code{\startverb potential_duplicate\stopverb} flags}
}
}

\subtree{
\title{Units and Standards}
\ul{
\li{Bioactivity values use standard units (nM, uM, etc.)}
\li{\code{\startverb pchembl_value\stopverb} provides normalized activity (-log scale)}
\li{Check \code{\startverb standard_type\stopverb} to understand measurement type (IC50, Ki, EC50, etc.)}
}
}

\subtree{
\title{Rate Limiting}
\ul{
\li{Respect ChEMBL's fair usage policies}
\li{Use caching to minimize repeated requests}
\li{Consider bulk downloads for large datasets}
\li{Avoid hammering the API with rapid consecutive requests}
}
}

\subtree{
\title{Chemical Structure Formats}
\ul{
\li{SMILES strings are the primary structure format}
\li{InChI keys available for compounds}
\li{SVG images can be generated via the image endpoint}
}
}
}

