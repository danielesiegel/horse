\title{Chembl Database}

\taxon{skill}

\meta{description}{"Query ChEMBL's bioactive molecules and drug discovery data. Search compounds by structure/properties, retrieve bioactivity data (IC50, Ki), find inhibitors, perform SAR studies, for medicinal chemistry."}

\subtree{
\title{ChEMBL Database}
\subtree{
\title{Overview}
\p{ChEMBL is a manually curated database of bioactive molecules maintained by the European Bioinformatics Institute (EBI), containing over 2 million compounds, 19 million bioactivity measurements, 13,000+ drug targets, and data on approved drugs and clinical candidates. Access and query this data programmatically using the ChEMBL Python client for drug discovery and medicinal chemistry research.}
}

\subtree{
\title{When to Use This Skill}
\p{This skill should be used when:}

\ul{
\li{\strong{Compound searches}: Finding molecules by name, structure, or properties}
\li{\strong{Target information}: Retrieving data about proteins, enzymes, or biological targets}
\li{\strong{Bioactivity data}: Querying IC50, Ki, EC50, or other activity measurements}
\li{\strong{Drug information}: Looking up approved drugs, mechanisms, or indications}
\li{\strong{Structure searches}: Performing similarity or substructure searches}
\li{\strong{Cheminformatics}: Analyzing molecular properties and drug-likeness}
\li{\strong{Target-ligand relationships}: Exploring compound-target interactions}
\li{\strong{Drug discovery}: Identifying inhibitors, agonists, or bioactive molecules}
}
}

\subtree{
\title{Installation and Setup}
\subtree{
\title{Python Client}
\p{The ChEMBL Python client is required for programmatic access:}

\pre{\startverb
uv pip install chembl_webresource_client
\stopverb}
}

\subtree{
\title{Basic Usage Pattern}
\pre{\startverb
from chembl_webresource_client.new_client import new_client

# Access different endpoints
molecule = new_client.molecule
target = new_client.target
activity = new_client.activity
drug = new_client.drug
\stopverb}
}
}

\subtree{
\title{Core Capabilities}
\subtree{
\title{1. Molecule Queries}
\p{\strong{Retrieve by ChEMBL ID:}}

\pre{\startverb
molecule = new_client.molecule
aspirin = molecule.get('CHEMBL25')
\stopverb}

\p{\strong{Search by name:}}

\pre{\startverb
results = molecule.filter(pref_name__icontains='aspirin')
\stopverb}

\p{\strong{Filter by properties:}}

\pre{\startverb
# Find small molecules (MW <= 500) with favorable LogP
results = molecule.filter(
    molecule_properties__mw_freebase__lte=500,
    molecule_properties__alogp__lte=5
)
\stopverb}
}

\subtree{
\title{2. Target Queries}
\p{\strong{Retrieve target information:}}

\pre{\startverb
target = new_client.target
egfr = target.get('CHEMBL203')
\stopverb}

\p{\strong{Search for specific target types:}}

\pre{\startverb
# Find all kinase targets
kinases = target.filter(
    target_type='SINGLE PROTEIN',
    pref_name__icontains='kinase'
)
\stopverb}
}

\subtree{
\title{3. Bioactivity Data}
\p{\strong{Query activities for a target:}}

\pre{\startverb
activity = new_client.activity
# Find potent EGFR inhibitors
results = activity.filter(
    target_chembl_id='CHEMBL203',
    standard_type='IC50',
    standard_value__lte=100,
    standard_units='nM'
)
\stopverb}

\p{\strong{Get all activities for a compound:}}

\pre{\startverb
compound_activities = activity.filter(
    molecule_chembl_id='CHEMBL25',
    pchembl_value__isnull=False
)
\stopverb}
}

\subtree{
\title{4. Structure-Based Searches}
\p{\strong{Similarity search:}}

\pre{\startverb
similarity = new_client.similarity
# Find compounds similar to aspirin
similar = similarity.filter(
    smiles='CC(=O)Oc1ccccc1C(=O)O',
    similarity=85  # 85% similarity threshold
)
\stopverb}

\p{\strong{Substructure search:}}

\pre{\startverb
substructure = new_client.substructure
# Find compounds containing benzene ring
results = substructure.filter(smiles='c1ccccc1')
\stopverb}
}

\subtree{
\title{5. Drug Information}
\p{\strong{Retrieve drug data:}}

\pre{\startverb
drug = new_client.drug
drug_info = drug.get('CHEMBL25')
\stopverb}

\p{\strong{Get mechanisms of action:}}

\pre{\startverb
mechanism = new_client.mechanism
mechanisms = mechanism.filter(molecule_chembl_id='CHEMBL25')
\stopverb}

\p{\strong{Query drug indications:}}

\pre{\startverb
drug_indication = new_client.drug_indication
indications = drug_indication.filter(molecule_chembl_id='CHEMBL25')
\stopverb}
}
}

