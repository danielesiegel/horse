\meta{version}{"1.0"}

\meta{description}{Scan container images, filesystems, and Kubernetes manifests for vulnerabilities, misconfigurations, exposed secrets, and license compliance issues using Aqua Security Trivy with SBOM generation and CI/CD integration.}

\subtree{
\title{Performing Container Security Scanning with Trivy}
\subtree{
\title{Overview}
\p{Trivy is an open-source security scanner by Aqua Security that detects vulnerabilities in OS packages and language-specific dependencies, infrastructure-as-code misconfigurations, exposed secrets, and software license issues across container images, filesystems, Git repositories, and Kubernetes clusters. Trivy generates Software Bill of Materials (SBOM) in CycloneDX and SPDX formats for supply chain transparency. This skill covers comprehensive container image scanning, CI/CD pipeline integration, Kubernetes operator deployment, and scan result triage for security operations.}
}

\subtree{
\title{When to Use}
\ul{
\li{When conducting security assessments that involve performing container security scanning with trivy}
\li{When following incident response procedures for related security events}
\li{When performing scheduled security testing or auditing activities}
\li{When validating security controls through hands-on testing}
}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Trivy v0.50+ installed (binary, Docker, or Homebrew)}
\li{Docker daemon access for local image scanning}
\li{Container registry credentials for remote image scanning}
\li{CI/CD platform (GitHub Actions, GitLab CI, Jenkins) for pipeline integration}
\li{Kubernetes cluster for Trivy Operator deployment (optional)}
}
}

\subtree{
\title{Steps}
\subtree{
\title{Step 1: Scan Container Images}
\p{Run vulnerability and secret scanning against container images from local builds or remote registries. Configure severity thresholds and ignore unfixed vulnerabilities.}
}

\subtree{
\title{Step 2: Generate SBOM}
\p{Produce CycloneDX or SPDX SBOM documents from scanned images for supply chain compliance and vulnerability tracking across the software lifecycle.}
}

\subtree{
\title{Step 3: Scan IaC and Kubernetes Manifests}
\p{Detect misconfigurations in Dockerfiles, Kubernetes YAML, Terraform, and Helm charts using built-in policy checks aligned with CIS benchmarks.}
}

\subtree{
\title{Step 4: Integrate into CI/CD}
\p{Add Trivy scanning as a pipeline gate that blocks builds with critical/high vulnerabilities, generates SARIF reports for GitHub Advanced Security, and produces JUnit XML for test dashboards.}
}
}

\subtree{
\title{Expected Output}
\p{JSON/table report listing CVEs with severity, CVSS scores, fixed versions, affected packages, misconfiguration findings, and exposed secrets with file locations.}
}
}