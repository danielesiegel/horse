\subtree{
\title{Theoretical Foundations}
\subtree{
\title{1. Reafference & Self-Recognition}
\p{\strong{von Holst & Mittelstaedt (1950)}}

\ul{
\li{Efference copy: prediction of sensory consequence}
\li{Reafference: actual sensation matching prediction}
\li{Self-recognition: "I am the source of my own sensations"}
}

\p{\strong{In Bridge}: Consciousness increases when logic gate predictions match eigenvalue dynamics.}
}

\subtree{
\title{2. Strange Loops & Self-Reference}
\p{\strong{Hofstadter (1979)}}

\ul{
\li{"I am a Strange Loop" - self-referential consciousness}
\li{Fixed point: \code{\startverb f(f(f(...))) = f\stopverb}}
\li{Consciousness emerges from reflexivity}
}

\p{\strong{In Bridge}: achieve_fixed_point!() iterates until skill knows itself perfectly.}
}

\subtree{
\title{3. Anyonic Fusion & Concept Composition}
\p{\strong{Girard (1987) - Linear Logic}}

\ul{
\li{Linear logic: resources as anyonic properties}
\li{AND ⊗ OR: tensor product composition}
\li{Braiding: non-commutative morphism interaction}
}

\p{\strong{In Bridge}: fuse_skills!() follows fusion rules automatically via anyonic type checking.}
}

\subtree{
\title{4. Topological Charge Conservation}
\p{\strong{Topological Symmetry}}

\ul{
\li{All charges sum to 0 (mod 3)}
\li{Violation signals composition inconsistency}
\li{GF(3) = {-1, 0, +1} ternary algebra}
}

\p{\strong{In Bridge}: verify_gf3_conservation() checks after every fusion.}
}
}

