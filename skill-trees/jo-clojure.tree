\subtree{
\title{REPL Startup}
\p{Create \code{\startverb ~/.clojure/repl-init.clj\stopverb}:}

\pre{\startverb
; Load commonly used skills
(require '[clojure.java.io :as io])
(require '[clojure.string :as str])
(require '[clojure.pprint :as pp])

(defn skills-dir []
  "/Users/bob/i/boxxy/skills")

(defn load-skill [name]
  (println (format "Loading skill: %s" name)))

(println "Boxxy skill coordinator ready")
(println "  skills-dir    - show skills directory")
(println "  load-skill    - load a skill by name")
\stopverb}
}
}

\subtree{
\title{When to Use}
\ul{
\li{\strong{Coordinating multi-language skills}: Compose Go, Clojure, Hy, and Zig tools}
\li{\strong{GF(3) validation}: Check that skill triads maintain conservation}
\li{\strong{Skill discovery}: List and inspect available skills}
\li{\strong{Dynamic dispatch}: Route to different implementations based on input}
\li{\strong{JVM ecosystem integration}: Manage Clojure, Babashka, and other JVM tools}
\li{\strong{REPL-based development}: Interactive skill testing and composition}
}
}

\subtree{
\title{When NOT to Use}
\ul{
\li{Simple single-language tasks (use language-specific skills directly)}
\li{Performance-critical code (use native Go/Zig skills)}
\li{Tasks not requiring triadic balance (simpler coordination systems exist)}
}
}

\subtree{
\title{GF(3) Conservation}
\p{jo-clojure is assigned \strong{trit = 0 (ERGODIC)} for coordinator role:}

\pre{\startverb
Validator (-1) + Coordinator (0) + Generator (+1) ≡ 0 (mod 3)
 [joker]        [jo-clojure]      [hy-regime]
\stopverb}

\p{Ensures every triadic composition maintains GF(3) sum ≡ 0 (mod 3).}
}

\subtree{
\title{Common Tasks}
\subtree{
\title{Load All Skills and Check Balance}
\pre{\startverb
(let [skills (skills/list-all-skills "/Users/bob/i/boxxy/skills")
      trits (map :gf3-trit skills)]
  (println "Total trits:" (apply + trits))
  (println "Balanced?" (zero? (mod (apply + trits) 3))))
\stopverb}
}

\subtree{
\title{Compose Three Skills}
\pre{\startverb
(let [validator (skills/find "joker-sims-parser")
      coordinator (skills/find "jo-clojure")
      generator (skills/find "hy-regime")]
  (triadic/validate-triad [validator coordinator generator])
  (triadic/execute [validator coordinator generator] input-data))
\stopverb}
}

\subtree{
\title{Dynamic Skill Invocation}
\pre{\startverb
(invoke-skill {:language :go
               :binary "/Users/bob/i/boxxy/bin/joker"
               :flags ["parse" "save.sims3pack"]})
\stopverb}
}
}

\subtree{
\title{Troubleshooting}
\p{\strong{"command not found: clojure"}}

\ul{
\li{Install Clojure CLI: \code{\startverb brew install clojure/tools/clojure\stopverb}}
\li{Verify: \code{\startverb clojure -version\stopverb}}
}

\p{\strong{Dependency resolution errors}}

\ul{
\li{Clear cache: \code{\startverb rm -rf ~/.m2/repository\stopverb}}
\li{Update indices: \code{\startverb clojure -X:deps list-aliases\stopverb}}
}

\p{\strong{REPL not starting}}

\ul{
\li{Check Java version: \code{\startverb java -version\stopverb} (requires 11+)}
\li{Verify Clojure: \code{\startverb clojure -e '(clojure-version)'\stopverb}}
}

\p{\strong{GF(3) validation failures}}

\ul{
\li{Check trit assignments in skill metadata}
\li{Verify sum: \code{\startverb (+ -1 0 1)\stopverb} should equal 0}
}
}

