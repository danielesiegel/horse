\subtree{
\title{Key Principles}
\p{Follow these principles when working with LaminDB:}

\ol{
\li{\strong{Track everything}: Use \code{\startverb ln.track()\stopverb} at the start of every analysis for automatic lineage capture}
}

\ol{
\li{\strong{Validate early}: Define schemas and validate data before extensive analysis}
}

\ol{
\li{\strong{Use ontologies}: Leverage public biological ontologies for standardized annotations}
}

\ol{
\li{\strong{Organize with keys}: Structure artifact keys hierarchically (e.g., \code{\startverb project/experiment/batch/file.h5ad\stopverb})}
}

\ol{
\li{\strong{Query metadata first}: Filter and search before loading large files}
}

\ol{
\li{\strong{Version, don't duplicate}: Use built-in versioning instead of creating new keys for modifications}
}

\ol{
\li{\strong{Annotate with features}: Define typed features for queryable metadata}
}

\ol{
\li{\strong{Document thoroughly}: Add descriptions to artifacts, schemas, and transforms}
}

\ol{
\li{\strong{Leverage lineage}: Use \code{\startverb view_lineage()\stopverb} to understand data provenance}
}

\ol{
\li{\strong{Start local, scale cloud}: Develop locally with SQLite, deploy to cloud with PostgreSQL}
}
}

