\subtree{
\title{Bundled Resources}
\subtree{
\title{References - Progressive Loading Guide}
\p{\strong{Important:} References are version-specific. Use \code{\startverb scripts/get_references.py\stopverb} to get the correct reference path for the detected Zig version, or load from \code{\startverb references/latest/\stopverb} (symlink to current stable: 0.15.2).}

\p{Load documentation progressively based on task complexity. Use this decision tree:}

\p{\strong{New to Zig?} Start with fundamentals in order:}

\ol{
\li{\code{\startverb references/latest/core-language.md\stopverb} → Basic syntax, types, operators}
\li{\code{\startverb references/latest/control-flow.md\stopverb} → If, while, for, switch}
\li{\code{\startverb references/latest/functions-errors.md\stopverb} → Functions and error handling}
\li{\code{\startverb references/latest/quick-reference.md\stopverb} → Syntax quick lookup}
}

\p{\strong{Solving specific problems?} Jump directly to:}

\ul{
\li{\strong{Error handling} → \code{\startverb latest/functions-errors.md\stopverb} + \code{\startverb latest/patterns-error-testing.md\stopverb}}
\li{\strong{Memory/allocators} → \code{\startverb latest/memory-management.md\stopverb} + \code{\startverb latest/patterns-memory-comptime.md\stopverb}}
\li{\strong{Data structures} → \code{\startverb latest/arrays-slices.md\stopverb}, \code{\startverb latest/structs-methods.md\stopverb}, \code{\startverb latest/enums-unions.md\stopverb}, \code{\startverb latest/pointers-references.md\stopverb}}
\li{\strong{Struct/array/enum patterns} → \code{\startverb latest/patterns-data-structures.md\stopverb}}
\li{\strong{Stdlib lookup} → grep \code{\startverb latest/stdlib-builtins.md\stopverb} (large file, 68KB)}
\li{\strong{C interop} → \code{\startverb latest/c-interop.md\stopverb} + \code{\startverb latest/patterns-integration.md\stopverb}}
\li{\strong{Build system} → \code{\startverb latest/build-system.md\stopverb} + \code{\startverb latest/patterns-integration.md\stopverb}}
}

\p{\strong{Advanced topics} (after mastering fundamentals):}

\ul{
\li{\code{\startverb references/latest/comptime.md\stopverb} - Compile-time execution and generics}
\li{\code{\startverb references/latest/patterns-memory-comptime.md\stopverb} - Advanced memory and comptime patterns}
\li{\code{\startverb references/latest/testing-quality.md\stopverb} - Testing framework and best practices}
}

\p{\strong{Version migration} → \code{\startverb references/version-differences.md\stopverb} (shared across versions, comprehensive migration guides)}

\p{\strong{Using version-specific references:}}

\pre{\startverb
# Get reference path for detected version
python scripts/get_references.py
# Output: references/v0.15.2

# With specific version
python scripts/get_references.py --version 0.13.0
# Output: references/v0.15.2 (with fallback warning)

# JSON output for programmatic use
python scripts/get_references.py --json
\stopverb}
}

