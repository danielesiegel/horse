\li{\code{\startverb get_target_info()\stopverb} - Retrieve target annotations}
\li{\code{\startverb get_disease_info()\stopverb} - Retrieve disease information}
\li{\code{\startverb get_target_disease_evidence()\stopverb} - Get supporting evidence}
\li{\code{\startverb get_known_drugs_for_disease()\stopverb} - Find drugs for a disease}
\li{\code{\startverb get_drug_info()\stopverb} - Retrieve drug details}
\li{\code{\startverb get_target_associations()\stopverb} - Get all associations for a target}
\li{\code{\startverb execute_query()\stopverb} - Execute custom GraphQL queries}
}
}

