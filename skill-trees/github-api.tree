\subtree{
\title{Best Practices Summary}
\subtree{
\title{1. Rate Limiting}
\ul{
\li{Use conditional requests with ETags to avoid counting against limits}
\li{Implement exponential backoff when hitting limits}
\li{Use GraphQL for complex multi-resource queries}
\li{Check \code{\startverb rate_limit\stopverb} endpoint before batch operations}
}
}

\subtree{
\title{2. Authentication}
\ul{
\li{Use fine-grained PATs with minimal scopes}
\li{Prefer GitHub Apps for integrations}
\li{Use \code{\startverb gh\stopverb} CLI when available}
\li{Never commit tokens to version control}
}
}

\subtree{
\title{3. Error Handling}
\ul{
\li{Implement retry logic with exponential backoff}
\li{Validate input before sending requests}
\li{Check rate limits before making requests}
\li{Log errors with context}
}
}

\subtree{
\title{4. Performance}
\ul{
\li{Use GraphQL for complex data requirements combining multiple resources}
\li{Implement pagination properly}
\li{Cache responses when appropriate}
\li{Use webhooks instead of polling}
}

\p{→ See \code{\startverb resources/rest-api-basics.md\stopverb} for detailed patterns}
}
}

\subtree{
\title{GraphQL vs REST Decision Tree}
\p{\strong{Use GraphQL API v4 when:}}

\ul{
\li{Querying multiple related resources (e.g., repo + issues + PRs in one call)}
\li{Complex filtering or sorting requirements}
\li{Need precise field selection (bandwidth optimization)}
\li{Working with Projects V2}
}

\p{\strong{Use REST API v3 when:}}

\ul{
\li{Simple, straightforward resource operations}
\li{Comfort with REST patterns}
\li{Legacy integrations}
\li{Bulk operations (GitHub CLI integration)}
}
}

