\title{Github Api}

\taxon{skill}

\meta{version}{2.0}

\meta{description}{Orchestrates comprehensive GitHub API access across all services. Intelligently routes API operations to specialized resource files covering authentication, repositories, issues/PRs, workflows, security, and more. Use when implementing GitHub integrations, automating operations, or building applications that interact with GitHub.}

\subtree{
\title{GitHub API Orchestration Skill}
\p{Comprehensive skill for working with the GitHub API across all services and operations. This skill provides intelligent routing to focused resource files covering both REST API v3 and GraphQL API v4.}

