\subtree{
\title{Org Entry Template}
\pre{\startverb
** STATE #RANK: SUMMARY
:PROPERTIES:
:SESSION_ID: SESSION_ID_OR_DATE
:SOURCE:     SOURCE
:RANK:       RANK
:THEME:      THEME_NAME
:TAG:        @TAG
:START:      [YYYY-MM-DD DAY]
:END:

*** Context
- Brief context line 1
- Brief context line 2

*** Tasks
- [ ] Task 1
- [ ] Task 2
\stopverb}

\subtree{
\title{Fields}
\ul{
\li{\strong{STATE}: One of \code{\startverbSTARTED\stopverb}, \code{\startverbIN_PROGRESS\stopverb}, \code{\startverbSUBSTANTIAL\stopverb}, \code{\startverbABANDONED\stopverb}, \code{\startverbCOMPLETED\stopverb}}
\li{\strong{RANK}: Auto-incremented via \code{\startverbscripts/next-rank.sh\stopverb}}
\li{\strong{SUMMARY}: First 120 chars of goal description}
\li{\strong{SESSION_ID}: From \code{\startverb.claude/history.jsonl\stopverb} or \code{\startverb.factory/history.json\stopverb}, or \code{\startverbsession-YYYY-MM-DD\stopverb} if manual}
\li{\strong{SOURCE}: \code{\startverbclaude\stopverb}, \code{\startverbfactory\stopverb}, or \code{\startverbconversation\stopverb}}
\li{\strong{START}: Today's date in org timestamp format \code{\startverb[YYYY-MM-DD DAY]\stopverb}}
}
}
}

\subtree{
\title{Placement}
\p{Append the new entry inside the matching \code{\startverb* THEME (N)\stopverb} section if it exists. If the theme section doesn't exist yet, create it before \code{\startverb* Cross-References\stopverb}. Update the count in the theme heading.}
}

\subtree{
\title{Target File}
\p{Currently: \code{\startverb/Users/alice/v/goals-119.org\stopverb}. When rank exceeds ~170, start a new \code{\startverbgoals-169.org\stopverb}.}
}
}