\meta{version}{2.0.0}

\meta{description}{Comprehensive GitHub release orchestration with AI swarm coordination for automated versioning, testing, deployment, and rollback management}

\subtree{
\title{GitHub Release Management Skill}
\p{Intelligent release automation and orchestration using AI swarms for comprehensive software releases - from changelog generation to multi-platform deployment with rollback capabilities.}

\subtree{
\title{Quick Start}
\subtree{
\title{Simple Release Flow}
\pre{\startverb
# Plan and create a release
gh release create v2.0.0 \
  --draft \
  --generate-notes \
  --title "Release v2.0.0"

# Orchestrate with swarm
npx claude-flow github release-create \
  --version "2.0.0" \
  --build-artifacts \
  --deploy-targets "npm,docker,github"
\stopverb}
}

\subtree{
\title{Full Automated Release}
\pre{\startverb
# Initialize release swarm
npx claude-flow swarm init --topology hierarchical

# Execute complete release pipeline
npx claude-flow sparc pipeline "Release v2.0.0 with full validation"
\stopverb}
}
}

