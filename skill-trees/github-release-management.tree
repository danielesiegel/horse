\subtree{
\title{Appendix: Release Checklist Template}
\subtree{
\title{Pre-Release Checklist}
\ul{
\li{[ ] Version numbers updated across all packages}
\li{[ ] Changelog generated and reviewed}
\li{[ ] Breaking changes documented with migration guide}
\li{[ ] All tests passing (unit, integration, e2e)}
\li{[ ] Security scan completed with no critical issues}
\li{[ ] Performance benchmarks within acceptable range}
\li{[ ] Documentation updated (API docs, README, examples)}
\li{[ ] Release notes drafted and reviewed}
\li{[ ] Stakeholders notified of upcoming release}
\li{[ ] Deployment plan reviewed and approved}
}
}

\subtree{
\title{Release Checklist}
\ul{
\li{[ ] Release branch created and validated}
\li{[ ] CI/CD pipeline completed successfully}
\li{[ ] Artifacts built and verified}
\li{[ ] GitHub release created with proper notes}
\li{[ ] Packages published to registries}
\li{[ ] Docker images pushed to container registry}
\li{[ ] Deployment to staging successful}
\li{[ ] Smoke tests passing in staging}
\li{[ ] Production deployment completed}
\li{[ ] Health checks passing}
}
}

\subtree{
\title{Post-Release Checklist}
\ul{
\li{[ ] Release announcement published}
\li{[ ] Monitoring dashboards reviewed}
\li{[ ] Error rates within normal range}
\li{[ ] Performance metrics stable}
\li{[ ] User feedback collected}
\li{[ ] Documentation links verified}
\li{[ ] Release retrospective scheduled}
\li{[ ] Next release planning initiated}
}

