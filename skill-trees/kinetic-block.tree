\subtree{
\title{GF(3) Conservation Proof}
\p{For any kinetic block K with components (s, f, c):}

\pre{\startverb
trit(s) + trit(f) + trit(c) = (-1) + 0 + 1 = 0 ≡ 0 (mod 3) ✓
\stopverb}

\p{The kinetic block is \strong{closed under composition}: composing two blocks preserves conservation.}

\pre{\startverb
K₁ ⊗ K₂ = (s₁⊗s₂, f₁⊗f₂, c₁⊗c₂)
Σ trits = 2×((-1) + 0 + 1) = 0 ✓
\stopverb}
}

\subtree{
\title{Information Energy Framework}
\subtree{
\title{Kinetic Information Energy (KIE)}
\p{\strong{Definition}: Energy associated with \em{active} information flow—computation in progress.}

\pre{\startverb
KIE = ½ × m_info × v²_processing

where:
  m_info = information mass (bits in transit)
  v_processing = processing velocity (bits/sec)
\stopverb}

\p{In the kinetic block:}

\ul{
\li{\strong{Stratification} → KIE increases (layer separation requires work)}
\li{\strong{Fabrication} → KIE converts to structure (composition crystallizes)}
\li{\strong{Conservation} → KIE verified (no energy leak)}
}
}

\subtree{
\title{Potential Information Energy (PIE)}
\p{\strong{Definition}: Energy stored in \em{latent} structure—information ready to be activated.}

\pre{\startverb
PIE = m_info × g_entropy × h_depth

where:
  m_info = information mass (bits stored)
  g_entropy = entropy gradient (bits/layer)
  h_depth = structural depth (layers)
\stopverb}

\p{Energy wells correspond to:}

\ul{
\li{\strong{H^0 generators}: Stable configurations (local minima)}
\li{\strong{Cohomology obstructions}: Barriers between wells}
\li{\strong{Spectral gap}: Minimum energy to transition between wells}
}
}

\subtree{
\title{Free Energy Principle}
\p{From Friston's active inference:}

\pre{\startverb
F = Prediction Error + Model Complexity
F = D_KL[Q(s) || P(s|o)] + E_Q[log P(o,s)]
\stopverb}

\p{In kinetic blocks:}

\ul{
\li{\strong{Prediction}: Expected color from seed}
\li{\strong{Observation}: Actual color generated}
\li{\strong{Free Energy}: Hue difference / 180° (normalized)}
}
}

\subtree{
\title{Energy Conservation}
\pre{\startverb
Total Energy = KIE + PIE = constant

When KIE ↑ (active processing):
  - PIE ↓ (structure being consumed)
  - Free energy fluctuates
  
When KIE ↓ (processing complete):
  - PIE ↑ (new structure formed)
  - Free energy minimized
\stopverb}
}

\subtree{
\title{Markov Blanket as Energy Boundary}
\p{The Markov blanket separates:}

\ul{
\li{\strong{Internal states}: PIE reservoir (stored structure)}
\li{\strong{External states}: Environment (potential KIE source)}
\li{\strong{Blanket states}: Energy exchange interface}
}

\pre{\startverb
# From Gay.jl markov_blanket tool
blanket = MarkovBlanket(internal_seed=35271, external_seed=42069)

# Permeability determines energy flow rate
if blanket.permeable
    KIE_flow = gradient(PIE_internal, PIE_external)
else
    KIE_flow = 0  # Insulated system
end
\stopverb}
}

\subtree{
\title{PCT Energy Dynamics}
\p{Powers' Perceptual Control Theory provides the control loop:}

\pre{\startverb
Reference (desired PIE state)
    ↓
Comparator: error = reference - perception
    ↓
Output: corrective action (KIE expenditure)
    ↓
Environment: action affects world
    ↓
Sensor: new perception (updated PIE)
    ↓
Loop continues until error ≈ 0
\stopverb}

\p{\strong{Gain} controls KIE/PIE conversion efficiency:}

\ul{
\li{High gain (0.8-1.0): Rapid response, oscillation risk}
\li{Low gain (0.1-0.3): Slow response, stable convergence}
}
}

\subtree{
\title{Valence as Energy Gradient}
\p{From QRI's Symmetry Theory of Valence:}

\pre{\startverb
Valence = -∇(Defect Density)

High valence: Smooth field, low defects, PIE minimum
Low valence: Frustrated field, high defects, PIE maximum
\stopverb}

\p{Kinetic blocks operate optimally at \strong{BKT critical temperature} τ* ≈ 0.5:}

\ul{
\li{Defects mobile enough to annihilate (KIE available)}
\li{Not proliferating (PIE stable)}
}
}

