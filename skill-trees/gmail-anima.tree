\title{Gmail Anima}

\taxon{skill}

\meta{description}{Gmail inbox management via ANIMA condensation. Transforms messages into GF(3)-typed Interactions, routes to triadic queues, detects saturation for inbox-zero-as-condensed-state. Use for email triage, workflow automation, or applying ANIMA principles to Gmail.}

\subtree{
\title{Gmail ANIMA Skill}
\p{Transform Gmail into an ANIMA-condensed system with GF(3) conservation.}

\p{\strong{Trit}: 0 (ERGODIC - coordinator) \strong{Principle}: Inbox Zero = Condensed Equilibrium State \strong{Implementation}: GmailACSet + TriadicQueues + AnimaDetector}

\subtree{
\title{Overview}
\p{Gmail ANIMA applies the ANIMA framework to email:}

\ol{
\li{\strong{Transform} - Messages → GF(3)-typed Interactions}
\li{\strong{Route} - Interactions → Triadic queue fibers (MINUS/ERGODIC/PLUS)}
\li{\strong{Detect} - Saturation → ANIMA condensed state}
\li{\strong{Verify} - Narya proofs for consistency}
}
}

\subtree{
\title{GmailACSet Schema}
\pre{\startverb
┌────────────────────────────────────────────────────────────────────┐
│                      GmailACSet Schema                             │
├────────────────────────────────────────────────────────────────────┤
│                                                                    │
│  Interaction ─────┬────▶ Thread                                   │
│  ├─ verb: String  │      ├─ thread_id: String                     │
│  ├─ timebin: Int  │      ├─ needs_action: Bool                    │
│  ├─ trit: Trit    │      ├─ last_action_bin: Int                  │
│  └─ person ───────┼──▶   └─ saturated: Bool                       │
│                   │                                                │
│  QueueItem ───────┼────▶ Agent3                                   │
│  ├─ interaction ──┘      ├─ fiber: Trit {-1, 0, +1}               │
│  └─ agent ───────────▶   └─ name: String                          │
│                                                                    │
│  Person ◀─────────────── Partner ────────────────▶ Person         │
│  ├─ email: String        ├─ src                                   │
│  └─ name: String         ├─ tgt                                   │
│                          └─ weight: Int                            │
└────────────────────────────────────────────────────────────────────┘
\stopverb}

\subtree{
\title{Objects}
\pre{\startverb
| Object | Description | Trit Role |
|--------|-------------|-----------|
| `Interaction` | Single email action with verb + trit | Data |
| `Thread` | Gmail conversation with saturation state | Aggregate |
| `Agent3` | Queue fiber (MINUS/ERGODIC/PLUS) | Router |
| `QueueItem` | Links Interaction → Agent3 | Edge |
| `Person` | Email contact | Node |
| `Partner` | Relationship edge in contact graph | Edge |
\stopverb}
}
}

\subtree{
\title{GF(3) Verb Typing}
\p{Gmail actions are assigned trits based on information flow:}

\pre{\startverb
VERB_TRIT_MAP = {
    # MINUS (-1): Consumption/Validation
    "read": -1,      "search": -1,     "view": -1,
    "fetch": -1,     "list": -1,
    
    # ERGODIC (0): Coordination/Metadata
    "label": 0,      "archive": 0,     "snooze": 0,
    "star": 0,       "mark_read": 0,   "mark_unread": 0,
    "move": 0,
    
    # PLUS (+1): Generation/Execution
    "send": +1,      "forward": +1,    "reply": +1,
    "schedule": +1,  "draft": +1,      "compose": +1,
}
\stopverb}

