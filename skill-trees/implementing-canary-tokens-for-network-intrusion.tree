\stopverb}
}
}

\subtree{
\title{Validation Checklist}
\ul{
\li{[ ] DNS tokens resolve correctly and generate alerts within 60 seconds}
\li{[ ] HTTP tokens return a valid response and log source IP}
\li{[ ] AWS key tokens trigger alerts when used with \code{\startverb aws sts get-caller-identity\stopverb}}
\li{[ ] Webhook alerts arrive in Slack/Teams/SIEM within acceptable latency}
\li{[ ] Token memo fields contain sufficient context for SOC triage}
\li{[ ] Deployment locations are documented in token inventory}
\li{[ ] Alert escalation procedures are defined and tested}
\li{[ ] Tokens do not interfere with legitimate operations}
\li{[ ] Self-hosted Canarytokens instance (if used) is hardened and monitored}
\li{[ ] Token rotation schedule is established (quarterly recommended)}
}
}

