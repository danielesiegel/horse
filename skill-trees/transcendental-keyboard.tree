\subtree{
\title{Installation}
\subtree{
\title{Via straight.el}
\pre{\startverb
(use-package transcendental-keyboard
  :straight (transcendental-keyboard
             :type git
             :host github
             :repo "plurigrid/asi"
             :files ("skills/transcendental-keyboard/*.el"))
  :config
  (setq trans-kb-gay-seed 1069)
  (setq trans-kb-color-mode t)
  (add-hook 'coq-mode-hook #'transcendental-keyboard-mode)
  (add-hook 'lean-mode-hook #'transcendental-keyboard-mode))
\stopverb}
}

\subtree{
\title{Manual}
\pre{\startverb
# Clone ASI repo
git clone https://github.com/plurigrid/asi ~/asi

# Add to init.el
(add-to-list 'load-path "~/asi/skills/transcendental-keyboard")
(require 'transcendental-keyboard)
\stopverb}
}

\subtree{
\title{Dependencies}
\pre{\startverb
# Proof General
git clone https://github.com/ProofGeneral/PG ~/.emacs.d/proof-general

# Narya
git clone https://github.com/mikeshulman/narya ~/narya
cd ~/narya && dune build

# Stellogen
git clone https://github.com/engboris/stellogen ~/stellogen
cd ~/stellogen && dune build

# Gay.jl (for Emacs integration)
git clone https://github.com/bmorphism/Gay.jl ~/Gay.jl
ln -s ~/i/gay.el ~/.emacs.d/gay.el
\stopverb}
}
}

\subtree{
\title{Example Workflow}
\subtree{
\title{1. Narya Higher-Dimensional Proof}
\pre{\startverb
-- File: bridge_example.ny

-- Define natural numbers
def Nat : Type := data [
  | zero : Nat
  | suc : Nat → Nat
]

-- Addition
def add : Nat → Nat → Nat := [
  | zero, n => n
  | suc m, n => suc (add m n)
]

-- Bridge between two addition orders
def add_comm (m n : Nat) : add m n ≡ add n m := {
  -- C-c C-a to auto-prove
  -- Mode-line: RED → YELLOW → GREEN
}
\stopverb}

\p{\strong{Keyboard sequence}:}

\ol{
\li{\code{\startverb C-c t\stopverb} → Main menu}
\li{\code{\startverb p\stopverb} → Proof menu}
\li{\code{\startverb n\stopverb} → Step forward (mode-line: RED → YELLOW → GREEN)}
\li{\code{\startverb C-c C-a\stopverb} → Auto-prove attempt}
}
}

\subtree{
\title{2. Stellogen Constellation}
\pre{\startverb
# File: nat_add.sg

spec nat =
  -i(z) ok;
  -i(s(X)) +i(X).

spec add =
  -add(z Y) +result(Y);
  -add(s(X) Y) +add(X s(Y)).

show process #input(s(s(z))). #add. &kill. end
\stopverb}

\p{\strong{Keyboard sequence}:}

\ol{
\li{\code{\startverb C-c t s\stopverb} → Stellogen menu}
\li{\code{\startverb r\stopverb} → Run file}
\li{Output in \code{\startverb \em{stellogen}\stopverb} buffer}
}
}

