\subtree{
\title{Quantum Guitar}
\p{\strong{Trit}: 0 (ERGODIC - coordinator between classical and quantum) \strong{Author}: Bob Coecke (Quantum Brain Art Ltd / Oxford / Perimeter) \strong{arXiv}: 2509.04526v1 [quant-ph] 3 Sep 2025}

\subtree{
\title{Core Principle}
\blockquote{"A guitar string represents a wave, and by associating a qubit to each of its playable states we get a quantum wave."}

\p{\strong{Quantisation}: Each playable state of a guitar string → qubit \strong{Control}: Four limbs like a drummer (hands: guitar, feet: qubit) \strong{Transition}: Smooth classical ↔ quantum sound continuum}
}

