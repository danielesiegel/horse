\title{Svelte Components}

\taxon{skill}

\meta{description}{Svelte component patterns. Use for web components, component libraries (Bits UI, Ark UI, Melt UI), form patterns, or third-party integration.}

\subtree{
\title{Svelte Components}
\subtree{
\title{Quick Start}
\p{\strong{Component libraries:} Bits UI (headless) | Ark UI | Melt UI (primitives)}

\p{\strong{Form trick:} Use \code{\startverb form\stopverb} attribute when form can't wrap inputs:}

\pre{\startverb
<form id="my-form" action="/submit"><!-- outside table --></form>
<table>
	<tr>
		<td><input form="my-form" name="email" /></td>
		<td><button form="my-form">Submit</button></td>
	</tr>
</table>
\stopverb}
}

\subtree{
\title{Web Components}
\pre{\startverb
// svelte.config.js
export default {
	compilerOptions: {
		customElement: true,
	},
};
\stopverb}

\pre{\startverb
<!-- MyButton.svelte -->
<svelte:options customElement="my-button" />

<button><slot /></button>
\stopverb}
}

