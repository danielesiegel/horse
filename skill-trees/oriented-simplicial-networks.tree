\title{References}
\ul{
\li{Bodnar et al. "Weisfeiler and Lehman Go Cellular" (NeurIPS 2021)}
\li{Hajij et al. "Topological Deep Learning" (Nature 2023)}
\li{Carlsson "Topology and Data" (AMS 2009)}
}
}

