\subtree{
\title{XOR Uniqueness Proof}
\p{For bound \code{\startverb n\stopverb} parallel operations from \code{\startverb seed\stopverb}:}

\pre{\startverb
def xor_unique(seed: int, bound: int) -> bool:
    """XOR with distinct indices yields distinct seeds."""
    seen = set()
    for i in range(bound):
        derived = seed ^ i
        if derived in seen:
            return False  # Collision!
        seen.add(derived)
    return True

# Always true for i,j < 2^64 and i ≠ j:
# seed ⊕ i = seed ⊕ j ⟹ i = j (XOR cancellation)
\stopverb}
}

