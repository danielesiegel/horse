\title{Say Ducklake Xor}

\taxon{skill}

\meta{trit}{0}

\meta{description}{Parallel thread/DuckLake discovery with XOR uniqueness from gay_seed. Finds "say" or MCP usage, cross-refs with all DuckDB sources, launches bounded parallel ops.}

\subtree{
\title{Say-DuckLake XOR Discovery}
\p{\strong{Maximally parallel discovery with deterministic uniqueness guarantees.}}

\subtree{
\title{Core Invariants}
\pre{\startverb
∀ i,j ∈ [0, bound): i ≠ j ⟹ seed ⊕ i ≠ seed ⊕ j   (XOR uniqueness)
∀ parallel ops: same gay_seed ⟹ same colors        (SPI guarantee)
Σ(trits) ≡ 0 (mod 3)                                (GF(3) conservation)
\stopverb}
}

\subtree{
\title{Usage}
\pre{\startverb
# Find all "say" usage in threads, cross-ref with DuckLakes
python scripts/say_ducklake_xor.py

# With explicit seed and parallelism bound
python scripts/say_ducklake_xor.py --seed 1069 --bound 27

# XOR verification mode
python scripts/say_ducklake_xor.py --verify-xor
\stopverb}
}

