}
}

\subtree{
\title{Prerequisites}
\ul{
\li{Familiarity with security operations concepts and tools}
\li{Access to a test or lab environment for safe execution}
\li{Python 3.8+ with required dependencies installed}
\li{Appropriate authorization for any testing activities}
}
}

\subtree{
\title{Instructions}
\p{Deploy honeytokens across critical systems to detect unauthorized access. Each token type alerts via webhook when triggered by an attacker.}

\pre{\startverb
import requests

# Create a DNS canary token via Canarytokens
resp = requests.post("https://canarytokens.org/generate", data={
    "type": "dns",
    "email": "soc@company.com",
    "memo": "Production DB server honeytoken",
})
token = resp.json()
print(f"DNS token: {token['hostname']}")
\stopverb}

\p{Token types to deploy:}

\ol{
\li{AWS credential files (~/.aws/credentials) with canary keys}
\li{DNS tokens embedded in configuration files}
\li{Document beacons (Word/PDF) in sensitive file shares}
\li{Database honeytoken records in user tables}
\li{Web bugs in internal wiki/documentation pages}
}
}

\subtree{
\title{Examples}
\pre{\startverb
# Generate a fake AWS credentials file with canary token
aws_creds = f"[default]\naws_access_key_id = {canary_key_id}\naws_secret_access_key = {canary_secret}\n"
with open("/opt/backup/.aws/credentials", "w") as f:
    f.write(aws_creds)
\stopverb}
}
}