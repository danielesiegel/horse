\subtree{
\title{Indexing Your Repository}
\p{To make your public GitHub repo available via DeepWiki MCP:}

\ol{
\li{Visit [DeepWiki.com](https://deepwiki.com/)}
\li{Enter your repository URL}
\li{Wait for indexing to complete}
\li{Add the DeepWiki badge to your README:}
}

\pre{\startverb
[![Ask DeepWiki](https://deepwiki.com/badge.svg)](https://deepwiki.com/owner/repo)
\stopverb}
}

