\title{Deepwiki Mcp}

\taxon{skill}

\meta{description}{DeepWiki MCP server for AI-powered GitHub repository documentation and}

\subtree{
\title{DeepWiki MCP Skill}
\blockquote{AI-powered documentation and Q&A for any public GitHub repository}

\p{\strong{Version}: 1.0.0 \strong{Trit}: 0 (Ergodic - coordinates knowledge retrieval) \strong{Bundle}: research \strong{Provider}: Cognition (Devin AI) - Official, Free, No Auth Required}

\subtree{
\title{Overview}
\p{DeepWiki MCP provides programmatic access to AI-generated documentation for any public GitHub repository indexed on [DeepWiki.com](https://deepwiki.com/). It enables:}

\ol{
\li{\strong{Wiki Structure}: Get table of contents for any repo's documentation}
\li{\strong{Wiki Contents}: Read AI-generated documentation for specific topics}
\li{\strong{Ask Questions}: Get AI-powered answers grounded in repository context}
}
}

\subtree{
\title{Server Configuration}
\subtree{
\title{Base URL}
\pre{\startverb
https://mcp.deepwiki.com/
\stopverb}
}

\subtree{
\title{Wire Protocols}
\pre{\startverb
| Protocol | URL | Best For |
|----------|-----|----------|
| **SSE** | `https://mcp.deepwiki.com/sse` | Claude, most clients |
| **Streamable HTTP** | `https://mcp.deepwiki.com/mcp` | OpenAI, Cloudflare, Amp |
\stopverb}
}
}

\subtree{
\title{Tools}
\subtree{
\title{1. \code{\startverb read_wiki_structure\stopverb}}
\p{Get the documentation topic tree for a GitHub repository.}

\pre{\startverb
{
  "tool": "read_wiki_structure",
  "params": {
    "repo_owner": "AlgebraicJulia",
    "repo_name": "ACSets.jl"
  }
}
\stopverb}

\p{Returns: List of documentation topics/sections}
}

\subtree{
\title{2. \code{\startverb read_wiki_contents\stopverb}}
\p{Read documentation for a specific topic.}

\pre{\startverb
{
  "tool": "read_wiki_contents",
  "params": {
    "repo_owner": "AlgebraicJulia",
    "repo_name": "ACSets.jl",
    "topic": "Overview"
  }
}
\stopverb}

\p{Returns: AI-generated documentation content}
}

\subtree{
\title{3. \code{\startverb ask_question\stopverb}}
\p{Ask any question about a repository with AI-powered, context-grounded response.}

\pre{\startverb
{
  "tool": "ask_question",
  "params": {
    "repo_owner": "AlgebraicJulia",
    "repo_name": "Catlab.jl",
    "question": "How do wiring diagrams compose?"
  }
}
\stopverb}

\p{Returns: AI-powered answer with repository context}
}
}

\subtree{
\title{Client Configuration}
\subtree{
\title{Amp / Codex (.mcp.json)}
\pre{\startverb
{
  "mcpServers": {
    "deepwiki": {
      "serverUrl": "https://mcp.deepwiki.com/mcp"
    }
  }
}
\stopverb}
}

\subtree{
\title{Claude Desktop}
\pre{\startverb
{
  "mcpServers": {
    "deepwiki": {
      "serverUrl": "https://mcp.deepwiki.com/sse"
    }
  }
}
\stopverb}
}

\subtree{
\title{Claude Code (CLI)}
\pre{\startverb
claude mcp add -s user -t http deepwiki https://mcp.deepwiki.com/mcp
\stopverb}
}

\subtree{
\title{Cursor / Windsurf}
\p{Add to \code{\startverb .cursor/mcp.json\stopverb}:}

\pre{\startverb
{
  "mcpServers": {
    "deepwiki": {
      "serverUrl": "https://mcp.deepwiki.com/sse"
    }
  }
}
\stopverb}
}
}

