\title{Jank Llvm}

\taxon{skill}

\meta{trit}{1}

\meta{description}{Jank - Clojure dialect targeting LLVM with seamless C++ interoperability}

\subtree{
\title{Jank LLVM Skill}
\blockquote{jank-lang/jank: A Clojure dialect hosted on LLVM with native C++ interop}

\p{\strong{Trit}: +1 (PLUS) - Forward compilation to native code}

\subtree{
\title{Overview}
\p{Jank is a Clojure dialect that:}

\ul{
\li{\strong{Targets LLVM} for native machine code generation}
\li{\strong{Seamless C++ interop} via \code{\startverb c++/\stopverb} namespace}
\li{\strong{JIT compilation} with clang::Interpreter}
\li{\strong{Load native libraries} (.o, .dylib, .so)}
\li{\strong{Persistent data structures} like Clojure}
}
}

\subtree{
\title{Architecture}
\pre{\startverb
┌─────────────────────────────────────────────────────────────────────────┐
│                         JANK COMPILATION PIPELINE                        │
├─────────────────────────────────────────────────────────────────────────┤
│                                                                          │
│  Source Code                                                             │
│      │                                                                   │
│      ▼                                                                   │
│  ┌─────────┐     ┌──────────┐     ┌──────────┐     ┌─────────────┐     │
│  │  Lexer  │ ──► │  Parser  │ ──► │ Analyzer │ ──► │ LLVM Codegen│     │
│  └─────────┘     └──────────┘     └──────────┘     └──────┬──────┘     │
│                                                           │             │
│                                                           ▼             │
│                                                    ┌──────────────┐     │
│                                                    │ Optimization │     │
│                                                    │    Passes    │     │
│                                                    └──────┬───────┘     │
│                                                           │             │
│                                                           ▼             │
│                                                    ┌──────────────┐     │
│                                                    │     JIT      │     │
│                                                    │  Execution   │     │
│                                                    └──────────────┘     │
│                                                                          │
└─────────────────────────────────────────────────────────────────────────┘
\stopverb}
}

\subtree{
\title{C++ Interoperability}
\subtree{
\title{Calling C++ from Jank}
\pre{\startverb
;; Access C++ namespaces with c++/ prefix
(c++/std.cout "Hello from C++!")

;; Use chrono
(def duration (c++/std.chrono.milliseconds 100))

;; Call C++ functions
(c++/my.namespace.my-function arg1 arg2)
\stopverb}
}

\subtree{
\title{Name Mangling}
\p{Jank automatically handles:}

\ul{
\li{\code{\startverb kebab-case\stopverb} → \code{\startverb snake_case\stopverb}}
\li{Namespace dots → C++ \code{\startverb ::\stopverb}}
\li{Symbol escaping for special characters}
}
}

\subtree{
\title{Loading Native Code}
\pre{\startverb
;; Load object file
(native-load "/path/to/mylib.o")

;; Load dynamic library
(native-load "/path/to/mylib.dylib")  ; macOS
(native-load "/path/to/mylib.so")     ; Linux
\stopverb}
}
}

\subtree{
\title{C++ REPL Mode}
\pre{\startverb
jank cpp_repl

# Now you can evaluate C++ directly:
cpp> #include <iostream>
cpp> std::cout << "Hello from C++ REPL!" << std::endl;
Hello from C++ REPL!
\stopverb}
}

\subtree{
\title{LLVM Optimization Passes}
\p{Jank applies these optimization passes:}

\ul{
\li{\code{\startverb InstCombinePass\stopverb} - Instruction combining}
\li{\code{\startverb ReassociatePass\stopverb} - Reassociate expressions}
\li{\code{\startverb GVNPass\stopverb} - Global value numbering}
\li{\code{\startverb SimplifyCFGPass\stopverb} - Simplify control flow}
}
}

\subtree{
\title{Unique Features}
\subtree{
\title{1. Persistent Data Structures}
\pre{\startverb
;; Just like Clojure
(def m {:a 1 :b 2})
(def m2 (assoc m :c 3))
;; m is unchanged, m2 has :c
\stopverb}
}

\subtree{
\title{2. Native Performance}
\ul{
\li{No JVM startup overhead}
\li{Direct machine code execution}
\li{C++ level performance for hot paths}
}
}

\subtree{
\title{3. Ray Tracer Example}
\pre{\startverb
;; From jank examples - demonstrates performance
(ns ray-tracer)

(defn render [width height]
  (for [y (range height)
        x (range width)]
    (compute-pixel x y)))
\stopverb}
}
}

\subtree{
\title{Build from Source}
\pre{\startverb
git clone https://github.com/jank-lang/jank.git
cd jank

# Requires LLVM 17+, Clang
mkdir build && cd build
cmake ..
make -j$(nproc)
\stopverb}
}

\subtree{
\title{End-of-Skill Interface}

}

\subtree{
\title{Integration with Interaction Entropy}
\pre{\startverb
;; Track jank compilations
(def JANK_DB "~/.jank/interactions.duckdb")

(defn log-compilation [source-file llvm-ir-size opt-level]
  {:file source-file
   :ir-size llvm-ir-size
   :optimization opt-level
   :entropy-bits (* 2.0 (Math/log llvm-ir-size))
   :trit 1  ; PLUS - forward compilation
   :timestamp (System/currentTimeMillis)})
\stopverb}
}

\subtree{
\title{GF(3) Triads with Jank}
\pre{\startverb
Triad 1: Native Performance
  Jank (+1) ←→ SCI (0) ←→ Scittle (-1)
  
  Interface:
    Jank: Native LLVM compilation
    SCI: Interpreted sandboxed execution
    Scittle: Browser script tags
  
  Sum: +1 + 0 + (-1) = 0 ✓

Triad 2: C++ Bridge
  Jank (+1) ←→ Joker (0) ←→ clj-kondo (-1)
  
  Interface:
    Jank: C++ interop, native code
    Joker: Go-based linting
    clj-kondo: Static analysis
  
  Sum: +1 + 0 + (-1) = 0 ✓

Triad 3: Compilation Spectrum
  Jank (+1) ←→ Babashka (0)* ←→ nbb (-1)
  
  *Babashka acts as ergodic bridge here
  Interface:
    Jank: AOT to LLVM
    Babashka: GraalVM native-image
    nbb: Node.js interpreted
  
  Sum: +1 + 0 + (-1) = 0 ✓
\stopverb}
}

