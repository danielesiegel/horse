\title{Skill Specification}

\taxon{skill}

\meta{description}{Agent Skills formal specification for cross-platform compatibility. Ensures skills are evolutionarily robust across Claude, Codex, Cursor, Amp, and future agents.}

\subtree{
\title{Skill Specification}
\p{Formal specification for evolutionarily robust agent skills.}

\subtree{
\title{Why This Matters}
\p{Skills that follow the spec work across:}

\ul{
\li{\strong{Claude Code} (Anthropic)}
\li{\strong{Codex CLI} (OpenAI)}
\li{\strong{Cursor} (Anysphere)}
\li{\strong{Amp} (Sourcegraph)}
\li{\strong{Letta} (memGPT)}
\li{Future agents}
}

\p{Non-compliant skills break silently or fail validation.}
}

\subtree{
\title{SKILL.md Schema}
\pre{\startverb
---
name: skill-name              # REQUIRED: lowercase, hyphens, 1-64 chars
description: What and when    # REQUIRED: max 1024 chars, no < or >
license: Apache-2.0           # optional
compatibility: Requires git   # optional, max 500 chars
metadata:                     # optional: custom key-value pairs
  trit: 0
  author: bmorphism
  version: "1.0"
allowed-tools: Bash Read      # optional, experimental
---

# Body content (Markdown)
\stopverb}
}

\subtree{
\title{Field Constraints}
\pre{\startverb
| Field | Required | Rules |
|-------|----------|-------|
| `name` | ✓ | `[a-z0-9-]+`, no `--`, no leading/trailing `-`, max 64 |
| `description` | ✓ | 1-1024 chars, no `<` or `>`, includes WHEN to use |
| `license` | ✗ | Short name or file reference |
| `compatibility` | ✗ | Environment requirements, max 500 |
| `metadata` | ✗ | Arbitrary k:v for custom fields |
| `allowed-tools` | ✗ | Space-delimited tool names |
\stopverb}
}

\subtree{
\title{Evolutionary Robustness Patterns}
\subtree{
\title{1. Progressive Disclosure}
\pre{\startverb
Level 1: name + description (~100 tokens) - loaded at startup
Level 2: SKILL.md body (<5000 tokens) - loaded on activation
Level 3: scripts/, references/, assets/ - loaded on demand
\stopverb}

\p{Keep SKILL.md under 500 lines. Move details to \code{\startverb references/\stopverb}.}
}

\subtree{
\title{2. Cross-Platform Compatibility}
\pre{\startverb
# BAD - platform-specific
allowed-tools: claude_desktop_mcp

# GOOD - generic capability
compatibility: Requires MCP server access
\stopverb}
}

\subtree{
\title{3. Self-Validation Hook}
\p{Include validation in your skill:}

\pre{\startverb
# scripts/validate.sh
skills-ref validate "$(dirname "$0")/.."
\stopverb}
}

\subtree{
\title{4. Semantic Versioning in Metadata}
\pre{\startverb
metadata:
  version: "2.1.0"
  breaking-changes: "v2.0 changed API"
\stopverb}
}

\subtree{
\title{5. Triadic Classification (GF(3) Extension)}
\p{For plurigrid/asi skills:}

\pre{\startverb
metadata:
  trit: -1   # MINUS: verification, constraint
  trit: 0    # ERGODIC: balance, mediation
  trit: +1   # PLUS: generation, exploration
\stopverb}

\p{Conservation: \code{\startverb Σ trits ≡ 0 (mod 3)\stopverb} across compositions.}
}
}

\subtree{
\title{Directory Structure}
\pre{\startverb
skill-name/
├── SKILL.md           # Required
├── scripts/           # Executable code
│   └── main.py
├── references/        # Additional docs
│   └── REFERENCE.md
└── assets/            # Static resources
    └── template.json
\stopverb}
}

\subtree{
\title{Validation Commands}
\pre{\startverb
# Official validator
skills-ref validate ./my-skill

# Codex-rs validator
python3 codex-rs/core/src/skills/assets/samples/skill-creator/scripts/quick_validate.py ./my-skill

# Batch validate
for d in skills/*/; do skills-ref validate "$d"; done
\stopverb}
}

\subtree{
\title{Common Failures}
\pre{\startverb
| Error | Fix |
|-------|-----|
| No YAML frontmatter | Add `---` delimiters |
| Unexpected keys | Move to `metadata:` |
| Angle brackets in description | Remove `<` and `>` |
| Name not hyphen-case | Lowercase, hyphens only |
| Description too long | Max 1024 chars |
| YAML colon in value | Quote the string |
\stopverb}
}

\subtree{
\title{Evolution Strategy}
\ol{
\li{\strong{Start minimal} - name + description + one paragraph}
\li{\strong{Add scripts/} when automation helps}
\li{\strong{Add references/} when body exceeds 300 lines}
\li{\strong{Add metadata} for custom classification}
\li{\strong{Validate on every commit} via CI}
}
}

