\subtree{
\title{Installation}
\pre{\startverb
# Install astropy
uv pip install astropy

# With optional dependencies for full functionality
uv pip install astropy[all]
\stopverb}
}

\subtree{
\title{Common Workflows}
\subtree{
\title{Converting Coordinates Between Systems}
\pre{\startverb
from astropy.coordinates import SkyCoord
import astropy.units as u

# Create coordinate
c = SkyCoord(ra='05h23m34.5s', dec='-69d45m22s', frame='icrs')

# Transform to galactic
c_gal = c.galactic
print(f"l={c_gal.l.deg}, b={c_gal.b.deg}")

# Transform to alt-az (requires time and location)
from astropy.time import Time
from astropy.coordinates import EarthLocation, AltAz

observing_time = Time('2023-06-15 23:00:00')
observing_location = EarthLocation(lat=40*u.deg, lon=-120*u.deg)
aa_frame = AltAz(obstime=observing_time, location=observing_location)
c_altaz = c.transform_to(aa_frame)
print(f"Alt={c_altaz.alt.deg}, Az={c_altaz.az.deg}")
\stopverb}
}

\subtree{
\title{Reading and Analyzing FITS Files}
\pre{\startverb
from astropy.io import fits
import numpy as np

# Open FITS file
with fits.open('observation.fits') as hdul:
    # Display structure
    hdul.info()

    # Get image data and header
    data = hdul[1].data
    header = hdul[1].header

    # Access header values
    exptime = header['EXPTIME']
    filter_name = header['FILTER']

    # Analyze data
    mean = np.mean(data)
    median = np.median(data)
    print(f"Mean: {mean}, Median: {median}")
\stopverb}
}

\subtree{
\title{Cosmological Distance Calculations}
\pre{\startverb
from astropy.cosmology import Planck18
import astropy.units as u
import numpy as np

# Calculate distances at z=1.5
z = 1.5
d_L = Planck18.luminosity_distance(z)
d_A = Planck18.angular_diameter_distance(z)

print(f"Luminosity distance: {d_L}")
print(f"Angular diameter distance: {d_A}")

# Age of universe at that redshift
age = Planck18.age(z)
print(f"Age at z={z}: {age.to(u.Gyr)}")

# Lookback time
t_lookback = Planck18.lookback_time(z)
print(f"Lookback time: {t_lookback.to(u.Gyr)}")
\stopverb}
}

\subtree{
\title{Cross-Matching Catalogs}
\pre{\startverb
from astropy.table import Table
from astropy.coordinates import SkyCoord, match_coordinates_sky
import astropy.units as u

# Read catalogs
cat1 = Table.read('catalog1.fits')
cat2 = Table.read('catalog2.fits')

# Create coordinate objects
coords1 = SkyCoord(ra=cat1['RA']*u.degree, dec=cat1['DEC']*u.degree)
coords2 = SkyCoord(ra=cat2['RA']*u.degree, dec=cat2['DEC']*u.degree)

# Find matches
idx, sep, _ = coords1.match_to_catalog_sky(coords2)

# Filter by separation threshold
max_sep = 1 * u.arcsec
matches = sep < max_sep

# Create matched catalogs
cat1_matched = cat1[matches]
cat2_matched = cat2[idx[matches]]
print(f"Found {len(cat1_matched)} matches")
\stopverb}
}
}

\subtree{
\title{Best Practices}
\ol{
\li{\strong{Always use units}: Attach units to quantities to avoid errors and ensure dimensional consistency}
\li{\strong{Use context managers for FITS files}: Ensures proper file closing}
\li{\strong{Prefer arrays over loops}: Process multiple coordinates/times as arrays for better performance}
\li{\strong{Check coordinate frames}: Verify the frame before transformations}
\li{\strong{Use appropriate cosmology}: Choose the right cosmological model for your analysis}
\li{\strong{Handle missing data}: Use masked columns for tables with missing values}
\li{\strong{Specify time scales}: Be explicit about time scales (UTC, TT, TDB) for precise timing}
\li{\strong{Use QTable for unit-aware tables}: When table columns have units}
\li{\strong{Check WCS validity}: Verify WCS before using transformations}
\li{\strong{Cache frequently used values}: Expensive calculations (e.g., cosmological distances) can be cached}
}
}

