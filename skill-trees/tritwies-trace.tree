\subtree{
\title{Omega (𝛀) Key Features}
\p{From README:}

\ol{
\li{\strong{Diagram/Operad support} - Parallel execution of causal models and graphical languages (CatCollab parity)}
\li{\strong{Structure-aware editing} - Beyond git version control via observational bridge types}
\li{\strong{Multimodal data support} - Physics, Chemistry, Biology, Whole Earth models}
\li{\strong{MCP implementation} - Hardened servers with reliable Effects and Capabilities}
\li{\strong{DPO graph rewriting} - C-Set categorical rewriting with benchmarking}
\li{\strong{Proof assistants} - ProofGeneral, Lean4 mathlib4 parity}
\li{\strong{Collaborative world modeling} - Compositional structure transport}
\li{\strong{DuckDB integration} - Continuous information integration}
\li{\strong{Task delegation operad} - Multi-agent automations}
\li{\strong{RISC-V zkVM} - Jolt, RISC0 integrations}
\li{\strong{Paredit/Calva mode} - S-expression editing}
\li{\strong{vim/Kakoune keymap} - Modal editing}
}
}

