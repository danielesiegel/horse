\subtree{
\title{Key Invariants}
\ol{
\li{\strong{GF(3) Conservation:} \code{\startverb (∑ gf3_i) mod 3 = 0\stopverb} for all slices}
\li{\strong{Color Determinism:} \code{\startverb color(seed) = f(seed)\stopverb} where f is SplitMix64}
\li{\strong{XOR Commutativity:} \code{\startverb (a ⊕ b) ⊕ c = a ⊕ (b ⊕ c)\stopverb}}
\li{\strong{Triangle Inequality:} \code{\startverb d(W1, W3) ≤ d(W1, W2) + d(W2, W3)\stopverb}}
\li{\strong{Reafferent Threshold:} Recognition if \code{\startverb hamming(xor) < 32\stopverb} or \code{\startverb dist < 0.5\stopverb}}
}
}

