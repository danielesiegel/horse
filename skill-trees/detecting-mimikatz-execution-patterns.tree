\ol{
\li{\strong{Scenario 1}: Standard sekurlsa::logonpasswords credential dump}
\li{\strong{Scenario 2}: PowerShell Invoke-Mimikatz reflective loading}
\li{\strong{Scenario 3}: DCSync from non-DC host}
\li{\strong{Scenario 4}: Golden ticket creation for persistence}
}
}

