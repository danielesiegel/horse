\title{Tailscale Localsend}

\taxon{skill}

\meta{version}{1.0.0}

\meta{description}{'Tailscale + LocalSend Peer Discovery'}

\subtree{
\title{Tailscale + LocalSend Peer Discovery}
\p{Discover peers via Tailscale mesh and exchange files via LocalSend protocol.}

\subtree{
\title{Architecture}
\pre{\startverb
┌─────────────────┐     ┌──────────────────┐     ┌─────────────────┐
│  Tailscale API  │────▶│  Peer Discovery  │────▶│  LocalSend API  │
│  (mesh network) │     │  (propagator)    │     │  (file xfer)    │
└─────────────────┘     └──────────────────┘     └─────────────────┘
\stopverb}
}

\subtree{
\title{Discovery Flow}
\ol{
\li{\strong{Tailscale Status}: \code{\startverb tailscale status --json\stopverb} → get mesh peers}
\li{\strong{LocalSend Probe}: UDP multicast 224.0.0.167:53317 → find localsend-enabled peers  }
\li{\strong{Intersection}: Peers on both networks get deterministic Gay.jl colors}
}
}

\subtree{
\title{Usage}
\pre{\startverb
# Discover peers on tailscale with localsend
just ts-localsend-discover

# Send file to peer
just ts-localsend-send <peer> <file>

# Receive mode
just ts-localsend-receive
\stopverb}
}

\subtree{
\title{Python API}
\pre{\startverb
from tailscale_localsend import TailscaleLocalSend

tls = TailscaleLocalSend(seed=0x6761795f636f6c6f)

# Discover peers
peers = tls.discover()
# [{'name': 'macbook', 'tailscale_ip': '100.x.x.x', 'localsend_port': 53317, 'color': '#A855F7'}]

# Send file
tls.send(peer='macbook', file='data.json')

# Receive (blocking)
tls.receive(callback=lambda f: print(f"Got {f}"))
\stopverb}
}

\subtree{
\title{Protocol Details}
\subtree{
\title{Tailscale Discovery}
\ul{
\li{Uses \code{\startverb tailscale status --json\stopverb} for mesh peers}
\li{Extracts TailscaleIPs for each peer}
\li{Falls back to Tailscale API if CLI unavailable}
}
}

\subtree{
\title{LocalSend Protocol}
\ul{
\li{\strong{Multicast}: 224.0.0.167:53317 (UDP)}
\li{\strong{Announce}: JSON with alias, fingerprint, port}
\li{\strong{Transfer}: REST API over HTTPS}
\li{\code{\startverb POST /api/localsend/v2/prepare-upload\stopverb}}
\li{\code{\startverb POST /api/localsend/v2/upload?sessionId=...\stopverb}}
}
}

\subtree{
\title{Color Assignment}
\p{Each peer gets deterministic color from Gay.jl:}

\pre{\startverb
peer_color = gay_color_at(hash(peer_fingerprint) % 1000, seed=GAY_SEED)
\stopverb}
}
}

\subtree{
\title{Integration with epistemic-arbitrage}
\pre{\startverb
from epistemic_arbitrage import ArbitrageNetwork

network = ArbitrageNetwork(seed=1069)
for peer in tls.discover():
    network.add_cell(peer['name'], knowledge=peer.get('files', 0))
    
# Propagate knowledge between peers
network.add_propagator(:peer_sync, sources, targets)
network.run_parallel(n_workers=len(peers))
\stopverb}
}

\subtree{
\title{Commands}
\pre{\startverb
just ts-peers          # List tailscale peers
just ls-peers          # List localsend peers  
just ts-ls-bridge      # Bridge both networks
\stopverb}

\p{Base directory: ~/.codex/skills/tailscale-localsend}
}
}