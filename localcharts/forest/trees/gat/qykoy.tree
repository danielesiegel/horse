  
\title{ThPreorder}
\tag{theory}

 \p{Theory of *preorders*}\p{The generalized algebraic theory of preorders encodes inequalities #{A≤B} as dependent types `#{Leq(A,B)} and the axioms of reflexivity and transitivity as term constructors.}
